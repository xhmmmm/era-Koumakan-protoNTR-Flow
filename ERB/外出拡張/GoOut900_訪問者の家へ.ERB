;-------------------------------------------------------------------------------
;事前の予定に従い、訪問者の家へおでかけさせる
; return 1 でかけた
; return 0 でかけなかった
@GoOut_Ready_900(角色)
#DIM 角色
RETURN 0

;-------------------------------------------------------------------------------
;訪問者の家へお出かけするかどうかを判定する
; return 0 でかけない
; return 1 でかける
@GoOut_Able_900(角色)
#DIM 角色
#DIM 放置時間
#DIM 基础空闲时间
#DIM 空闲时间
#DIM 空闲时间修正值
#DIM 子宮内精液量
#DIM 是否结束空闲

CALL GoOut_Able_Check(角色)
IF 0 == RESULT:0
	RETURN 0
ENDIF

是否结束空闲 = 1

;基本休暇13日
基础空闲时间 = 18720 ;=24*60*13
;浮気を容易にする補正値を計算
空闲时间修正值 = 0
空闲时间修正值 -= ( 基础空闲时间 * TALENT:角色:淫乱             / 10 ) ; 淫乱で-10%、娼婦で-20%
空闲时间修正值 -= ( 基础空闲时间 * TALENT:角色:浮気癖           / 10 ) ; 10%
空闲时间修正值 -= ( 基础空闲时间 * TALENT:角色:浮気的蜜壶       / 10 ) ; 10%
空闲时间修正值 -= ( 基础空闲时间 * TALENT:角色:浮気的菊花       / 10 ) ; 10%
空闲时间修正值 -= ( 基础空闲时间 * TALENT:角色:浮気的蜜唇         / 10 ) ; 10%
空闲时间修正值 -= ( 基础空闲时间 * SQRT(MARK:角色:浮気快乐刻印) / 10 ) ; 10～30%

IF CFLAG:角色:屈服度/2 > CFLAG:角色:好感度
	放置時間 = DATETIME() - CFLAG:角色:与访问者最后做爱的时间
	是否结束空闲 = 1
ENDIF

;最低１時間は休息を確保する（会话ができないと辛いので）
IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
	;NTR的情况下回家休息
	空闲时间 = 1430
	是否结束空闲 = 1
ELSE
	空闲时间 = MAX( 600 ,基础空闲时间 + 空闲时间修正值)
ENDIF
[IF_DEBUG]
SETCOLOR 颜色_黄
PRINTFORML %"恋人の『"+CALLNAME:角色+"』の空闲时间(分)："+TOSTR(空闲时间)+" ＆ 放置時間(分)："+TOSTR(放置時間)%
RESETCOLOR
[ENDIF]

;所以说“空闲时间”就是角色预计的最长不和访问者互动的时间？因此没互动的时间超过这个预期的时间就让角色和访问者互动？
;之所以是“空闲”是原版认为访问者是强迫角色，所以角色不被强迫的时候就是“空闲”？日本人真傻逼——2026.07.05
IF 空闲时间 < 放置時間
	RETURN 是否结束空闲
ENDIF

RETURN 0


;-------------------------------------------------------------------------------
;訪問者の家へお出かけするかどうかを判定する
;子宮内精液量の判定なし
; return 1 でかける
; return 0 でかけない
@GoOut_Able_Check(角色)
#DIM 角色
#DIM 放置時間
#DIM 空闲时间
#DIM 子宮内精液量

IF 0 == IS_NTR_TAKINGOUT_ENABLE()
	;	;お持ち帰り禁止時は出て行かない
	RETURN 0
ENDIF
IF TALENT:角色:妊娠 || TALENT:角色:育儿中
	;妊娠中、育儿中は出て行かない
	RETURN 0
ENDIF
IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
	SIF CFLAG:角色:好感度 >= CFLAG:角色:屈服度 || TALENT:角色:恋慕 == 0
		RETURN 0
ENDIF
IF FLAG:訪問者の气氛 > 0 && !NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
	;訪問者が誰かとうふふ中だったら行かない(相手して貰えないので)
	RETURN 0
ENDIF
SIF !IS_NTR_VISITOR_COME()
	RETURN 0
RETURN 1



;-------------------------------------------------------------------------------
;主动去访问者家时，先和苦主打招呼
; return 1 でかけた
; return 0 でかけなかった
@GoOut_SeeYou_900(角色, 强制外出)
#DIM 角色
#DIM 强制外出

IF !强制外出
	;判断是否可以外出，返回值为0就跳出函数
	CALL GoOut_Able_900(角色)
	IF RESULT:0 == 0
		RETURN 0
	ENDIF
ENDIF
IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
	CALL GoOut_SeeYou_900_2(角色)
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
	CALL GoOut_SeeYou_900_3(角色)
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
	CALL GoOut_SeeYou_900_4(角色)
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
	CALL GoOut_SeeYou_900_5(角色)
ELSE
	CALL GoOut_SeeYou_900_9(角色)
ENDIF
CALL NTR_SET_STAYOUT_MAXIMUM(LOCAL, LIMIT(CFLAG:LOCAL:屈服度 /(CFLAG:LOCAL:好感度+1),0,7))
;TODO 这里可以口上化，给每个角色、不同情况加不同的文本
IF CFLAG:角色:長期滞在最大日数 == 0
	PRINTFORMW 说是最晚明天就会回来……
ELSE
	PRINTFORMW 说是最晚{NTR_GET_STAYOUT_MAXIMUM(角色)}天后回来的样子……
ENDIF
PRINTL
;去访问者家的时候对角色进行初始化
CALL INIT_TAKINGOUT(角色)
;去访问者家的口上
IF NTR_CHK_VISIBLE(位置_訪問者宅)
	TRYCALLLIST
		FUNC NTR_KOJO_K{CFLAG:角色:口上パターン}_10_0(角色)
		FUNC NTR_KOJO_K_10_0(角色)
	ENDFUNC
ENDIF
RETURN 1

;-------------------------------------------------------------------------------
;訪問者の家へおでかけ：FAV_寝取られ
@GoOut_SeeYou_900_2(角色)
#DIM 角色
#DIM 同伴 
同伴 = (FLAG:访问者当前位置 != 位置_訪問者宅)
;積極的にお出かけする

TRYCALLLIST
	FUNC KOJO_MESSAGE_K{角色}_SeeYou_900_2(角色,同伴)
	FUNC KOJO_MESSAGE_KU_SeeYou_900_2(角色,同伴)
ENDFUNC

IF 同伴
	PRINTDATAL
		DATAFORM %CALLNAME:角色+"和"+NTR_NAME(0)+"手拉着手走了・・。"%
		DATAFORM %CALLNAME:角色+"和"+NTR_NAME(0)+"一边缠绵着一边走了・・。"%
		DATAFORM %CALLNAME:角色+"和"+NTR_NAME(0)+"快乐地笑着，高兴地走了・・。"%
	ENDDATA
ELSE
	PRINTFORML %CALLNAME:角色+"告诉"+CALLNAME:MASTER+"自己将要去"+NTR_NAME(0)+"的家・・。"%
ENDIF

RETURN 1

