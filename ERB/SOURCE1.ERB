;---------------------------------------------------
;PLAYERにも影響を与えるSOURCE
;---------------------------------------------------
@SOURCE_欢乐(角色,主人=0)
#DIM 角色
#DIM 主人
VARSET LOCAL
LOCAL = SOURCE:角色:欢乐
;恋慕
LOCAL = LOCAL * (10 + 5 * TALENT:角色:恋慕) / 10
;ABL:亲密をみる
IF LOCAL < 100000
	LOCAL = LOCAL * (ABL:角色:亲密 * 5 + 100) / 100
ELSEIF LOCAL < 100000000
	LOCAL = LOCAL / 100 * (ABL:角色:亲密 * 5 + 100)
ENDIF
;ABL:欲望をみる
IF LOCAL < 100000
	LOCAL = LOCAL * (ABL:角色:欲望 * 5 + 100) / 100
ELSEIF LOCAL < 100000000
	LOCAL = LOCAL / 100 * (ABL:角色:欲望 * 5 + 100)
ENDIF
;好感度を見る
IF CFLAG:角色:好感度 <= 10
	TIMES LOCAL , 0.50
ELSEIF CFLAG:角色:好感度 <= 50
	TIMES LOCAL , 0.80
ELSEIF CFLAG:角色:好感度 <= 100
	TIMES LOCAL , 1.00
ELSEIF CFLAG:角色:好感度 <= 300
	TIMES LOCAL , 1.10
ELSEIF CFLAG:角色:好感度 <= 500
	TIMES LOCAL , 1.20
ELSEIF CFLAG:角色:好感度 <= 700
	TIMES LOCAL , 1.30
ELSEIF CFLAG:角色:好感度 <= 1000
	TIMES LOCAL , 1.40
ELSEIF CFLAG:角色:好感度 <= 3000
	TIMES LOCAL , 1.50
ELSEIF CFLAG:角色:好感度 <= 5000
	TIMES LOCAL , 1.70
ELSEIF CFLAG:角色:好感度 <= 500000
	IF LOCAL < 100000
		LOCAL = LOCAL * (CFLAG:角色:好感度 / 50 + 100) / 100
	ELSEIF LOCAL < 10000000
		LOCAL = LOCAL / 100 * (CFLAG:角色:好感度 / 50 + 100)
	ELSEIF LOCAL < 100000000
		IF CFLAG:角色:好感度 <= 50000
			LOCAL = LOCAL / 100 * (CFLAG:角色:好感度 / 50 + 100)
		ELSE
			LOCAL = 1000000000
		ENDIF
	ENDIF
ENDIF
CUP:角色:好意 += LOCAL
IF 主人 < CHARANUM
	CUP:主人:欲情 += MIN(LOCAL / 10 , 100)
ENDIF

