;-------------------------------------------------------------------------------
;非TARGET依存性SOURCE
;-------------------------------------------------------------------------------
;-------------------------------------------------------------------------------
;FIXME:関数の説明を書いてください
;@return 1:xxx,0:xxx
@SOURCE_EXP(角色,主人=0)
#DIM 角色
#DIM 主人
VARSET LOCAL
SIF SOURCE:角色:快Ｃ
	EXP:角色:Ｃ经验 ++
IF SOURCE:角色:快Ｖ && (!TALENT:角色:处女 || !TFLAG:2)
	EXP:角色:Ｖ经验 ++
ENDIF
SIF SOURCE:角色:快Ａ
	EXP:角色:Ａ经验 ++
SIF SOURCE:角色:快Ｂ
	EXP:角色:Ｂ经验 ++
SIF CFLAG:角色:跳蛋挿入 && EXP_UP(1,角色) > 0
	EXP:角色:Ｖ经验 --
SIF CFLAG:角色:跳蛋A挿入 && EXP_UP(2,角色) > 0
	EXP:角色:Ａ经验 --

;-------------------------------------------------------------------------------
;FIXME:関数の説明を書いてください
;@return 1:xxx,0:xxx
@SOURCE_快Ｃ(角色,主人=0)
#DIM 角色
#DIM 主人
VARSET LOCAL
;Ｃ敏感とＣ鈍感はここで処理
SOURCE:角色:快Ｃ = SOURCE:角色:快Ｃ * (2 + TALENT:角色:Ｃ感度) / 2
;C感覚
SOURCE:角色:快Ｃ = SOURCE:角色:快Ｃ * SOURCE_REVISION1(ABL:角色:Ｃ感觉) / 10
LOCAL = SOURCE:角色:快Ｃ
;PALAM:欲情をみる
IF PALAM:角色:欲情 < PALAMLV:1
	TIMES LOCAL , 0.80
ELSEIF PALAM:角色:欲情 < PALAMLV:2
	TIMES LOCAL , 1.00
ELSEIF PALAM:角色:欲情 < PALAMLV:3
	TIMES LOCAL , 1.20
ELSEIF PALAM:角色:欲情 < PALAMLV:4
	TIMES LOCAL , 1.40
ELSEIF PALAM:角色:欲情 >= PALAMLV:4
	TIMES LOCAL , 1.60
ENDIF
CUP:角色:快Ｃ += LOCAL
LOCAL = SOURCE:角色:快Ｃ
;ABL:欲望をみる
LOCAL = LOCAL * SOURCE_REVISION2(ABL:角色:欲望) / 100
CUP:角色:欲情 += LOCAL

