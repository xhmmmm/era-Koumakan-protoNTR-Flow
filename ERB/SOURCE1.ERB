;@return 1:xxx,0:xxx
@SOURCE_DOWNBASE(角色,主人=0)
#DIM 角色
#DIM 主人
BASE:角色:体力 = MAX(0,BASE:角色:体力 - DOWNBASE:角色:体力)
BASE:角色:气力 = MAX(0,BASE:角色:气力 - DOWNBASE:角色:气力)
