;@return 1:xxx,0:xxx
@SOURCE_CVAB_EXTRA(角色,主人=0)
#DIM 角色
#DIM 主人
VARSET LOCAL
;-------------------------------------------------
;气力０による上下の処理（快楽系）
;-------------------------------------------------
IF BASE:角色:气力 <= 0
	;UP:0,1,2,3は絶頂に絡むので先に処理してある
	CUP:角色:快Ｃ /= 2
	CUP:角色:快Ｖ /= 2
	CUP:角色:快Ａ /= 2
	CUP:角色:快Ｂ /= 2
ENDIF
;-------------------------------------------------
;相性による上下の処理（快楽系）
;-------------------------------------------------
IF 主人 < CHARANUM && RELATION:角色:(NO:主人) != 0
	CUP:角色:快Ｃ *= RELATION:角色:(NO:主人)
	CUP:角色:快Ｃ /= 100
	CUP:角色:快Ｖ *= RELATION:角色:(NO:主人)
	CUP:角色:快Ｖ /= 100
	CUP:角色:快Ａ *= RELATION:角色:(NO:主人)
	CUP:角色:快Ａ /= 100
	CUP:角色:快Ｂ *= RELATION:角色:(NO:主人)
	CUP:角色:快Ｂ /= 100
ENDIF
;-------------------------------------------------
;快感の否定は、快ソースの数値に応じて、抑郁増加（淫乱で無効）
;-------------------------------------------------
SIF TALENT:角色:快感应答 < 0 && !TALENT:角色:淫乱
	SOURCE:角色:抑郁 += (CUP:角色:快Ｃ + CUP:角色:快Ｖ + CUP:角色:快Ａ + CUP:角色:快Ｂ)/10
;-------------------------------------------------
;素質などによる上下の処理（快楽系）
;-------------------------------------------------
;媚药
IF TEQUIP:角色:媚药
	TIMES CUP:角色:快Ｃ , 2.00
	TIMES CUP:角色:快Ｖ , 2.00
	TIMES CUP:角色:快Ａ , 2.00
	TIMES CUP:角色:快Ｂ , 2.00
ENDIF
;-------------------------------------------------
;陥落素質
;-------------------------------------------------
;淫乱
IF TALENT:角色:淫乱
	TIMES CUP:角色:快Ｃ , 1.20
	TIMES CUP:角色:快Ｖ , 1.20
	TIMES CUP:角色:快Ａ , 1.20
	TIMES CUP:角色:快Ｂ , 1.20
ENDIF
;-------------------------------------------------
;素質
;-------------------------------------------------
;自制心
IF TALENT:角色:自制心
	TIMES CUP:角色:快Ｃ , 0.70
	TIMES CUP:角色:快Ｖ , 0.90
	TIMES CUP:角色:快Ａ , 1.00
	TIMES CUP:角色:快Ｂ , 0.70
ENDIF
;立即陷落
IF TALENT:角色:立即陷落
	TIMES CUP:角色:快Ｃ , 2.00
	TIMES CUP:角色:快Ｖ , 2.00
	TIMES CUP:角色:快Ａ , 2.00
	TIMES CUP:角色:快Ｂ , 2.00
ENDIF
;自慰狂
SIF TALENT:角色:自慰狂
	TIMES CUP:角色:快Ｃ , 1.20
;淫壶
SIF TALENT:角色:淫壶
	TIMES CUP:角色:快Ｖ , 1.20
;淫肛
SIF TALENT:角色:淫肛
	TIMES CUP:角色:快Ａ , 1.20
;淫乳
SIF TALENT:角色:淫乳
	TIMES CUP:角色:快Ｂ , 1.20
;オトコ
IF !(HAS_VAGINA(角色))
	TIMES CUP:角色:快Ａ , 1.30
ENDIF
;-------------------------------------------------
;難易度による上下の処理（快楽系）
;-------------------------------------------------
CUP:角色:快Ｃ = CUP:角色:快Ｃ * (16 - 4 * FLAG:難易度) / 10
CUP:角色:快Ｖ = CUP:角色:快Ｖ * (16 - 4 * FLAG:難易度) / 10
CUP:角色:快Ａ = CUP:角色:快Ａ * (16 - 4 * FLAG:難易度) / 10
CUP:角色:快Ｂ = CUP:角色:快Ｂ * (16 - 4 * FLAG:難易度) / 10
;-------------------------------------------------
;愛液処理
;-------------------------------------------------
LOCAL:1 = CUP:角色:快Ｃ + CUP:角色:快Ｖ + CUP:角色:快Ａ + CUP:角色:快Ｂ
;快Ｃ＋快Ｖ＋快Ａ＋快Ｂが合わせて100以上上昇ならその20%の液体のソースが加わる
IF LOCAL:1 > 100
