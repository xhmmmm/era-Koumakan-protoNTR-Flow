ELSEIF MARK:角色:快乐刻印 == 2
	TIMES CUP:角色:欲情 , 1.20
	TIMES CUP:角色:习得 , 1.20
ELSEIF MARK:角色:快乐刻印 == 1
	TIMES CUP:角色:欲情 , 1.10
	TIMES CUP:角色:习得 , 1.10
ENDIF
;屈服刻印
IF MARK:角色:屈服刻印 == 3
	TIMES CUP:角色:恭顺 , 1.30
	TIMES CUP:角色:屈服 , 1.30
ELSEIF MARK:角色:屈服刻印 == 2
	TIMES CUP:角色:恭顺 , 1.20
	TIMES CUP:角色:屈服 , 1.20
ELSEIF MARK:角色:屈服刻印 == 1
	TIMES CUP:角色:恭顺 , 1.10
	TIMES CUP:角色:屈服 , 1.10
ENDIF
;反発刻印
IF MARK:角色:反発刻印 == 3
	TIMES CUP:角色:恭顺 , 0.10
	TIMES CUP:角色:反感 , 1.30
ELSEIF MARK:角色:反発刻印 == 2
	TIMES CUP:角色:恭顺 , 0.40
	TIMES CUP:角色:反感 , 1.20
ELSEIF MARK:角色:反発刻印 == 1
	TIMES CUP:角色:恭顺 , 0.60
	TIMES CUP:角色:反感 , 1.10
ENDIF
;-------------------------------------------------
;難易度などによる上下の処理
;-------------------------------------------------
CUP:角色:润滑 = CUP:角色:润滑 * (16 - 4 * FLAG:難易度) / 10
CUP:角色:恭顺 = CUP:角色:恭顺 * (16 - 4 * FLAG:難易度) / 10
CUP:角色:欲情 = CUP:角色:欲情 * (16 - 4 * FLAG:難易度) / 10
CUP:角色:屈服 = CUP:角色:屈服 * (16 - 4 * FLAG:難易度) / 10
CUP:角色:习得 = CUP:角色:习得 * (16 - 4 * FLAG:難易度) / 10
CUP:角色:耻情 = CUP:角色:耻情 * (16 - 4 * FLAG:難易度) / 10
CUP:角色:苦痛 = CUP:角色:苦痛 * (16 - 4 * FLAG:難易度) / 10
CUP:角色:恐怖 = CUP:角色:恐怖 * (16 - 4 * FLAG:難易度) / 10
CUP:角色:好意 = CUP:角色:好意 * (16 - 4 * FLAG:難易度) / 10
CUP:角色:优越 = CUP:角色:优越 * (16 - 4 * FLAG:難易度) / 10
CUP:角色:反感 = CUP:角色:反感 * (8 +  4 * FLAG:難易度) / 10
CUP:角色:不快 = CUP:角色:不快 * (8 + 4 * FLAG:難易度) / 10
CUP:角色:抑郁 = CUP:角色:抑郁 * (8 + 4 * FLAG:難易度) / 10
;-------------------------------------------------
;相性による上下の処理
;-------------------------------------------------
IF 主人 < CHARANUM && RELATION:角色:(NO:主人) != 0
	CUP:角色:欲情 *= RELATION:角色:(NO:主人)
	CUP:角色:欲情 /= 100
	CUP:角色:屈服 *= RELATION:角色:(NO:主人)
	CUP:角色:屈服 /= 100
	CUP:角色:耻情 *= RELATION:角色:(NO:主人)
	CUP:角色:耻情 /= 100
	CUP:角色:反感 *= 100
	CUP:角色:反感 /= RELATION:角色:(NO:主人)
	CUP:角色:不快 *= 100
	CUP:角色:不快 /= RELATION:角色:(NO:主人)
	CUP:角色:抑郁 *= 100
	CUP:角色:抑郁 /= RELATION:角色:(NO:主人)
ENDIF
;-------------------------------------------------
;气力０による上下の処理
;-------------------------------------------------
IF BASE:角色:1 <= 0
	;UP:0,1,2は絶頂に絡むので先に処理してある
	CUP:角色:欲情 /= 2
	CUP:角色:恭顺 /= 2
	CUP:角色:屈服 /= 2
	CUP:角色:习得 /= 2
	CUP:角色:耻情 /= 2
	CUP:角色:恐怖 /= 2
	CUP:角色:苦痛 /= 2
	DOWNBASE:角色:体力 *= 2
	DOWNBASE:角色:体力 += 80
ENDIF
;-------------------------------------------------
;苦痛からくる体力・气力の減少
;-------------------------------------------------
LOCAL = CUP:角色:苦痛 / 20
;ABL:抖Ｍ之气をみる
SELECTCASE ABL:角色:抖Ｍ之气
	CASE 0
		TIMES LOCAL , 1.00
	CASE 1
		TIMES LOCAL , 0.95
	CASE 2
		TIMES LOCAL , 0.90
	CASE 3
		TIMES LOCAL , 0.80
	CASE 4
		TIMES LOCAL , 0.65
	CASEELSE
		TIMES LOCAL , 0.50
ENDSELECT
;痛觉
LOCAL = LOCAL * (10 + TALENT:角色:痛觉 * 2) / 10
DOWNBASE:角色:体力 += LOCAL
DOWNBASE:角色:气力 += LOCAL

;-------------------------------------------------------------------------------
