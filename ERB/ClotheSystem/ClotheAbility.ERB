;----------------------------------
;服装效果
;---------------------------------

@CLOTHE_EFFECT(ARG)

;------------------------------------------------------------------------------------------------------------------------------------
;素质附加说明：没有则保存素质附加后的能力(保存1)，钝感则先保存能力再附加素质(保存-1)，敏感则保持原样
;				   角色扮演效果发动后，素质会一直保持，因此根据能力保存值重新设置素质。
;------------------------------------------------------------------------------------------------------------------------------------

;啦啦队效果　加油加油
;素质附加：鼓舞
;回复效果：侍奉快乐经验
IF EQUIP:ARG:上半身外衣_副 == 衣装_上半身外衣_副_啦啦队服
	;如果不在H场景中则不发动效果
	IF CFLAG:ARG:うふふ == 0
		SIF CFLAG:ARG:能力保存１ == 1  && TALENT:ARG:鼓舞 == 1
			TALENT:ARG:鼓舞 = 0
		SIF CFLAG:ARG:能力保存１ == -1 && TALENT:ARG:鼓舞 == 1
			TALENT:ARG:鼓舞 = -1
		RETURN 0
	ELSE
		IF TALENT:ARG:鼓舞 == 0
			TALENT:ARG:鼓舞 = 1
			CFLAG:ARG:能力保存１ = TALENT:ARG:鼓舞
		ELSEIF TALENT:ARG:鼓舞 == -1
			CFLAG:ARG:能力保存１ = TALENT:ARG:鼓舞
			TALENT:ARG:鼓舞 = -1
		ENDIF
		EXP:ARG:侍奉快乐经验 += 1
	ENDIF
	RETURN 1

;裸体围裙效果
;回复效果：爱情经验
ELSEIF EQUIP:ARG:连体外衣 == 衣装_连体外衣_裸体围裙
	;如果不在H场景中则不发动效果
	SIF CFLAG:ARG:うふふ == 0
		RETURN 0
	EXP:ARG:爱情经验 += 1
	RETURN 1

;女骑士效果　强气的女人嘛…
;素质附加：A敏感、淫肛、药毒耐性
;敏感度增加:Ａ
ELSEIF EQUIP:ARG:上半身外衣_主 == 衣装_上半身外衣_主_铠甲
	;退出H场景后恢复原有能力
	IF CFLAG:ARG:うふふ == 0
		SIF CFLAG:ARG:能力保存１ == 1  && TALENT:ARG:淫乳 == 1
			TALENT:ARG:淫乳 = 0
		SIF CFLAG:ARG:能力保存１ == -1 && TALENT:ARG:淫乳 == 1
			TALENT:ARG:淫乳 = -1
		SIF CFLAG:ARG:能力保存２ == 1 && TALENT:ARG:Ａ感度 == 1
			TALENT:ARG:Ａ感度 = 0
		SIF CFLAG:ARG:能力保存２ == -1 && TALENT:ARG:Ａ感度 == 1
			TALENT:ARG:Ａ感度 = -1
		SIF CFLAG:ARG:能力保存３ == 1 && TALENT:ARG:药毒耐性 == 1
			TALENT:ARG:药毒耐性 = 0
		SIF CFLAG:ARG:能力保存３ == -1 && TALENT:ARG:药毒耐性 == 1
			TALENT:ARG:药毒耐性 = -1
		RETURN 0
		;H场景中的效果
	ELSE
		IF TALENT:ARG:淫乳 == 0
			TALENT:ARG:淫乳 = 1
			CFLAG:ARG:能力保存１ = TALENT:ARG:淫乳
		ELSEIF TALENT:ARG:淫乳 == -1
			CFLAG:ARG:能力保存１ = TALENT:ARG:淫乳
			TALENT:ARG:淫乳 = 1
		ELSEIF TALENT:ARG:Ａ感度 == 0
			TALENT:ARG:Ａ感度 = 1
			CFLAG:ARG:能力保存２ = TALENT:ARG:Ａ感度
		ELSEIF TALENT:ARG:Ａ感度 == -1
			CFLAG:ARG:能力保存２ = TALENT:ARG:淫乳
			TALENT:ARG:淫乳 = 1
		ELSEIF TALENT:ARG:药毒耐性 == 0
			TALENT:ARG:药毒耐性 = 1
			CFLAG:ARG:能力保存３ = TALENT:ARG:药毒耐性
		ELSEIF TALENT:ARG:药毒耐性 == -1
			CFLAG:ARG:能力保存３ = TALENT:ARG:药毒耐性
			TALENT:ARG:药毒耐性 = 1
		ENDIF

	ENDIF
	RETURN 1

;忍者效果：哎！？对魔忍！？
ELSEIF EQUIP:ARG:连体外衣 == 衣装_连体外衣_忍者装束
	;非H场景时恢复
	IF CFLAG:ARG:うふふ == 0
		SIF CFLAG:ARG:能力保存１ == 1 && TALENT:ARG:容易中毒 == 1
			TALENT:ARG:容易中毒 = 0
		SIF CFLAG:ARG:能力保存１ == -1 && TALENT:ARG:容易中毒 == 1
			TALENT:ARG:容易中毒 = -1
		SIF CFLAG:ARG:能力保存２ == 1 && TALENT:ARG:Ｃ感度 == 1
			TALENT:ARG:Ｃ感度 = 0
		SIF CFLAG:ARG:能力保存２ == -1 && TALENT:ARG:Ｃ感度 == 1
			TALENT:ARG:Ｃ感度 = -1
		SIF CFLAG:ARG:能力保存３ == 1 && TALENT:ARG:Ｖ感度 == 1
			TALENT:ARG:Ｖ感度 = 0
		SIF CFLAG:ARG:能力保存３ == -1 && TALENT:ARG:Ｖ感度 == 1
			TALENT:ARG:Ｖ感度 = -1
		SIF CFLAG:ARG:能力保存４ == 1 && TALENT:ARG:Ａ感度 == 1
			TALENT:ARG:Ａ感度 = 0
		SIF CFLAG:ARG:能力保存４ == -1 && TALENT:ARG:Ａ感度 == 1
			TALENT:ARG:Ａ感度 = -1
		SIF CFLAG:ARG:能力保存５ == 1 && TALENT:ARG:Ｂ感度 == 1
			TALENT:ARG:Ｂ感度 = 0
		SIF CFLAG:ARG:能力保存５ == -1 && TALENT:ARG:淫乳 == 1
			TALENT:ARG:Ｂ感度 = -1
		RETURN 0
	ELSE
		IF TALENT:ARG:容易中毒 == 0
			TALENT:ARG:容易中毒 = 1
			CFLAG:ARG:能力保存１ = TALENT:ARG:容易中毒
		ELSEIF TALENT:ARG:容易中毒 == -1
			CFLAG:ARG:能力保存１ = TALENT:ARG:容易中毒
			TALENT:ARG:容易中毒 = 1
		ELSEIF TALENT:ARG:Ｃ感度 == 0
			TALENT:ARG:Ｃ感度 = 1
			CFLAG:ARG:能力保存２ = TALENT:ARG:Ｃ感度
		ELSEIF TALENT:ARG:Ｃ感度 == -1
			CFLAG:ARG:能力保存２ = TALENT:ARG:Ｃ感度
			TALENT:ARG:Ｃ感度 = 1
		ELSEIF TALENT:ARG:Ｖ感度 == 0
			TALENT:ARG:Ｖ感度 = 1
			CFLAG:ARG:能力保存３ = TALENT:ARG:Ｖ感度
		ELSEIF TALENT:ARG:Ｖ感度 == -1
			CFLAG:ARG:能力保存３ = TALENT:ARG:Ｖ感度
			TALENT:ARG:Ｖ感度 = 1
		ELSEIF TALENT:ARG:Ａ感度 == 0
			TALENT:ARG:Ａ感度 = 1
			CFLAG:ARG:能力保存４ = TALENT:ARG:Ａ感度
		ELSEIF TALENT:ARG:Ａ感度 == -1
			CFLAG:ARG:能力保存４ = TALENT:ARG:Ａ感度
			TALENT:ARG:Ａ感度 = 1
		ELSEIF TALENT:ARG:Ｂ感度 == 0
			TALENT:ARG:Ｂ感度 = 1
			CFLAG:ARG:能力保存５ = TALENT:ARG:Ｂ感度
		ELSEIF TALENT:ARG:Ｂ感度 == -1
			CFLAG:ARG:能力保存５ = TALENT:ARG:Ｂ感度
			TALENT:ARG:Ｂ感度 = 1
		ENDIF
	ENDIF
	RETURN 1

;绑缚效果　SM风格
;素质效果：倒错的
;回复效果：紧缚体验
ELSEIF EQUIP:ARG:下半身内衣_主 == 衣装_下半身内衣_主_粉红内裤 || EQUIP:ARG:上半身外衣_副 == 衣装_上半身外衣_副_束缚装
	;非H场景时恢复
	IF CFLAG:ARG:うふふ == 0
		SIF CFLAG:ARG:能力保存１ == 1 && TALENT:ARG:倒错的 == 1
			TALENT:ARG:倒错的 = 0
		SIF CFLAG:ARG:能力保存１ == -1 && TALENT:ARG:倒错的 == 1
			TALENT:ARG:倒错的 = -1
		RETURN 0
	ELSE
		IF TALENT:ARG:倒错的 == 0
			TALENT:ARG:倒错的 = 1
			CFLAG:ARG:能力保存１ = TALENT:ARG:倒错的
		ELSEIF TALENT:ARG:倒错的 == -1
			CFLAG:ARG:能力保存１ = TALENT:ARG:倒错的
			TALENT:ARG:倒错的 = -1
		ENDIF
		EXP:ARG:紧缚经验 += 1
	ENDIF
	RETURN 1


;护士效果　毕竟是护士嘛
;素质效果：治愈
ELSEIF EQUIP:ARG:上半身外衣_副 == 衣装_上半身外衣_副_护士服
	;非H场景时恢复
	IF CFLAG:ARG:うふふ == 0
		SIF CFLAG:ARG:能力保存１ == 1 && TALENT:ARG:治疗 == 1
			TALENT:ARG:治疗 = 0
		SIF CFLAG:ARG:能力保存１ == -1 && TALENT:ARG:治疗 == 1
			TALENT:ARG:治疗 = -1
		RETURN 0
	ELSE
		IF TALENT:ARG:治疗 == 0
			TALENT:ARG:治疗 = 1
			CFLAG:ARG:能力保存１ = TALENT:ARG:治疗
		ELSEIF TALENT:ARG:治疗 == -1
			CFLAG:ARG:能力保存１ = TALENT:ARG:治疗
			TALENT:ARG:治疗 = -1
		ENDIF
	ENDIF
	RETURN 1

;魔法少女效果　充满谜之魔力的服装
;常驻效果：男变女
ELSEIF EQUIP:ARG:上半身外衣_副 == 衣装_上半身外衣_副_魔法少女
	IF TALENT:ARG:性别 == 2
		CFLAG:ARG:コスプレ着用 = 1
		TALENT:ARG:性别 = 1
	ENDIF
	RETURN 1
;魔法少女效果消除
ELSEIF CFLAG:ARG:コスプレ着用 == 1 && EQUIP:ARG:上半身外衣_副 != 衣装_上半身外衣_副_魔法少女
	TALENT:ARG:性别 = 2
	CFLAG:ARG:コスプレ着用 = 0
	RETURN 0

;触手服效果　大概是从触手宫带来的吧
;常驻回复：异常经验＋各种增加。某种快感会积累
ELSEIF EQUIP:ARG:连体外衣 == 衣装_连体外衣_触手服
	CFLAG:ARG:コスプレ着用 = 2
	EXP:ARG:异常经验 ++
	SOURCE:ARG:快Ｃ += TIME_PROGRESS(TFLAG:300) * 5
	SOURCE:ARG:快Ａ += TIME_PROGRESS(TFLAG:300) * 5
	SOURCE:ARG:快Ｂ += TIME_PROGRESS(TFLAG:300) * 5
	IF TALENT:ARG:性别 != 2 && TALENT:ARG:处女 == 0
		SOURCE:ARG:快Ｖ += TIME_PROGRESS(TFLAG:300) * 5
	ENDIF
	RETURN 1

;牛娘　不过稍微榨乳一下的话倒想看看
;素质效果：母乳
ELSEIF EQUIP:ARG:上半身内衣_主 == 衣装_上半身内衣_主_牛比基尼
	;非H场景时恢复
	IF CFLAG:ARG:うふふ == 0
		SIF CFLAG:ARG:能力保存１ == 1 && TALENT:ARG:泌乳体质 == 1
			TALENT:ARG:泌乳体质 = 0
		SIF CFLAG:ARG:能力保存１ == -1 && TALENT:ARG:泌乳体质 == 1
			TALENT:ARG:泌乳体质 = -1
		RETURN 0
	ELSE
		IF TALENT:ARG:泌乳体质 == 0
			TALENT:ARG:泌乳体质 = 1
			CFLAG:ARG:能力保存１ = TALENT:ARG:泌乳体质
		ELSEIF TALENT:ARG:泌乳体质 == -1
			CFLAG:ARG:能力保存１ = TALENT:ARG:泌乳体质
			TALENT:ARG:泌乳体质 = -1
		ENDIF
	ENDIF
	RETURN 1
;圣诞：礼物…？
ELSEIF EQUIP:ARG:上半身外衣_副 == 衣装_上半身外衣_副_圣诞装 && 日期_月数 == 5 && 日期_天数 == 24
	IF ARG != 0
		CFLAG:ARG:サンタ = 1
	ELSE
		RETURN 0
	ENDIF
;没有任何效果则直接返回，并消除常驻效果
ELSE
	;触手服效果消除
	IF CFLAG:ARG:コスプレ着用 == 2
		CFLAG:ARG:コスプレ着用 = 0
	ENDIF
	RETURN 0
ENDIF


@SANTA(ARG)
IF CFLAG:ARG:サンタ == 1
	PRINTL 早上起来的时候旁边放着什么东西
	PRINTL 像圣诞礼物一样
	PRINTFORML 「%CALLNAME:ARG%送给%CALLNAME:MASTER%嗒へ」拿出了里面的东西

	IF TALENT:ARG:NTR == 1
		LOCAL = RAND:2
		IF LOCAL == 0
			PRINTFORML 是访问者和%CALLNAME:ARG%做爱的照片
		ELSEIF LOCAL == 1
			PRINTL 是一份录像，于是播放里面的内容
			PRINTL ・・・
			PRINTL
			PRINTL ・・・・・・
			PRINTFORML %CALLNAME:ARG%跟不认识的男人乱交的视频
		ENDIF
	ELSE
		PRINTL 手织的毛衣,有什么东西掉下来了
		LOCAL = RAND:2
		IF LOCAL == 0
			PRINTFORML 是情书……读起来使人害羞的内容
		ELSE
			PRINTFORML 是内裤，接触到的时候感到奇妙的温暖
		ENDIF
	ENDIF

	CFLAG:ARG:サンタ = 0
ENDIF
