;=================================================
; 角色扮演预设
; 内置造型用于即时换装；保存的角色扮演套装使用独立快照。
;=================================================

@CLOTHES_Preset_Cosplay(着用者, 更换内衣=1)
#DIM 着用者
#DIM 更换内衣
CALL CLOTHES_RESTORE_SNAPSHOT(着用者, 衣装记录_Cosplay_起始位, 更换内衣)
CFLAG:着用者:寝間着着用 = 0
RETURN 0

@CLOTHES_Preset_Cosplay_Save(着用者)
#DIM 着用者
CALL CLOTHES_SAVE_SNAPSHOT(着用者, 衣装记录_Cosplay_起始位)
RETURN 0
