;=================================================
; Cosplay 服装预设
;=================================================

;-------------------------------------------------
; Cosplay 预设：委托给 CLOTHES_Preset_CUSTOM
; 与 CLOTHES_Preset_CUSTOM 实现完全相同
; CLOTHES_Preset_Cosplay_Save 保存后从此读取
;-------------------------------------------------
@CLOTHES_Preset_Cosplay(着用者,更换内衣=1)
#DIM 着用者
#DIM 更换内衣
CALL CLOTHES_Preset_CUSTOM(着用者,更换内衣)
RETURN RESULT

;-------------------------------------------------
; 保存当前服装到私服集
;-------------------------------------------------
@CLOTHES_Preset_Cosplay_Save(着用者)
#DIM 着用者
#DIM 部位计数

FOR 部位计数, 1, 19
	CFLAG:着用者:(衣装记录_私服_起始位 + 部位计数) = EQUIP:着用者:部位计数
NEXT
RETURN 1

;-------------------------------------------------
; 比基尼
;-------------------------------------------------
@CLOTHES_Preset_Bikini(着用者,更换内衣=1)
#DIM 着用者
#DIM 更换内衣
CALL CLOTHES_Preset_NUDE(着用者,更换内衣)
EQUIP:着用者:衣装部位_下半身内衣_主 = 衣装_下半身内衣_主_比基尼
EQUIP:着用者:衣装部位_上半身内衣_主 = 衣装_上半身内衣_主_比基尼
CFLAG:着用者:寝間着着用 = 0
RETURN 1

