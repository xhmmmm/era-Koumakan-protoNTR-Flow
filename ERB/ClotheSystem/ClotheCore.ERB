;=================================================
; 服装系统核心函数
; 提供穿/脱/保存/恢复/TEQUIP刷新/属性查询等基础操作
;=================================================

;-------------------------------------------------
; 穿上一件衣服
; 处理互斥：全身型 ↔ 分体、主 ↔ 全身型
;-------------------------------------------------
@CLOTHES_WEAR(着用者, 部位, 款式)
#DIM 着用者
#DIM 部位
#DIM 款式

; 全身型穿上时，清除所有分体服装
SELECTCASE 部位
CASE 衣装部位_赛车服, 衣装部位_连衣裙, 衣装部位_着物, 衣装部位_紧身衣
	CALL CLOTHES_CLEAR_BODY(着用者)
; 分体穿上时，清除全身型
CASE 衣装部位_上半身外衣_主, 衣装部位_上半身外衣_副, 衣装部位_上半身内衣_主, 衣装部位_上半身内衣_副
	CALL CLOTHES_CLEAR_FULLBODY(着用者)
CASE 衣装部位_下半身外衣_主, 衣装部位_下半身外衣_副, 衣装部位_下半身内衣_主, 衣装部位_下半身内衣_副, 衣装部位_裙子
	CALL CLOTHES_CLEAR_FULLBODY(着用者)
ENDSELECT

EQUIP:着用者:部位 = 款式
RETURN 1

;-------------------------------------------------
; 脱下一件衣服
;-------------------------------------------------
@CLOTHES_STRIP(着用者, 部位)
#DIM 着用者
#DIM 部位

EQUIP:着用者:部位 = 0
RETURN 1

;-------------------------------------------------
; 清除所有分体服装（穿全身型时调用）
;-------------------------------------------------
@CLOTHES_CLEAR_BODY(着用者)
#DIM 着用者

EQUIP:着用者:衣装部位_上半身外衣_主 = 0
EQUIP:着用者:衣装部位_上半身外衣_副 = 0
EQUIP:着用者:衣装部位_上半身内衣_主 = 0
EQUIP:着用者:衣装部位_上半身内衣_副 = 0
EQUIP:着用者:衣装部位_下半身外衣_主 = 0
EQUIP:着用者:衣装部位_下半身外衣_副 = 0
EQUIP:着用者:衣装部位_下半身内衣_主 = 0
EQUIP:着用者:衣装部位_下半身内衣_副 = 0
EQUIP:着用者:衣装部位_裙子 = 0
RETURN 1

;-------------------------------------------------
; 清除全身型服装（穿分体时调用）
;-------------------------------------------------
@CLOTHES_CLEAR_FULLBODY(着用者)
#DIM 着用者

EQUIP:着用者:衣装部位_赛车服 = 0
EQUIP:着用者:衣装部位_连衣裙 = 0
EQUIP:着用者:衣装部位_着物 = 0
EQUIP:着用者:衣装部位_紧身衣 = 0
RETURN 1

;-------------------------------------------------
; 全裸
;-------------------------------------------------
@CLOTHES_STRIP_ALL(着用者)
#DIM 着用者

EQUIP:着用者:衣装部位_配件 = 0
EQUIP:着用者:衣装部位_帽子 = 0
EQUIP:着用者:衣装部位_鞋 = 0
EQUIP:着用者:衣装部位_袜 = 0
EQUIP:着用者:衣装部位_下半身内衣_副 = 0
EQUIP:着用者:衣装部位_下半身内衣_主 = 0
EQUIP:着用者:衣装部位_下半身外衣_主 = 0
EQUIP:着用者:衣装部位_下半身外衣_副 = 0
EQUIP:着用者:衣装部位_裙子 = 0
EQUIP:着用者:衣装部位_上半身内衣_副 = 0
EQUIP:着用者:衣装部位_上半身内衣_主 = 0
EQUIP:着用者:衣装部位_上半身外衣_主 = 0
EQUIP:着用者:衣装部位_上半身外衣_副 = 0
EQUIP:着用者:衣装部位_赛车服 = 0
EQUIP:着用者:衣装部位_连衣裙 = 0
EQUIP:着用者:衣装部位_着物 = 0
EQUIP:着用者:衣装部位_紧身衣 = 0
EQUIP:着用者:衣装部位_手 = 0
RETURN 1

;-------------------------------------------------
; 判断是否穿着任何衣物
; 返回 0=全裸, 1=穿着
;-------------------------------------------------
@CLOTHES_IsDressed(着用者)
#FUNCTION
#DIM 着用者

; 检查所有部位
SIF EQUIP:着用者:衣装部位_配件
	RETURNF 1
SIF EQUIP:着用者:衣装部位_帽子
	RETURNF 1
SIF EQUIP:着用者:衣装部位_鞋
	RETURNF 1
SIF EQUIP:着用者:衣装部位_袜
	RETURNF 1
SIF EQUIP:着用者:衣装部位_下半身内衣_副
	RETURNF 1
SIF EQUIP:着用者:衣装部位_下半身内衣_主
	RETURNF 1
SIF EQUIP:着用者:衣装部位_下半身外衣_主
	RETURNF 1
SIF EQUIP:着用者:衣装部位_下半身外衣_副
	RETURNF 1
SIF EQUIP:着用者:衣装部位_裙子
	RETURNF 1
SIF EQUIP:着用者:衣装部位_上半身内衣_副
	RETURNF 1
SIF EQUIP:着用者:衣装部位_上半身内衣_主
	RETURNF 1
SIF EQUIP:着用者:衣装部位_上半身外衣_主
	RETURNF 1
SIF EQUIP:着用者:衣装部位_上半身外衣_副
	RETURNF 1
SIF EQUIP:着用者:衣装部位_赛车服
	RETURNF 1
SIF EQUIP:着用者:衣装部位_连衣裙
	RETURNF 1
SIF EQUIP:着用者:衣装部位_着物
	RETURNF 1
SIF EQUIP:着用者:衣装部位_紧身衣
	RETURNF 1
SIF EQUIP:着用者:衣装部位_手
	RETURNF 1
RETURNF 0

;-------------------------------------------------
; 保存当前穿着到 CFLAG:服装_*
;-------------------------------------------------
@CLOTHES_Save(着用者)
#DIM 着用者
#DIM 部位计数

; 逐部位保存（EQUIP索引 = CFLAG偏移量）
FOR 部位计数, 1, 19
	CFLAG:着用者:(衣装记录_服装_起始位 + 部位计数) = EQUIP:着用者:部位计数
NEXT
RETURN 1

;-------------------------------------------------
; 从 CFLAG:服装_* 恢复穿着
; 更换内衣=1 时也恢复内衣，否则只恢复外衣
;-------------------------------------------------
@CLOTHES_Load(着用者, 更换内衣 = 1)
#DIM 着用者
#DIM 更换内衣
#DIM 部位计数

; 恢复外衣和配件（排除内衣部位 5,6,10,11）
FOR 部位计数, 1, 19
	SELECTCASE 部位计数
	CASE 衣装部位_下半身内衣_副, 衣装部位_下半身内衣_主, 衣装部位_上半身内衣_副, 衣装部位_上半身内衣_主
		; 内衣仅在 更换内衣 时恢复
		SIF 更换内衣
			EQUIP:着用者:部位计数 = CFLAG:着用者:(衣装记录_服装_起始位 + 部位计数)
	CASEELSE
		EQUIP:着用者:部位计数 = CFLAG:着用者:(衣装记录_服装_起始位 + 部位计数)
	ENDSELECT
NEXT

RETURN 1

;-------------------------------------------------
; 保存当前穿着到 CFLAG:私服_*
;-------------------------------------------------
@CLOTHES_Save_Custom(着用者)
#DIM 着用者
#DIM 部位计数


FOR 部位计数, 1, 19
	CFLAG:着用者:(衣装记录_私服_起始位 + 部位计数) = EQUIP:着用者:部位计数
NEXT
RETURN 1

;-------------------------------------------------
; 从 CFLAG:私服_* 恢复穿着
;-------------------------------------------------
@CLOTHES_Load_Custom(着用者, 更换内衣 = 1)
#DIM 着用者
#DIM 更换内衣
#DIM 部位计数

FOR 部位计数, 1, 19
	SELECTCASE 部位计数
	CASE 衣装部位_下半身内衣_副, 衣装部位_下半身内衣_主, 衣装部位_上半身内衣_副, 衣装部位_上半身内衣_主
		SIF 更换内衣
			EQUIP:着用者:部位计数 = CFLAG:着用者:(衣装记录_私服_起始位 + 部位计数)
	CASEELSE
		EQUIP:着用者:部位计数 = CFLAG:着用者:(衣装记录_私服_起始位 + 部位计数)
	ENDSELECT
NEXT

RETURN 1

;-------------------------------------------------
; 旧接口兼容：CLOTHES_RESET → CLOTHES_Load
;-------------------------------------------------
@CLOTHES_RESET(着用者, 更换内衣 = 1)
#DIM 着用者
#DIM 更换内衣

CALL CLOTHES_Load(着用者, 更换内衣)
RETURN RESULT

;-------------------------------------------------
; 旧接口兼容：CLOTHES_SETTING_TRAIN → CLOTHES_REFRESH_TEQUIP
;-------------------------------------------------
@CLOTHES_SETTING_TRAIN(着用者)
#DIM 着用者

CALL CLOTHES_REFRESH_TEQUIP(着用者)
RETURN RESULT

;-------------------------------------------------
; EQUIP → TEQUIP 转换
; 将穿着状态转换为位标记，供调教命令判断使用
;-------------------------------------------------
@CLOTHES_REFRESH_TEQUIP(着用者)
#DIM 着用者

; 不处理全裸的角色
SIF !CLOTHES_IsDressed(着用者)
	RETURN 0

;--- 下半身着衣状况 ---
TEQUIP:着用者:下半身着衣状況 = 0

; bit0: 裙子
IF EQUIP:着用者:衣装部位_裙子 || EQUIP:着用者:衣装部位_连衣裙 || EQUIP:着用者:衣装部位_着物
	SETBIT TEQUIP:着用者:下半身着衣状況, 着衣_下半身_裙子
ENDIF

; bit1: 副层（可偏移的内层）
IF EQUIP:着用者:衣装部位_下半身内衣_主 || EQUIP:着用者:衣装部位_下半身外衣_副 || EQUIP:着用者:衣装部位_紧身衣
	SETBIT TEQUIP:着用者:下半身着衣状況, 着衣_下半身_副层
ENDIF

; bit2: 主层（不可偏移的主层）
IF EQUIP:着用者:衣装部位_下半身内衣_副 || EQUIP:着用者:衣装部位_下半身外衣_主 || EQUIP:着用者:衣装部位_赛车服
	SETBIT TEQUIP:着用者:下半身着衣状況, 着衣_下半身_主层
ENDIF

; bit3: 下半身外衣_主
IF EQUIP:着用者:衣装部位_下半身外衣_主 || EQUIP:着用者:衣装部位_赛车服
	SETBIT TEQUIP:着用者:下半身着衣状況, 着衣_下半身_主层外衣
ENDIF

; bit4: 全身型
IF EQUIP:着用者:衣装部位_赛车服 || EQUIP:着用者:衣装部位_紧身衣
	SETBIT TEQUIP:着用者:下半身着衣状況, 着衣_下半身_全身型
ENDIF

;--- 上半身着衣状况 ---
TEQUIP:着用者:上半身着衣状況 = 0

; bit0: 副层（可掀开的副层）
IF EQUIP:着用者:衣装部位_上半身内衣_主 || EQUIP:着用者:衣装部位_上半身外衣_副 || EQUIP:着用者:衣装部位_着物
	SETBIT TEQUIP:着用者:上半身着衣状況, 着衣_上半身_副层
ENDIF

; bit1: 主层（不可掀开的主层）
IF EQUIP:着用者:衣装部位_上半身内衣_副 || EQUIP:着用者:衣装部位_上半身外衣_主 || EQUIP:着用者:衣装部位_赛车服 || EQUIP:着用者:衣装部位_连衣裙 || EQUIP:着用者:衣装部位_紧身衣
	SETBIT TEQUIP:着用者:上半身着衣状況, 着衣_上半身_主层
ENDIF

; bit2: 主层内衣
IF EQUIP:着用者:衣装部位_上半身内衣_副 || EQUIP:着用者:衣装部位_上半身外衣_主 || EQUIP:着用者:衣装部位_赛车服 || EQUIP:着用者:衣装部位_紧身衣
	SETBIT TEQUIP:着用者:上半身着衣状況, 着衣_上半身_主层内衣
ENDIF

; bit3: 全身型
IF EQUIP:着用者:衣装部位_赛车服 || EQUIP:着用者:衣装部位_紧身衣
	SETBIT TEQUIP:着用者:上半身着衣状況, 着衣_上半身_全身型
ENDIF

;--- 偏移/掀开状态处理 ---
; 下半身偏移中：清除副层标记
IF TEQUIP:着用者:下半身ずらし状態
	CLEARBIT TEQUIP:着用者:下半身着衣状況, 着衣_下半身_副层
ENDIF

; 上半身掀开中：清除副层标记
IF TEQUIP:着用者:上半身はだけ状態
	CLEARBIT TEQUIP:着用者:上半身着衣状況, 着衣_上半身_副层
ENDIF

RETURN 1

;-------------------------------------------------
; 查询服装属性：可掀开/可偏移
; 返回 1=可, 0=不可
; 这是解耦后的属性查询，不再由槽位决定
;-------------------------------------------------
@衣装_可掀开(着用者, 部位)
#FUNCTION
#DIM 着用者
#DIM 部位
#DIM 款式

款式 = EQUIP:着用者:部位

; 没穿东西当然不可掀开
SIF 款式 == 0
	RETURNF 0

SELECTCASE 部位
;--- 上半身 可掀开判定 ---
CASE 衣装部位_上半身外衣_主
	; 外层上衣默认可掀开（外套可以敞开露出内层）
	SELECTCASE 款式
	CASE 衣装_上半身外衣_主_铠甲
		RETURNF 0
	CASEELSE
		RETURNF 1
	ENDSELECT

CASE 衣装部位_上半身外衣_副
	; 内层上衣默认可掀开
	SELECTCASE 款式
	CASE 衣装_上半身外衣_副_大衣, 衣装_上半身外衣_副_巫女服, 衣装_上半身外衣_副_博丽巫女服
		RETURNF 0
	CASEELSE
		RETURNF 1
	ENDSELECT

CASE 衣装部位_上半身内衣_主
	; 胸罩默认可掀开
	SELECTCASE 款式
	CASE 衣装_上半身内衣_主_胸贴, 衣装_上半身内衣_主_裹胸布
		RETURNF 0
	CASEELSE
		RETURNF 1
	ENDSELECT

CASE 衣装部位_上半身内衣_副
	; 乳贴不可掀开
	RETURNF 0

;--- 下半身 可偏移判定 ---
CASE 衣装部位_下半身外衣_主
	; 裤子/紧身裤不可偏移
	SELECTCASE 款式
	CASE 衣装_下半身外衣_主_裤子, 衣装_下半身外衣_主_紧身裤
		RETURNF 0
	CASE 衣装_下半身外衣_主_袴
		RETURNF 1
	ENDSELECT

CASE 衣装部位_下半身外衣_副
	; 短裤/灯笼裤等可偏移
	RETURNF 1

CASE 衣装部位_下半身内衣_主
	; 内裤可偏移
	RETURNF 1

CASE 衣装部位_下半身内衣_副
	; 贞操带不可偏移，创口贴可偏移
	SELECTCASE 款式
	CASE 衣装_下半身内衣_副_贞操带
		RETURNF 0
	CASEELSE
		RETURNF 1
	ENDSELECT

CASE 衣装部位_裙子
	; 裙子可掀起
	RETURNF 1

;--- 全身型 ---
CASE 衣装部位_赛车服
	RETURNF 0

CASE 衣装部位_连衣裙
	; 连衣裙部分款式可掀开
	SELECTCASE 款式
	CASE 衣装_连衣裙_裸体围裙, 衣装_连衣裙_斗篷
		RETURNF 1
	CASEELSE
		RETURNF 0
	ENDSELECT

CASE 衣装部位_着物
	; 和服可掀开
	RETURNF 1

CASE 衣装部位_紧身衣
	; 紧身衣多数不可掀开
	SELECTCASE 款式
	CASE 衣装_紧身衣_忍者装束
		RETURNF 1
	CASEELSE
		RETURNF 0
	ENDSELECT

ENDSELECT

RETURNF 0

;-------------------------------------------------
; 判断是否没穿内裤
; 返回 1=没穿, 0=穿了
;-------------------------------------------------
@CHK_NO_PANTS(着用者)
#FUNCTION
#DIM 着用者

SIF EQUIP:着用者:衣装部位_下半身内衣_主 == 0 && EQUIP:着用者:衣装部位_下半身内衣_副 == 0
	RETURNF 1
RETURNF 0

;-------------------------------------------------
; 获取下半身内裤名称
;-------------------------------------------------
@下着名１_２(着用者)
#FUNCTIONS
#DIM 着用者

; 优先取副层名称（贞操带等），其次取主层名称
IF EQUIP:着用者:衣装部位_下半身内衣_副
	RETURNF 服装名_取得(衣装部位_下半身内衣_副, EQUIP:着用者:衣装部位_下半身内衣_副)
ELSEIF EQUIP:着用者:衣装部位_下半身内衣_主
	RETURNF 服装名_取得(衣装部位_下半身内衣_主, EQUIP:着用者:衣装部位_下半身内衣_主)
ENDIF
RETURNF "下半身"

;-------------------------------------------------
; 内裤选择（上半身胸罩）
;-------------------------------------------------
@CLOTHES_Change_Bra(着用者, 更换内衣 = 1)
#DIM 着用者
#DIM 更换内衣

SIF 更换内衣 == 0
	RETURN 0

; 无胸罩指定
SIF GETBIT(CFLAG:着用者:服装パターンオプション, 1)
	RETURN 0

; 绝壁不需要胸罩
SIF TALENT:着用者:胸部尺寸 == -2
	RETURN 0

; 穿上普通胸罩
EQUIP:着用者:衣装部位_上半身内衣_副 = 0
EQUIP:着用者:衣装部位_上半身内衣_主 = 衣装_上半身内衣_主_胸罩
RETURN 1

;-------------------------------------------------
; 内裤选择（下半身内裤）
;-------------------------------------------------
@CLOTHES_Change_Knickers(着用者, 更换内衣 = 1)
#DIM 着用者
#DIM 更换内衣

SIF 更换内衣 == 0
	RETURN 0

; 无内裤指定
SIF GETBIT(CFLAG:着用者:服装パターンオプション, 0)
	RETURN 0

; 副层清零
EQUIP:着用者:衣装部位_下半身内衣_副 = 0

; 根据状态选择内裤类型
IF TALENT:着用者:淫乱
	CALL NTR_PANTS(着用者)
ELSEIF CFLAG:着用者:屈服度 > CFLAG:着用者:好感度 && CFLAG:着用者:屈服度 > 999
	CALL NTR_PANTS(着用者, 1)
ELSE
	CALL NTR_PANTS(着用者, 0)
ENDIF
RETURN 1

;-------------------------------------------------
; 一天开始时的服装初始化
; 根据 CFLAG:服装パターン 选择预设，然后保存并刷新TEQUIP
;-------------------------------------------------
@CLOTHES_INIT_DAY(着用者, 更换内衣 = 1)
#DIM 着用者
#DIM 更换内衣

; 睡眠中统一穿睡衣
IF CFLAG:着用者:睡眠
	CALL CLOTHES_Preset_NIGHTWEAR(着用者)
ELSE
	; 根据预设编号选择服装
	SELECTCASE CFLAG:着用者:服装パターン
	CASE 衣装预设_全裸
		CALL CLOTHES_Preset_NUDE(着用者)
	CASE 衣装预设_男装
		CALL CLOTHES_Preset_MALE(着用者)
	CASE 衣装预设_女装
		CALL CLOTHES_Preset_FEMALE(着用者)
	CASE 衣装预设_绅士
		CALL CLOTHES_Preset_jentle(着用者)
	CASE 衣装预设_女仆
		CALL CLOTHES_Preset_MAID(着用者)
	CASE 衣装预设_私服
		CALL CLOTHES_Preset_CUSTOM(着用者)
	CASE 衣装预设_角色开始 TO 衣装预设_角色结束
		; 角色预设：预设编号 - 100 即为角色编号
		TRYCALLFORM CLOTHES_Preset_{CFLAG:着用者:服装パターン - 100}(着用者)
	CASE 衣装预设_Cosplay
		CALL CLOTHES_Preset_Cosplay(着用者)
	CASEELSE
		CALL CLOTHES_Preset_NUDE(着用者)
	ENDSELECT
ENDIF

; 保存当前穿着状态
CALL CLOTHES_Save(着用者)
; 刷新 TEQUIP
CALL CLOTHES_REFRESH_TEQUIP(着用者)
RETURN 1
