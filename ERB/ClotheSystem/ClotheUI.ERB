#DIM  选择服装模式
#DIMS 选择预设名
重绘行数 = LINECOUNT
DO
	CLEARLINE (LINECOUNT - 重绘行数)
	PRINTFORML %"□ 预设 □---------------------------------------------------------------"%
	PRINTFORML %"[0] - 男装套装"%
	PRINTFORML %"[1] - 女装套装"%
	PRINTFORML %"[2] - 绅士套装"%
	PRINTFORML %"[3] - 女仆套装"%
	PRINTFORML %"[4] - 美铃套装"%
	PRINTFORML %"[5] - 小恶魔套装"%
	PRINTFORML %"[6] - 帕秋莉套装"%
	PRINTFORML %"[7] - 咲夜套装"%
	PRINTFORML %"[8] - 蕾米莉亚套装"%
	PRINTFORML %"[9] - 芙兰套装"%
	PRINTFORML %"[91] - 私服套装 换衣"%
	PRINTFORML %"[92] - 私服套装 注册"%
	PRINTFORML %"[100] - 返回"%
	INPUT
	选择预设 = RESULT
	SELECTCASE 选择预设
		CASE 0
			CALL CLOTHES_Preset_MALE(角色)
			选择预设名 = %"男装套装"%
			选择服装模式 = 1
		CASE 1
			CALL CLOTHES_Preset_FEMALE(角色)
			选择预设名 = %"女装套装"%
			选择服装模式 = 2
		CASE 2
			CALL CLOTHES_Preset_jentle(角色)
			选择预设名 = %"绅士套装"%
			选择服装模式 = 3
		CASE 3
			CALL CLOTHES_Preset_MAID(角色)
			选择预设名 = %"女仆套装"%
			选择服装模式 = 4
		CASE 4
			CALL CLOTHES_Preset_1(角色)
			选择预设名 = %"美铃套装"%
			选择服装模式 = 101
		CASE 5
			CALL CLOTHES_Preset_2(角色)
			选择预设名 = %"小恶魔套装"%
			选择服装模式 = 102
		CASE 6
			CALL CLOTHES_Preset_3(角色)
			选择预设名 = %"帕秋莉套装"%
			选择服装模式 = 103
		CASE 7
			CALL CLOTHES_Preset_4(角色)
			选择预设名 = %"咲夜套装"%
			选择服装模式 = 104
		CASE 8
			CALL CLOTHES_Preset_5(角色)
			选择预设名 = %"蕾米莉亚套装"%
			选择服装模式 = 105
		CASE 9
			CALL CLOTHES_Preset_6(角色)
			选择预设名 = %"芙兰套装"%
			选择服装模式 = 106
		CASE 91
			CALL CLOTHES_Preset_CUSTOM(角色)
			选择预设名 = %"私服套装"%
			选择服装模式 = 100
		CASE 92
			CALL CLOTHES_Preset_Cosplay_Save(角色)
			选择预设名 = %"私服套装"%
			选择服装模式 = 100
		CASE 100
			RETURN 0
		CASEELSE
			选择预设 = 0
	ENDSELECT
LOOP (选择预设 == 0)
重绘行数 = LINECOUNT
DO
	CLEARLINE (LINECOUNT - 重绘行数)
	PRINTFORML %"要将日常着装改为"+选择预设名+"吗？（起床时自动换衣）"%
	PRINTFORML %"[0] - 是的"%
	PRINTFORML %"[1] - 不要"%
	INPUT
	SELECTCASE RESULT
		CASE 0
			CFLAG:角色:服装パターン = 选择服装模式
			RETURN 0
		CASE 1
			RETURN 0
	ENDSELECT
LOOP 1
RETURN 0

