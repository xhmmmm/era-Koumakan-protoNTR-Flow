			选择预设 = 0
	ENDSELECT
LOOP (选择预设 == 0)
重绘行数 = LINECOUNT
DO
	CLEARLINE (LINECOUNT - 重绘行数)
	PRINTFORML %"要将日常着装改为"+选择预设名+"吗？（起床时自动换衣）"%
