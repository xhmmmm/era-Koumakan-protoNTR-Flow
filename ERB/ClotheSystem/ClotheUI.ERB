;=================================================
; 换装界面
; 换装菜单只写入可换部件；特殊饰品由角色状态和剧情处理。
;=================================================

@CLOTHES_SLOT_NAME(槽位)
#FUNCTIONS
#DIM 槽位
SELECTCASE 槽位
CASE 衣装部位_手部配饰
    RETURNF "手部配饰"
CASE 衣装部位_头部
    RETURNF "头部"
CASE 衣装部位_手部
    RETURNF "手部"
CASE 衣装部位_腿部
    RETURNF "腿部"
CASE 衣装部位_鞋
    RETURNF "鞋"
CASE 衣装部位_下半身内衣_主
    RETURNF "下身内衣"
CASE 衣装部位_下半身内衣_副
    RETURNF "下身附加内衣"
CASE 衣装部位_上半身内衣_主
    RETURNF "上身内衣"
CASE 衣装部位_上半身内衣_副
    RETURNF "上身附加内衣"
CASE 衣装部位_上半身外衣_主
    RETURNF "上装"
CASE 衣装部位_上半身外衣_副
    RETURNF "附加上装"
CASE 衣装部位_下半身外衣_主
    RETURNF "下装"
CASE 衣装部位_下半身外衣_副
    RETURNF "附加下装"
CASE 衣装部位_连体外衣
    RETURNF "连体外衣"
CASE 衣装部位_颈部环饰
    RETURNF "颈部环饰"
CASE 衣装部位_颈部挂饰
    RETURNF "颈部挂饰"
ENDSELECT
RETURNF ""

@CLOTHES_PRINT_SLOT(角色, 槽位, 可更换, 隐藏内衣 = 0)
#DIM 角色
#DIM 槽位
#DIM 可更换
#DIM 隐藏内衣
#DIMS 标签
#DIMS 名称
标签 '= CLOTHES_SLOT_NAME(槽位)
IF 隐藏内衣 && 角色 != MASTER && Unknown下着(角色, 槽位)
    IF 槽位 == 衣装部位_下半身内衣_副
        名称 '= "？内裤？"
    ELSE
        名称 '= "未确认"
    ENDIF
ELSE
    名称 '= CLOTHNAME(槽位, EQUIP:角色:槽位)
    SIF 名称 == ""
        名称 '= "未穿"
ENDIF
IF 可更换
    PRINTFORM [{槽位,2}]
ELSE
    PRINTFORM [--]
ENDIF
PRINTFORM %标签,12,LEFT%：%名称,16,LEFT%
RETURN 1

@CLOTHES_PRINT_SLOT_PAIR(角色, 槽位1, 槽位2, 允许内衣, 隐藏内衣 = 0)
#DIM 角色
#DIM 槽位1
#DIM 槽位2
#DIM 允许内衣
#DIM 隐藏内衣
CALL CLOTHES_PRINT_SLOT(角色, 槽位1, CLOTHES_SLOT_CAN_CHANGE(槽位1, 允许内衣), 隐藏内衣)
PRINTFORM 　　
CALL CLOTHES_PRINT_SLOT(角色, 槽位2, CLOTHES_SLOT_CAN_CHANGE(槽位2, 允许内衣), 隐藏内衣)
PRINTL
RETURN 1

@CLOTHES_PRINT_SPECIAL(角色, 槽位)
#DIM 角色
#DIM 槽位
CALL CLOTHES_PRINT_SLOT(角色, 槽位, 0)
RETURN 1
@CLOTHES_CHOOSE(角色, 允许内衣 = 1, 允许色情内衣 = 1, 隐藏内衣 = 0)
#DIM 角色
#DIM 允许内衣
#DIM 允许色情内衣
#DIM 隐藏内衣
#DIM 结束
DO
    DRAWLINE
    PRINTL □ 更衣 □---------------------------------------------------------------------
    PRINTFORML %CALLNAME:角色% 的穿着
    PRINTL
    PRINTL □ 特殊饰品 □-----------------------------------------------------------------
    CALL CLOTHES_PRINT_SPECIAL(角色, 衣装部位_手部配饰)
    PRINTFORM 　　
    CALL CLOTHES_PRINT_SPECIAL(角色, 衣装部位_颈部环饰)
    PRINTL
    PRINTL □ 外部部件 □-----------------------------------------------------------------
    CALL CLOTHES_PRINT_SLOT_PAIR(角色, 衣装部位_头部, 衣装部位_手部, 允许内衣, 隐藏内衣)
    CALL CLOTHES_PRINT_SLOT_PAIR(角色, 衣装部位_腿部, 衣装部位_鞋, 允许内衣, 隐藏内衣)
    CALL CLOTHES_PRINT_SLOT(角色, 衣装部位_颈部挂饰, CLOTHES_SLOT_CAN_CHANGE(衣装部位_颈部挂饰, 允许内衣), 隐藏内衣)
    PRINTL
    PRINTL □ 外衣 □---------------------------------------------------------------------
    CALL CLOTHES_PRINT_SLOT_PAIR(角色, 衣装部位_上半身外衣_主, 衣装部位_上半身外衣_副, 允许内衣, 隐藏内衣)
    CALL CLOTHES_PRINT_SLOT_PAIR(角色, 衣装部位_下半身外衣_主, 衣装部位_下半身外衣_副, 允许内衣, 隐藏内衣)
    CALL CLOTHES_PRINT_SLOT(角色, 衣装部位_连体外衣, CLOTHES_SLOT_CAN_CHANGE(衣装部位_连体外衣, 允许内衣), 隐藏内衣)
    PRINTL
    PRINTL □ 贴身衣物 □-----------------------------------------------------------------
    CALL CLOTHES_PRINT_SLOT_PAIR(角色, 衣装部位_上半身内衣_主, 衣装部位_上半身内衣_副, 允许内衣, 隐藏内衣)
    CALL CLOTHES_PRINT_SLOT_PAIR(角色, 衣装部位_下半身内衣_主, 衣装部位_下半身内衣_副, 允许内衣, 隐藏内衣)
    PRINTL
    IF 允许内衣
        PRINTL [30] 常用预设　　[31] 全部脱下　　[32] 角色扮演预设
    ENDIF
    PRINTL [100] 完成
    INPUT
    IF RESULT >= 衣装部位_手部配饰 && RESULT <= 衣装部位_最后槽位 && CLOTHES_SLOT_CAN_CHANGE(RESULT, 允许内衣)
        CALL CLOTHES_CHOOSE_SLOT(角色, RESULT, 允许内衣, 允许色情内衣)
    ELSEIF 允许内衣 && RESULT == 30
        CALL CLOTHES_CHOOSE_PRESET(角色)
    ELSEIF 允许内衣 && RESULT == 31
        CALL CLOTHES_CLEAR_OUTFIT(角色)
    ELSEIF 允许内衣 && RESULT == 32
        CALL CLOTHES_CHOOSE_COSPLAY(角色)
    ELSEIF RESULT == 100
        结束 = 1
    ENDIF
LOOP !结束
CALL CLOTHES_SAVE(角色)
RETURN 1

@CLOTHES_CHOOSE_SLOT(角色, 槽位, 允许内衣 = 1, 允许色情内衣 = 1)
#DIM 角色
#DIM 槽位
#DIM 允许内衣
#DIM 允许色情内衣
#DIM 目录序号
#DIM 款式
#DIM 款式数量
#DIM 已显示
SIF !CLOTHES_SLOT_CAN_CHANGE(槽位, 允许内衣)
    RETURN 0
DRAWLINE
PRINTFORML □ %CLOTHES_SLOT_NAME(槽位)% □----------------------------------------------------------------
PRINTFORML 当前：%CLOTHNAME(槽位, EQUIP:角色:槽位)%
PRINTL
PRINTFORM [  0] %"脱下",18,LEFT%
已显示 = 1
款式数量 = CLOTHES_STYLE_COUNT(槽位)
FOR 目录序号, 1, 款式数量 + 1
    款式 = CLOTHES_STYLE_ID(槽位, 目录序号)
    SIF !CLOTHES_STYLE_CAN_CHANGE(槽位, 款式, 允许色情内衣)
        CONTINUE
    PRINTFORM [{款式,3}] %CLOTHNAME(槽位, 款式),18,LEFT%
    已显示 ++
    SIF 已显示 % 3 == 0
        PRINTL
NEXT
SIF 已显示 % 3 != 0
    PRINTL
PRINTL
PRINTL [999] 返回
INPUT
IF RESULT == 0
    CALL CLOTHES_UNEQUIP(角色, 槽位)
ELSEIF RESULT > 0 && CLOTHES_STYLE_CAN_CHANGE(槽位, RESULT, 允许色情内衣)
    CALL CLOTHES_EQUIP(角色, 槽位, RESULT)
ENDIF
RETURN 1

@CLOTHES_CHOOSE_PRESET(角色)
#DIM 角色
DRAWLINE
PRINTL □ 常用预设 □-----------------------------------------------------------------
PRINTFORM %"[0] 全裸",18,LEFT%%"[1] 男装",18,LEFT%[2] 女装
PRINTFORM %"[3] 绅士装",18,LEFT%%"[4] 女仆装",18,LEFT%[5] 私服
PRINTL
PRINTL [6] 将当前穿着保存为私服　　[7] 将私服设为日常穿着
PRINTL [999] 返回
INPUT
SELECTCASE RESULT
CASE 0
    CALL CLOTHES_Preset_NUDE(角色)
CASE 1
    CALL CLOTHES_Preset_MALE(角色)
CASE 2
    CALL CLOTHES_Preset_FEMALE(角色)
CASE 3
    CALL CLOTHES_Preset_jentle(角色)
CASE 4
    CALL CLOTHES_Preset_MAID(角色)
CASE 5
    CALL CLOTHES_Preset_CUSTOM(角色)
CASE 6
    CALL CLOTHES_SAVE_SNAPSHOT(角色, 衣装记录_私服_起始位)
CASE 7
    CFLAG:角色:服装パターン = 衣装预设_私服
ENDSELECT
RETURN 1

