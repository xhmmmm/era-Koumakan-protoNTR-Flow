@CLOTHES_CHOOSE_Head(角色)
#DIM 角色
#DIM 重绘行数
重绘行数 = LINECOUNT
DO
	CLEARLINE (LINECOUNT - 重绘行数)
	PRINTFORML %"□ 分类 □-----------------------------------------------------------------"%
	PRINTFORML %"        帽子           ："+CLOTHNAME(GETNUM(EQUIP,"帽子")          ,EQUIP:角色:帽子)%
	PRINTFORML %"□ 帽子 □---------------------------------------------------------------------"%
	PRINTFORML %"[  0] - 脱掉"%
	PRINTFORML %"[  1] - 帽子"%
	PRINTFORML %"[  2] - 头饰"%
	PRINTFORML %"[  3] - 蝴蝶结"%
	PRINTFORML %"[  4] - 猫耳"%
	PRINTFORML %"[  5] - 兔耳"%
	PRINTFORML %"[  6] - 犬耳"%
	PRINTFORML %"[100] - 返回"%
	INPUT
	SELECTCASE RESULT
		CASE 0,1,2,3,4,5,6
			EQUIP:角色:帽子 = RESULT
		CASE 100
			RETURN 0
	ENDSELECT
LOOP 1
RETURN 0

