	PRINTFORML %"[1] - 不要"%
	INPUT
	SELECTCASE RESULT
		CASE 0
			CFLAG:角色:服装パターン = 200
			RETURN 0
		CASE 1
			RETURN 0
	ENDSELECT
LOOP 1
RETURN 0

;-------------------------------------------------
; 服装_初始化_角色睡衣自定义
; 新存档第一次进SHOP时调用
;-------------------------------------------------
@服装_初始化_角色服装自定义

PRINTL 可以改变角色的服装

FOR LOCAL, 0, CHARANUM
	PRINTFORML [{LOCAL,3}] - %CALLNAME:LOCAL%
NEXT
PRINTL [999] 设置完成
INPUT

IF RESULT >= 0 && RESULT < CHARANUM
	CALL CLOTHES_CHOOSE(RESULT)
ELSEIF RESULT == 999
	PRINTL 这样可以吗？
	PRINTL [0] 是的
	PRINTBUTTON "[ELSE] 不要", 1
	PRINTL
	ONEINPUT
	SIF RESULT == 0
		RETURN
ENDIF
RESTART
RETURN 0

;-------------------------------------------------
; 服装_初始化_角色睡衣自定义
; 新存档第一次进SHOP时调用
;-------------------------------------------------
@服装_初始化_角色睡衣自定义
#DIM 睡衣最大编号 = 11
DRAWLINE
PRINTL 请设定角色们睡觉时的睡衣（只设定一次，以后不会再改变）
PRINTL
FOR LOCAL, 1, CHARANUM
	PRINTFORML [{LOCAL,3}] %CALLNAME:LOCAL%（%睡衣名称(CFLAG:LOCAL:寝間着)%）
NEXT
PRINTL [999] OK
INPUT
IF RESULT >= 1 && RESULT < CHARANUM
	LOCAL:1 = RESULT
	DRAWLINE
	PRINTFORML 设置%CALLNAME:(LOCAL:1)%的睡衣
	FOR LOCAL, 0, 睡衣最大编号 + 1
		PRINTFORML [{LOCAL}] %睡衣名称(LOCAL)%
	NEXT
	PRINTFORML [100] 返回
	INPUT
	IF RESULT >= 0 && RESULT <= 睡衣最大编号
		CFLAG:(LOCAL:1):寝間着 = RESULT
	ENDIF
ELSEIF RESULT == 999
	PRINTL 真的确定了吗？
	PRINTL [0] 是的
	PRINTBUTTON "[ELSE] 不要", 1
	ONEINPUT
	SIF RESULT == 0
		RETURN
ENDIF
RESTART
RETURN 0
