;=================================================
; 服装系统UI函数
; 换衣服选择界面、开局换衣、服装_初始化_角色睡衣自定义
;=================================================

;-------------------------------------------------
; 换衣服主UI
; 统一入口：COM430指令和开局换衣都调用此函数
;-------------------------------------------------
@CLOTHES_CHOOSE(角色)
#DIM 角色
#DIM 重绘行数
#DIMS 换前内裤名
#DIM 退出标志

; 记录换衣前的内裤名，用于退出时比较
换前内裤名 = 下着名１_２(角色)
退出标志 = 0

重绘行数 = LINECOUNT
DO
	CLEARLINE (LINECOUNT - 重绘行数)
	;CALL PRINT_STATE_CLOTH(角色)
	PRINTFORML %"□ 分类 □-----------------------------------------------------------------"%
	PRINTFORML %"[   ] - 配件     ："+CLOTHNAME(GETNUM(EQUIP,"配件")    ,EQUIP:角色:配件)+"(不可更改)"%
	PRINTFORML %"[  0] - 帽子           ："+CLOTHNAME(GETNUM(EQUIP,"帽子")          ,EQUIP:角色:帽子)%
	PRINTFORML %"[  1] - 鞋子           ："+CLOTHNAME(衣装部位_鞋 ,EQUIP:角色:鞋  )%
	PRINTFORML %"[  2] - 袜子           ："+CLOTHNAME(衣装部位_袜 ,EQUIP:角色:袜)%
	PRINTFORML %"[  3] - 手套           ："+CLOTHNAME(GETNUM(EQUIP,"手")            ,EQUIP:角色:手)%
	PRINTFORML %"[  4] - 下半身内衣     ："+CLOTHNAME(GETNUM(EQUIP,"下半身内衣_副")  ,EQUIP:角色:下半身内衣_副)  +CLOTHNAME(GETNUM(EQUIP,"下半身内衣_主"),EQUIP:角色:下半身内衣_主)%
	PRINTFORML %"[  5] - 下半身外衣     ："+CLOTHNAME(GETNUM(EQUIP,"下半身外衣_主")  ,EQUIP:角色:下半身外衣_主)  +CLOTHNAME(GETNUM(EQUIP,"下半身外衣_副"),EQUIP:角色:下半身外衣_副)+CLOTHNAME(GETNUM(EQUIP,"裙子"),EQUIP:角色:裙子)%
	PRINTFORML %"[  6] - 上半身内衣     ："+CLOTHNAME(GETNUM(EQUIP,"上半身内衣_副")  ,EQUIP:角色:上半身内衣_副)  +CLOTHNAME(GETNUM(EQUIP,"上半身内衣_主"),EQUIP:角色:上半身内衣_主)%
	PRINTFORML %"[  7] - 上半身外衣     ："+CLOTHNAME(GETNUM(EQUIP,"上半身外衣_主")  ,EQUIP:角色:上半身外衣_主)  +CLOTHNAME(GETNUM(EQUIP,"上半身外衣_副"),EQUIP:角色:上半身外衣_副)%
	PRINTFORML %"[  8] - 全身外衣       ："+CLOTHNAME(GETNUM(EQUIP,"赛车服"),EQUIP:角色:赛车服)+CLOTHNAME(GETNUM(EQUIP,"连衣裙")  ,EQUIP:角色:连衣裙)+CLOTHNAME(GETNUM(EQUIP,"着物"),EQUIP:角色:着物)+CLOTHNAME(GETNUM(EQUIP,"紧身衣"),EQUIP:角色:紧身衣)%
	PRINTFORML %"[  9] - 预设     "%
	PRINTFORML %"[ 10] - 角色扮演 "%
	PRINTFORML %"[ 11] - 全部脱掉     "%
	PRINTFORML %"[100] - 这样就好了     "%
	INPUT
	SELECTCASE RESULT
		CASE 0
			CLEARLINE (LINECOUNT - 重绘行数)
			CALL CLOTHES_CHOOSE_Head(角色)
		CASE 1
			CLEARLINE (LINECOUNT - 重绘行数)
			CALL CLOTHES_CHOOSE_Foot(角色)
		CASE 2
			CLEARLINE (LINECOUNT - 重绘行数)
			CALL CLOTHES_CHOOSE_Leg(角色)
		CASE 3
			CLEARLINE (LINECOUNT - 重绘行数)
			CALL CLOTHES_CHOOSE_Hand(角色)
		CASE 4
			CLEARLINE (LINECOUNT - 重绘行数)
			CALL CLOTHES_CHOOSE_Knickers(角色)
		CASE 5
			CLEARLINE (LINECOUNT - 重绘行数)
			CALL CLOTHES_CHOOSE_Botoms(角色)
		CASE 6
			CLEARLINE (LINECOUNT - 重绘行数)
			CALL CLOTHES_CHOOSE_Bra(角色)
		CASE 7
			CLEARLINE (LINECOUNT - 重绘行数)
			CALL CLOTHES_CHOOSE_Tops(角色)
		CASE 8
			CLEARLINE (LINECOUNT - 重绘行数)
			CALL CLOTHES_CHOOSE_Suit(角色)
		CASE 9
			CLEARLINE (LINECOUNT - 重绘行数)
			CALL CLOTHES_CHOOSE_Preset(角色)
		CASE 10
			CLEARLINE (LINECOUNT - 重绘行数)
			CALL CLOTHES_CHOOSE_Cosplay(角色)
		CASE 11
			CLEARLINE (LINECOUNT - 重绘行数)
			CALL CLOTHES_Preset_NUDE(角色)
		CASE 100
			退出标志 = 1
	ENDSELECT
	;每次操作后保存到CFLAG
	CALL CLOTHES_Save(角色)
LOOP 退出标志 == 0

; 退出时统一后处理
CALL CLOTHES_Save(角色)
CALL CLOTHES_REFRESH_TEQUIP(角色)

; 内裤变化确认
SIF 换前内裤名 != 下着名１_２(角色)
	CFLAG:角色:内裤确认 = 3

; 女装判定：无阴道且穿了裙子+上衣 或 穿连衣裙无裤子时标记女装
; 设定条件：(裙子+上衣) || (连衣裙+无裤子)
; 取消条件：不满足上述任一，即(!裙子||!上衣) && (!连衣裙||有裤子)
IF HAS_VAGINA(角色) == 0 && ( EQUIP:角色:裙子 && ( EQUIP:角色:上半身外衣_主 || EQUIP:角色:上半身外衣_副 ) || EQUIP:角色:连衣裙 && !EQUIP:角色:下半身外衣_主 )
	TALENT:角色:女装 = 1
ELSEIF TALENT:角色:女装 && ( !EQUIP:角色:裙子 || !( EQUIP:角色:上半身外衣_主 || EQUIP:角色:上半身外衣_副 ) ) && ( !EQUIP:角色:连衣裙 || EQUIP:角色:下半身外衣_主 )
	TALENT:角色:女装 = 0
ENDIF

RETURN 0

;-------------------------------------------------
; 帽子选择
