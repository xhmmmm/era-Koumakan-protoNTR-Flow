@服装_初始化_角色服装自定义
#DIM 角色
#DIM 已显示
DO
    DRAWLINE
    PRINTL □ 角色服装设定 □-------------------------------------------------------------
    已显示 = 0
    FOR 角色, 0, CHARANUM
        PRINTFORM [{角色,2}] %CALLNAME:角色,16,LEFT%
        已显示 ++
        SIF 已显示 % 3 == 0
            PRINTL
    NEXT
    SIF 已显示 % 3 != 0
        PRINTL
    PRINTL
    PRINTL [999] 设置完成
    INPUT
    SIF RESULT >= 0 && RESULT < CHARANUM
        CALL CLOTHES_CHOOSE(RESULT, 1, 0, 0)
LOOP RESULT != 999
RETURN 1

@服装_初始化_角色睡衣自定义
#DIM 睡衣最大编号 = 11
#DIM 已显示
DRAWLINE
PRINTL □ 睡衣设定 □-----------------------------------------------------------------
PRINTL 请设定角色们睡觉时的睡衣（只设定一次，以后不会再改变）
PRINTL
已显示 = 0
FOR LOCAL, 1, CHARANUM
    PRINTFORM [{LOCAL,2}] %CALLNAME:LOCAL,12,LEFT%（%睡衣名称(CFLAG:LOCAL:寝間着),12,LEFT%）
    已显示 ++
    SIF 已显示 % 3 == 0
        PRINTL
NEXT
SIF 已显示 % 3 != 0
    PRINTL
PRINTL
PRINTL [999] 设置完成
INPUT
IF RESULT >= 1 && RESULT < CHARANUM
    LOCAL:1 = RESULT
    DRAWLINE
    PRINTFORML □ %CALLNAME:(LOCAL:1)% 的睡衣 □---------------------------------------------------------
    已显示 = 0
    FOR LOCAL, 0, 睡衣最大编号 + 1
        PRINTFORM [{LOCAL,2}] %睡衣名称(LOCAL),18,LEFT%
        已显示 ++
        SIF 已显示 % 3 == 0
            PRINTL
    NEXT
    SIF 已显示 % 3 != 0
        PRINTL
    PRINTL
    PRINTL [100] 返回
    INPUT
    SIF RESULT >= 0 && RESULT <= 睡衣最大编号
        CFLAG:(LOCAL:1):寝間着 = RESULT
ELSEIF RESULT == 999
    PRINTL 这样可以吗？
    PRINTL [0] 确定　　[1] 返回继续设定
    ONEINPUT
    SIF RESULT == 0
        RETURN
ENDIF
RESTART
RETURN 0