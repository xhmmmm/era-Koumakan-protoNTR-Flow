;-------------------------------------------------
; 私服预设（从CFLAG:私服_*恢复）
;@return 1:换衣成功
;-------------------------------------------------
@CLOTHES_Preset_CUSTOM(着用者, 更换内衣=1)
#DIM 着用者
#DIM 更换内衣
#DIM 部位计数

CALL CLOTHES_Preset_NUDE(着用者, 更换内衣)

; 外衣用循环恢复，排除内衣部位(5,6,10,11)
FOR 部位计数, 1, 19
	SELECTCASE 部位计数
		CASE 衣装部位_下半身内衣_副, 衣装部位_下半身内衣_主, 衣装部位_上半身内衣_副, 衣装部位_上半身内衣_主
			; 内衣部位在外衣循环中跳过
		CASEELSE
			EQUIP:着用者:部位计数 = CFLAG:着用者:(衣装记录_私服_起始位 + 部位计数)
	ENDSELECT
NEXT

; 内衣恢复
IF 更换内衣
	; 内裤判定：私服_下半身内衣_主 在女性内裤范围内则随机选
	IF CFLAG:着用者:私服_下半身内衣_主 >= 衣装_下半身内衣_主_女内裤下限 && CFLAG:着用者:私服_下半身内衣_主 <= 衣装_下半身内衣_主_女内裤上限
		; 女性内裤编号，选取今日内裤
		CALL CLOTHES_Change_Knickers(着用者, 更换内衣)
	ELSE
		; 男性内裤等，直接恢复
		EQUIP:着用者:衣装部位_下半身内衣_主 = CFLAG:着用者:私服_下半身内衣_主
	ENDIF
	EQUIP:着用者:衣装部位_下半身内衣_副 = CFLAG:着用者:私服_下半身内衣_副
	EQUIP:着用者:衣装部位_上半身内衣_副 = CFLAG:着用者:私服_上半身内衣_副
	EQUIP:着用者:衣装部位_上半身内衣_主 = CFLAG:着用者:私服_上半身内衣_主
ENDIF

CFLAG:着用者:寝間着着用 = 0
RETURN 1

