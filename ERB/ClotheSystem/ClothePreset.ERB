;=================================================
; 睡衣预设
;=================================================

;-------------------------------------------------
; 穿睡衣
;-------------------------------------------------
@CLOTHES_Preset_NIGHTWEAR(着用者, 更换内衣=0)
#DIM 着用者
#DIM 更换内衣

; 先脱掉所有衣物
CALL CLOTHES_Preset_NUDE(着用者, 更换内衣)

SELECTCASE CFLAG:着用者:寝間着
	CASE 0
		; 全裸时强制也脱掉内衣
		CALL CLOTHES_Preset_NUDE(着用者, 1)
	CASE 1
		; 平时穿的衣服（不含普通外部部件）
		; 预设后脱掉上下服以外的衣物
		SELECTCASE CFLAG:着用者:服装パターン
			CASE 衣装预设_全裸
				CALL CLOTHES_Preset_NUDE(着用者, 更换内衣)
			CASE 衣装预设_男装
				CALL CLOTHES_Preset_MALE(着用者, 更换内衣)
			CASE 衣装预设_女装
				CALL CLOTHES_Preset_FEMALE(着用者, 更换内衣)
			CASE 衣装预设_女仆
				CALL CLOTHES_Preset_MAID(着用者, 更换内衣)
			CASE 衣装预设_私服
				CALL CLOTHES_Preset_CUSTOM(着用者, 更换内衣)
            CASE 衣装预设_Cosplay
                CALL CLOTHES_Preset_Cosplay(着用者, 更换内衣)
			CASE 101
				CALL CLOTHES_Preset_1(着用者, 更换内衣)
			CASE 102
				CALL CLOTHES_Preset_2(着用者, 更换内衣)
			CASE 103
				CALL CLOTHES_Preset_3(着用者, 更换内衣)
			CASE 104
				CALL CLOTHES_Preset_4(着用者, 更换内衣)
			CASE 105
				CALL CLOTHES_Preset_5(着用者, 更换内衣)
			CASE 106
				CALL CLOTHES_Preset_6(着用者, 更换内衣)
			CASE 107
				CALL CLOTHES_Preset_7(着用者, 更换内衣)
			CASE 108
				CALL CLOTHES_Preset_8(着用者, 更换内衣)
			CASE 109
				CALL CLOTHES_Preset_9(着用者, 更换内衣)
			CASE 110
				CALL CLOTHES_Preset_10(着用者, 更换内衣)
			CASE 111
				CALL CLOTHES_Preset_11(着用者, 更换内衣)
			CASE 112
				CALL CLOTHES_Preset_12(着用者, 更换内衣)
			CASE 113
				CALL CLOTHES_Preset_13(着用者, 更换内衣)
		ENDSELECT
		; 去掉头部、鞋、袜与手套
		CALL CLOTHES_EQUIP(着用者, 衣装部位_头部, 0)
		CALL CLOTHES_EQUIP(着用者, 衣装部位_鞋, 0)
		CALL CLOTHES_EQUIP(着用者, 衣装部位_腿部, 0)
		CALL CLOTHES_EQUIP(着用者, 衣装部位_手部, 0)
	; 内衣·长裤
	CASE 3
		CALL CLOTHES_EQUIP(着用者, 衣装部位_下半身外衣_主, 衣装_下半身外衣_主_直筒长裤)
	; 衬衫·内裤
	CASE 4
		CALL CLOTHES_EQUIP(着用者, 衣装部位_上半身外衣_副, 衣装_上半身外衣_副_衬衫)
	; 睡衣上衣·长裤
	CASE 5
		CALL CLOTHES_EQUIP(着用者, 衣装部位_上半身外衣_副, 衣装_上半身外衣_副_睡衣)
		CALL CLOTHES_EQUIP(着用者, 衣装部位_下半身外衣_主, 衣装_下半身外衣_主_直筒长裤)
	; T恤·内裤
	CASE 6
		CALL CLOTHES_EQUIP(着用者, 衣装部位_上半身外衣_副, 衣装_上半身外衣_副_T恤)
	; 吊带衫·内裤
	CASE 7
		CALL CLOTHES_EQUIP(着用者, 衣装部位_上半身外衣_副, 衣装_上半身外衣_副_吊带衫)
	; 睡袍·内裤
	CASE 8
		CALL CLOTHES_EQUIP(着用者, 衣装部位_连体外衣, 衣装_连体外衣_睡袍)
	; 玩偶睡裙·内裤
	CASE 9
		CALL CLOTHES_EQUIP(着用者, 衣装部位_连体外衣, 衣装_连体外衣_玩偶)
	; 浴衣·内裤
	CASE 10
		CALL CLOTHES_EQUIP(着用者, 衣装部位_连体外衣, 衣装_连体外衣_浴衣)
	CASE 11
		CALL CLOTHES_EQUIP(着用者, 衣装部位_腿部, 衣装_腿部_吊带袜)
		CALL CLOTHES_EQUIP(着用者, 衣装部位_下半身内衣_主, RAND(29, 51))
		CALL CLOTHES_EQUIP(着用者, 衣装部位_手部, 衣装_手部_歌剧手套)
		CALL CLOTHES_EQUIP(着用者, 衣装部位_上半身内衣_主, 衣装_上半身内衣_主_露点文胸)
ENDSELECT

IF CFLAG:着用者:寝間着
	; 平时穿的衣服以外的内衣穿着
	IF CFLAG:着用者:寝間着 >= 2
		IF HAS_VAGINA(着用者)
			; 平胸及以下穿睡衣时不穿上半身内衣
			; ※但是，像蕾米莉亚那样平胸且私服中穿着上半身内衣的情况，穿睡衣时也维持穿着状态
			IF TALENT:着用者:胸部尺寸 >= 0
				CALL CLOTHES_Change_Bra(着用者, 更换内衣)
			ENDIF
			; 女性角色则穿女性内衣
			CALL CLOTHES_Change_Knickers(着用者, 更换内衣)
		ELSE
			; 男性角色则穿短裤
			CALL CLOTHES_EQUIP(着用者, 衣装部位_下半身内衣_主, 衣装_下半身内衣_主_短裤)
		ENDIF
	ENDIF
ENDIF

CFLAG:着用者:寝間着着用 = 1
RETURN 1

;-------------------------------------------------
; 睡衣着鞋（移动时）
;-------------------------------------------------
@CLOTHES_Preset_NIGHTWEAR_S(着用者)
#DIM 着用者

; 私服时不穿鞋的话这里也不穿鞋
IF CFLAG:着用者:服装パターン != 0 && CFLAG:着用者:服装パターン != 108 && CFLAG:着用者:服装パターン != 109
	SELECTCASE 着用者
		; 美铃、咲夜、小恶魔穿鞋
		CASE 1, 2, 4
			CALL CLOTHES_EQUIP(着用者, 衣装部位_鞋, 衣装_鞋_小圆鞋)
		; 其他人穿拖鞋
		CASEELSE
			CALL CLOTHES_EQUIP(着用者, 衣装部位_鞋, 衣装_鞋_拖鞋)
	ENDSELECT
ENDIF
RETURN 1
