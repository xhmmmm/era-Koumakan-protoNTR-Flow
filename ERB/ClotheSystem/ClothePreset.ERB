	IF HAS_VAGINA(着用者)
		EQUIP:着用者:衣装部位_上半身内衣_主 = 衣装_上半身内衣_主_胸罩
	ELSE
		; 伪娘不穿文胸
		EQUIP:着用者:衣装部位_上半身内衣_主 = 0
	ENDIF
ENDIF
