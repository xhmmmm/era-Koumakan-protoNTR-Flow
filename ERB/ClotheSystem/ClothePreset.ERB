;=================================================
; 服装预设函数集
;=================================================

;-------------------------------------------------
; 全裸预设
;@return 1:换衣成功
;-------------------------------------------------
@CLOTHES_Preset_NUDE(着用者, 更换内衣=1)
#DIM 着用者
#DIM 更换内衣
#DIM 内衣保存_下半身内衣_副
#DIM 内衣保存_下半身内衣_主
#DIM 内衣保存_上半身内衣_副
#DIM 内衣保存_上半身内衣_主

内衣保存_下半身内衣_副 = 0
内衣保存_下半身内衣_主 = 0
内衣保存_上半身内衣_副 = 0
内衣保存_上半身内衣_主 = 0

; 更换内衣=0 时保留内衣
IF 更换内衣 == 0
	内衣保存_下半身内衣_副 = EQUIP:着用者:衣装部位_下半身内衣_副
	内衣保存_下半身内衣_主 = EQUIP:着用者:衣装部位_下半身内衣_主
	内衣保存_上半身内衣_副 = EQUIP:着用者:衣装部位_上半身内衣_副
	内衣保存_上半身内衣_主 = EQUIP:着用者:衣装部位_上半身内衣_主
ENDIF

; 脱去所有衣物
CALL CLOTHES_STRIP_ALL(着用者)

; 更换内衣=0 时恢复内衣
IF 更换内衣 == 0
	EQUIP:着用者:衣装部位_下半身内衣_副 = 内衣保存_下半身内衣_副
	EQUIP:着用者:衣装部位_下半身内衣_主 = 内衣保存_下半身内衣_主
	EQUIP:着用者:衣装部位_上半身内衣_副 = 内衣保存_上半身内衣_副
	EQUIP:着用者:衣装部位_上半身内衣_主 = 内衣保存_上半身内衣_主
ENDIF
CFLAG:着用者:寝間着着用 = 0
CFLAG:着用者:内裤确认 = 0
; 配件装备判定
CALL CLOTHES_ACCESSORY(着用者)
RETURN 1

;-------------------------------------------------
; 配件装备判定
; 人妻：按NTR好感度判定是否装结婚戒指
; NTR素质：装项圈
;-------------------------------------------------
@CLOTHES_ACCESSORY(着用者)
#DIM 着用者
#DIM 判定率

判定率 = 0

IF TALENT:着用者:人妻
	; 人妻则装备戒指
	; 不过如果正在被NTR也可能摘掉…
	IF NTR_CHK_FAVORABLY(着用者, FAV_寝取られ寸前)
		判定率 = 3		; NTR边缘则3成概率
	ELSEIF NTR_CHK_FAVORABLY(着用者, FAV_寝取られそう)
		判定率 = 5		; 快被NTR则5成概率
	ELSEIF NTR_CHK_FAVORABLY(着用者, FAV_主人より高い)
		判定率 = 9		; 比主人好感高则9成概率
	ELSE
		判定率 = 10	; 否则始终装备
	ENDIF
	SIF TALENT:着用者:亲爱
		判定率 = 10	; 亲爱则始终装备
	SIF 判定率 >= RAND:10
		EQUIP:着用者:衣装部位_配件 = 衣装_配件_结婚戒指
ENDIF

IF TALENT:着用者:NTR
	; NTR则装备项圈
	判定率 = 10
	SIF 判定率 >= RAND:10
		EQUIP:着用者:衣装部位_配件 = 衣装_配件_颈环
ENDIF
RETURN

;-------------------------------------------------
; 绅士预设
;@return 1:换衣成功
;-------------------------------------------------
@CLOTHES_Preset_jentle(着用者, 更换内衣=1)
#DIM 着用者
#DIM 更换内衣

CALL CLOTHES_Preset_NUDE(着用者, 更换内衣)
EQUIP:着用者:衣装部位_鞋 = 衣装_鞋_小圆鞋
EQUIP:着用者:衣装部位_袜 = 衣装_袜_短袜
IF HAS_VAGINA(着用者)
	; 女性角色则穿女性内衣
	CALL CLOTHES_Change_Knickers(着用者, 更换内衣)
	; 女性角色则穿裹胸布
	IF 更换内衣
		EQUIP:着用者:衣装部位_上半身内衣_主 = 衣装_上半身内衣_主_裹胸布
	ENDIF
ELSE
	; 男性角色则穿短裤
	IF 更换内衣
		EQUIP:着用者:衣装部位_下半身内衣_主 = 衣装_下半身内衣_主_短裤
	ENDIF
ENDIF
EQUIP:着用者:衣装部位_下半身外衣_主 = 衣装_下半身外衣_主_裤子
EQUIP:着用者:衣装部位_上半身外衣_主 = 衣装_上半身外衣_主_绅士服
CFLAG:着用者:寝間着着用 = 0
RETURN 1

