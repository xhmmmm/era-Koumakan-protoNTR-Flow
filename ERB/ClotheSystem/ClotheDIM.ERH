;=================================================
; 服装系统常量定义
; 对应 EQUIP 数组索引 0~18
; 命名规范：全中文，下着=内衣，上着=外衣
;=================================================

;-------------------------------------------------
; EQUIP 部位索引（与 Equip.csv 编号一一对应）
;-------------------------------------------------
#DIM CONST 衣装部位_配件				= 1		; 戒指/项圈等
#DIM CONST 衣装部位_帽子				= 2
#DIM CONST 衣装部位_鞋					= 3
#DIM CONST 衣装部位_袜					= 4
#DIM CONST 衣装部位_下半身内衣_副		= 5		; 创口贴/贞操带等附加内衣
#DIM CONST 衣装部位_下半身内衣_主		= 6		; 内裤等主要内衣
#DIM CONST 衣装部位_下半身外衣_主		= 7		; 裤子/紧身裤/袴
#DIM CONST 衣装部位_下半身外衣_副		= 8		; 短裤/灯笼裤等
#DIM CONST 衣装部位_裙子				= 9
#DIM CONST 衣装部位_上半身内衣_副		= 10	; 乳贴等附加内衣
#DIM CONST 衣装部位_上半身内衣_主		= 11	; 胸罩等主要内衣
#DIM CONST 衣装部位_上半身外衣_主		= 12	; 外衣/铠甲/军服/绅士服
#DIM CONST 衣装部位_上半身外衣_副		= 13	; 女衬衫/水手服/T恤等
#DIM CONST 衣装部位_赛车服				= 14
#DIM CONST 衣装部位_连衣裙				= 15
#DIM CONST 衣装部位_着物				= 16
#DIM CONST 衣装部位_紧身衣				= 17
#DIM CONST 衣装部位_手					= 18

;-------------------------------------------------
; 部位分组（用于互斥判定、TEQUIP生成等）
; 全身型穿上时清除其他上半身+下半身；反之亦然
;-------------------------------------------------
#DIM CONST 衣装组_全身型			= 0
#DIM CONST 衣装组_上半身外衣		= 1
#DIM CONST 衣装组_上半身内衣		= 2
#DIM CONST 衣装组_下半身外衣		= 3
#DIM CONST 衣装组_下半身内衣		= 4
#DIM CONST 衣装组_配件类			= 5		; 配件/帽子/鞋/袜/手

;-------------------------------------------------
; 配件编号 (EQUIP:配件)
;-------------------------------------------------
#DIM CONST 衣装_配件_结婚戒指		= 1
#DIM CONST 衣装_配件_项圈			= 100
#DIM CONST 衣装_配件_颈环			= 101

