;=================================================
; 服装属性标志（可掀开/可偏移等）
; 通过 @衣装_可掀开(部位, 编号) 查询
; 属性与具体服装绑定，与部位槽位无关
;=================================================

; 属性类型
#DIM CONST 衣装属性_可掀开			= 0		; 上半身：能否敞开露出内层
#DIM CONST 衣装属性_可偏移			= 1		; 下半身：能否偏移露出内层
#DIM CONST 衣装属性_遮蔽全身		= 2		; 全身型服装是否完全遮蔽

;=================================================
; TEQUIP 着衣状态位标志
; TEQUIP:下半身着衣状況 和 TEQUIP:上半身着衣状況
;=================================================

;--- 下半身着衣状况 (TEQUIP:0) ---
#DIM CONST 着衣_下半身_裙子			= 0		; bit0: 穿着裙子
#DIM CONST 着衣_下半身_副层			= 1		; bit1: 有可偏移的内层
#DIM CONST 着衣_下半身_主层			= 2		; bit2: 有不可偏移的主层
#DIM CONST 着衣_下半身_主层外衣		= 3		; bit3: 有下半身外衣_主
#DIM CONST 着衣_下半身_全身型		= 4		; bit4: 穿着全身型服装
#DIM CONST 着衣_下半身_偏移中		= 5		; bit5: 下半身偏移状态

;--- 上半身着衣状况 (TEQUIP:1) ---
#DIM CONST 着衣_上半身_副层			= 0		; bit0: 有可掀开的副层
#DIM CONST 着衣_上半身_主层			= 1		; bit1: 有不可掀开的主层
#DIM CONST 着衣_上半身_主层内衣		= 2		; bit2: 有上半身内衣_主
#DIM CONST 着衣_上半身_全身型		= 3		; bit3: 穿着全身型服装
#DIM CONST 着衣_上半身_掀开中		= 4		; bit4: 上半身掀开状态

;=================================================
; 服装预设编号（CFLAG:服装パターン 的值）
;=================================================
#DIM CONST 衣装预设_全裸			= 0
#DIM CONST 衣装预设_男装			= 1
#DIM CONST 衣装预设_女装			= 2
#DIM CONST 衣装预设_绅士			= 3
#DIM CONST 衣装预设_女仆			= 4
#DIM CONST 衣装预设_私服			= 100
; 角色默认预设 101~113
#DIM CONST 衣装预设_角色开始		= 101
#DIM CONST 衣装预设_角色结束		= 113
#DIM CONST 衣装预设_Cosplay		= 200

;=================================================
; CFLAG 服装存储偏移
; CFLAG:服装_XXX 起始于 200，偏移量 = EQUIP索引
; CFLAG:私服_XXX 起始于 220，偏移量 = EQUIP索引
;=================================================
#DIM CONST 衣装记录_服装_起始位		= 200
#DIM CONST 衣装记录_私服_起始位		= 220
