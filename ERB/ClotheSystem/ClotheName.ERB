;=================================================
; 显示辅助函数
;=================================================

;-------------------------------------------------
; 取得上半身最外层服装的通用名称
;-------------------------------------------------
@SHOW_TOP(着用者, 指定层级 = -1)
#FUNCTIONS
#DIM 着用者
#DIM 指定层级
#DIM 最外层

IF 指定层级 >= 0
	最外层 = 指定层级
ELSE
	; 从 TEQUIP 判断最外层
	IF GETBIT(TEQUIP:着用者:上半身着衣状況, 着衣_上半身_主层)
		最外层 = 2
	ELSEIF GETBIT(TEQUIP:着用者:上半身着衣状況, 着衣_上半身_副层)
		最外层 = 1
	ELSE
		RETURNF ""
	ENDIF
ENDIF

SELECTCASE 最外层
CASE 2
	; 主层（不可掀开）
	IF EQUIP:着用者:衣装部位_赛车服
		RETURNF "服"
	ENDIF
	IF EQUIP:着用者:衣装部位_连衣裙
		SELECTCASE EQUIP:着用者:衣装部位_连衣裙
		CASE 衣装_连衣裙_旗袍
			RETURNF "旗袍"
		CASE 衣装_连衣裙_裸体围裙
			RETURNF "裸体围裙"
		CASE 衣装_连衣裙_斗篷
			RETURNF "斗篷"
		CASE 衣装_连衣裙_修道服
			RETURNF "修道服"
		CASE 衣装_连衣裙_魔女连衣裙
			RETURNF "魔女连衣裙"
		ENDSELECT
		RETURNF "服"
	ENDIF
	IF EQUIP:着用者:衣装部位_紧身衣
		SELECTCASE EQUIP:着用者:衣装部位_紧身衣
		CASE 衣装_紧身衣_忍者装束
			RETURNF "忍者装束"
		CASE 衣装_紧身衣_Y型
			RETURNF "Y型紧身衣"
		CASE 衣装_紧身衣_触手服
			RETURNF "触手服"
		CASE 衣装_紧身衣_竞赛泳衣
			RETURNF "竞赛泳衣"
		CASE 衣装_紧身衣_赛车女模
			RETURNF "赛车女模"
		CASE 衣装_紧身衣_林科斯
			RETURNF "林科斯"
		ENDSELECT
		RETURNF "紧身衣"
	ENDIF
	IF EQUIP:着用者:衣装部位_上半身外衣_主
		RETURNF "外衣"
	ENDIF
	IF EQUIP:着用者:衣装部位_上半身内衣_副
		RETURNF "内衣"
	ENDIF
CASE 1
	; 副层（可掀开）
	IF EQUIP:着用者:衣装部位_着物
		RETURNF "和服"
	ENDIF
	IF EQUIP:着用者:衣装部位_上半身外衣_副
		RETURNF "女衬衫"
	ENDIF
	IF EQUIP:着用者:衣装部位_上半身内衣_主
		RETURNF "内衣"
	ENDIF
ENDSELECT
RETURNF ""

;-------------------------------------------------
; 取得下半身最外层服装的通用名称
;-------------------------------------------------
@SHOW_BOTTOM(着用者, 指定层级 = -1)
#FUNCTIONS
#DIM 着用者
#DIM 指定层级
#DIM 最外层

IF 指定层级 >= 0
	最外层 = 指定层级
ELSE
	; 从 TEQUIP 判断最外层
	IF GETBIT(TEQUIP:着用者:下半身着衣状況, 着衣_下半身_主层外衣)
		最外层 = 4
	ELSEIF GETBIT(TEQUIP:着用者:下半身着衣状況, 着衣_下半身_主层)
		最外层 = 3
	ELSEIF GETBIT(TEQUIP:着用者:下半身着衣状況, 着衣_下半身_副层)
		最外层 = 2
	ELSEIF GETBIT(TEQUIP:着用者:下半身着衣状況, 着衣_下半身_裙子)
		最外层 = 1
	ELSE
		RETURNF ""
	ENDIF
ENDIF

SELECTCASE 最外层
CASE 4
	; 主层外衣
	IF EQUIP:着用者:衣装部位_下半身外衣_主 || EQUIP:着用者:衣装部位_赛车服
		RETURNF "衣服"
	ENDIF
CASE 3
	; 主层
	IF EQUIP:着用者:衣装部位_赛车服 || EQUIP:着用者:衣装部位_下半身外衣_主
		RETURNF "衣服"
	ENDIF
	IF EQUIP:着用者:衣装部位_下半身内衣_副
		RETURNF "内衣"
	ENDIF
CASE 2
	; 副层
	IF EQUIP:着用者:衣装部位_紧身衣 || EQUIP:着用者:衣装部位_下半身外衣_副
		RETURNF "衣服"
	ENDIF
	IF EQUIP:着用者:衣装部位_下半身内衣_主
		RETURNF "内衣"
	ENDIF
CASE 1
	; 裙子
	IF EQUIP:着用者:衣装部位_裙子
		SELECTCASE EQUIP:着用者:衣装部位_裙子
		CASE 衣装_裙子_超短裙
			RETURNF "超短裙"
		CASEELSE
			RETURNF "裙子"
		ENDSELECT
	ENDIF
	IF EQUIP:着用者:衣装部位_连衣裙
		RETURNF "裙子"
	ENDIF
	IF EQUIP:着用者:衣装部位_着物
		RETURNF "和服下摆"
	ENDIF
ENDSELECT
RETURNF ""

