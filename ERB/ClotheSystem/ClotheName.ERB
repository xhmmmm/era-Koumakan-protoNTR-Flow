;=================================================
; 款式目录
; 目录序号只用于菜单遍历，EQUIP 始终保存对应槽位中的款式编号。
;=================================================

@CLOTHES_STYLE_COUNT(槽位)
#FUNCTION
#DIM 槽位
SELECTCASE 槽位
CASE 衣装部位_手部配饰
    RETURNF 1
CASE 衣装部位_颈部环饰
    RETURNF 2
CASE 衣装部位_颈部挂饰
    RETURNF 4
CASE 衣装部位_头部
    RETURNF 9
CASE 衣装部位_手部
    RETURNF 8
CASE 衣装部位_腿部
    RETURNF 7
CASE 衣装部位_鞋
    RETURNF 6
CASE 衣装部位_下半身内衣_主
    RETURNF 55
CASE 衣装部位_下半身内衣_副
    RETURNF 2
CASE 衣装部位_上半身内衣_主
    RETURNF 12
CASE 衣装部位_上半身内衣_副
    RETURNF 1
CASE 衣装部位_上半身外衣_主
    RETURNF 7
CASE 衣装部位_上半身外衣_副
    RETURNF 27
CASE 衣装部位_下半身外衣_主
    RETURNF 12
CASE 衣装部位_下半身外衣_副
    RETURNF 4
CASE 衣装部位_连体外衣
    RETURNF 19
ENDSELECT
RETURNF 0

@CLOTHES_STYLE_ID(槽位, 目录序号)
#FUNCTION
#DIM 槽位
#DIM 目录序号
SELECTCASE 槽位
CASE 衣装部位_手部配饰
    SIF 目录序号 == 1
        RETURNF 衣装_手部配饰_结婚戒指
CASE 衣装部位_颈部环饰, 衣装部位_颈部挂饰
    RETURNF 目录序号
CASE 衣装部位_下半身内衣_主
    SIF 目录序号 <= 49
        RETURNF 目录序号 + 1
    SIF 目录序号 <= 55
        RETURNF 目录序号 + 52
CASE 衣装部位_上半身内衣_副
    SIF 目录序号 == 1
        RETURNF 衣装_上半身内衣_副_乳贴
CASEELSE
    RETURNF 目录序号
ENDSELECT
RETURNF 0
