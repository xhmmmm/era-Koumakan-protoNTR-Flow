@服装名_下半身内衣_主(款式)
#FUNCTIONS
#DIM 款式
; 男性内裤
IF 款式 >= 衣装_下半身内衣_主_男内裤下限 && 款式 <= 衣装_下半身内衣_主_男内裤上限
	SELECTCASE 款式
	CASE 衣装_下半身内衣_主_短裤
		RETURNF "短裤"
	CASE 衣装_下半身内衣_主_三角裤
		RETURNF "三角裤"
	CASE 衣装_下半身内衣_主_平角裤
		RETURNF "平角裤"
	CASE 衣装_下半身内衣_主_比基尼
		RETURNF "比基尼内裤"
	CASE 衣装_下半身内衣_主_微型比基尼
		RETURNF "微型比基尼内裤"
	CASE 衣装_下半身内衣_主_牛比基尼
		RETURNF "牛比基尼内裤"
	ENDSELECT
ENDIF
; 女性内裤
IF 款式 >= 衣装_下半身内衣_主_女内裤下限 && 款式 <= 衣装_下半身内衣_主_女内裤上限
	RETURNF 内裤名称(款式)
ENDIF
