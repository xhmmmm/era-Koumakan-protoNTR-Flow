;-------------------------------------------------
; 衣物气味名称
;-------------------------------------------------
@IRUINAME_SMELL(穿着天数)
#FUNCTIONS
#DIM 穿着天数

SELECTCASE 穿着天数
CASE IS <= 1
	RETURNF "芳香的"
CASE IS <= 3
	RETURNF "微微有体味的"
CASE IS <= 5
	RETURNF "有汗味的"
CASE IS <= 7
	RETURNF "有体臭的"
CASE IS <= 9
	RETURNF "有强烈体臭的"
CASEELSE
	RETURNF "体液与垢粘连的"
ENDSELECT
RETURNF ""
