;-------------------------------------------------
; 取得上半身最外层服装的通用名称
;-------------------------------------------------

@SHOW_TOP(着用者, 指定层级 = -1)
#FUNCTIONS
#DIM 着用者
#DIM 指定层级
SIF !GETBIT(TEQUIP:着用者:上半身着衣状況, 着衣_上半身_主层) && !GETBIT(TEQUIP:着用者:上半身着衣状況, 着衣_上半身_副层)
	RETURNF ""
SIF EQUIP:着用者:衣装部位_连体外衣
	RETURNF CLOTHNAME(衣装部位_连体外衣, EQUIP:着用者:衣装部位_连体外衣)
SIF EQUIP:着用者:衣装部位_上半身外衣_主
	RETURNF CLOTHNAME(衣装部位_上半身外衣_主, EQUIP:着用者:衣装部位_上半身外衣_主)
SIF EQUIP:着用者:衣装部位_上半身外衣_副
	RETURNF CLOTHNAME(衣装部位_上半身外衣_副, EQUIP:着用者:衣装部位_上半身外衣_副)
SIF EQUIP:着用者:衣装部位_上半身内衣_主
	RETURNF CLOTHNAME(衣装部位_上半身内衣_主, EQUIP:着用者:衣装部位_上半身内衣_主)
SIF EQUIP:着用者:衣装部位_上半身内衣_副
	RETURNF CLOTHNAME(衣装部位_上半身内衣_副, EQUIP:着用者:衣装部位_上半身内衣_副)
RETURNF ""

@SHOW_BOTTOM(着用者, 指定层级 = -1)
#FUNCTIONS
#DIM 着用者
#DIM 指定层级
SIF !GETBIT(TEQUIP:着用者:下半身着衣状況, 着衣_下半身_主层) && !GETBIT(TEQUIP:着用者:下半身着衣状況, 着衣_下半身_副层)
	RETURNF ""
SIF EQUIP:着用者:衣装部位_连体外衣
	RETURNF CLOTHNAME(衣装部位_连体外衣, EQUIP:着用者:衣装部位_连体外衣)
SIF EQUIP:着用者:衣装部位_下半身外衣_主
	RETURNF CLOTHNAME(衣装部位_下半身外衣_主, EQUIP:着用者:衣装部位_下半身外衣_主)
SIF EQUIP:着用者:衣装部位_下半身外衣_副
	RETURNF CLOTHNAME(衣装部位_下半身外衣_副, EQUIP:着用者:衣装部位_下半身外衣_副)
SIF EQUIP:着用者:衣装部位_下半身内衣_主
	RETURNF CLOTHNAME(衣装部位_下半身内衣_主, EQUIP:着用者:衣装部位_下半身内衣_主)
SIF EQUIP:着用者:衣装部位_下半身内衣_副
	RETURNF CLOTHNAME(衣装部位_下半身内衣_副, EQUIP:着用者:衣装部位_下半身内衣_副)
RETURNF ""
