@CLOTHNAME(槽位, 款式)
#FUNCTIONS
#DIM 槽位
#DIM 款式
SELECTCASE 槽位
CASE 衣装部位_手部配饰
    RETURNF 服装名_手部配饰(款式)
CASE 衣装部位_颈部环饰
    RETURNF 服装名_颈部环饰(款式)
CASE 衣装部位_颈部挂饰
    RETURNF 服装名_颈部挂饰(款式)
CASE 衣装部位_头部
	RETURNF 服装名_头部(款式)
CASE 衣装部位_手部
	RETURNF 服装名_手部(款式)
CASE 衣装部位_腿部
	RETURNF 服装名_腿部(款式)
CASE 衣装部位_鞋
	RETURNF 服装名_鞋(款式)
CASE 衣装部位_下半身内衣_主
	RETURNF 服装名_下半身内衣_主(款式)
CASE 衣装部位_下半身内衣_副
	RETURNF 服装名_下半身内衣_副(款式)
CASE 衣装部位_上半身内衣_主
	RETURNF 服装名_上半身内衣_主(款式)
CASE 衣装部位_上半身内衣_副
	RETURNF 服装名_上半身内衣_副(款式)
CASE 衣装部位_上半身外衣_主
	RETURNF 服装名_上半身外衣_主(款式)
CASE 衣装部位_上半身外衣_副
	RETURNF 服装名_上半身外衣_副(款式)
CASE 衣装部位_下半身外衣_主
	RETURNF 服装名_下半身外衣_主(款式)
CASE 衣装部位_下半身外衣_副
	RETURNF 服装名_下半身外衣_副(款式)
CASE 衣装部位_连体外衣
	RETURNF 服装名_连体外衣(款式)
ENDSELECT
RETURNF ""

