;=================================================
; 服装名称
;=================================================

;-------------------------------------------------
; 统一入口：按部位+编号获取服装名称
;-------------------------------------------------
@服装名_取得(部位, 款式)
#FUNCTIONS
#DIM 部位
#DIM 款式

SELECTCASE 部位
CASE 衣装部位_配件
	RETURNF 服装名_配件(款式)
CASE 衣装部位_帽子
	RETURNF 服装名_帽子(款式)
CASE 衣装部位_鞋
	RETURNF 服装名_鞋(款式)
CASE 衣装部位_袜
	RETURNF 服装名_袜(款式)
CASE 衣装部位_下半身内衣_副
	RETURNF 服装名_下半身内衣_副(款式)
CASE 衣装部位_下半身内衣_主
	RETURNF 服装名_下半身内衣_主(款式)
CASE 衣装部位_下半身外衣_主
	RETURNF 服装名_下半身外衣_主(款式)
CASE 衣装部位_下半身外衣_副
	RETURNF 服装名_下半身外衣_副(款式)
CASE 衣装部位_裙子
	RETURNF 服装名_裙子(款式)
CASE 衣装部位_上半身内衣_副
	RETURNF 服装名_上半身内衣_副(款式)
CASE 衣装部位_上半身内衣_主
	RETURNF 服装名_上半身内衣_主(款式)
CASE 衣装部位_上半身外衣_主
	RETURNF 服装名_上半身外衣_主(款式)
CASE 衣装部位_上半身外衣_副
	RETURNF 服装名_上半身外衣_副(款式)
CASE 衣装部位_赛车服
	RETURNF 服装名_赛车服(款式)
CASE 衣装部位_连衣裙
	RETURNF 服装名_连衣裙(款式)
CASE 衣装部位_着物
	RETURNF 服装名_着物(款式)
CASE 衣装部位_紧身衣
	RETURNF 服装名_紧身衣(款式)
CASE 衣装部位_手
	RETURNF 服装名_手(款式)
ENDSELECT
RETURNF ""

;-------------------------------------------------
; 旧接口兼容：CLOTHNAME(服種類, 服番号)
; 服種類 = EQUIP索引，与 服装名_取得 一致
;-------------------------------------------------
@CLOTHNAME(服種類, 服番号)
#FUNCTIONS
#DIM 服種類
#DIM 服番号
	RETURNF 服装名_取得(服種類, 服番号)

