

;妊娠系新規作成======================================
;使用フラグ
;CFLAG:351 卵子生存日数 (1=排卵 2=受精不可)
;CFLAG:352 生理周期フラグ　（10～15で“危险日”付与）

;TALENT:危险日


;====================================================

;AFTERTRA.ERB～～～～～～～～～～～～～～～～～～

@妊娠確定時の追加処理, ARG
;妊娠が確定したのでいらないフラグをリセット
CFLAG:ARG:卵子生存日数 = 0
CFLAG:ARG:生理周期 = 0
TALENT:ARG:危险日 = 0


;生理関連---------------------------------
@生理周期, ARG

;男(ふたなり以外)はスキップ
SIF TALENT:ARG:性別 == 2 || TALENT:ARG:妖精 == 1
	RETURN 0

;娘が成長期未満で生理処理が機能していたらここでリセット
IF NO:ARG == 149 && CFLAG:ARG:75 < 3 && (TALENT:ARG:危险日 || CFLAG:ARG:生理周期 || CFLAG:ARG:卵子生存日数)
	TALENT:ARG:危险日 = 0
	CFLAG:ARG:生理周期 = 0
	CFLAG:ARG:卵子生存日数 = 0
ENDIF

;避孕药使用判定リセット
CFLAG:ARG:避孕药使用 = 0


;娘の場合成長期から生理開始
SIF NO:ARG == 149 && CFLAG:ARG:75 < 3
	RETURN 0

;妊娠しているならスキップ
SIF TALENT:ARG:妊娠
	RETURN 0

;生理日数経過
CFLAG:ARG:生理周期 ++

;危险日以外ならたまに長引く
IF !TALENT:ARG:危险日 && !CFLAG:ARG:卵子生存日数
	SIF RAND:20 == 0
		CFLAG:ARG:生理周期 --
ENDIF

;生理フラグ10で危险日付与
IF CFLAG:ARG:生理周期 == 10
	TALENT:ARG:危险日 = 1
	;生理フラグ15で生理フラグ、危险日、排卵フラグリセット
ELSEIF CFLAG:ARG:生理周期 >= 15
	CFLAG:ARG:生理周期 = 0
	CFLAG:ARG:卵子生存日数 = 0
ENDIF

;危险日の何時の日かに排卵
IF TALENT:ARG:危险日 && CFLAG:ARG:卵子生存日数 == 0
	;30%の確率で排卵日に
	IF RAND:100 < 30
		CFLAG:ARG:卵子生存日数 ++
		;生理フラグ14(危险日の最終日)までに排卵日が来なかった場合は確実に排卵日となる
	ELSEIF CFLAG:ARG:生理周期 == 14
		CFLAG:ARG:卵子生存日数 ++
	ENDIF
	;排卵後1日経過で卵子が受精不可となり素質[危险日]消去
ELSEIF CFLAG:ARG:卵子生存日数 == 1
	TALENT:ARG:危险日 = 0
	CFLAG:ARG:卵子生存日数 ++
ENDIF