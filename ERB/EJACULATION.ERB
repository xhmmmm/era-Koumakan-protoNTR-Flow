; EJACULATION.ERB
;	射精関係の関数
;

;口内射精
;好感度、屈服度等の管理は行わない。この関数を呼び出す処理で行うこと。
@EJACULATION_M(角色, 射精者)
#DIM 角色
#DIM 射精者
#DIM 精液经验増量

CFLAG:角色:射精者M = 射精者
TRYCALL 精力取得, 射精者
;Vと違い角色側の精子取得はない
;TRYCALL 精子取得, 射精者, 角色
;精液经验
精液经验増量 = MAX(TFLAG:精子量 / 100, 1)
;NekoAdd
IF 射精者 == 人物_訪問者
	CFLAG:角色:M累积内射 += TFLAG:精子量
	CFLAG:角色:浮気M累积内射 += TFLAG:精子量
ELSEIF 射精者 == MASTER
	CFLAG:角色:M累积内射 += TFLAG:精子量
ENDIF
IF MASTER == 射精者
	EXP:角色:精液经验 += 精液经验増量
	EXP:角色:精饮经验 += 精液经验増量
ENDIF
;相手により分岐のある処理
SELECTCASE 射精者
	CASE 人物_客, 人物_村人
		IF 角色 != MASTER && !TALENT:角色:亲爱
			CALL NTR_EXP_ADD_SEMEN(角色,精液经验増量)
			CALL NTR_EXP_ADD_DRINK_SEMEN(角色,精液经验増量)
		ENDIF
	CASE 人物_訪問者
		IF 角色 != MASTER && !TALENT:角色:亲爱
			CALL NTR_EXP_ADD_SEMEN(角色,精液经验増量)
			CALL NTR_EXP_ADD_DRINK_SEMEN(角色,精液经验増量)
		ENDIF
	CASE IS < CHARANUM
		EXP:射精者:射精经验 ++
		EXP:射精者:Ｃ经验 ++
		IF ABL:射精者:Ｃ感觉 > RAND:5
			EXP:射精者:Ｃ绝顶经验 ++
			EXP:射精者:绝顶经验 ++
		ENDIF
		IF MASTER == 射精者
			SETBIT CFLAG:角色:あなた射精フラグ,被射精箇所_口
		ENDIF
	CASEELSE
		;什麽也不做
ENDSELECT

;射精に伴う汚れ追加
CALL STAIN_ADD_SEMEN_M(角色, 射精者)
RETURN 0

;膣内射精
;好感度、屈服度等の管理は行わない。この関数を呼び出す処理で行うこと。
@EJACULATION_V(角色, 射精者)
#DIM 角色
#DIM 射精者
#DIM 精液经验増量

TEQUIP:角色:Ｖ性爱 = 射精者
CFLAG:角色:射精者V = 射精者
TRYCALL 精力取得, 射精者
TRYCALL 精子取得, 射精者, 角色
CFLAG:角色:精液残留中 = 40
;精液经验
精液经验増量 = MAX(TFLAG:精子量 / 100, 1)
SIF MASTER == 射精者
	EXP:角色:精液经验 += 精液经验増量
;NekoAdd
IF 射精者 == 人物_訪問者
	CFLAG:角色:V累积内射 += TFLAG:精子量
	CFLAG:角色:浮気V累积内射 += TFLAG:精子量
ELSEIF 射精者 == MASTER
	CFLAG:角色:V累积内射 += TFLAG:精子量
ENDIF
;中出しフラグ
TCVAR:角色:102 = 2
TCVAR:角色:103 = 射精者
;相手により分岐のある処理
SELECTCASE 射精者
	CASE 人物_訪問者
		IF 角色 != MASTER && !TALENT:角色:亲爱
			CALL NTR_EXP_ADD_SEMEN(角色,精液经验増量)
		ENDIF
		IF TALENT:角色:处女
		ENDIF
	CASE IS < CHARANUM
		EXP:射精者:射精经验 ++
		EXP:射精者:Ｃ经验 ++
		IF ABL:射精者:Ｃ感觉 > RAND:5
			EXP:射精者:Ｃ绝顶经验 ++
			EXP:射精者:绝顶经验 ++
		ENDIF
		IF TALENT:角色:处女
		ENDIF
		IF MASTER == 射精者
			SETBIT CFLAG:角色:あなた射精フラグ,被射精箇所_Ｖ
		ENDIF
	CASEELSE
		;什麽也不做
ENDSELECT
;射精に伴う汚れ追加
CALL STAIN_ADD_SEMEN_V(角色, 射精者)
RETURN 0

