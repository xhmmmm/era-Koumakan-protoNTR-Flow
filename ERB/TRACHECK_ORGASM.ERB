;-------------------------------------------------
;調教対象の喷乳チェック
;-------------------------------------------------
@TARGET_MILK_CHECK(角色)
#DIM 角色
#DIM 母乳蓄積基準値
#DIM 母乳噴出量
#DIM 母乳蓄積量

SIF !TALENT:角色:泌乳体质
	RETURN 0

;場合によってはMAXBASE未設定のまま来る事があるので0なら強制設定する
IF MAXBASE:角色:母乳 == 0
	MAXBASE:角色:母乳 = 5000+5000*(!TALENT:角色:淫乳)
ENDIF

;快感の上昇量から母乳蓄積基準値を決定
母乳蓄積基準値 = CUP:角色:快Ｃ/5 + CUP:角色:快Ｖ/5 + CUP:角色:快Ａ/5 + CUP:角色:快Ｂ*3

;蓄積基準値が0、つまり刺激がなければ突然噴き出したりはしない
IF (母乳蓄積基準値 == 0)
	RETURN 0
ENDIF

;最大でも150%しか増えないようにする（大量喷乳を減らす）
母乳蓄積量 = MIN(母乳蓄積基準値,MAXBASE:角色:母乳*3/2)

;自制心持ちなら母乳が貯まりづらい
SIF TALENT:角色:自制心
	母乳蓄積量 /= 2
;快感に素直なら母乳が貯まりやすい
SIF TALENT:角色:快感应答 > 0
	TIMES 母乳蓄積量 , 1.20
;快感の否定なら母乳が貯まりづらい（淫乱、娼婦で無効）
SIF TALENT:角色:快感应答 < 0 && !TALENT:角色:淫乱
	TIMES 母乳蓄積量 , 0.80
;B敏感なら母乳が貯まりやすい
SIF TALENT:角色:Ｂ感度 > 0
	TIMES 母乳蓄積量 , 1.20
;媚药状態なら母乳が貯まりやすい
SIF TEQUIP:角色:媚药
	母乳蓄積量 *= 2
;調教者が幼児退行なら母乳が貯まりやすい
SIF TALENT:PLAYER:幼儿／幼儿退行
	TIMES 母乳蓄積量 , 1.20
;調教者が幼稚なら母乳が貯まりやすい
SIF TALENT:PLAYER:幼稚
	TIMES 母乳蓄積量 , 1.20
;貧乳なら母乳が貯まりづらい
SIF TALENT:角色:胸部尺寸 < 0
	TIMES 母乳蓄積量 , 0.50

BASE:角色:母乳 += 母乳蓄積量

;噴出チェック、100%以上貯まっていれば必ず、そうでなければ量と今回受けた刺激に応じて噴出率が変わる
IF (BASE:角色:母乳 > MAXBASE:角色:母乳)
	;噴出後の母乳量が50%未満になるようにする(連続噴出防止)
	母乳噴出量 = MAX( RAND(BASE:角色:母乳), (BASE:角色:母乳-MAXBASE:角色:母乳/2) )
ELSEIF 	( RAND(MAX(CUP:角色:快Ｂ,1)) > (MAXBASE:角色:母乳-BASE:角色:母乳) )
	;100%超えていない場合は量は知れてる
	母乳噴出量 = MAX(RAND(BASE:角色:母乳),0)
ENDIF
母乳噴出量 = MIN(母乳噴出量, BASE:角色:母乳)

IF 母乳噴出量 < 1
	RETURN 0
ENDIF

DOWNBASE:角色:体力 += 20 * MAX(母乳噴出量 / MAXBASE:角色:母乳, 1)
DOWNBASE:角色:气力 += 50 * MAX(母乳噴出量 / MAXBASE:角色:母乳, 1)

IF EXP:角色:喷乳经验 < EXPLV:1
	SOURCE:角色:露出 += MAX(10000 * 母乳噴出量 / MAXBASE:角色:母乳, 1)
	SOURCE:角色:屈从 += MAX( 5000 * 母乳噴出量 / MAXBASE:角色:母乳, 1)
	SOURCE:角色:肮脏 += MAX( 2000 * 母乳噴出量 / MAXBASE:角色:母乳, 1)
ELSEIF EXP:角色:喷乳经验 < EXPLV:2
	SOURCE:角色:露出 += MAX( 5000 * 母乳噴出量 / MAXBASE:角色:母乳, 1)
	SOURCE:角色:屈从 += MAX( 3000 * 母乳噴出量 / MAXBASE:角色:母乳, 1)
	SOURCE:角色:肮脏 += MAX( 1500 * 母乳噴出量 / MAXBASE:角色:母乳, 1)
ELSEIF EXP:角色:喷乳经验 < EXPLV:3
	SOURCE:角色:露出 += MAX( 3000 * 母乳噴出量 / MAXBASE:角色:母乳, 1)
	SOURCE:角色:屈从 += MAX( 1500 * 母乳噴出量 / MAXBASE:角色:母乳, 1)
	SOURCE:角色:肮脏 += MAX( 1000 * 母乳噴出量 / MAXBASE:角色:母乳, 1)
ELSEIF EXP:角色:喷乳经验 < EXPLV:4
	SOURCE:角色:露出 += MAX( 1500 * 母乳噴出量 / MAXBASE:角色:母乳, 1)
	SOURCE:角色:屈从 += MAX(  800 * 母乳噴出量 / MAXBASE:角色:母乳, 1)
	SOURCE:角色:肮脏 += MAX(  700 * 母乳噴出量 / MAXBASE:角色:母乳, 1)
ELSEIF EXP:角色:喷乳经验 < EXPLV:5
	SOURCE:角色:露出 += MAX( 1000 * 母乳噴出量 / MAXBASE:角色:母乳, 1)
	SOURCE:角色:屈从 += MAX(  500 * 母乳噴出量 / MAXBASE:角色:母乳, 1)
	SOURCE:角色:肮脏 += MAX(  400 * 母乳噴出量 / MAXBASE:角色:母乳, 1)
ELSE
	SOURCE:角色:露出 += MAX(  500 * 母乳噴出量 / MAXBASE:角色:母乳, 1)
	SOURCE:角色:屈从 += MAX(  300 * 母乳噴出量 / MAXBASE:角色:母乳, 1)
ENDIF

SELECTCASE 母乳噴出量
	CASE IS > MAXBASE:角色:母乳
		PRINTFORML %CALLNAME:角色+"的乳头喷出了大量的母乳"%
		EXP:角色:异常经验 += (EXP:角色:喷乳经验==0)
		EXP:角色:喷乳经验 += 3
		NOWEX:角色:喷乳 += 3
		EX:角色:喷乳 += 3
	CASE IS > (MAXBASE:角色:母乳/2)
		PRINTFORML %CALLNAME:角色+"的乳头喷出了母乳"%
		EXP:角色:异常经验 += (EXP:角色:喷乳经验==0)
		EXP:角色:喷乳经验 += 2
		NOWEX:角色:喷乳 += 2
		EX:角色:喷乳 += 2
	CASE IS > (MAXBASE:角色:母乳/4)
		;125%以上貯まっていた
		PRINTFORML %CALLNAME:角色+"的乳头溢出了母乳"%
		EXP:角色:异常经验 += (EXP:角色:喷乳经验==0)
		EXP:角色:喷乳经验 += 1
		NOWEX:角色:喷乳 += 1
		EX:角色:喷乳 += 1
	CASEELSE
		PRINTFORML %CALLNAME:角色+"的乳头渗出了母乳"%
ENDSELECT

;Ｂに母乳汚れを付ける
STAIN:角色:Ｂ |= 汚れ_母乳

;母乳を減らす
BASE:角色:母乳 -= 母乳噴出量
;万一の為に最大母乳-1になるように調整
BASE:角色:母乳 = MIN(BASE:角色:母乳, MAXBASE:角色:母乳 - 1)

;录像摄影判定
IF TEQUIP:角色:录像摄影
	IF NOWEX:角色:喷乳 == 1
		LOCALS = MILK/
	ELSEIF NOWEX:角色:喷乳 == 2
		LOCALS = MILK/MILK/
	ENDIF
	TSTR:视频摄影记录 += LOCALS
ENDIF

WAIT
