;-------------------------------------------------------------------------------
;絶頂系の処理など
;-------------------------------------------------
;絶頂処理
;-------------------------------------------------
@ORGASM_ADD(角色,調教者)
#DIM 角色
#DIM 調教者
#DIM 絶頂要求係数
#DIM 総合快感値
#DIM 部位快感値
#DIM 絶頂候補
#DIM Ａ绝顶強度
#DIM Ｂ绝顶強度
#DIM Ｃ绝顶強度
#DIM Ｖ绝顶強度
#DIM 浮気快楽強度
#DIM A绝顶基准
#DIM B绝顶基准
#DIM C绝顶基准
#DIM V绝顶基准
#DIM A快感溢出
#DIM B快感溢出
#DIM C快感溢出
#DIM V快感溢出
#DIM A假高潮
#DIM B假高潮
#DIM C假高潮
#DIM V假高潮

絶頂候補 = 0
絶頂候補 += ((CUP:角色:快Ｃ + PALAM:角色:快Ｃ) >= PALAMLV:4)
絶頂候補 += ((CUP:角色:快Ｖ + PALAM:角色:快Ｖ) >= PALAMLV:4)
絶頂候補 += ((CUP:角色:快Ａ + PALAM:角色:快Ａ) >= PALAMLV:4)
絶頂候補 += ((CUP:角色:快Ｂ + PALAM:角色:快Ｂ) >= PALAMLV:4)
SELECTCASE 絶頂候補
	CASE 4
		総合快感値 = 7000
	CASE 3
		総合快感値 = 5000
	CASE 2
		総合快感値 = 3000
	CASE 1
		総合快感値 = 2000
ENDSELECT
[IF_DEBUG]
PRINTFORML 角色：%CALLNAME:角色%
PRINTFORML 総合快感値{総合快感値}
[ENDIF]
;視認性の問題で残しておく
Ｃ绝顶強度 = 0
Ｖ绝顶強度 = 0
Ａ绝顶強度 = 0
Ｂ绝顶強度 = 0

;訪問者以外の調教で、快乐刻印よりも浮気快乐刻印のレベルが高い場合、絶頂しづらくなる
IF 調教者 == MASTER && GET_MARK_LEVEL(角色,刻印番号_快乐刻印,調教者) < MARK:角色:浮気快乐刻印
	;絶頂要求係数 = MAX( 100 * MARK:角色:浮気快乐刻印 / MAX(1,GET_MARK_LEVEL(角色,刻印番号_快乐刻印,調教者)) , 100 )
	絶頂要求係数 = MAX(50,(100-RelativeSizeOfVaginaAndPenis(角色,調教者,1)*25)) - GET_MARK_LEVEL(角色,刻印番号_快乐刻印,調教者)*10 + MARK:角色:浮気快乐刻印*50
ELSEIF 調教者 == MASTER
	絶頂要求係数 = MAX(50,(100-RelativeSizeOfVaginaAndPenis(角色,調教者,1)*25))
ELSEIF 調教者 == 人物_訪問者
	絶頂要求係数 = MAX(30,MIN(120,(100-RelativeSizeOfVaginaAndPenis(角色,調教者,1)*25)-MARK:角色:浮気快乐刻印*1))
ELSE
	絶頂要求係数 = 100
ENDIF
[IF_DEBUG]
PRINTFORML 絶頂要求係数{絶頂要求係数}
[ENDIF]
;-------------------------------------------------------------------
;絶頂Ｃ
部位快感値 = (CUP:角色:快Ｃ > 0) * 総合快感値
[IF_DEBUG]
PRINTFORML C绝顶基准{絶頂要求係数}
PRINTFORML C部位快感値：{部位快感値}  高潮阈值{PALAMLV:4 * 2 * 絶頂要求係数 / 100}/{PALAMLV:4 * 絶頂要求係数 / 100}
PRINTFORML 实际判定值：{CUP:角色:快Ｃ + PALAM:角色:快Ｃ + 部位快感値}
[ENDIF]
IF CUP:角色:快Ｃ + PALAM:角色:快Ｃ + 部位快感値 >= PALAMLV:4 * 2 * 絶頂要求係数 / 100
	Ｃ绝顶強度 = 2
	C快感溢出 = (CUP:角色:快Ｃ+PALAM:角色:快Ｃ+部位快感値)/(PALAMLV:4*2*絶頂要求係数/100)
	[IF_DEBUG]
	PRINTFORML Ｃ绝顶強度 = 2
	[ENDIF]
	CDOWN:角色:快Ｃ = PALAMLV:4 * 2 - 部位快感値
ELSEIF CUP:角色:快Ｃ + PALAM:角色:快Ｃ + 部位快感値 >= PALAMLV:4 * 絶頂要求係数 / 100
	Ｃ绝顶強度 = 1
	[IF_DEBUG]
	PRINTFORML Ｃ绝顶強度 = 1
	[ENDIF]
	CDOWN:角色:快Ｃ = PALAMLV:4 - 部位快感値
ELSEIF CUP:角色:快Ｃ + PALAM:角色:快Ｃ + 部位快感値 >= PALAMLV:4
	;イけるはずなのにイけなかった場合
	[IF_DEBUG]
	PRINTFORML Ｃ绝顶強度 = 0 （假绝顶）
	[ENDIF]
	NOWEX:角色:绝顶演技++
ENDIF
;CDOWN:角色:快Ｃで下げても絶頂以上なら
;その値-1になるように調整（10000で絶頂なら9999）
SIF CUP:角色:快Ｃ + PALAM:角色:快Ｃ - CDOWN:角色:快Ｃ >= PALAMLV:4
	CDOWN:角色:快Ｃ = CUP:角色:快Ｃ + PALAM:角色:快Ｃ - PALAMLV:4 + 1
;-------------------------------------------------------------------
;絶頂Ｖ
IF 調教者 == MASTER && CFLAG:角色:和访问者已做爱 && EXP:角色:浮気Ｖ性交经验 > EXP:角色:浮気Ｖ性交经验 - EXP:角色:Ｖ性交经验
	V绝顶基准 = 絶頂要求係数 + TALENT:角色:浮気的蜜壶*100
ELSEIF 調教者 == MASTER && !CFLAG:角色:和访问者已做爱
	;保底一下，防止访问者出手前都没让角色高潮导致一部分剧情不能触发。（额……没有参照物的情况下能高潮很正常吧.jpg）
	V绝顶基准 = 100 - TALENT:調教者:阴茎尺寸 * 15
ELSE
	V绝顶基准 = 絶頂要求係数
ENDIF
部位快感値 = (CUP:角色:快Ｖ > 0) * 総合快感値
[IF_DEBUG]
PRINTFORML V绝顶基准{V绝顶基准}
PRINTFORML V部位快感値：{部位快感値}  高潮阈值{PALAMLV:4 * 2 * V绝顶基准 / 100}/{PALAMLV:4 * V绝顶基准 / 100}
PRINTFORML 实际判定值：{CUP:角色:快Ｖ + PALAM:角色:快Ｖ + 部位快感値}
[ENDIF]
IF CUP:角色:快Ｖ + PALAM:角色:快Ｖ + 部位快感値 >= PALAMLV:4 * 2 * V绝顶基准 / 100
	Ｖ绝顶強度 = 2
	V快感溢出 = (CUP:角色:快Ｖ+PALAM:角色:快Ｖ+部位快感値)/(PALAMLV:4*2*V绝顶基准/100)
	[IF_DEBUG]
	PRINTFORML Ｖ绝顶強度 = 2
	[ENDIF]
	CDOWN:角色:快Ｖ = PALAMLV:4 * 2 - 部位快感値
ELSEIF CUP:角色:快Ｖ + PALAM:角色:快Ｖ + 部位快感値 >= PALAMLV:4 * V绝顶基准 / 100
	Ｖ绝顶強度 = 1
	[IF_DEBUG]
	PRINTFORML Ｖ绝顶強度 = 1
	[ENDIF]
	CDOWN:角色:快Ｖ = PALAMLV:4 - 部位快感値
ELSEIF CUP:角色:快Ｖ + PALAM:角色:快Ｖ + 部位快感値 >= PALAMLV:4
	;イけるはずなのにイけなかった場合
	[IF_DEBUG]
	PRINTFORML Ｖ绝顶強度 = 0 （假绝顶）
	[ENDIF]
	NOWEX:角色:绝顶演技++
ENDIF
;CDOWN:角色:快Ｖで下げても絶頂以上なら
;その値-1になるように調整（10000で絶頂なら9999）
SIF CUP:角色:快Ｖ + PALAM:角色:快Ｖ - CDOWN:角色:快Ｖ >= PALAMLV:4
	CDOWN:角色:快Ｖ = CUP:角色:快Ｖ + PALAM:角色:快Ｖ - PALAMLV:4 + 1
;-------------------------------------------------------------------
;絶頂Ａ
IF 調教者 == MASTER && EXP:角色:浮気Ａ性交经验 > EXP:角色:浮気Ａ性交经验 - EXP:角色:Ａ性交经验
	A绝顶基准 = 絶頂要求係数 + TALENT:角色:浮気的菊花*100
ELSE
	A绝顶基准 = 絶頂要求係数
ENDIF
部位快感値 = (CUP:角色:快Ａ > 0) * 総合快感値
[IF_DEBUG]
PRINTFORML A绝顶基准{A绝顶基准}
PRINTFORML A部位快感値：{部位快感値}  高潮阈值{PALAMLV:4 * 2 * A绝顶基准 / 100}/{PALAMLV:4 * A绝顶基准 / 100}
PRINTFORML 实际判定值：{CUP:角色:快Ａ + PALAM:角色:快Ａ + 部位快感値}
[ENDIF]
IF CUP:角色:快Ａ + PALAM:角色:快Ａ + 部位快感値 >= PALAMLV:4 * 2 * A绝顶基准 / 100
	Ａ绝顶強度 = 2
	A快感溢出 = (CUP:角色:快Ａ+PALAM:角色:快Ａ+部位快感値)/(PALAMLV:4*2*A绝顶基准/100)
	[IF_DEBUG]
	PRINTFORML Ａ绝顶強度 = 2
	[ENDIF]
	CDOWN:角色:快Ａ = PALAMLV:4 * 2 - 部位快感値
ELSEIF CUP:角色:快Ａ + PALAM:角色:快Ａ + 部位快感値 >= PALAMLV:4 * A绝顶基准 / 100
	Ａ绝顶強度 = 1
	[IF_DEBUG]
	PRINTFORML Ａ绝顶強度 = 1
	[ENDIF]
	CDOWN:角色:快Ａ = PALAMLV:4 - 部位快感値
ELSEIF CUP:角色:快Ａ + PALAM:角色:快Ａ + 部位快感値 >= PALAMLV:4
	;イけるはずなのにイけなかった場合
	[IF_DEBUG]
	PRINTFORML Ａ绝顶強度 = 0 （假绝顶）
	[ENDIF]
	NOWEX:角色:绝顶演技++
ENDIF
;CDOWN:角色:快Ａで下げても絶頂以上なら
;その値-1になるように調整（10000で絶頂なら9999）
SIF CUP:角色:快Ａ + PALAM:角色:快Ａ - CDOWN:角色:快Ａ >= PALAMLV:4
	CDOWN:角色:快Ａ = CUP:角色:快Ａ + PALAM:角色:快Ａ - PALAMLV:4 + 1
;-------------------------------------------------------------------
;絶頂Ｂ
部位快感値 = (CUP:角色:快Ｂ > 0) * 総合快感値
[IF_DEBUG]
PRINTFORML B绝顶基准{絶頂要求係数}
PRINTFORML B部位快感値：{部位快感値}  高潮阈值{PALAMLV:4 * 2 * 絶頂要求係数 / 100}/{PALAMLV:4 * 絶頂要求係数 / 100}
PRINTFORML 实际判定值：{CUP:角色:快Ｂ + PALAM:角色:快Ｂ + 部位快感値}
[ENDIF]
IF CUP:角色:快Ｂ + PALAM:角色:快Ｂ + 部位快感値 >= PALAMLV:4 * 2 * 絶頂要求係数 / 100
	Ｂ绝顶強度 = 2
	B快感溢出 = (CUP:角色:快Ｂ+PALAM:角色:快Ｂ+部位快感値)/(PALAMLV:4*2*絶頂要求係数/100)
	[IF_DEBUG]
	PRINTFORML Ｂ绝顶強度 = 2
	[ENDIF]
	CDOWN:角色:快Ｂ = (PALAMLV:4 * 2 - 1000) - 部位快感値
ELSEIF CUP:角色:快Ｂ + PALAM:角色:快Ｂ + 部位快感値 >= PALAMLV:4 * 絶頂要求係数 / 100
	Ｂ绝顶強度 = 1
	[IF_DEBUG]
	PRINTFORML Ｂ绝顶強度 = 1
	[ENDIF]
	CDOWN:角色:快Ｂ = (PALAMLV:4 - 1000) - 部位快感値
ELSEIF CUP:角色:快Ｂ + PALAM:角色:快Ｂ + 部位快感値 >= PALAMLV:4
	;イけるはずなのにイけなかった場合
	[IF_DEBUG]
	PRINTFORML Ｂ绝顶強度 = 0 （假绝顶）
	[ENDIF]
	NOWEX:角色:绝顶演技++
ENDIF
;CDOWN:角色:快Ｂで下げても絶頂以上なら
;その値-1になるように調整（10000で絶頂なら9999）
SIF CUP:角色:快Ｂ + PALAM:角色:快Ｂ - CDOWN:角色:快Ｂ >= PALAMLV:4
	CDOWN:角色:快Ｂ = CUP:角色:快Ｂ + PALAM:角色:快Ｂ - PALAMLV:4 + 1
;-------------------------------------------------
;絶頂時の追加処理
;-------------------------------------------------
;快乐刻印の処理
;絶頂の部位と強度の合計が一定以上で刻印を取得する
LOCAL = Ｃ绝顶強度 + Ｖ绝顶強度 * 2 + Ａ绝顶強度 * 2 + Ｂ绝顶強度
;Rが4以上で快乐刻印３に相当
IF LOCAL >= 3 && MARK:角色:快乐刻印 < 3
	TCVAR:角色:快楽強度 = 3
	;Rが3以上で快乐刻印２に相当
ELSEIF LOCAL >= 2 && MARK:角色:快乐刻印 < 2
	TCVAR:角色:快楽強度 = 2
	;Rが2以上で快乐刻印１に相当
ELSEIF LOCAL >= 1 && MARK:角色:快乐刻印 < 1
	TCVAR:角色:快楽強度 = 1
ELSE
	TCVAR:角色:快楽強度 = 0
ENDIF
IF Ｃ绝顶強度 == 2 && Ｖ绝顶強度 == 2 && Ａ绝顶強度 == 2 && Ｂ绝顶強度 == 2
	Ｃ绝顶強度 *= 16
	Ｖ绝顶強度 *= 16
	Ａ绝顶強度 *= 16
	Ｂ绝顶強度 *= 16
	NOWEX:角色:四重绝顶 = 1
ELSEIF Ｃ绝顶強度 && Ｖ绝顶強度 && Ａ绝顶強度 && Ｂ绝顶強度
	Ｃ绝顶強度 *= 8
	Ｖ绝顶強度 *= 8
	Ａ绝顶強度 *= 8
	Ｂ绝顶強度 *= 8
	NOWEX:角色:四重绝顶 = 1
ELSEIF Ｃ绝顶強度 && Ｖ绝顶強度 && Ａ绝顶強度
	Ｃ绝顶強度 *= 4
	Ｖ绝顶強度 *= 4
	Ａ绝顶強度 *= 4
	NOWEX:角色:三重绝顶 = 1
ELSEIF Ｂ绝顶強度 && Ｖ绝顶強度 && Ａ绝顶強度
	Ｂ绝顶強度 *= 4
	Ｖ绝顶強度 *= 4
	Ａ绝顶強度 *= 4
	NOWEX:角色:三重绝顶 = 2
ELSEIF Ｃ绝顶強度 && Ｂ绝顶強度 && Ａ绝顶強度
	Ｃ绝顶強度 *= 4
	Ｂ绝顶強度 *= 4
	Ａ绝顶強度 *= 4
	NOWEX:角色:三重绝顶 = 3
ELSEIF Ｃ绝顶強度 && Ｖ绝顶強度 && Ｂ绝顶強度
	Ｃ绝顶強度 *= 4
	Ｖ绝顶強度 *= 4
	Ｂ绝顶強度 *= 4
	NOWEX:角色:三重绝顶 = 4
ELSEIF Ｃ绝顶強度 && Ｖ绝顶強度
	Ｃ绝顶強度 *= 2
	Ｖ绝顶強度 *= 2
	NOWEX:角色:二重绝顶 = 1
ELSEIF Ｃ绝顶強度 && Ａ绝顶強度
	Ｃ绝顶強度 *= 2
	Ａ绝顶強度 *= 2
	NOWEX:角色:二重绝顶 = 2
ELSEIF Ｖ绝顶強度 && Ａ绝顶強度
	Ｖ绝顶強度 *= 2
	Ａ绝顶強度 *= 2
	NOWEX:角色:二重绝顶 = 3
ELSEIF Ｃ绝顶強度 && Ｂ绝顶強度
	Ｃ绝顶強度 *= 2
	Ｂ绝顶強度 *= 2
	NOWEX:角色:二重绝顶 = 4
ELSEIF Ｖ绝顶強度 && Ｂ绝顶強度
	Ｖ绝顶強度 *= 2
	Ｂ绝顶強度 *= 2
	NOWEX:角色:二重绝顶 = 5
ELSEIF Ａ绝顶強度 && Ｂ绝顶強度
	Ａ绝顶強度 *= 2
	Ｂ绝顶強度 *= 2
	NOWEX:角色:二重绝顶 = 6
ENDIF
IF Ｃ绝顶強度
	SOURCE:角色:露出 += 500 * Ｃ绝顶強度
	SOURCE:角色:屈从 += 200 * Ｃ绝顶強度
	SOURCE:角色:反感 += 150 * Ｃ绝顶強度
	DOWNBASE:角色:体力 += 20
	DOWNBASE:角色:气力 += 10
ENDIF
IF Ｖ绝顶強度
	SOURCE:角色:欲情 += 800 * Ｖ绝顶強度
	SOURCE:角色:恭顺 += 500 * Ｖ绝顶強度
	SOURCE:角色:露出 += 700 * Ｖ绝顶強度
	SOURCE:角色:屈从 += 400 * Ｖ绝顶強度
	SOURCE:角色:反感 += 300 * Ｖ绝顶強度
	DOWNBASE:角色:体力 += 40
	DOWNBASE:角色:气力 += 20
ENDIF
IF Ａ绝顶強度
	SOURCE:角色:欲情 += 500 * Ａ绝顶強度
	SOURCE:角色:恭顺 += 700 * Ａ绝顶強度
	SOURCE:角色:露出 += 900 * Ａ绝顶強度
	SOURCE:角色:屈从 += 500 * Ａ绝顶強度
	SOURCE:角色:反感 += 400 * Ａ绝顶強度
	DOWNBASE:角色:体力 += 60
	DOWNBASE:角色:气力 += 30
ENDIF
IF Ｂ绝顶強度
	SOURCE:角色:露出 += 500 * Ｂ绝顶強度
	SOURCE:角色:屈从 += 200 * Ｂ绝顶強度
	SOURCE:角色:反感 += 150 * Ｂ绝顶強度
	DOWNBASE:角色:体力 += 20
	DOWNBASE:角色:气力 += 10
ENDIF
;NOWEXにデータを入れる（絶頂時口上に使う）
NOWEX:角色:Ｃ绝顶 = Ｃ绝顶強度
NOWEX:角色:Ｖ绝顶 = Ｖ绝顶強度
NOWEX:角色:Ａ绝顶 = Ａ绝顶強度
NOWEX:角色:Ｂ绝顶 = Ｂ绝顶強度
;絶頂回数を増やす
EX:角色:Ｃ绝顶 += Ｃ绝顶強度
EX:角色:Ｖ绝顶 += Ｖ绝顶強度
EX:角色:Ａ绝顶 += Ａ绝顶強度
EX:角色:Ｂ绝顶 += Ｂ绝顶強度
;绝顶经验を増
IF 調教者 == 人物_訪問者 || (調教者 != 0 && 調教者 >= CHARANUM && (TALENT:角色:恋慕 || TALENT:角色:亲爱 || TALENT:角色:人妻 || TALENT:角色:恋人))
	CALL NTR_EXP_ADD_C_EX(角色,Ｃ绝顶強度 * C快感溢出 / 3)
	CALL NTR_EXP_ADD_V_EX(角色,Ｖ绝顶強度 * V快感溢出 / 5)
	CALL NTR_EXP_ADD_A_EX(角色,Ａ绝顶強度 * A快感溢出 / 5)
	CALL NTR_EXP_ADD_B_EX(角色,Ｂ绝顶強度 * B快感溢出 / 3)
ELSE
	EXP:角色:绝顶经验 += Ｃ绝顶強度 + Ｖ绝顶強度 + Ａ绝顶強度 + Ｂ绝顶強度
	EXP:角色:Ｃ绝顶经验 += Ｃ绝顶強度
	EXP:角色:Ｖ绝顶经验 += Ｖ绝顶強度
	EXP:角色:Ａ绝顶经验 += Ａ绝顶強度
	EXP:角色:Ｂ绝顶经验 += Ｂ绝顶強度
ENDIF
;ビデオ
IF TEQUIP:角色:录像摄影
	IF NOWEX:角色:四重绝顶
		LOCALS = O2/O3/O4/
		TSTR:视频摄影记录 += LOCALS
	ENDIF
	IF NOWEX:角色:三重绝顶
		LOCALS = O2/O3/
		TSTR:视频摄影记录 += LOCALS
	ENDIF
	IF NOWEX:角色:二重绝顶
		LOCALS = O2/
		TSTR:视频摄影记录 += LOCALS
	ENDIF
	IF NOWEX:角色:Ｃ绝顶 == 2
		LOCALS = C/C/
		TSTR:视频摄影记录 += LOCALS
	ELSEIF NOWEX:角色:Ｃ绝顶 == 1
		LOCALS = C/
		TSTR:视频摄影记录 += LOCALS
	ENDIF
	IF NOWEX:角色:Ｖ绝顶 == 2
		LOCALS = V/V/
		TSTR:视频摄影记录 += LOCALS
	ELSEIF NOWEX:角色:Ｖ绝顶 == 1
		LOCALS = V/
		TSTR:视频摄影记录 += LOCALS
	ENDIF
	IF NOWEX:角色:Ａ绝顶 == 2
		LOCALS = A/A/
		TSTR:视频摄影记录 += LOCALS
	ELSEIF NOWEX:角色:Ａ绝顶 == 1
		LOCALS = A/
		TSTR:视频摄影记录 += LOCALS
	ENDIF
	IF NOWEX:角色:Ｂ绝顶 == 2
		LOCALS = B/B/
