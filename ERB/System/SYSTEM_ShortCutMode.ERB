;-------------------------------------------------
;ショートカットモード
;-------------------------------------------------
@SHORT_CUT_MODE
PRINTL 　
PRINTL 　
PRINTL 推荐从最初好感度的情况下开始游戏。
PRINT (口上などに不具合が生じる可能性があります)
SETCOLOR 0x131213
PRINTL ［-1］と入力しないでください
RESETCOLOR
PRINTL 那么要从某种攻略状态下开始游戏吗？
SETCOLOR 0x151515
PRINTL [0]是的
RESETCOLOR
PRINTL [1]不要
PRINTL [2]还是不要

$INPUT_LOOP
INPUT
;ショートカット
IF RESULT == 0
	FOR LOCAL,1,CHARANUM
		;好感度は1200
		CFLAG:LOCAL:2 = 1200

		;基本、亲密＆顺从は４、欲望＆技巧は３まで上昇。最初から高ければ+1
		;顺从
		IF ABL:LOCAL:亲密 >= 3
			ABL:LOCAL:亲密 = 5
		ELSE
			ABL:LOCAL:亲密 = 4
		ENDIF
		;顺从
		IF ABL:LOCAL:顺从 >= 3
			ABL:LOCAL:顺从 = 5
		ELSE
			ABL:LOCAL:顺从 = 4
		ENDIF
		;欲望
		IF ABL:LOCAL:欲望 >= 2
			ABL:LOCAL:欲望 = 4
		ELSE
			ABL:LOCAL:欲望 = 3
		ENDIF
		;技巧
		IF ABL:LOCAL:技巧 >= 2
			ABL:LOCAL:技巧 = 4
		ELSE
			ABL:LOCAL:技巧 = 3
		ENDIF

		;侍奉快乐经验を増加
		EXP:LOCAL:侍奉快乐经验 += 15

	NEXT
	PRINTW ある程度攻略が進んだ状態からスタートします
	;NTR
ELSEIF RESULT == -1
	FOR LOCAL,1,CHARANUM
		;[NTR]を付ける
		TALENT:LOCAL:6 = 1

		;屈服度が1000
		CFLAG:LOCAL:21 = 1000

		;基本、亲密＆顺从は５、欲望＆技巧は４で上昇。最初から高ければ+1
		;顺从
		IF ABL:LOCAL:亲密 >= 4
			ABL:LOCAL:亲密 = 6
		ELSE
			ABL:LOCAL:亲密 = 5
		ENDIF
		;顺从
		IF ABL:LOCAL:顺从 >= 4
			ABL:LOCAL:顺从 = 6
		ELSE
			ABL:LOCAL:顺从 = 5
		ENDIF
		;欲望
		IF ABL:LOCAL:欲望 >= 3
			ABL:LOCAL:欲望 = 5
		ELSE
			ABL:LOCAL:欲望 = 4
		ENDIF
		;技巧
		IF ABL:LOCAL:技巧 >= 3
			ABL:LOCAL:技巧 = 5
		ELSE
			ABL:LOCAL:技巧 = 4
		ENDIF

	NEXT
	PRINTW 最　初　か　ら　ネ　ト　ラ　レ　！　！
	;通常
ELSEIF RESULT == 1 || RESULT == 2
	PRINTW 以通常模式开始

ELSE
	GOTO INPUT_LOOP
ENDIF
PRINTL 　


