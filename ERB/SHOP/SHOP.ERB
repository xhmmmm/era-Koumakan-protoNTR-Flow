@SHOW_SHOP
TRYCALL COM461_PUNISHMENT_END
TRYCALL 追加パッチVerUP
FOR LOCAL , 0 , CHARANUM
	CALL 肌肤等颜色改变(LOCAL)
	SIF LOCAL != 0
		CALL SHOP_计算最大体力气力(LOCAL)
NEXT
FOR LOCAL, 1, CHARANUM
	IF CFLAG:LOCAL:当前位置 != 位置_訪問者宅
		CALL NTR_SET_STAYOUT_MAXIMUM(LOCAL, LIMIT(RAND(14,31),14,30))
	ENDIF
NEXT
;角色購入ページフラグ
TFLAG:100 = 0
CALL UI_重分隔
;日期
PRINTFORM  %日期_年份名称(日期_年数)%（第{日期_年数}年）%日期_月份名称(日期_月数)%{日期_天数}日(%GET_DAY()%)[第{DAY}天]
PRINTL
;拥有金钱
SETCOLOR 颜色_橙
PRINTFORM  拥有金钱：{MONEY}元
RESETCOLOR
PRINTL
;体力气力
SETCOLOR 颜色_暗粉红
PRINTFORM  体力 
RESETCOLOR
CALL 数据条绘制(BASE:MASTER:0,MAXBASE:MASTER:0,"░","░",颜色_暗粉红,颜色_深灰,10)
PRINTFORM  {BASE:MASTER:0,4}/{MAXBASE:MASTER:0,4}  
SETCOLOR 颜色_浊黄
PRINTFORM 气力 
RESETCOLOR
CALL 数据条绘制(BASE:MASTER:1,MAXBASE:MASTER:1,"░","░",颜色_浊黄,颜色_深灰,10)
PRINTFORM  {BASE:MASTER:1,4}/{MAXBASE:MASTER:1,4}
PRINTL
CALL UI_轻分隔
PRINTL
SETCOLOR 颜色_奶油
PRINTFORM [1060] 起床时间：
RESETCOLOR
PRINTFORM {CFLAG:MASTER:通常起床時間 / 60}时
PRINTL
SETCOLOR 颜色_奶油
PRINTFORM [1061] 卧室位置：
RESETCOLOR
PRINTFORM %GetPlaceName(CFLAG:MASTER:開始位置)%
PRINTL
;起床
PRINTL
SETCOLOR 颜色_橙红
PRINTFORML [100] - 起床
RESETCOLOR
PRINTL
;主菜单
SETCOLOR 颜色_浅金
PRINTFORM  · 主菜单
RESETCOLOR
PRINTL
PRINTFORML   [101] - 能力表示
PRINTFORML   [102] - 收藏
PRINTFORML   [103] - 通信販売
PRINTL
;系统菜单
SETCOLOR 颜色_奶油
PRINTFORM  · 系统菜单
RESETCOLOR
PRINTL
PRINTFORML   [200] - 存档
PRINTFORML   [300] - 读档
PRINTFORML   [400] - 设置选项
CALL UI_重分隔
TRYCALL 妊娠パッチDEBUG88

@USERSHOP

TRYCALL 妊娠パッチDEBUG88COM

IF RESULT == 100
	BEGIN TRAIN
	RETURN 1
ELSEIF RESULT == 101
	CALL SHOP_能力表示
ELSEIF RESULT == 102
	CALL SHOP_收藏
ELSEIF RESULT == 103
	CALL SHOP_购物
ELSEIF RESULT == 1060
	CALL SHOP_起床时间设定
ELSEIF RESULT == 1061
	CALL SHOP_卧室设定
ELSEIF RESULT == 200
	SAVEGAME
ELSEIF RESULT == 300
	LOADGAME
ELSEIF RESULT == 400
	CALL OPTION
ELSEIF RESULT == 9988
	CALL DEBUG_Maid
ENDIF
