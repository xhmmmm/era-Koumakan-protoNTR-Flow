@SHOW_SHOP
TRYCALL COM461_PUNISHMENT_END
TRYCALL 追加パッチVerUP
FOR LOCAL , 0 , CHARANUM
	CALL 肌肤等颜色改变(LOCAL)
	SIF LOCAL != 0
		CALL SHOP_计算最大体气(LOCAL)
NEXT
FOR LOCAL, 1, CHARANUM
	IF CFLAG:LOCAL:当前位置 != 位置_訪問者宅
		CALL NTR_SET_STAYOUT_MAXIMUM(LOCAL, LIMIT(RAND(14,31),14,30))
	ENDIF
NEXT
;角色購入ページフラグ
TFLAG:100 = 0
CALL UI_重分隔
;日期和所持金
PRINTFORM  %日期_年份名称(日期_年数)%（第{日期_年数}年）%日期_月份名称(日期_月数)%{日期_天数}日[{DAY}日目](%GET_DAY()%)
SETCOLOR 颜色_主题_星
PRINTFORM  所持金：
RESETCOLOR
PRINTFORM {MONEY}元
PRINTL
;体力气力
PRINTFORM  体力 
CALL 数据条绘制(BASE:MASTER:0,MAXBASE:MASTER:0,"░","░",颜色_暗粉红,颜色_深灰,10)
PRINTFORM  {BASE:MASTER:0,4}/{MAXBASE:MASTER:0,4}   气力 
CALL 数据条绘制(BASE:MASTER:1,MAXBASE:MASTER:1,"░","░",颜色_浊黄,颜色_深灰,10)
PRINTFORM  {BASE:MASTER:1,4}/{MAXBASE:MASTER:1,4}
PRINTL
CALL UI_重分隔
PRINTL
PRINTBUTTON "[起床时间]", 1060
PRINTFORML ：{CFLAG:MASTER:通常起床時間 / 60}时
PRINTBUTTON "[卧室位置]", 1061
PRINTFORM ：%GetPlaceName(CFLAG:MASTER:開始位置)%
PRINTL
;起床
PRINTL
SETCOLOR 颜色_主题_星
PRINTFORML  [100] - 起床
RESETCOLOR
PRINTL
;日常
CALL UI_节标题("日常")
PRINTFORMC [101] - 能力表示
PRINTFORMC [102] - 收藏    
PRINTFORMC [103] - 通信販売
PRINTL
;系统
CALL UI_节标题("系统")
PRINTFORMC [200] - 存档    
PRINTFORMC [300] - 读档    
PRINTFORMC [400] - 设置选项
PRINTL
TRYCALL 妊娠パッチDEBUG88

@USERSHOP

TRYCALL 妊娠パッチDEBUG88COM

IF RESULT == 100
	BEGIN TRAIN
	RETURN 1
ELSEIF RESULT == 101
	CALL SHOP_能力表示
ELSEIF RESULT == 102
	CALL SHOP_收藏
ELSEIF RESULT == 103
	CALL SHOP_购物
ELSEIF RESULT == 1060
	CALL SHOP_起床时间设定
ELSEIF RESULT == 1061
	CALL SHOP_卧室设定
ELSEIF RESULT == 200
	SAVEGAME
ELSEIF RESULT == 300
	LOADGAME
ELSEIF RESULT == 400
	CALL OPTION
ELSEIF RESULT == 9988
	CALL DEBUG_Maid
ENDIF
