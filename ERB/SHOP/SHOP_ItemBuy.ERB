@SHOP_购物
#DIM LOOP_CHR
#DIM LOOP_ITEM
#DIM ITEM_NO

CALL SHOP_商品销售
CALL 主界面_节标题("购买")
SETCOLOR 颜色_暗金
PRINTFORM  拥有金钱：{MONEY}元
RESETCOLOR
PRINTL
CALL SHOP_商品一览
CALL UI_轻分隔
PRINTBUTTON "[100] 返回", 100
PRINTFORM    [200] 物品重置
PRINTL
$INPUT_LOOP
INPUT
ITEM_NO = RESULT
IF RESULT == 100
	RETURN 0
ELSEIF RESULT == 200
	LOCALS = 要重置物品持有数量吗？
	CALL CHOICE(LOCALS, "是的", "不要")
	SIF RESULT
		RESTART
	FOR LOOP_ITEM, 0, 100
		ITEMSALES:LOOP_ITEM = 0
	NEXT
	RESTART
ELSEIF ITEMSTOCK(RESULT) == 1 || ITEMSTOCK(RESULT) == 4 || RESULT < 0 || RESULT > 100
	RESTART
ELSEIF ITEMSTOCK(RESULT) == 2
	PRINTW 已售罄
	RESTART
ELSEIF ITEMSTOCK(RESULT) == 3
	PRINTW 所需金额不足
	RESTART
ELSEIF ITEMSTOCK(RESULT) == 5
	PRINTW 持有数量已达上限
	RESTART
ENDIF
;物品说明
CALL UI_轻分隔
SETCOLOR 颜色_浅金
PRINTFORM  ✧ %ITEMNAME:ITEM_NO%
RESETCOLOR
PRINTFORM  ${ITEMPRICE:ITEM_NO}
PRINTL
CALLFORM SHOP_ItemDescription{ITEM_NO}
PRINTL
CALL UI_轻分隔

;个别物品需要特殊处理
IF ITEM_NO == 60 || ITEM_NO == 61 || ITEM_NO == 62
	LOCALS = 要习得%ITEMNAME:ITEM_NO%吗？
	CALL CHOICE(LOCALS, "是的", "不要")
	SIF RESULT
		RESTART
	MONEY -= ITEMPRICE:ITEM_NO
	SELECTCASE ITEM_NO
		CASE 60
			TALENT:MASTER:污臭耐性 = 2
		CASE 61
			TALENT:MASTER:调和知识 = 1
		CASE 62
			TALENT:MASTER:禁断的知识 = 1
	ENDSELECT
	ITEMSALES:ITEM_NO = -1
	RESTART
ENDIF
IF ITEM_NO == 63
	CALL CHOICE("要购买【技巧UP】吗？", "是的", "不要")
	SIF RESULT
		RESTART
	MONEY -= ITEMPRICE:ITEM_NO
	ABL:MASTER:技巧 += 1
	RESTART
ENDIF
IF ITEM_NO == 64
	CALL CHOICE("要购买【技巧DOWN】吗？", "是的", "不要")
	SIF RESULT
		RESTART
	MONEY -= ITEMPRICE:ITEM_NO
	ABL:MASTER:技巧 -= 1
	RESTART
ENDIF
IF ITEM_NO == 70
	CALL CHOICE("要购买【元气之药】吗？", "是的", "不要")
	SIF RESULT
		RESTART
	PRINTL 对谁使用？
	PRINTL [-1] - 返回
	FOR LOOP_CHR, 0, CHARANUM
		IF BASE:LOOP_CHR:0 < MAXBASE:LOOP_CHR:0
			PRINTFORM [{LOOP_CHR,3}] - %CALLNAME:(LOOP_CHR)%
			CALL PRINT_BASE("体力",LOOP_CHR,0,32)
			PRINTL
		ENDIF
	NEXT
	$INPUT_LOOP_70
	INPUT
	IF RESULT == -1
		RESTART
	ELSEIF RESULT <= -1 || RESULT >= CHARANUM || BASE:RESULT:0 == MAXBASE:RESULT:0
		GOTO INPUT_LOOP_70
	ELSE
		PRINTFORMW %CALLNAME:RESULT%的体力+300
		MONEY -= ITEMPRICE:ITEM_NO
		BASE:RESULT:0 += 300
		SIF BASE:RESULT:0 > MAXBASE:RESULT:0
			BASE:RESULT:0 = MAXBASE:RESULT:0
	ENDIF
	RESTART
ENDIF
IF ITEM_NO == 71
