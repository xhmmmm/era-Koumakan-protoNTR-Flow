	IF RESULT == -1
		RESTART
	ELSEIF RESULT <= -1 || RESULT >= CHARANUM || TALENT:RESULT:2 != 1
		GOTO INPUT_LOOP_71
	ELSE
		PRINTFORMW %CALLNAME:RESULT%成为了扶她
		MONEY -= ITEMPRICE:ITEM_NO
