;可以拥有多个的道具
SELECTCASE ITEM_NO
	CASE 40 TO 60, 91, 92,
		PRINTFORM 要购买%ITEMNAME:ITEM_NO%吗？
		SIF ITEM_NO == 50
			PRINTFORM (剩余{ITEMSALES:ITEM_NO}个)
		PRINTFORML
		PRINTL [0] - 放弃
		PRINT [1] - 1
		PRINT [5] - 5
		PRINT [10] - 10
		PRINT [20] - 20
		PRINT [50] - 50
		PRINT [999] - 最大数量购入
		INPUT
		SIF RESULT <= 0
			RESTART
		SIF RESULT * ITEMPRICE:ITEM_NO > MONEY
			RESULT = MONEY / ITEMPRICE:ITEM_NO
		;限制个数
		IF ITEMSALES:ITEM_NO
			IF RESULT >= ITEMSALES:ITEM_NO
				RESULT = ITEMSALES:ITEM_NO
				ITEMSALES:ITEM_NO = -1
			ELSE
				ITEMSALES:ITEM_NO -= RESULT
			ENDIF
		ELSE
			ITEM:ITEM_NO += RESULT
			IF ITEM:ITEM_NO > 999
				RESULT = 999 - (ITEM:ITEM_NO - RESULT)
				ITEM:ITEM_NO = 999
			ENDIF
		ENDIF
		PRINTFORMW 购入了{RESULT}个%ITEMNAME:ITEM_NO%，花费${RESULT * ITEMPRICE:ITEM_NO}
		MONEY -= RESULT * ITEMPRICE:ITEM_NO
		RESTART
	;单品道具
	CASE 0 TO 39
		PRINTFORML 要购买%ITEMNAME:ITEM_NO%吗？
		PRINTL [0] - 是的  [1] - 不要
		INPUT
		SIF RESULT
			RESTART
		ITEM:ITEM_NO ++
		ITEMSALES:ITEM_NO --
		MONEY -= ITEMPRICE:ITEM_NO
		RESTART
ENDSELECT

@SHOP_商品一览
#DIM LOOP_I

FOR LOOP_I,0,100
	SIF ITEMSTOCK(LOOP_I) == 1
		CONTINUE
	SIF ITEMSTOCK(LOOP_I) == 4
		CONTINUE
	IF ITEMSTOCK(LOOP_I) == 2
		SETCOLOR 颜色_文本_无效
		PRINTFORMLC [{LOOP_I}] %ITEMNAME:LOOP_I% (售罄)
		RESETCOLOR
	ELSEIF ITEMSTOCK(LOOP_I) == 5
		SETCOLOR 颜色_文本_无效
		PRINTFORMLC [{LOOP_I}] %ITEMNAME:LOOP_I%
		RESETCOLOR
	ELSE
		PRINTFORMLC [{LOOP_I}] %ITEMNAME:(LOOP_I)% ${ITEMPRICE:(LOOP_I)}
	ENDIF
NEXT
PRINTL

;条件物品的处理
@SHOP_商品销售
#DIM LOOP_I
#DIM LOOP_CHR
;ITEMSALES = 0 可购买
;ITEMSALES = -1 售罄
;ITEMSALES = -2 封印
;技巧
IF ABL:MASTER:技巧 < 5
	ITEMSALES:63 = 0
ELSE
	ITEMSALES:63 = -2
ENDIF
IF ABL:MASTER:技巧
	ITEMSALES:64 = 0
ELSE
	ITEMSALES:64 = -2
ENDIF

SIF TALENT:MASTER:禁断的知识
	ITEMSALES:62 = -1
SIF TALENT:MASTER:调和知识
	ITEMSALES:61 = -1
SIF TALENT:MASTER:污臭耐性 == 2
	ITEMSALES:60 = -1
SIF FLAG:真实模式 == 0
	ITEMSALES:18 = -2
;結婚
;SIF TALENT:MASTER:恋慕 || TALENT:MASTER:亲爱
;		ITEMSALES:96 =  0
ITEMSALES:96 =  0

;媚药
IF ABL:MASTER:教养 < 1
	ITEMSALES:41 = -2
ELSE
	IF ITEM:41
		ITEMSALES:41 = -1
	ELSE
		ITEMSALES:41 = 0
	ENDIF
ENDIF
;禁断
FOR LOOP_I,70,96
	;卖完了的情况
	SIF ITEMSALES:LOOP_I == -1
		CONTINUE
	ITEMSALES:LOOP_I = -2
	;禁断的知识
	IF (LOOP_I > 70 && LOOP_I < 89) || LOOP_I == 90 || LOOP_I == 95
		SIF TALENT:MASTER:禁断的知识 || (ASSI > 0 && TALENT:ASSI:禁断的知识)
			ITEMSALES:LOOP_I = 0
	;调和知识
	ELSEIF LOOP_I == 70 || LOOP_I == 91 || LOOP_I == 93 || LOOP_I == 94
		SIF TALENT:MASTER:调和知识 || (ASSI > 0 && TALENT:ASSI:调和知识)
			ITEMSALES:LOOP_I = 0
	ENDIF
NEXT
ITEMSALES:92 = 0

