		IF MAXBASE:RESULT:精力 > 0
			MAXBASE:RESULT:精力 = LIMIT(MAXBASE:RESULT:精力,200,1000)
		ELSE
			MAXBASE:RESULT:精力 = 1000
		ENDIF
		IF MAXBASE:RESULT:勃起 > 0
			MAXBASE:RESULT:勃起 = LIMIT(MAXBASE:RESULT:勃起,500,1500)
		ELSE
			MAXBASE:RESULT:勃起 = 1500
