;在第一次进入SHOP的时候进行初始化
@SHOP_初始化
IF FLAG:初始化标志 == 0
	;子供の親をチェック
	FOR LOCAL, 0, CHARANUM
		IF NO:LOCAL == 148 || NO:LOCAL == 149
			;親の子供の数を加算
			;父親が訪問者なら訪問者用の人数フラグ処理
			IF (CFLAG:LOCAL:73) >= CHARANUM
				FLAG:訪問者の子供の数 ++
			ELSE
				CFLAG:(CFLAG:LOCAL:73):85 ++
			ENDIF
			CFLAG:(CFLAG:LOCAL:74):85 ++

			;子供が両親にとっての何人目の子供かを設定
			IF (CFLAG:LOCAL:73) >= CHARANUM
				CFLAG:LOCAL:父親の子番号 = FLAG:訪問者の子供の数
			ELSE
				CFLAG:LOCAL:父親の子番号 = CFLAG:(CFLAG:LOCAL:73):85
			ENDIF
			CFLAG:LOCAL:母親の子番号 = CFLAG:(CFLAG:LOCAL:74):85

			;このパッチをつけるまでに里子に出した子は含まれない
		ENDIF
	NEXT
	FLAG:初始化标志 = 1
ENDIF

IF FLAG:初始化标志 <= 1

	FOR LOCAL, 0, CHARANUM
		;妊娠してない且つ診療所にいるなら開始位置に戻す
		IF LOCAL != MASTER && !TALENT:LOCAL:妊娠 && CFLAG:LOCAL:当前位置 == 950
			CFLAG:LOCAL:当前位置 = CFLAG:LOCAL:311
		ENDIF
	NEXT
	FLAG:初始化标志 = 2
ENDIF

IF FLAG:初始化标志 <= 2
	;生理周期ランダム設定
	FOR LOCAL, 0, CHARANUM
		;男(ふたなり以外)はスキップ
		SIF TALENT:LOCAL:性别 == 2
			CONTINUE
		CFLAG:LOCAL:生理周期 = RAND:10
	NEXT
	FLAG:初始化标志 = 3
ENDIF

IF FLAG:初始化标志 <= 3
	;子宫内体积設定(男も一応含む)
	FOR LOCAL, 0, CHARANUM
		CALL 子宫内体积設定(LOCAL)
	NEXT
	FLAG:初始化标志  = 4
ENDIF

IF FLAG:初始化标志 <= 4
	;相性０を１００にする
	FOR LOCAL, 0, CHARANUM
		FOR LOCAL:1, 0, CHARANUM
			SIF RELATION:LOCAL:(LOCAL:1) == 0
				RELATION:LOCAL:(LOCAL:1) = 100
		NEXT
	NEXT
	;子供の相性再設定
	FOR LOCAL, 0, CHARANUM
		SIF NO:LOCAL == 148 || NO:LOCAL == 149
			CALL 子供相性設定, LOCAL
	NEXT
	SETCOLOR 200, 200, 0
	PRINTL -生理～出産まわりパッチ初期処理完了-
	RESETCOLOR
	FLAG:初始化标志  = 5
ENDIF
IF FLAG:初始化标志 <= 5
	CALL 日期_日期初始化
	FLAG:初始化标志  = 6
ENDIF
IF FLAG:初始化标志 <= 6
	CALL 服装_初始化_角色睡衣自定义
	FOR LOCAL, 11, CHARANUM
		IF NO:LOCAL == 148
			IF CFLAG:LOCAL:成長度 >= 成長度_成長期
				CFLAG:LOCAL:寝間着 = RAND:8
			ELSEIF CFLAG:LOCAL:成長度 == 成長度_幼児
				CFLAG:LOCAL:寝間着 = 5
			ENDIF
		ELSE
			IF CFLAG:LOCAL:成長度 >= 成長度_成長期
				CFLAG:LOCAL:寝間着 = RAND:11
			ELSEIF CFLAG:LOCAL:成長度 == 成長度_幼児
				CFLAG:LOCAL:寝間着 = 5
			ENDIF
		ENDIF
	NEXT
	FLAG:初始化标志  = 7
ENDIF
IF FLAG:初始化标志 <= 7
	CALL 気温耐性取得
	FLAG:初始化标志  = 8
ENDIF
IF FLAG:初始化标志 <= 8
	FOR LOCAL,0,CHARANUM
		CALL 体詳細初期設定(LOCAL)
	NEXT
	CALL 体詳細設定１
	;既に子供がいる場合の処理
	IF CHARANUM > 开局角色数量
		FOR LOCAL, 开局角色数量, CHARANUM
			;対象が多生児の場合、既に同じ日に生まれた兄弟の情報を取得していると多生児用の処理へ
			IF CFLAG:LOCAL:多生児兄弟フラグ && CFLAG:LOCAL:多生児兄弟フラグ == CFLAG:(LOCAL-1):多生児兄弟フラグ
				CALL 体設定_遺伝(LOCAL, CFLAG:LOCAL:父親, CFLAG:LOCAL:母親, 1, LOCAL-1)
			ELSE
				CALL 体設定_遺伝(LOCAL, CFLAG:LOCAL:父親, CFLAG:LOCAL:母親, 0, 0)
			ENDIF
			IF CFLAG:LOCAL:成長度
				CALL 体設定_子供髪変更(LOCAL)
				CFLAG:LOCAL:髪の長さ = (100 * CFLAG:LOCAL:髪の長さ指定)
			ENDIF
		NEXT
	ENDIF
	FLAG:初始化标志  = 9
ENDIF
IF FLAG:初始化标志 <= 9
	CALL 服装_初始化_角色服装自定义
	FLAG:初始化标志 = 10
ENDIF
IF FLAG:初始化标志 <= 10
	;既に子供がいる場合の処理
	IF CHARANUM > 开局角色数量
		FOR LOCAL, 开局角色数量, CHARANUM
			;血統を受け継ぐ
			SIF CFLAG:LOCAL:父親 == 人物_訪問者 || TALENT:(CFLAG:LOCAL:父親):访问者的血统 || TALENT:(CFLAG:LOCAL:母親):访问者的血统
				TALENT:LOCAL:访问者的血统 = 1
		NEXT
	ENDIF
	FLAG:初始化标志 = 11
ENDIF

IF FLAG:初始化标志 <= 13
	;子供の強制移动
	FOR LOCAL, 开局角色数量, CHARANUM
		;成人以外はスキップ
		SIF CFLAG:LOCAL:成長度 != 成長度_成人
			CONTINUE
		;訪問していない子供の位置を変更
		SIF CFLAG:LOCAL:子供訪問フラグ >= 0
			CFLAG:LOCAL:当前位置 = 位置_里の住処
	NEXT
	FLAG:初始化标志 = 14
ENDIF
IF FLAG:初始化标志 <= 14
	FOR LOCAL, 1, 开局角色数量
		; 口上パターンが 0 であればキャラ番号に設定
		SIF CFLAG:LOCAL:297 == 0
			CFLAG:LOCAL:297 = LOCAL
	NEXT
	FLAG:初始化标志 = 15
ENDIF
IF FLAG:初始化标志 <= 15
	;子供が先天的人妻だったら解除
	;恋慕なしで人妻持ちだったら解除とします。
	FOR LOCAL, 开局角色数量, CHARANUM
		IF !TALENT:LOCAL:恋慕 && TALENT:LOCAL:人妻
			TALENT:LOCAL:人妻 = 0
		ENDIF
	NEXT
	FLAG:初始化标志 = 16
ENDIF

