;-------------------------------------------------------------------------------
;蕾米莉亚
@CHARA_MOVEMENT_ACTIVETIME_5(住人)
#DIM 住人

;6時〜18時は寝てる。ちょっと寝過ぎ。
RETURN (TIME > 360 && TIME < 1080) || CFLAG:住人:衰弱

;-------------------------------------------------------------------------------
