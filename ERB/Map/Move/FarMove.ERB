;=================================================
; FARMOVE — 远距离路径计算（BFS广度优先搜索）
;
; 原理：从当前位置出发，逐层搜索所有可达位置，
;       直到找到最终目的地，然后回溯构建路径。
;
; 替代了原来的逆向贪心算法
; BFS 自动处理：最短路径、环路、死胡同、多路径选择
;
; @param 角色      角色编号
; @param 当前位置  出发位置（0以下则用角色的開始位置）
; @param 最终目的地 目标位置
; @return 无（将路径写入 移动路线:角色:0~路径上限-1）
;=================================================
@FARMOVE(角色, 当前位置, 最终目的地)
#FUNCTION
#DIM 角色
#DIM 当前位置
#DIM 最终目的地
; BFS 工作变量
#DIM 前驱, 1000
#DIM 队列, 1000
#DIM 队头
#DIM 队尾
#DIM 当前节点
#DIM 邻居数
#DIM 邻居
; 路径构建变量
#DIM 路径长度
#DIM 临时路线, 50
#DIM 路线循环

IF 当前位置 <= 0
	当前位置 = CFLAG:角色:開始位置
ENDIF

; 重置路线（不清除移动目的）
CALLF RESET_ROUTE(角色, 0)

; 起点=终点，无需移动
IF 当前位置 == 最终目的地
	IF FLAG:DEBUG模式
		PRINTFORML [FARMOVE] %CALLNAME:角色% 已在%GetPlaceName(当前位置)%，无需移动
	ENDIF
	RETURNF
ENDIF

; 直达检查
IF CAN_MOVE(当前位置, 最终目的地)
	移动路线:角色:0 = 最终目的地
	IF FLAG:DEBUG模式
		PRINTFORML [FARMOVE] %CALLNAME:角色% %GetPlaceName(当前位置)%→%GetPlaceName(最终目的地)% 直达
	ENDIF
	RETURNF
ENDIF

;=============================================
; BFS 主循环
;=============================================
VARSET 前驱, -1
VARSET 队列
队头 = 0
队尾 = 0

; 起点
前驱:当前位置 = 当前位置
队列:队尾 = 当前位置
队尾 ++

WHILE 队头 < 队尾
	当前节点 = 队列:队头
	队头 ++

	; 遍历当前节点的所有邻居
	邻居数 = DB:当前节点:0
	FOR 路线循环, 1, 邻居数 + 1
		邻居 = DB:当前节点:路线循环

		; 跳过已访问的节点
		SIF 前驱:邻居 != -1
			CONTINUE

		; 记录前驱
		前驱:邻居 = 当前节点

		; 找到目的地
		IF 邻居 == 最终目的地
			GOTO BFS_FOUND
		ENDIF

		; 加入队列
		队列:队尾 = 邻居
		队尾 ++
	NEXT
WEND

; 未找到路径
THROW BFS未找到路径: 角色={角色} 从={当前位置} 到={最终目的地}

$BFS_FOUND
;=============================================
; 从目的地回溯到出发地，构建正向路径
;=============================================
VARSET 临时路线
路径长度 = 0
当前节点 = 最终目的地

WHILE 当前节点 != 当前位置
	临时路线:路径长度 = 当前节点
	路径长度 ++
	当前节点 = 前驱:当前节点
WEND

; 写入移动路线（反转为正向：从近到远）
FOR 路线循环, 0, 路径长度
	移动路线:角色:路线循环 = 临时路线:(路径长度 - 1 - 路线循环)
NEXT

; DEBUG输出路径
IF FLAG:DEBUG模式
	PRINTFORM [FARMOVE] %CALLNAME:角色% %GetPlaceName(当前位置)%→%GetPlaceName(最终目的地)% {路径长度}步: 
	FOR 路线循环, 0, 路径长度
		PRINTFORM %GetPlaceName(临时路线:(路径长度 - 1 - 路线循环))%
		SIF 路线循环 < 路径长度 - 1
			PRINT →
	NEXT
	PRINTL
ENDIF

RETURNF

;=================================================
; RESET_ROUTE — 重置移动路线
;
; @param 角色      角色编号
; @param 目的消去  1=同时清除移动目的, 0=保留
;=================================================
@RESET_ROUTE(角色, 目的消去)
#FUNCTION
#DIM 角色
#DIM 目的消去
#DIM 路线循环

FOR 路线循环, 0, 路径上限
	移动路线:角色:路线循环 = 0
NEXT

IF 目的消去 && CFLAG:角色:移动目的
	CFLAG:角色:移动目的 = 0
ENDIF
RETURNF
