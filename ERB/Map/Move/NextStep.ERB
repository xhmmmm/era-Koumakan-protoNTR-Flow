;=================================================
; NEXT_STEP — BFS计算从出发地到目的地的第一步
;
; 与 FARMOVE 不同，此函数不写入移动路线数组，
; 仅返回路径的第一步。用于需要知道"往哪走"但
; 不需要完整路径的场景（如访问者移动辅助）。
;
; @param 出发地   当前位置
; @param 目的地   目标位置
; @return 第一步应该到达的位置编号，-1=不可达
;=================================================
@NEXT_STEP(出发地, 目的地)
#FUNCTION
#DIM 出发地
#DIM 目的地
#DIM 前驱, 1000
#DIM 队列, 1000
#DIM 队头
#DIM 队尾
#DIM 当前节点
#DIM 邻居数
#DIM 邻居
#DIM 邻居循环

; 直达
IF CAN_MOVE(出发地, 目的地)
	RETURNF 目的地
ENDIF

; BFS
VARSET 前驱, -1
VARSET 队列
队头 = 0
队尾 = 0
前驱:出发地 = 出发地
队列:队尾 = 出发地
队尾 ++

WHILE 队头 < 队尾
	当前节点 = 队列:队头
	队头 ++
	邻居数 = DB:当前节点:0
	FOR 邻居循环, 1, 邻居数 + 1
		邻居 = DB:当前节点:邻居循环
		SIF 前驱:邻居 != -1
			CONTINUE
		前驱:邻居 = 当前节点
		IF 邻居 == 目的地
			GOTO NEXT_STEP_FOUND
		ENDIF
		队列:队尾 = 邻居
		队尾 ++
	NEXT
WEND
RETURNF -1

$NEXT_STEP_FOUND
; 回溯到出发地的直接邻居，那就是第一步
当前节点 = 目的地
WHILE 前驱:当前节点 != 出发地
	当前节点 = 前驱:当前节点
WEND
RETURNF 当前节点
