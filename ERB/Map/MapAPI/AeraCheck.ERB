;=================================================
; 区域判定与地图位置查询
;
; 数据来源：DC数组（由 INIT_MAP_DATA 初始化）
;=================================================

;=================================================
; 位置所在区域
;
; @param 位置编号
; @return 区域编号（区域_红魔馆=1, 区域_雾之湖=2, 区域_魔法之森=3, 0=未知）
;=================================================
@位置所在区域(位置编号)
#FUNCTION
#DIM 位置编号
SIF 位置编号 < 0 || 位置编号 >= 1000
	RETURNF 0
RETURNF DC:位置编号:1

;=================================================
; 地图位置 — 返回位置所属的地图编号（用于渲染）
;
; @param 位置编号
; @return 地图编号（0=红魔馆1F, 1=红魔馆2F/3F, 2=雾之湖西北, 3=雾之湖西南/魔法森林）
;=================================================
@地图位置(位置编号)
#FUNCTION
#DIM 位置编号
SIF 位置编号 < 0 || 位置编号 >= 1000
	RETURNF 0
RETURNF DC:位置编号:2

;=================================================
; 位置所属领域
;
; @param 位置编号
; @return 领域编号（0=未知）
;=================================================
@位置所属领域(位置编号)
#FUNCTION
#DIM 位置编号
SIF 位置编号 < 0 || 位置编号 >= 1000
	RETURNF 0
RETURNF DC:位置编号:0

;=================================================
; 旧版遗留：位于红魔馆内返回0，否则返回1
;=================================================
@MAP_DISTINCTION(ARG)
#FUNCTION
SIF 位置所在区域(ARG) == 区域_红魔馆
	RETURNF 0
RETURNF 1
