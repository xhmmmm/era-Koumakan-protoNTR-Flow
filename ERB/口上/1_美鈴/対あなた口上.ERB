@KOJO_MESSAGE_COM_K1_312_1
;唇の汚れで拒否された時
IF TFLAG:193 == -2
	PRINTFORML 「不、不行啊！！」
	PRINTFORML 不明白原因地在嘴唇碰触之前被拒绝了。
	PRINTFORML 「呀…是了…可以给我一杯茶吗？」
	PRINTFORML %CALLNAME:TARGET%好像想喝茶。
	;失敗時
ELSEIF TFLAG:193 == -1
	PRINTDATAL
		DATAFORM 「什、为什么突然？」
		DATAFORM 「呀！！」
		DATAFORM 「晚一点！」
	ENDDATA
	PRINTFORML 被拒绝了，在嘴唇碰触之前被阻止。
	;成功時
ELSE
	IF NTR_CHK_FAVORABLY(TARGET, FAV_寝取られ)
		;唇が精液で汚れていたとき
		IF CFLAG:射精者M != 0 && STAIN:口 & 汚れ_精液
			PRINTFORML 和%CALLNAME:TARGET%的吻%CALLNAME:MASTER%对她唾液的味道感到違和感。
			PRINTFORML 「・・呼呼・・很刺激的味道呢・・・」
			;好意度低いと冷たい
		ELSE
			PRINTFORML 「・・不行・・・恩・・・」
		ENDIF
	ELSEIF NTR_CHK_FAVORABLY(TARGET, FAV_寝取られ寸前)
		PRINTDATAL
			DATAFORM 「嗯・・啾・・」
			DATAFORM 「嗯啾・・啾・・」
			DATAFORM 「嗯……恩……啾啵……」
		ENDDATA
		PRINTFORML （・・果然・・不够・・・）
	ELSEIF NTR_CHK_FAVORABLY(TARGET, FAV_寝取られそう)
		IF ABL:欲望 >= 5
			PRINTDATAL
				DATAFORM 「嗯哼……啾……啾……」
				DATAFORM 「啾・・啾・・啾啵・・」
				DATAFORM 「嗯・・舔噜・・舔噜っ・・」
			ENDDATA
		ELSE
			PRINTDATAL
				DATAFORM 「嗯・・啾啵・・」
				DATAFORM 「嗯啾・・啾・・」
				DATAFORM 「嗯……恩……啾啵……」
			ENDDATA
		ENDIF
		PRINTFORML （・・不能比较・・・不能比较・・・但是・・）
	ELSEIF ABL:欲望 >= 5
		;互相激烈地
		PRINTDATAL
			DATAFORM 「嗯哼……啾……啾……」
			DATAFORM 「啾・・啾・・啾啵・・」
			DATAFORM 「嗯・・舔噜・・舔噜っ・・」
		ENDDATA
		PRINTDATAL
			DATAFORM 互相吞噬着嘴唇和舌头，品尝着那味道。
			DATAFORM 像吸吮着柔软的舌头一样品味，吞下纯净的露水。
			DATAFORM %CALLNAME:TARGET%把唾液从舌头输进嘴里的时候，白色的咽喉发出了咕噜咕噜的声音。
		ENDDATA
		PRINTDATAL
			DATAFORM 「呵呵…就这些吗？」
			DATAFORM 「嗯……再给我一点也没关系吧？」
			DATAFORM 「呵呵・・太棒了・・・」
		ENDDATA
	ELSEIF ABL:亲密 >= 5
		;親しく求め合うように
		PRINTDATAL
			DATAFORM 「嗯・・啾・・」
			DATAFORM 「嗯啾・・啾・・」
			DATAFORM 「嗯……恩……啾啵……」
		ENDDATA
		PRINTDATAL
			DATAFORM 互相靠近嘴唇，享受着柔软的味道。
			DATAFORM 以相互依偎的姿势交换了嘴唇。
			DATAFORM 放开了嘴唇、似乎在期待着继续的%CALLNAME:TARGET%染红脸颊。
		ENDDATA
	ELSE
		;不意打ちで
		PRINTFORML 「んっ・・！？」
		PRINTDATAL
			DATAFORM 被突然袭击，嘴唇被夺走的%CALLNAME:TARGET%睁圆了眼睛。
			DATAFORM 嘴唇被重叠，%CALLNAME:TARGET%一瞬间身体变硬了。
			DATAFORM 放开了嘴唇、%CALLNAME:TARGET%一口气平静下来。
		ENDDATA
		PRINTDATAL
			DATAFORM 「··被拿了一勝呢。疏忽大意了」
			DATAFORM 「・・對我没关系，但是请不要对大小姐做失礼的事情」
			DATAFORM 「・・下次我会避开给你看」
		ENDDATA
	ENDIF
ENDIF
RETURN 1


;==================================================
;汎用処理
;==================================================
;-------------------------------------------
;美鈴が他の人を呼ぶときの例外処理関数
;-------------------------------------------
@CALLNAME_K1(角色, 対象)
#FUNCTIONS
#DIM 角色
#DIM 対象
#DIMS 呼称

呼称 = %CALLNAME:対象%さん
IF CALLNAME:角色 == "美鈴"
	IF CALLNAME:対象 == "蕾米莉亚"
		呼称 = 蕾米莉亚お嬢様
	ELSEIF CALLNAME:対象 == "フラン" || CALLNAME:対象 == "芙兰朵露"
		呼称 = 芙兰朵露お嬢様
	ELSEIF CALLNAME:対象 == "パチュリー"
		呼称 = パチュリー様
	ELSE
	ENDIF
ELSE
	; 名称変更時はデフォルトのまま
ENDIF
RETURNF 呼称
