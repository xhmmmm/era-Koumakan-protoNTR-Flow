;カウンター：乳搾り手コキ
;==================================================
;たしかふたなりの時はこないはず（弱気
@KOJO_MESSAGE_COUNTER_K1_29_0
PRINTFORML 「那个，请面向后面，手贴着墙壁」
RETURN 1

@KOJO_MESSAGE_COUNTER_K1_29_1
#DIM 角色
角色 = 人物_美铃
IF CFLAG:PLAYER:跳蛋A挿入 != 0
	;あなたが菊花に跳蛋挿入時分岐
	PRINTFORML %CALLNAME:角色%一邊向%CALLNAME:PLAYER%的菊穴插入了振動棒,一邊微笑了。
	IF CFLAG:PLAYER:跳蛋挿入者 == 角色
		PRINTFORML 「啊……按您吩咐的做了吧」
	ELSE
		PRINTFORML 「啊……我不知道这是谁说的，刚刚好。」
	ENDIF
	PRINTL
ELSEIF EQUIP:PLAYER:下半身下着１ == 0 && EQUIP:PLAYER:下半身下着２ == 0
	;あなたがノーパンの時分岐
	PRINTFORML %CALLNAME:角色%注意到%CALLNAME:PLAYER%内衣没穿的时候微笑了。
	PRINTFORML 「啊……哈哈，刚刚好。」
	PRINTL
ENDIF
RETURN 1

@KOJO_MESSAGE_COUNTER_K1_29_2
IF CFLAG:PLAYER:跳蛋A挿入 != 0
	PRINTFORML 「好快啊…这个振動棒很有效吧？」
ELSE
	PRINTFORML 「好早啊・・我觉得还是稍微忍耐一下比较好哦？」
ENDIF
RETURN 1

@KOJO_MESSAGE_COUNTER_K1_29_3
SELECTCASE BASE:PLAYER:精力
	CASE IS == 0
		;全部搾り取った
		PRINTFORML 「已经结束了吗？嘛，這蛋蛋看起來好像很疼呢,明天见。」
	CASE IS < MAXBASE:PLAYER:精力 /2
		;大半搾り取った
		PRINTFORML 「出来很多了。但是好像还有时间呢？」
	CASEELSE
		;少し搾り取った
		PRINTFORML 「出来很多啊。但是看起来还很健康，继续吧？」
ENDSELECT
RETURN 1

