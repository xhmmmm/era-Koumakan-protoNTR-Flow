;==================================================
;会话拡張：结婚戒指について
;　前提：恋慕かつ人妻
;==================================================
@KOJO_MESSAGE_COM_K1_300_14_01(角色, 調教者)
#DIM 調教者
#DIM 角色
IF TALENT:角色:NTR
	;チョーカーが優先
	PRINTFORML %"もう"+CALLNAME:MASTER+"のものではないのだから指輪をする必要は無いと言い切られた。"%
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
	;装着率３割
	IF TALENT:角色:浮気公認
		PRINTDATAL
			DATAFORM 「ええ、指輪は着けないようにしているんです」
			DATAFORM 「指輪ですか？最近は着けてない方が多いですね」
			DATAFORM 「指輪なら外してきました」
		ENDDATA
		PRINTDATAL
			DATAFORM 「だって、そのほうがあの人がお喜びになられますから」
			DATAFORM 「デートに誘われたとき、结婚戒指なんて着けていたら無粋じゃないですか？」
			DATAFORM 「浮気して欲しいと言ったのは%CALLNAME:MASTER%ですよね？」
		ENDDATA
		PRINTFORML 最近は指輪を外しているのだと言われてしまった。
	ELSE
		PRINTFORML %"指に合わない感じがして、最近はあまり指輪をしないのだと言い返された。"%
	ENDIF
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
	;装着率５割
	IF TALENT:角色:浮気公認
		PRINTDATAL
			DATAFORM 「ごめんなさい、今日は着けていないんです」
			DATAFORM 「たまたまですよ」
			DATAFORM 「指輪なら部屋ですね」
		ENDDATA
		PRINTDATAL
			DATAFORM 「こう、拳を握ったときの感覚が違うんですよ」
			DATAFORM 「もっとこう、武器になるような指輪の方がいいですかねぇ？」
			DATAFORM 「でも、浮気して欲しいと言ったのは%CALLNAME:MASTER%ですよね？」
		ENDDATA
		PRINTFORML 今日は敢えて指輪を外しているのだと言われてしまった。
	ELSE
		PRINTFORML %"拳を握った時の感覚が違うので外している事が多いのだと言い訳された。"%
	ENDIF
	;ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
ELSE
	;装着率９割
	IF TALENT:角色:浮気公認
		PRINTDATAL
			DATAFORM 「あっはっは、ごめんなさい、忘れてました」
			DATAFORM 「いけないいけない、うっかりしてました」
			DATAFORM 「あ～、たぶん部屋です」
		ENDDATA
		PRINTDATAL
			DATAFORM 「たまたまですよ、たまたま」
			DATAFORM 「今朝寝坊して慌てていたから、つい」
			DATAFORM 「明日はわすれず着けますから」
		ENDDATA
		PRINTFORML 今日はたまたま指輪を外していたのだと謝られた。
	ELSE
		PRINTFORML %"拳を握った時の感覚が違うので外している事が多いのだと言い訳された。"%
	ENDIF
ENDIF

RETURN 1

