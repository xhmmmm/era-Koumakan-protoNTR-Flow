;==================================================
;与访问者对话
;==================================================
;主人（MASTER）不在场
@NTR_KOJO_K8_1(角色)
#DIM 角色
;大浴场
IF CFLAG:角色:当前位置 == 位置_红魔馆_大浴场
	IF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
		PRINTDATAL
			DATAFORM 「嗯っ・・嗯・・」
			DATAFORM 「啊・・那里っ・・」
			DATAFORM 「嗯っ・・色情」
		ENDDATA
		PRINTFORML 被%NTR_NAME(0)%洗身体的手摸弄着股间，%CALLNAME:角色%漏出了甜美的声音。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
		PRINTDATAL
			DATAFORM 「嗯っ・・好痒・・」
			DATAFORM 「呀哈哈哈っ」
			DATAFORM 「呀啊っ、不要挠痒痒啦」
		ENDDATA
		PRINTFORML 被%NTR_NAME(0)%洗身体的手挠着腋下，%CALLNAME:角色%发出了可爱的声音。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)
		PRINTDATAL
			DATAFORM 「诶？要帮我洗头发吗？」
			DATAFORM 「诶？我自己会洗的哦？」
			DATAFORM 「翘起来的地方我也能弄好的哦」
		ENDDATA
		IF IS_NTR_SOFT()
			PRINTFORML %CALLNAME:角色%在%NTR_NAME(0)%视线的注视下，用幼小的裸身在洗身处洗着身体。
		ELSE
			PRINTFORML %CALLNAME:角色%在%NTR_NAME(0)%仿佛舔舐般的视线注视下，用幼小的裸身在洗身处洗着身体。
		ENDIF
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_体を触らせる程度)
		PRINTFORML 「・・・」
		PRINTFORML %CALLNAME:角色%被%NTR_NAME(0)%盯着看，似乎很不愉快。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_接吻程度)
		PRINTFORML %CALLNAME:角色%似乎并不在意%NTR_NAME(0)%的视线。
	ELSE
		PRINTFORML %CALLNAME:角色%似乎并不在意%NTR_NAME(0)%的视线。
	ENDIF
	;其他
ELSE
	IF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
		PRINTDATAL
			DATAFORM 「那很好啊！下次本小姐也一起！」
			DATAFORM 「告诉你一件超厉害的事。要保密哦？」
			DATAFORM 「之前那个，好有趣呢！」
		ENDDATA
		PRINTFORML %CALLNAME:角色%高兴地聊着天。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
		PRINTDATAL
			DATAFORM 「是这样啊！」
			DATAFORM 「啊哈哈っ，刚才那个好有趣！」
			DATAFORM 「呐呐你知道吗？ 之前啊・・」
		ENDDATA
		PRINTFORML %CALLNAME:角色%开心地聊着天。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)
		PRINTDATAL
			DATAFORM 「是这样啊！」
			DATAFORM 「啊哈哈っ，刚才那个好有趣！」
			DATAFORM 「骗人？ 那种事我都没听说过！」
		ENDDATA
		PRINTFORML %CALLNAME:角色%正常地聊着天。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_体を触らせる程度)
		PRINTDATAL
			DATAFORM 「诶～，是这样吗？」
			DATAFORM 「那是真的吗？」
			DATAFORM 「还有那种事啊？」
		ENDDATA
		PRINTFORML %CALLNAME:角色%似乎对%NTR_NAME(0)%的话题产生了兴趣。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_接吻程度)
		PRINTDATAL
			DATAFORM 「哼～，好无聊」
			DATAFORM 「这样啊」
			DATAFORM 「啊，蜻蜓！」
		ENDDATA
		PRINTFORML %CALLNAME:角色%似乎没什么兴趣。
	ELSE
		PRINTDATAL
			DATAFORM 「哼～，好无聊」
			DATAFORM 「这样啊」
			DATAFORM 「啊，蜻蜓！」
		ENDDATA
		PRINTFORML %CALLNAME:角色%似乎没什么兴趣。
	ENDIF
ENDIF
RETURN 0

;玩家在场
@NTR_KOJO_KW8_1(角色)
#DIM 角色
;大浴场
IF CFLAG:角色:当前位置 == 位置_红魔馆_大浴场
	IF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
		PRINTDATAL
			DATAFORM 「然后呢～，大酱啊～」
			DATAFORM 「吼啊，然后门卫啊～」
			DATAFORM 「嗯っ，本小姐是最强的！」
		ENDDATA
		PRINTFORML %CALLNAME:角色%坐在%NTR_NAME(0)%的膝上入浴着。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
		PRINTDATAL
			DATAFORM 「然后呢～，大酱啊～」
			DATAFORM 「吼啊，然后门卫啊～」
			DATAFORM 「嗯っ，本小姐是最强的！」
		ENDDATA
		PRINTFORML %CALLNAME:角色%抱着%NTR_NAME(0)%的手臂入浴着。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)
		PRINTDATAL
			DATAFORM 「嗯？ 你们两个怎么了？」
			DATAFORM 「嘿嘿っ，原来是这样啊」
			DATAFORM 「吼啊，没问题！」
		ENDDATA
		PRINTFORML %CALLNAME:角色%坐在%NTR_NAME(0)%和%CALLNAME:MASTER%之间入浴着。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_体を触らせる程度)
		PRINTFORML 「・・・」
		PRINTFORML %CALLNAME:角色%被%NTR_NAME(0)%盯着看不愉快，把%CALLNAME:MASTER%当成了挡箭牌。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_接吻程度)
		PRINTFORML 坐在%CALLNAME:MASTER%旁边的%CALLNAME:角色%似乎并不在意%NTR_NAME(0)%的视线。
	ELSE
		PRINTFORML 坐在%CALLNAME:MASTER%旁边的%CALLNAME:角色%似乎并不在意%NTR_NAME(0)%的视线。
	ENDIF
	;其他
ELSE
	IF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
		PRINTFORML 「啊！那个，本小姐也知道！」
		PRINTFORML %CALLNAME:角色%无视%CALLNAME:MASTER%在和%NTR_NAME(0)%聊天。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
		PRINTFORML 「那个不错呢！」
		PRINTFORML %CALLNAME:角色%在和%NTR_NAME(0)%聊天。仿佛听不见%CALLNAME:MASTER%的声音一样。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)
		PRINTFORML 「那个不错呢，对吧，%CALLNAME:MASTER%？」
		PRINTFORML %CALLNAME:角色%一边和%NTR_NAME(0)%聊天，一边时不时向%CALLNAME:MASTER%寻求赞同。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_体を触らせる程度)
		PRINTFORML %CALLNAME:角色%在和%NTR_NAME(0)%与%CALLNAME:MASTER%交替着聊天。
		PRINTFORML 似乎勉强才能跟上话题。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_接吻程度)
		PRINTFORML %CALLNAME:角色%无视%NTR_NAME(0)%，在和%CALLNAME:MASTER%聊天。
	ELSE
		PRINTFORML %CALLNAME:角色%无视%NTR_NAME(0)%，在和%CALLNAME:MASTER%聊天。
	ENDIF
ENDIF
RETURN 0

;==================================================
;与访问者接吻
;==================================================
;开始
@NTR_KOJO_K8_2_0(角色)
#DIM 角色
IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)

	IF NTR_CHK_PEEP_CONT(角色)
		PRINTFORML 「虽然被看着但没关系吧？ 嗯ふっ・・啾っ・・く啾・・」
		PRINTFORML %CALLNAME:角色%在%CALLNAME:MASTER%视线的尽头与%NTR_NAME(0)%唇齿相依，主动缠绕着舌头。
	ELSE
		PRINTFORML 「嗯っ・・啾っ・・く啾っ、啾っ・・」
		PRINTFORML %CALLNAME:角色%与%NTR_NAME(0)%唇齿相依，主动缠绕着舌头。
	ENDIF

ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)

	IF NTR_CHK_PEEP_CONT(角色)
		PRINTFORML 「虽然被看着但没关系吧？ 嗯ふっ・・啾っ・・く啾・・」
		IF TALENT:角色:恋慕
			PRINTFORM %CALLNAME:角色%对%ANATA_LOVER(角色)%的
		ELSE
			PRINTFORM %CALLNAME:角色%对%CALLNAME:MASTER%的
		ENDIF
		PRINTFORML 视线虽然察觉到了，却仍与%NTR_NAME(0)%唇齿相依，主动缠绕着舌头。
	ELSE
		PRINTFORML 「嗯っ・・啾っ・・く啾っ、啾っ・・」
		PRINTFORML %CALLNAME:角色%与%NTR_NAME(0)%唇齿相依，也接受着他的舌头。
	ENDIF

ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)

	IF NTR_CHK_PEEP_CONT(角色)
		PRINTFORML 「嗯っ・・被看着呢・・嗯嗯っ・・啾・・く啾っ・・」
		IF TALENT:角色:恋慕
			PRINTFORML %CALLNAME:角色%对%ANATA_LOVER(角色)%的
		ELSE
			PRINTFORML %CALLNAME:角色%对%CALLNAME:MASTER%的
		ENDIF
		PRINTFORML 视线虽然察觉到了，却仍与%NTR_NAME(0)%唇齿相依，也接受着他的舌头。
	ELSE
		PRINTFORML 「嗯っ・・啾っ・・く啾っ、啾っ・・」
		PRINTFORML %CALLNAME:角色%与%NTR_NAME(0)%唇齿相依，也接受着他的舌头。
	ENDIF

ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)

	IF NTR_CHK_PEEP_CONT(角色)
		PRINTFORML 「呀んっ・・被看着呢・・嗯嗯っ・・嗯・・」
		IF TALENT:角色:恋慕
			PRINTFORML %CALLNAME:角色%在%ANATA_LOVER(角色)%的
		ELSE
			PRINTFORML %CALLNAME:角色%在%CALLNAME:MASTER%的
		ENDIF
		PRINTFORML 视线的尽头与%NTR_NAME(0)%唇齿相依了。
	ELSE
		PRINTFORML 「嗯っ・・！ 嗯・・」
		PRINTFORML 被%NTR_NAME(0)%夺去双唇的%CALLNAME:角色%惊讶地睁圆了眼睛，脸颊泛红接受了那个吻。
	ENDIF

ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)

	IF NTR_CHK_PEEP_CONT(角色)
		PRINTFORML 「呀っ・・被看着呢・・嗯嗯っ・・嗯・・」
		IF TALENT:角色:恋慕
			PRINTFORML %CALLNAME:角色%在%ANATA_LOVER(角色)%的
		ELSE
			PRINTFORML %CALLNAME:角色%在%CALLNAME:MASTER%的
		ENDIF
		PRINTFORML 视线的尽头被%NTR_NAME(0)%夺去了双唇。
	ELSE
		PRINTFORML 「嗯っ・・！ 嗯・・」
		PRINTFORML 被%NTR_NAME(0)%夺去双唇的%CALLNAME:角色%一瞬间露出了惊讶的表情，但还是接受了他的亲吻。
	ENDIF

ELSE

	IF NTR_CHK_PEEP_CONT(角色)
		PRINTFORML 「呀っ・・不要っ・嗯嗯っ！」
		IF TALENT:角色:恋慕
			PRINTFORML %CALLNAME:角色%在%ANATA_LOVER(角色)%的
		ELSE
			PRINTFORML %CALLNAME:角色%在%CALLNAME:MASTER%的
		ENDIF
		PRINTFORML 视线的尽头被%NTR_NAME(0)%夺去双唇，眼睛翻白不知所措。
	ELSE
		PRINTFORML 「嗯っ・・！ 嗯・・」
		PRINTFORML 被%NTR_NAME(0)%夺去双唇的%CALLNAME:角色%眼睛翻白不知所措。
	ENDIF

ENDIF
RETURN 0

