		;不要用PRINTW比较好
		PRINTFORML
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;TARGET进来了
	;填写检查
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		PRINTFORML
		RETURN 0
	ENDIF
	;其他
	PRINTFORML
ENDIF
RETURN 0

