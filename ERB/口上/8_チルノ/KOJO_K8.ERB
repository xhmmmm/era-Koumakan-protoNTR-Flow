	PRINTFORML 快乐的时光流逝着…
ELSEIF TFLAG:193 == -1
	PRINTFORML 话一停下来就弥漫了尴尬的气氛…
	RETURN RESULT
ENDIF
PRINTFORML
CALL KOJO_MESSAGE_COM_K8_300_1
RETURN RESULT
