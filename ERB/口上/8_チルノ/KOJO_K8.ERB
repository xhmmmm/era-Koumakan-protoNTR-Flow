@KOJO_EVENT_K8_0(ARG,ARG:1)
;口上主是TARGET
;--------------------------------------------------
LOCAL = 1
IF LOCAL
	;-------------------------------------------------
	;小分支
	;-------------------------------------------------
	;就目击情事一事进行追问
	;填写检查
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		PRINTFORML
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;MASTER进来了
	;填写检查
	LOCAL:1 = 1
	;-------------------------------------------------
