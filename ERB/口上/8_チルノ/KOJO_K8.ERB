;==================================================
;晚安口上
;==================================================
@KOJO_EVENT_K8_7(ARG,ARG:1)
;口上主是TARGET
;--------------------------------------------------
LOCAL = 1
IF LOCAL
	;-------------------------------------------------
	;小分支
	;-------------------------------------------------
	;正在睡觉
	;填写检查
	LOCAL:1 = 1
	;-------------------------------------------------
	IF CFLAG:睡眠
		IF LOCAL:1 && ARG == 2
			PRINTFORMW 「本小姐…是最强的…。」
			PRINTFORMW 不知道她在做什么梦呢？
		ENDIF
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;困了所以回房间了
	;填写检查
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 0
		PRINTFORMW 「呼唔…好困，先回去了啦…。」
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;要睡觉了所以把%CALLNAME:MASTER%赶出去了
	;填写检查
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		PRINTFORMW 「本小姐要睡了，明天见啦…。」
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;在%CALLNAME:MASTER%面前睡着了
	;填写检查
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		PRINTFORMW 「呼ぁ…好困…呼…。」
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;在%CALLNAME:MASTER%面前睡着了所以搬到床上去
	;填写检查
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		PRINTFORMW 「本小姐…好困哟…%CALLNAME:MASTER%…。」
		PRINTFORMW %CALLNAME:MASTER%把睡着的%CALLNAME:人物_琪露诺%搬回了家…。
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;在%CALLNAME:MASTER%的房间睡着了所以就这样晚安
	;填写检查
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 4
		PRINTFORMW %CALLNAME:MASTER%给睡着的%CALLNAME:人物_琪露诺%盖上了被子。
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;%CALLNAME:MASTER%睡着了所以搬过去
	;填写检查
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 5
		PRINTFORMW 「呜、呜咕，搬不动%CALLNAME:MASTER%还算什么最强啊！」
		RETURN 0
	ENDIF
	;其他
	PRINTFORMW
ENDIF
RETURN 0

