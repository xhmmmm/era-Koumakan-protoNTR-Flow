;唔呵呵反击
;-------------------------------------------------
;还没有

;-------------------------------------------------
;角色高潮时的口上
;NOWEX:Ｃ绝顶～3 CVAB絶頂
;NOWEX:二重绝顶 二重绝顶
;NOWEX:三重绝顶 三重绝顶
;NOWEX:四重绝顶 四重绝顶
;NOWEX:喷乳 喷乳
;NOWEX:射精 射精
;请随意组合使用
;-------------------------------------------------
@KOJO_MESSAGE_PALAMCNG_B_K8
CALL PALAM_MESSAGE_B
;-------------------------------------------------
;喷乳
;填写检查（=0, 不显示，1, 显示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL && NOWEX:喷乳
	PRINTFORMW 
ENDIF
;-------------------------------------------------
;射精
;填写检查（=0, 不显示，1, 显示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL && NOWEX:射精
	PRINTFORMW 
ENDIF
;-------------------------------------------------
;絶頂
;填写检查（=0, 不显示，1, 显示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;四重绝顶
	;填写检查（=0, 不显示，1, 显示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF NOWEX:四重绝顶
		PRINTFORMW 「…！」
		PRINTFORMW 快感流遍全身，%CALLNAME:人物_琪露诺%在朦胧的意识中品味着最高潮。
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;三重绝顶
	;填写检查（=0, 不显示，1, 显示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF NOWEX:三重绝顶
		SELECTCASE NOWEX:三重绝顶
				;Ｃ＆Ｖ＆Ａ绝顶
			CASE 1
				PRINTFORMW 
				RETURN 0
				;Ｂ＆Ｖ＆Ａ绝顶
			CASE 2
				PRINTFORMW 
				RETURN 0
				;Ｃ＆Ｂ＆Ａ绝顶
			CASE 3
				PRINTFORMW 
				RETURN 0
				;Ｃ＆Ｖ＆Ｂ绝顶
			CASE 4
				PRINTFORMW 
				RETURN 0
		ENDSELECT
	ENDIF
	;-------------------------------------------------
	;二重绝顶
	;填写检查（=0, 不显示，1, 显示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF NOWEX:二重绝顶
		SELECTCASE NOWEX:二重绝顶
				;Ｃ＆Ｖ绝顶
			CASE 1
				PRINTFORMW 
				RETURN 0
				;Ｃ＆Ａ绝顶
			CASE 2
				PRINTFORMW 
				RETURN 0
				;Ｖ＆Ａ绝顶
			CASE 3
				PRINTFORMW 
				RETURN 0
				;Ｃ＆Ｂ绝顶
			CASE 4
				PRINTFORMW 
				RETURN 0
				;Ｖ＆Ｂ绝顶
			CASE 5
				PRINTFORMW 
				RETURN 0
				;Ａ＆Ｂ绝顶
			CASE 6
				PRINTFORMW 
				RETURN 0
		ENDSELECT
	ENDIF
	IF NOWEX:Ｃ绝顶
		;強絶頂Ｃ
		IF NOWEX:Ｃ绝顶 == 2
			PRINTFORMW 「嗯呜呜！豆豆，好热，本小姐要怪怪的・・・！」
			;絶頂Ｃ
		ELSE
			PRINTFORMW 「哈啊呜呜・・・脑袋变得轻飘飘的・・・。」
		ENDIF
	ENDIF
	IF NOWEX:Ｖ绝顶
		;強絶頂Ｖ
		IF NOWEX:Ｖ绝顶 == 2
			PRINTFORMW 「嗯、嗯嗯嗯！？肚子下面，抖了一下…！」
			;絶頂Ｖ
		ELSE
			PRINTFORMW 「啊、哈啊、啊・・・深处抖了一下，这是什么・・・。」
		ENDIF
	ENDIF
	IF NOWEX:Ａ绝顶
		;強絶頂Ａ
		IF NOWEX:Ａ绝顶 == 2
			PRINTFORMW 「哈呜啊啊啊！屁股的洞，好舒服哟！」
			;絶頂Ａ
		ELSE
			PRINTFORMW 「不、不要・・・好奇怪・・・这边竟然会这样！」
		ENDIF
	ENDIF
	IF NOWEX:Ｂ绝顶
		;強絶頂Ｂ
		IF NOWEX:Ｂ绝顶 == 2
			PRINTFORMW 胸部的快感达到最高潮时，%CALLNAME:人物_琪露诺%仰起背沉浸在到达的快乐中。
			;絶頂Ｂ
		ELSE
			PRINTFORMW 「前端・・・酥酥麻麻的，以为要被弄掉了・・・。」
		ENDIF
	ENDIF
ENDIF


