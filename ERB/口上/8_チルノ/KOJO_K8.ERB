			IF TIME >= 360 && TIME <= 1080
				PRINTFORM 在白昼的光芒中
			ELSE
				PRINTFORM 在夜晚的静谧中
			ENDIF
		ENDIF
	ENDIF
ELSE
	IF RAND:6 == 0
		PRINTFORM 聊着世间
	ELSEIF RAND:5 == 0
		PRINTFORM 聊着漫无边际的
	ELSEIF RAND:4 == 0
