;-------------------------------------------------
;琪露诺口上NTR对应包装口上
;
;为了给不支持NTR的琪露诺口上添加NTR独有的分支而制作的包装口上。
;例如在指令311时执行 KOJO_MESSAGE_COM_K8_311 的情况下，
;如果存在 NTR_KOJO_MESSAGE_COM_K8_311 则优先执行后者。
;并且在 NTR_KOJO_MESSAGE_COM_K8_311 中，当NTR固有的分支全部
;条件不满足时，可以执行通常的（非NTR对应的） KOJO_MESSAGE_COM_K8_311。
;-------------------------------------------------
;※※※※※※关于他人进行修正、加笔、改编的附带条款※※※※※※
;前提是除了原创作者以外的人要进行修改时，必须征求原创作者的许可
;在无法与原创作者取得联系的情况下，请根据以下条款判断是否可以上传。
;
;◎修正（错字、漏字、条件分支等ERB语法BUG修正、本体版本升级、降级对应等）
;（　许可　）※请选择其中一项
;
;◎加笔（未填写部分、随机分支、条件分支等的增补）
;（　标明为他人版则可　）※请选择其中一项
;
;◎改编（对原创作者所写部分的覆盖、消除）
;（　标明为他人版则可　）※请选择其中一项
;
;◎因制作中等理由设置时限
;（　年　月　日）为止不认可上述一切
;
;记　寝之人
;追记
;基本上在无法确认作者意向的情况下，加笔改编是允许的

;==================================================
;311,抱住
;==================================================
@NTR_KOJO_MESSAGE_COM_K8_311
CALL TRAIN_MESSAGE
; 执行NTR对应口上
CALL NTR_KOJO_MESSAGE_COM_K8_311_1
IF 1 == RESULT
	; 若返回值为1，则执行非NTR对应口上
	TRYCALL KOJO_MESSAGE_COM_K8_311_1
ENDIF
RETURN RESULT

@NTR_KOJO_MESSAGE_COM_K8_311_1
#DIM 角色
#DIM RET_VAL

角色 = 人物_琪露诺
RET_VAL = 0
IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ) 

	PRINTDATAL
		DATAFORM 「・・不行哦・・」
		DATAFORM 「・・都说了不要啦」
		DATAFORM 「・・要是被说不可以的话・・」
	ENDDATA

ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前) || NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)

	PRINTFORML 「・・・嗯」
	PRINTFORML 被搂进怀里的%CALLNAME:角色%微微把脸从%CALLNAME:MASTER%那边别开，浮现出仿佛在害怕着什么的表情。

ELSE
	; 除此之外的情况，执行非NTR口上
	RET_VAL = 1
ENDIF 
RETURN RET_VAL
