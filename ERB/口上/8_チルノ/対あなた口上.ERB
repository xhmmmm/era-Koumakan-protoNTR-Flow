;==================================================
;计数器：榨乳手交
;==================================================
;记得扶他的时候应该不会来（弱气
@KOJO_MESSAGE_COUNTER_K8_29_0
PRINTFORML 「呐%CALLNAME:MASTER%，转过身去，手贴着墙壁！」
RETURN 1

@KOJO_MESSAGE_COUNTER_K8_29_1
#DIM 角色
角色 = 人物_琪露诺
IF CFLAG:PLAYER:跳蛋A挿入 != 0
	;你菊花插入跳蛋时分支
	PRINTFORML %CALLNAME:角色%发现%CALLNAME:PLAYER%的菊花里插着跳蛋，高兴了起来。
	IF CFLAG:PLAYER:跳蛋挿入者 == 角色
		PRINTFORML 「啊…按照我说的做了嘛！」
	ELSE
		PRINTFORML 「啊…是谁让你这么做的呢？ 不过，正好呢！」
	ENDIF
	PRINTL
ELSEIF EQUIP:PLAYER:下半身内衣_副 == 0 && EQUIP:PLAYER:下半身内衣_主 == 0
	;你没穿内裤时分支
	PRINTFORML %CALLNAME:角色%发现%CALLNAME:PLAYER%没穿内裤，高兴了起来。
	PRINTFORML 「啊…居然没穿，正好呢！」
	PRINTL
ENDIF
RETURN 1

@KOJO_MESSAGE_COUNTER_K8_29_2
IF CFLAG:PLAYER:跳蛋A挿入 != 0
	PRINTFORML 「哇—出来了出来了！ 跳蛋好舒服呢！」
ELSE
	PRINTFORML 「哇—出来了出来了！ 屁股也好舒服呢！」
ENDIF
RETURN 1

@KOJO_MESSAGE_COUNTER_K8_29_3
SELECTCASE BASE:PLAYER:精力
	CASE IS == 0
		;全部榨取了
		PRINTFORML 「已经结束了吗？ 明明还想让你再射更多的！」
	CASE IS < MAXBASE:PLAYER:精力 /2
		;大半榨取了
		PRINTFORML 「射了好多呢？ 但还是很有精神嘛？」
	CASEELSE
		;稍微榨取了
		PRINTFORML 「射了好多呢？ 但还能射更多更多对吧？」
ENDSELECT
RETURN 1

;-------------------------------------------
;チルノが他の人を呼ぶときの例外処理関数
;-------------------------------------------
@CALLNAME_K8(角色, 対象)
#FUNCTIONS
#DIM 角色
#DIM 対象
#DIMS 呼称

呼称 = %CALLNAME:対象%
IF CALLNAME:角色 == "チルノ"
	IF CALLNAME:対象 == "大妖精"
		呼称 = 大ちゃん
	ELSE
	ENDIF
ELSE
	; 名称変更時はデフォルトのまま
ENDIF
RETURNF 呼称
