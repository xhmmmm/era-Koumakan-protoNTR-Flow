;-------------------------------------------
;チルノが他の人を呼ぶときの例外処理関数
;-------------------------------------------
@CALLNAME_K8(角色, 対象)
#FUNCTIONS
#DIM 角色
#DIM 対象
#DIMS 呼称

呼称 = %CALLNAME:対象%
IF CALLNAME:角色 == "チルノ"
	IF CALLNAME:対象 == "大妖精"
		呼称 = 大ちゃん
	ELSE
	ENDIF
ELSE
	; 名称変更時はデフォルトのまま
ENDIF
RETURNF 呼称
