;-------------------------------------------
;訪問者の家におでかけするときの挨拶
;	前提条件	浮気公認Lv >= 浮気_外泊公認
;-------------------------------------------
@KOJO_MESSAGE_K9_SeeYou_900_9(角色,同伴)
#DIM 角色
#DIM 同伴

IF 同伴
	PRINTFORML 「こちらにいらしたんですね、%CALLNAME:MASTER%、私、この人のお家にお泊りしてきますね」
ELSE
	PRINTFORML 「こちらにいらしたんですね、%CALLNAME:MASTER%、私、あの人のお家にお泊りしてきますね」
ENDIF

IF 同伴
	PRINTFORML 「じゃあ、行きましょう？」
	PRINTDATAL
		DATAFORM %CALLNAME:角色%は%NTR_NAME(0)%と一緒に出て行った・・。
		DATAFORM %CALLNAME:角色%は%NTR_NAME(0)%に連れられ出て行った・・。
		DATAFORM %CALLNAME:角色%は%NTR_NAME(0)%に伴われて出て行った・・。
	ENDDATA
ELSE
	PRINTFORML 「それでは、行ってきますね？」
	PRINTFORML %CALLNAME:角色%は%CALLNAME:MASTER%にそう言って%NTR_NAME(0)%の家へと行ってしまった・・。
ENDIF

RETURN 0

;-------------------------------------------
;大妖精が他の人を呼ぶときの例外処理関数
;-------------------------------------------
@CALLNAME_K9(角色, 対象)
#FUNCTIONS
#DIM 角色
#DIM 対象
#DIMS 呼称

呼称 = %CALLNAME:対象%
IF CALLNAME:角色 == "大妖精"
	IF CALLNAME:対象 == "チルノ"
		呼称 = チルノちゃん
	ELSE
		呼称 = %CALLNAME:対象%さん
	ENDIF
ELSE
	; 名称変更時はデフォルトのまま
ENDIF
RETURNF 呼称
