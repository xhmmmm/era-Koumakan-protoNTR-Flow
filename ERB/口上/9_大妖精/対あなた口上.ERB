;カウンター：乳搾り手コキ
;==================================================
;たしかふたなりの時はこないはず（弱気
@KOJO_MESSAGE_COUNTER_K9_29_0
PRINTFORML 「あ、あの、%CALLNAME:MASTER%・・後ろを向いて、壁に手をついてください」
RETURN 1

@KOJO_MESSAGE_COUNTER_K9_29_1
#DIM 角色
角色 = 人物_大妖精
IF CFLAG:PLAYER:跳蛋A挿入 != 0
	;あなたが菊花に跳蛋挿入時分岐
	PRINTFORML %CALLNAME:角色%は%CALLNAME:PLAYER%がアヌスに跳蛋を挿入していることに気付いて喜んだ。
	IF CFLAG:PLAYER:跳蛋挿入者 == 角色
		PRINTFORML 「あ…言いつけどおりにしてくれているんですね？」
	ELSE
		PRINTFORML 「あ…誰の言いつけなんですか？ でも、ちょうどいいです・・」
	ENDIF
	PRINTL
ELSEIF EQUIP:PLAYER:下半身内衣_副 == 0 && EQUIP:PLAYER:下半身内衣_主 == 0
	;あなたがノーパンの時分岐
	PRINTFORML %CALLNAME:角色%は%CALLNAME:PLAYER%が下着を身に着けていないことに気付いて喜んだ。
	PRINTFORML 「あ…はいてないだなんて、ちょうどいいです・・」
	PRINTL
ENDIF
RETURN 1

@KOJO_MESSAGE_COUNTER_K9_29_2
IF CFLAG:PLAYER:跳蛋A挿入 != 0
	PRINTFORML 「ふふっ、出ましたね♪ 跳蛋ってキモチいいんですか？」
ELSE
	PRINTFORML 「ふふっ、出ましたね♪ お尻もキモチいいんですか？」
ENDIF
RETURN 1

@KOJO_MESSAGE_COUNTER_K9_29_3
SELECTCASE BASE:PLAYER:精力
	CASE IS == 0
		;全部搾り取った
		PRINTFORML 「もうおしまいみたいですね・・もっと出させてあげてもよかったのに・・」
	CASE IS < MAXBASE:PLAYER:精力 /2
		;大半搾り取った
		PRINTFORML 「たくさん出ましたね？ でもまだまだお元気そうですよ？」
	CASEELSE
		;少し搾り取った
		PRINTFORML 「たっぷり出ましたね？ でももっともっと出せますよね？」
ENDSELECT
RETURN 1

;-------------------------------------------
;大妖精が他の人を呼ぶときの例外処理関数
;-------------------------------------------
@CALLNAME_K9(角色, 対象)
#FUNCTIONS
#DIM 角色
#DIM 対象
#DIMS 呼称

呼称 = %CALLNAME:対象%
IF CALLNAME:角色 == "大妖精"
	IF CALLNAME:対象 == "チルノ"
		呼称 = チルノちゃん
	ELSE
		呼称 = %CALLNAME:対象%さん
	ENDIF
ELSE
	; 名称変更時はデフォルトのまま
ENDIF
RETURNF 呼称
