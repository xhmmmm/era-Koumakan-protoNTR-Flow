;==================================================
;会话拡張：结婚戒指について
;　前提：恋慕かつ人妻
;==================================================
@KOJO_MESSAGE_COM_K4_300_14_01(角色, 調教者)
#DIM 調教者
#DIM 角色
IF TALENT:角色:NTR
	;チョーカーが優先
	PRINTFORML %"因为已经不属于"+CALLNAME:MASTER+"了，所以没必要继续戴着戒指。"%
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
	;装着率３割
	IF TALENT:角色:浮気公認
		PRINTDATAL
			DATAFORM 「唔哼哼、并不需要戴戒指哟」
			DATAFORM 「戒指？最近都没怎么戴呢」
			DATAFORM 「戒指已经摘下来了」
		ENDDATA
		PRINTDATAL
			DATAFORM 「因为、这样会让%MSG_HEART()%高兴」
			DATAFORM 「在被谁邀请的时候、戴上婚戒都显得太无趣了吧？」
			DATAFORM 「说希望对方出轨的是%CALLNAME:MASTER%吧？」
		ENDDATA
		PRINTFORML 看起来最近都没怎么戴戒指。
	ELSE
		PRINTFORML %"最近戒指都不怎么合手纸、还被反驳说为什么最近不戴戒指。"%
	ENDIF
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
	;装着率５割
	IF TALENT:角色:浮気公認
		PRINTDATAL
			DATAFORM 「对不起、今天没戴」
			DATAFORM 「偶尔戴」
			DATAFORM 「戒指放房间里了」
		ENDDATA
		PRINTDATAL
			DATAFORM 「有时候也会有这种感觉」
			DATAFORM 「这样的话就觉得不自由了？」
			DATAFORM 「但是、当初说想让对方出轨的是%CALLNAME:MASTER%吧？」
		ENDDATA
		PRINTFORML 被告知今天特意把戒指摘下来了。
	ELSE
		PRINTFORML %"以最近手指发肿为由解释了最近不戴戒指的原因。"%
	ENDIF
	;ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
ELSE
	;装着率９割
	IF TALENT:角色:浮気公認
		PRINTDATAL
			DATAFORM 「对不起、忘记了」
			DATAFORM 「糟糕、一不小心忘记了」
			DATAFORM 「啊・・对不起、忘在房间里了」
		ENDDATA
		PRINTDATAL
			DATAFORM 「因为今天要洗的东西有点多、所以就摘下来了」
			DATAFORM 「今天早上起来的时候太匆忙了、突然就..忘记戴了」
			DATAFORM 「明天我不会忘戴了的、这次就原谅我吧」
		ENDDATA
		PRINTFORML 为这次偶然摘下戒指而道歉了。
	ELSE
		PRINTFORML %"以最近因为保养戒指摘下来为由解释了为什么不戴戒指，然后就道歉了。"%
	ENDIF
ENDIF

RETURN 1

