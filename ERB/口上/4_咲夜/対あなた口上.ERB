;-------------------------------------------
;咲夜が他の人を呼ぶときの例外処理関数
;-------------------------------------------
@CALLNAME_K4(角色, 対象)
#FUNCTIONS
#DIM 角色
#DIM 対象
#DIMS 呼称

呼称 = %CALLNAME:対象%
IF CALLNAME:角色 == "咲夜"
	IF CALLNAME:対象 == "蕾米莉亚"
		呼称 = 蕾米莉亚お嬢様
	ELSEIF CALLNAME:対象 == "フラン" || CALLNAME:対象 == "芙兰朵露"
		呼称 = 芙兰朵露お嬢様
	ELSEIF CALLNAME:対象 == "パチュリー"
		呼称 = パチュリー様
	ELSE
	ENDIF
ELSE
	; 名称変更時はデフォルトのまま
ENDIF
RETURNF 呼称
