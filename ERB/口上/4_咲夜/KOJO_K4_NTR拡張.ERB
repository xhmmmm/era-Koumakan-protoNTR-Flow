RETURN RESULT

@NTR_KOJO_MESSAGE_COM_K4_311_1
#DIM 角色
#DIM RET_VAL

角色 = 人物_咲夜
RET_VAL = 0

IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ) 

	PRINTDATAL
		DATAFORM 「..不可以..」
		DATAFORM 「..请停手」
		DATAFORM 「..不要..」
	ENDDATA

ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前) || NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)

	PRINTFORML 「..・」
	PRINTFORML 在%CALLNAME:角色%抱着%CALLNAME:MASTER%的时候%CALLNAME:角色%稍微侧过去的脸上露出了不安的表情。
	PRINTFORML 实在不知道怎么翻了,以下原句
	PRINTFORML 抱き寄せられた%CALLNAME:角色%は%CALLNAME:MASTER%からわずかに顔を背け何かに怯えたような表情を浮かべていた。

ELSE
	; それ以外の場合、非NTR口上を実行する
	RET_VAL = 1
ENDIF 
RETURN RET_VAL

;==================================================
;312,接吻
;==================================================
@NTR_KOJO_MESSAGE_COM_K4_312
IF TFLAG:193 == 0
	CALL TRAIN_MESSAGE
ENDIF
CALL NTR_KOJO_MESSAGE_COM_K4_312_1
IF 1 == RESULT
	; 戻り値が1であれば、非NTR対応口上を実行
	TRYCALL KOJO_MESSAGE_COM_K4_312_1
ENDIF
RETURN RESULT

@NTR_KOJO_MESSAGE_COM_K4_312_1
#DIM 角色
#DIM RET_VAL

角色 = 人物_咲夜
RET_VAL = 0

;唇の汚れで拒否された時
IF TFLAG:193 == -2
	PRINTFORML 「不、不行哦」
	PRINTFORML 以嘴唇有污物为由拒绝了接吻。
	PRINTFORML 「呐、能不能给我倒杯茶呢？」
	PRINTFORML %CALLNAME:角色%把茶喝了下去。
	;失敗時
ELSEIF TFLAG:193 == -1
	PRINTFORML 「你、你在干什么」
	PRINTFORML 拒绝之后、被用力地推开了。
	;成功時
ELSE
	IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
		;唇が精液で汚れていたとき
		IF CFLAG:射精者M != 0 && STAIN:口 & 汚れ_精液
			PRINTFORML %CALLNAME:MASTER%察觉到%CALLNAME:角色%嘴里的意味之后将嘴唇分开了。
			PRINTFORML 「..哼哼..味道很重吗？」
			;好意度低いと冷たい
		ELSE
			PRINTFORML 「..不行..唔呃..」
		ENDIF
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
		PRINTDATAL
			DATAFORM 「唔..啾..」
			DATAFORM 「啾..啾..」
			DATAFORM 「唔..呼唔..啾..」
		ENDDATA
		PRINTFORML （果然、还是他的技术更胜一筹）
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)

		PRINTDATAL
			DATAFORM 「ん..ちゅっ..」
			DATAFORM 「ちゅっ..ちゅ..」
			DATAFORM 「ん..んん..ちゅ..」
		ENDDATA
		PRINTDATAL
			DATAFORM （..比起跟%CALLNAME:MASTER%接吻、跟他接吻更让人心跳加速呢..）
			DATAFORM （..不行.还是不够满足..）
			DATAFORM （果然、还是他的技术更胜一筹）
		ENDDATA

	ELSE
		RET_VAL = 1
	ENDIF
ENDIF
RETURN RET_VAL

;==================================================
;351,连行/离开
;==================================================
@NTR_KOJO_MESSAGE_COM_K4_351
CALL TRAIN_MESSAGE
; NTR対応口上実行
CALL NTR_KOJO_MESSAGE_COM_K4_351_1
IF 1 == RESULT
	; 戻り値が1であれば、非NTR対応口上を実行
	TRYCALL KOJO_MESSAGE_COM_K4_351_1
ENDIF
RETURN RESULT

@NTR_KOJO_MESSAGE_COM_K4_351_1
#DIM 角色
#DIM RET_VAL

角色 = TARGET
IF CFLAG:同行
	;同行するとき
	RET_VAL = 1
ELSE
	RET_VAL = 0
	;離れるとき
	IF CFLAG:角色:当前位置 == FLAG:访问者当前位置
		; 訪問者が同じ場所にいる
		IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ) 
			PRINTFORML 「啊啦、他来了。待会见。」
			PRINTFORML 感受到%NTR_NAME(0)%的视线的%CALLNAME:角色%离开%CALLNAME:MASTER%并微微脸红地向他那边走去。
		ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
			PRINTFORML 「啊啦」
			PRINTFORML 感受到%NTR_NAME(0)%的视线的%CALLNAME:角色%离开%CALLNAME:MASTER%并微微脸红地向他那边走去。
		ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
			IF TALENT:角色:恋慕
				PRINTFORML 「..」
				PRINTFORML 感受到%NTR_NAME(0)%的视线的%CALLNAME:角色%一脸若无其事地离开%CALLNAME:MASTER%并在他旁边停下。
			ELSE
				PRINTFORML 「啊啦」
				PRINTFORML 感受到%NTR_NAME(0)%的视线的%CALLNAME:角色%离开%CALLNAME:MASTER%并向他那边走去。
			ENDIF
		ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い) 
			IF TALENT:角色:恋慕
				PRINTFORML 「..」
				PRINTFORML 感受到%NTR_NAME(0)%的视线的%CALLNAME:角色%一脸若无其事地离开%CALLNAME:MASTER%并在%NTR_NAME(0)%的附近停下。
			ELSE
				PRINTFORML 「啊啦」
				PRINTFORML 感受到%NTR_NAME(0)%的视线的%CALLNAME:角色%一脸若无其事地离开%CALLNAME:MASTER%并在%NTR_NAME(0)%的附近停下。
			ENDIF
		ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
			IF TALENT:角色:恋慕 
				IF IS_NTR_SOFT()
					PRINTFORML 「..」
					PRINTFORML 感受到%NTR_NAME(0)%的视线的%CALLNAME:角色%在%CALLNAME:MASTER%和%NTR_NAME(0)%之间停了下来。
				ELSE
					PRINTFORML 「..」
					PRINTFORML 感受到%NTR_NAME(0)%那视奸一样的眼神的%CALLNAME:角色%并没有露出任何不适的表情。
					PRINTFORML %CALLNAME:MASTER%と%NTR_NAME(0)%の間で足をとめた。
				ENDIF
			ELSE
				RET_VAL = 1
			ENDIF
		ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)
			IF TALENT:角色:恋慕 && !IS_NTR_SOFT()
				PRINTFORML 「..」
				PRINTFORML 感受到%NTR_NAME(0)%那视奸一样的眼神的%CALLNAME:角色%警戒了起来。
				PRINTFORML %CALLNAME:MASTER%在%NTR_NAME(0)%之间停了下来。
			ELSE
				RET_VAL = 1
			ENDIF
		ELSE
			IF TALENT:角色:恋慕 && !IS_NTR_SOFT()
				PRINTFORML 「..」
				PRINTFORML 感受到%NTR_NAME(0)%那视奸一样的眼神的%CALLNAME:角色%往%CALLNAME:MASTER%那边凑了过去。
			ELSE
				RET_VAL = 1
			ENDIF
		ENDIF
	ELSE
		RET_VAL = 1
	ENDIF
ENDIF
RETURN RET_VAL

