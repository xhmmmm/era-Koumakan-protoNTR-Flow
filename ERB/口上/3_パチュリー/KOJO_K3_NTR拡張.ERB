;-------------------------------------------------
;帕秋莉口上NTR对应包装口上
;
;为未对应NTR的帕秋莉口上添加NTR独有分支的包装口上。
;例如执行命令311时调用 KOJO_MESSAGE_COM_K3_311 的情况，
;若存在 NTR_KOJO_MESSAGE_COM_K3_311 则优先执行该函数。
;且在 NTR_KOJO_MESSAGE_COM_K3_311 中，若NTR固有的分支条件
;全部不满足时，仍可执行通常的（非NTR对应的）KOJO_MESSAGE_COM_K3_311。
;-------------------------------------------------
;※※※※※※关于他人进行修正、加笔、改动的声明※※※※※※
;前提是原作作者以外的人进行修改时，应征求原作作者的许可
;若无法与原作作者取得联系，请根据以下声明判断是否可以上传。

;◎修正（错字、漏字、条件分支等ERB语法的bug修正、本体版本升级/降级对应等）
;（　许可　）※请选择其中之一
;
;◎加笔（未填写部分、随机分支、条件分支等增补）
;（　标明为他人版本则可　）※请选择其中之一
;
;◎改动（对原作作者所写部分的覆盖、删除）
;（　标明为他人版本则可　）※请选择其中之一
;
;◎因制作中等理由设置时限
;（　年　月　日）之前不认可上述任何一项
;
;记　寝の人
;追记
;基本上在无法确认作者意愿的情况下，加笔改动是允许的

;==================================================
;311,抱住
;==================================================
@NTR_KOJO_MESSAGE_COM_K3_311
CALL TRAIN_MESSAGE
; 执行NTR对应口上
CALL NTR_KOJO_MESSAGE_COM_K3_311_1
IF 1 == RESULT
	; 返回值为1时，执行非NTR对应口上
	TRYCALL KOJO_MESSAGE_COM_K3_311_1
ENDIF
RETURN RESULT

@NTR_KOJO_MESSAGE_COM_K3_311_1
#DIM 角色
#DIM RET_VAL

角色 = 人物_帕秋莉
RET_VAL = 0

IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ) 

	PRINTDATAL
		DATAFORM 「・・不可以」
		DATAFORM 「・・请住手」
		DATAFORM 「・・不・・不行・・」
	ENDDATA

ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前) || NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)

	PRINTFORML 「・・・」
	PRINTFORML 被揽入怀中的%CALLNAME:角色%微微将脸从%CALLNAME:MASTER%处别开，露出了仿佛惧怕着什么的神情。

ELSE
	; 其他情况，执行非NTR口上
	RET_VAL = 1
ENDIF 
RETURN RET_VAL

;==================================================
;312,接吻
;==================================================
@NTR_KOJO_MESSAGE_COM_K3_312
IF TFLAG:193 == 0
	CALL TRAIN_MESSAGE
ENDIF
CALL NTR_KOJO_MESSAGE_COM_K3_312_1
IF 1 == RESULT
	; 返回值为1时，执行非NTR对应口上
	TRYCALL KOJO_MESSAGE_COM_K3_312_1
ENDIF
RETURN RESULT

@NTR_KOJO_MESSAGE_COM_K3_312_1
#DIM 角色
#DIM RET_VAL

角色 = 人物_帕秋莉
RET_VAL = 0

;因嘴唇污渍被拒绝时
IF TFLAG:193 == -2
	PRINTDATAL
		DATAFORM 「不、不行！」
		DATAFORM 「不、不可以！」
		DATAFORM 「住、住手！」
	ENDDATA
	PRINTFORML 虽然不知道理由，但在嘴唇触碰之前就被拒绝了。
	PRINTDATAL
		DATAFORM 「呐，能给我一杯茶吗？」
		DATAFORM 「对了，给我来杯茶」
		DATAFORM 「是呢。让我喝杯茶吧」
	ENDDATA
	PRINTFORML %CALLNAME:角色%似乎想要喝茶。
	;失败时
ELSEIF TFLAG:193 == -1
	PRINTDATAL
		DATAFORM 「住、住手！」
		DATAFORM 「突然做什么！？」
		DATAFORM 「到此为止！」
	ENDDATA
	PRINTFORML 被拒绝了。
	;成功时
ELSE
	IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
		;嘴唇被精液沾污时
		IF CFLAG:射精者M != 0 && STAIN:口 & 汚れ_精液
			PRINTFORML 与%CALLNAME:角色%接吻的%CALLNAME:MASTER%对唾液的异样味道感到违和，离开了嘴唇。
			PRINTFORML 「・・呵呵・・淫靡味道的吻・・习惯之后倒也别有一番风味呢」
			;好感度低则冷淡
		ELSE
			PRINTFORML 「・・不、不行・・嗯・・」
		ENDIF
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前) || NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
		IF ABL:欲望 >= 5
			PRINTDATAL
				DATAFORM 「嗯・・啾・・啾啪・・」
				DATAFORM 「啾・・嘬・・」
				DATAFORM 「嗯・・嗯嗯・・啾・・」
			ENDDATA
			PRINTDATAL
				DATAFORM 互相贪婪地吮吸着彼此的唇与舌，尽情品味着那滋味。
				DATAFORM 如啜饮般品味着那柔软的舌头，咽下了清纯的甘露。
				DATAFORM 将舌头送入%CALLNAME:TARGET%口中注入唾液后，她白皙的咽喉咕咚一声轻响。
			ENDDATA
			PRINTDATAL
				DATAFORM 「哈・・这就结束了吗・・不是吧・・？」
				DATAFORM 「呼・・真好・・再让我多喝一点・・」
				DATAFORM 「呵呵・・还不够呢・・」
			ENDDATA
		ELSE
			PRINTDATAL
				DATAFORM 「嗯・・啾・・啾啪・・」
				DATAFORM 「啾・・嘬・・」
				DATAFORM 「嗯・・嗯嗯・・啾・・」
			ENDDATA
			PRINTDATAL
				DATAFORM 彼此将嘴唇贴近，细细品味着那柔软的触感。
				DATAFORM 以相互依偎的姿势交换了一个吻。
				DATAFORM 唇分之际，%CALLNAME:TARGET%双颊染上了红晕，似乎还在期待着后续。
			ENDDATA
			PRINTDATAL
				DATAFORM 「・・就到这里？」
				DATAFORM 「・・你不觉得还有进一步研究的余地吗・・？」
				DATAFORM 「・・好开心・・」
			ENDDATA
		ENDIF
		IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
			PRINTFORML （・・不够・・完全不够・・）
		ELSE
			PRINTFORML （・・无论如何，总是忍不住去比较呢・・）
		ENDIF
	ELSE
		RET_VAL = 1
	ENDIF
ENDIF
RETURN RET_VAL

