;-------------------------------------------------
;寝取られパッチ用パチュリー口上ファイル
;寝取られパッチ用パチュリー口上ファイルベース
;お好きなように埋めまくってください
;そしてあわよくばうｐしてください
;いやマジで
;注意：この口上が呼ばれるのは対象が主人から見える位置に居る状態か
;　　　筒抜けコマンド(デバグ用)を実行した場合に限ります
;　　　対象は気づいてない事が前提なので書く際にはご注意を
;
;protoNTR版追加要素
;関数名に「KW」がつく項目はMASTER同席の見せつけコマンド。
;屈服度が低いうちは訪問者による見せつけ、屈服度が好意度に勝り
;寝取られそう→寝取られと遷移すると住人がMASTERに見せ付けてきます。
;-------------------------------------------------

;==================================================
;訪問者と会话
;==================================================
;主人(マスター)は同席していない
@NTR_KOJO_K3_1(角色)
#DIM 角色
;大浴场
IF CFLAG:角色:当前位置 == 位置_红魔馆_大浴场
	IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
		PRINTDATAL
			DATAFORM 「这里也要好好清洁呢。毕竟也会变成我舔的地方」
			DATAFORM 「这边也要好好清洁一下呢。...什么嘛，还发出那么奇怪的声音。明明一直都在对我做这种事」
			DATAFORM 「没想到你也会发出这么可爱的声音呢。得把里面也好好地深入清洁一下才行呢」
		ENDDATA
		PRINTDATAL
			DATAFORM %CALLNAME:角色%正在用心地地清洁着%NTR_NAME(0)%身后的不净之穴。
			DATAFORM %CALLNAME:角色%将手指伸入%NTR_NAME(0)%狭窄的后穴，细致地清洁着。
			DATAFORM %CALLNAME:角色%像是在报复%NTR_NAME(0)%平日里对自己的所作所为，玩弄般清洗着他的后穴。
		ENDDATA
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
		PRINTDATAL
			DATAFORM 「嗯啊，那里也拜托了。啊啊...」
			DATAFORM 「嗯啊，好舒服...啊呜...」
			DATAFORM 「啊，竟然连那种地方也...嗯...可以哦...非常舒服呢...」
		ENDDATA
		PRINTDATAL
			DATAFORM %CALLNAME:角色%将身体交给了%NTR_NAME(0)%有力的大手，任由他清洁着身体的每一个角落。
			DATAFORM %CALLNAME:角色%放松地让%NTR_NAME(0)%清洗着自己的身体，就连胸部与腰间这样微妙的地方也不例外。
			DATAFORM 享受着身体角角落落被清洗的触感，%CALLNAME:角色%露出了陶醉的表情。
		ENDDATA
		PRINTFORML
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
		PRINTDATAL
			DATAFORM 「不，不可以，在这种地方...」
			DATAFORM 「啊呜...已经...」
			DATAFORM 「啊呜...真是不检点的手呢」
		ENDDATA
		PRINTFORML 感到%NTR_NAME(0)%的手伸向了自己的乳房，%CALLNAME:角色%虽然出声抗压，却并没有逃开。
		;ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_体を触らせる程度)
		PRINTDATAL
			DATAFORM 「不，不可以，在这种地方」
			DATAFORM 「啊嗯...快，快停下」
			DATAFORM 「啊嗯...真是没教养的手」
		ENDDATA
		PRINTFORML 感到%NTR_NAME(0)%的手伸向了自己的乳房，%CALLNAME:角色%试着躲开。
		;ELSEIF NTR_CHK_FAVORABLY(角色, FAV_接吻程度)
	ELSE
		PRINTFORML 「...为什么你这家伙会在这里呢？」
		PRINTFORML %CALLNAME:角色%似乎不喜欢%NTR_NAME(0)%那无礼的目光。
	ENDIF
	;その他
ELSE
	IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
		PRINTDATAL
			DATAFORM 「嗯呢...后面的内容，我想和你一起慢慢聊呢」
			DATAFORM 「很有趣呢...能找个安~静的地方，慢慢讲给我听吗？」
			DATAFORM 「有点累了呢...要一起休息吗？」
		ENDDATA
		PRINTFORML %CALLNAME:角色%红着脸，带着仿佛正期待着什么的表情催促%NTR_NAME(0)%。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
		PRINTDATAL
			DATAFORM 「呼呼，这真是有趣呢」
			DATAFORM 「很有趣呢...能再多跟我讲讲吗？」
			DATAFORM 「这个故事，还有后续吗？」
		ENDDATA
		PRINTFORML %CALLNAME:角色%绽放着笑颜，似乎十分开心。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
		PRINTDATAL
			DATAFORM 「是啊，也可以这样解释呢」
			DATAFORM 「从结论来讲确实是这样呢。就像你说的那样」
			DATAFORM 「哎呀，不过这样解释也可以吧？」
		ENDDATA
		PRINTFORML %CALLNAME:角色%愉快地与%NTR_NAME(0)%讨论着。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)
		PRINTFORML 
		PRINTDATAL
			DATAFORM 「这有一定道理呢」
			DATAFORM 「先等一下。确实可以从这个角度看待呢」
			DATAFORM 「不是那样的。你没考虑到隐藏的因素」
		ENDDATA
		PRINTFORML %CALLNAME:角色%认真地与%NTR_NAME(0)%交谈着。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_体を触らせる程度)
		PRINTDATAL
			DATAFORM 「也对。但是这样呢？」
			DATAFORM 「那样子也说得通呢」
			DATAFORM 「哎呀，似乎很有趣呢」
		ENDDATA
		PRINTFORML %CALLNAME:角色%对对方的话题稍微感到了一些兴趣。
		;ELSEIF NTR_CHK_FAVORABLY(角色, FAV_接吻程度)
	ELSE
		PRINTDATAL
			DATAFORM 「...是啊」
			DATAFORM 「那又怎样呢？」
			DATAFORM 「这个话题，第几次了？」
		ENDDATA
		PRINTFORML %CALLNAME:角色%兴致缺缺地回答着。
	ENDIF
ENDIF
RETURN 0

;玩家在场
@NTR_KOJO_KW3_1(角色)
#DIM 角色
;大浴场
IF CFLAG:角色:当前位置 == 位置_红魔馆_大浴场
	IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
		PRINTFORML 「像这样泡着澡，感觉身体都轻盈了不少呢」
		PRINTFORML %CALLNAME:角色%离开了%CALLNAME:MASTER%，走到%NTR_NAME(0)%身旁与他交谈着。
		PRINTFORML 别说是那仿佛要将全身舔遍般的视线了，就连偶尔被碰到也毫不在意的样子。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
		PRINTFORML 「像这样泡着澡，感觉身体都轻盈了不少呢」
		IF TALENT:角色:恋慕
			PRINTFORML %CALLNAME:角色%离开了%ANATA_LOVER(角色)%，走到%NTR_NAME(0)%身旁与他交谈着。
		ELSE
			PRINTFORML %CALLNAME:角色%离开了%CALLNAME:MASTER%，走到%NTR_NAME(0)%身旁与他交谈着。
		ENDIF
		PRINTFORML 对那仿佛要将全身舔遍般的视线似乎并不在意。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
		PRINTFORML 「...呼...好舒服呢...」
		PRINTFORML %CALLNAME:角色%与%CALLNAME:MASTER%和%NTR_NAME(0)%保持着差不多的距离入浴着。
		IF IS_NTR_SOFT()
			PRINTFORML 似乎是在意他的视线，时不时别过脸去。
		ELSE
			PRINTFORML 似乎是在意那仿佛要将全身舔遍般的视线，时不时别过脸去。
		ENDIF
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)
		PRINTFORML 「...呼...好舒服呢...」
		PRINTFORML %CALLNAME:角色%与%CALLNAME:MASTER%和%NTR_NAME(0)%保持着差不多的距离入浴着。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_体を触らせる程度)
		PRINTFORML %CALLNAME:角色%仿佛拿%CALLNAME:MASTER%当盾牌一般入浴着。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_接吻程度)
		PRINTFORML %CALLNAME:角色%仿佛拿%CALLNAME:MASTER%当盾牌一般入浴着。
	ELSE
		PRINTFORML %CALLNAME:角色%仿佛拿%CALLNAME:MASTER%当盾牌一般入浴着。
	ENDIF
	;其他
ELSE
	IF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
		PRINTFORML 「那真是令人感兴趣呢。能不能再多讲给我听听？」
		IF TALENT:角色:恋慕
			PRINTFORML %CALLNAME:角色%看都不看%ANATA_LOVER(角色)%一眼，只顾着和%NTR_NAME(0)%交谈着。
		ELSE
			PRINTFORML %CALLNAME:角色%看都不看%CALLNAME:MASTER%一眼，只顾着和%NTR_NAME(0)%交谈着。
		ENDIF
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
		PRINTFORML 「...是呢。%CALLNAME:MASTER%你觉得呢？」
		IF TALENT:角色:恋慕
			PRINTFORML %CALLNAME:角色%一边留意着%ANATA_LOVER(角色)%的反应，一边和%NTR_NAME(0)%交谈着。
		ELSE
			PRINTFORML %CALLNAME:角色%一边留意着%CALLNAME:MASTER%的反应，一边和%NTR_NAME(0)%交谈着。
		ENDIF
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)
		PRINTFORML 「是呢。%CALLNAME:MASTER%你觉得怎么样呢？
		PRINTFORML %CALLNAME:角色%与%CALLNAME:MASTER%交谈着，时不时也回应一下%NTR_NAME(0)%。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_体を触らせる程度)
		PRINTFORML %CALLNAME:角色%将笑容朝向了%CALLNAME:MASTER%。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_接吻程度)
		PRINTFORML %CALLNAME:角色%将笑容朝向了%CALLNAME:MASTER%。
	ELSE
		PRINTFORML %CALLNAME:角色%将笑容朝向了%CALLNAME:MASTER%。
	ENDIF
ENDIF
RETURN 0

;==================================================
;訪問者とキス
;==================================================
;開始
@NTR_KOJO_K3_2_0(角色)
#DIM 角色
IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)

	PRINTDATAL
		DATAFORM 「嗯...啾...%MSG_HEART()%」
		DATAFORM 「啾...好棒...嗯...%MSG_HEART()%」
		DATAFORM 「想要...接吻了...嗯...%MSG_HEART()%」
	ENDDATA
	IF NTR_CHK_PEEP_CONT(角色) && NTR_CHK_MISETUKE(角色)
		PRINTFORML %CALLNAME:角色%主动地拥抱着%NTR_NAME(0)%，像是要做给%CALLNAME:MASTER%看一样，献上了小巧的檀口与嫩舌。
	ELSE
		PRINTFORML %CALLNAME:角色%主动地拥抱着%NTR_NAME(0)%，向%NTR_NAME(0)%主动献上了小巧的檀口与嫩舌。
	ENDIF

ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)

	PRINTDATAL
		DATAFORM 「嗯...啾...%MSG_HEART()%」
		DATAFORM 「啾...好棒...嗯...%MSG_HEART()%」
		DATAFORM 「想要...接吻了...嗯...%MSG_HEART()%」
	ENDDATA
	IF TALENT:角色:恋慕
		IF NTR_CHK_PEEP_CONT(角色) && NTR_CHK_MISETUKE(角色)
			PRINTFORML %CALLNAME:角色%主动地拥抱着%NTR_NAME(0)%，像是要做给%CALLNAME:MASTER%看一样，献上了小巧的檀口与嫩舌。
		ELSE
			PRINTFORML %CALLNAME:角色%将%CALLNAME:MASTER%的存在彻底抛之脑后，向%NTR_NAME(0)%主动献上了小巧的檀口与嫩舌。
		ENDIF
	ELSE
		IF NTR_CHK_PEEP_CONT(角色) && NTR_CHK_MISETUKE(角色)
			PRINTFORML %CALLNAME:角色%主动地拥抱着%NTR_NAME(0)%，像是要做给%CALLNAME:MASTER%看一样，献上了小巧的檀口与嫩舌。
		ELSE
			PRINTFORML %CALLNAME:角色%向%NTR_NAME(0)%主动献上了小巧的檀口与嫩舌。
		ENDIF
	ENDIF

ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)

	PRINTDATAL
		DATAFORM 「嗯！ ...嗯...啾...♪」
		DATAFORM 「嗯！ ...啾...太棒了...嗯...♪」
		DATAFORM 「嗯！ 嗯...嗯...好棒...嗯...♪」
	ENDDATA

	IF TALENT:角色:恋慕
		IF NTR_CHK_PEEP_CONT(角色) && NTR_CHK_MISETUKE(角色)
			PRINTFORML 虽然被堵住嘴唇的%CALLNAME:角色%一时茫然了一下，但最终仍然像忘记了%ANATA_LOVER(角色)%的存在一样，顺从地接受了%NTR_NAME(0)%的舌头。
		ELSE
			PRINTFORML 虽然被堵住嘴唇的%CALLNAME:角色%一时茫然了一下，但好像忘记了%ANATA_LOVER(角色)%，顺从地接受了%NTR_NAME(0)%的舌头。
		ENDIF
	ELSE
		IF NTR_CHK_PEEP_CONT(角色) && NTR_CHK_MISETUKE(角色)
			PRINTFORML 虽然被堵住嘴唇的%CALLNAME:角色%一时茫然了一下，但能感受到%CALLNAME:MASTER%的目光，顺从地接受了%NTR_NAME(0)%的舌头。
		ELSE
			PRINTFORML 虽然被堵住嘴唇的%CALLNAME:角色%一时茫然了一下，但最终仍然张开檀口，接受了%NTR_NAME(0)%的舌头。
		ENDIF
	ENDIF

ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)

	PRINTDATAL
		DATAFORM 「嗯...嗯唔」
		DATAFORM 「什么...嗯...嗯嗯...」
		DATAFORM 「嗯...嗯嗯...」
	ENDDATA

	IF NTR_CHK_PEEP_CONT(角色)
		PRINTFORML 感受着远处%ANATA_LOVER(角色)%的视线，%CALLNAME:角色%与%NTR_NAME(0)%的嘴唇相接。
		PRINTFORML 虽然最初%CALLNAME:角色%震惊了一下，但%NTR_NAME(0)%的舌头一侵入她的嘴里，她便闭上眼睛接纳了他的舌头。
	ELSE
		PRINTFORML %CALLNAME:角色%毫无抵抗地接受了%NTR_NAME(0)%的嘴唇和舌头。
	ENDIF

ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)

	PRINTDATAL
		DATAFORM 「诶？ 嗯...嗯唔！！」
		DATAFORM 「什么...嗯！ 嗯嗯...！」
		DATAFORM 「嗯！？ 嗯...嗯嗯...」
	ENDDATA

	IF NTR_CHK_PEEP_CONT(角色)
		PRINTFORML 感受着远处%ANATA_LOVER(角色)%的视线，%CALLNAME:角色%被粗暴地夺走了嘴唇。
		PRINTFORML %CALLNAME:角色%虽然一开始弱弱地抵抗，但当%NTR_NAME(0)%的舌头侵入到嘴里后，便渐渐地变得老实，最终接纳了他的舌头。
	ELSE
		PRINTFORML %CALLNAME:角色%被粗暴地夺走了嘴唇，即使试着弱弱地抵抗也无法摆脱%NTR_NAME(0)%。
	ENDIF

ELSE

	PRINTDATAL
		DATAFORM 「诶？ 嗯...嗯，嗯唔！！」
		DATAFORM 「呀...不要...嗯嗯...！」
		DATAFORM 「嗯嗯！？ 呀...嗯...」
	ENDDATA

	IF NTR_CHK_PEEP_CONT(角色)
		PRINTFORML 感受着远处%ANATA_LOVER(角色)%的视线，%CALLNAME:角色%被粗暴地夺走了嘴唇。
	ELSE
		IF TALENT:角色:恋慕
			PRINTFORML %CALLNAME:MASTER%之外的男人粗暴地夺走了%CALLNAME:角色%的嘴唇。
		ELSE
			PRINTFORML %CALLNAME:角色%被%NTR_NAME(0)%粗暴地夺走了嘴唇。
		ENDIF
	ENDIF

ENDIF
RETURN 0

