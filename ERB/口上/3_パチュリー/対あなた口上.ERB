;==================================================
;会话拡張：结婚戒指について
;　前提：恋慕かつ人妻
;==================================================
@KOJO_MESSAGE_COM_K3_300_14_01(角色, 調教者)
#DIM 調教者
#DIM 角色
IF TALENT:角色:NTR
	;チョーカーが優先
	PRINTFORML %"もう"+CALLNAME:MASTER+"のものではないのだから指輪をする必要は無いと言い切られた。"%
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
	;装着率３割
	PRINTFORML %"指に合わない感じがして、最近はあまり指輪をしないのだと言い返された。"%
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
	;装着率５割
	PRINTFORML %"最近指が腫れるので外している事が多いのだと言い訳された。"%
	;ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
ELSE
	;装着率９割
	PRINTFORML %"手入れをするために外したまま忘れていたからだと謝られた。"%
ENDIF

RETURN 1

;==================================================
;会话拡張：ぱんつについて：ADULT下着（小恶魔/淫乱)
;==================================================
@KOJO_MESSAGE_COM_K3_300_15_02(角色, 調教者, ノーパン)
#DIM 調教者
#DIM 角色
#DIM ノーパン
#DIMS 下着名

下着名 = %下着名１_２(角色)%
IF ノーパン
	PRINTFORML 「ええ、開放的で気持ちいいわよ？」
ELSE
	PRINTFORML 「ええ、刺激的すぎたかしら？」
ENDIF
PRINTDATAL
	DATAFORM 「%CALLNAME:MASTER%もこういうの、好きなんじゃないかしら？」
	DATAFORM 「%CALLNAME:MASTER%もこういうの、好きなんでしょう？」
	DATAFORM 「今の%CALLNAME:MASTER%、いやらしい視線だったわよ？」
ENDDATA
IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
	PRINTFORML 「あの人も喜んでくれるわ」
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
	PRINTFORML 「他も喜んでくれるわ」
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
	PRINTFORML 「%CALLNAME:MASTER%だけじゃなくて他も喜んでくれるわ」
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
	PRINTFORML 「%CALLNAME:MASTER%だけじゃなくて他も喜んでくれるわ」
ELSE
	PRINTFORML 「あまり下半身を冷やしたくないのだけど」
ENDIF
RETURN 1

;==================================================
;会话拡張：ぱんつについて：ADULT(NTR)
;　前提：屈服度>好感度 かつ 屈服度>999
;==================================================
@KOJO_MESSAGE_COM_K3_300_15_03(角色, 調教者, ノーパン, 積極度)
#DIM 調教者
#DIM 角色
#DIM ノーパン
#DIM 積極度
#DIMS 下着名

下着名 = %下着名１_２(角色)%
IF ノーパン
	IF 1 == 積極度
		PRINTFORML 「ええ、今日はこうしていろって、他に言われたの」
		PRINTFORML 「恥ずかしいけど、こういうのも刺激的でいいわね」
	ELSE
		PRINTFORML 「今日はこうしていろって、他に言われたの」
		PRINTFORML 「恥ずかしいから、あまり見ないで欲しいわ」
	ENDIF
ELSE
	IF 1 == 積極度
		PRINTDATAL
			DATAFORM 「ええ、今日はこれを穿いていろって、他に言われたの」
			DATAFORM 「ええ、今日はこれを穿くようにって、他に言われたの」
			DATAFORM 「ええ、今日はこれを身に着けるようにって、他に言われたの」
		ENDDATA
		PRINTDATAL
			DATAFORM 「恥ずかしいけど、こういうのも刺激的ね」
			DATAFORM 「恥ずかしいけど、どう？ 似合うかしら？」
			DATAFORM 「恥ずかしいけど、こういうのも刺激的ね」
		ENDDATA
	ELSE
		PRINTDATAL
			DATAFORM 「今日はこれを穿いていろって、他に言われたの」
			DATAFORM 「今日はこれを穿くようにって、他に言われたの」
			DATAFORM 「今日はこれを身に着けるようにって、他に押し付けられたの」
		ENDDATA
		PRINTDATAL
			DATAFORM 「・・正直、恥ずかしいわね」
			DATAFORM 「恥ずかしいから、あまり見ないで欲しいわ」
			DATAFORM 「あまり下半身を冷やしたくないのだけど」
		ENDDATA
	ENDIF
ENDIF	
RETURN 1




;==================================================
;カウンター：乳搾り手コキ
;==================================================
;パチュリーということでこういうネタに走る
;相手しだいでは変なことになるかもしれないけど気にしない
;たしかふたなりの時はこないはず（弱気
@KOJO_MESSAGE_COUNTER_K3_29_0
IF TALENT:TARGET:施虐狂
	PRINTDATAL
		DATAFORM %"「後ろを向いて、壁に手をついて」"%
		DATAFORM %"「後ろを向いて。いいからそこの壁に手をついて」"%
		DATAFORM %"「そこの壁に手をつきなさい、そのまま動かないで」"%
	ENDDATA
ELSE
	PRINTDATAL
		DATAFORM %"「ちょっと後ろを向いてくれるかしら？ 悪いようにはしないから安心して」"%
		DATAFORM %"「後ろを向いて、そこの壁に手をついて頂戴。悪いようにはしないわ」"%
		DATAFORM %"「そこの壁に手をついてくれるかしら？ いいことしてあげるから、動かないで」"%
	ENDDATA
ENDIF
RETURN 1

@KOJO_MESSAGE_COUNTER_K3_29_1
#DIM 角色
角色 = 人物_帕秋莉
IF CFLAG:PLAYER:跳蛋A挿入 != 0
	;あなたが菊花に跳蛋挿入時分岐
	PRINTFORML %CALLNAME:角色%は%CALLNAME:PLAYER%がアヌスに跳蛋を挿入していることに気付いて微笑んだ。
	IF CFLAG:PLAYER:跳蛋挿入者 == 角色
		PRINTDATA
			DATAFORM %"「あら・・言いつけどおりにしていたのね。"%
			DATAFORM %"「あら、勝手に抜いたりしていないようね。"%
			DATAFORM %"「あら、跳蛋が気に入ったのかしら？"%
		ENDDATA
	ELSE
		PRINTDATA
			DATAFORM %"「あら・・誰の言いつけなのかしら。"%
			DATAFORM %"「・・これは誰に入れられたのかしら？"%
			DATAFORM %"「まさか自分で入れてるの？"%
		ENDDATA
	ENDIF
	PRINTDATAL
		DATAFORM %" ちょうどいいから、このまましてあげるわ」"%
		DATAFORM %" 気持ちいい方がいいでしょう？ 入れたまましてあげるわ」"%
		DATAFORM %" 跳蛋が好きなら仕方ないわね。このまましてあげるわ」"%
	ENDDATA
	PRINTL
ELSEIF EQUIP:PLAYER:下半身下着１ == 0 && EQUIP:PLAYER:下半身下着２ == 0
	;あなたがノーパンの時分岐
	PRINTFORML %CALLNAME:角色%は%CALLNAME:PLAYER%が下着を身に着けていないことに気付いて微笑んだ。
	PRINTFORML 「あら…ノーパンだなんて、ふふっ、ちょうどいいわね」
	PRINTDATAL
		DATAFORM %"「あら・・ノーパンだなんて、丁度いいわね」"%
		DATAFORM %"「ふふ・・履いてないだなんて、そういう健康法かしら？」"%
		DATAFORM %"「・・誰かに下着を取られたのかしら？ また何かしたの？」"%
	ENDDATA
	PRINTL
ENDIF
PRINTDATA
	DATAFORM %"「ホムンクルスの研究のために活きのいい精液が必要なの。"%
	DATAFORM %"「実験のためにザーメンが必要になったの。"%
	DATAFORM %"「調合に精液が要るのよ。"%
ENDDATA
IF TALENT:TARGET:施虐狂
	PRINTDATAL
		DATAFORM %" だから提供しなさい。全部ね」"%
		DATAFORM %" 抵抗する前に、とっとと出しちゃったほうが苦痛が少ないわよ」"%
		DATAFORM %" 痛くされたくなかったらおとなしくしなさい。痛いほうがいいのかしら？」"%
	ENDDATA
ELSE
	PRINTDATAL
		DATAFORM %" だから提供しなさい」"%
		DATAFORM %" 抵抗する前に、とっとと出しちゃったほうが楽よ」"%
		DATAFORM %" 痛くはしないから、おとなしくしなさい」"%
	ENDDATA
ENDIF
RETURN 1

@KOJO_MESSAGE_COUNTER_K3_29_2
IF CFLAG:PLAYER:跳蛋A挿入 != 0
	PRINTFORML 「早いわね・・跳蛋ってそんなにイイのかしら？」
ELSE
	PRINTFORML 「早いわね・・もしかしてお尻の方が好きなの？」
