;==================================================
;会话扩展：关于结婚戒指
;　前提：恋慕且人妻
;==================================================
@KOJO_MESSAGE_COM_K3_300_14_01(角色, 調教者)
#DIM 調教者
#DIM 角色
IF TALENT:角色:NTR
	;颈环优先
	PRINTFORML %"「已经不再是"+CALLNAME:MASTER+"的人了，所以没必要戴戒指。」她断言道。"%
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
	;佩戴率3成
	PRINTFORML %"「感觉尺寸不合手，最近不怎么戴戒指了。」她反驳道。"%
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
	;佩戴率5成
	PRINTFORML %"「最近手指容易肿，所以经常摘下来。」她找借口说。"%
	;ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
ELSE
	;佩戴率9成
	PRINTFORML %"「为了保养摘下来之后忘记戴回去了。」她道歉道。"%
ENDIF

RETURN 1

;==================================================
;会话扩展：关于内裤：ADULT内衣（小恶魔/淫乱)
;==================================================
@KOJO_MESSAGE_COM_K3_300_15_02(角色, 調教者, ノーパン)
#DIM 調教者
#DIM 角色
#DIM ノーパン
#DIMS 下着名

下着名 = %下着名１_２(角色)%
IF ノーパン
	PRINTFORML 「嗯，开放的很舒服哦？」
ELSE
	PRINTFORML 「嗯，难道说有点太刺激了？」
ENDIF
PRINTDATAL
	DATAFORM 「%CALLNAME:MASTER%也喜欢这样的，对吧？」
	DATAFORM 「%CALLNAME:MASTER%也喜欢这样的吧？」
	DATAFORM 「刚才%CALLNAME:MASTER%的眼神，很色哦？」
ENDDATA
IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
	PRINTFORML 「那个人也会高兴的」
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
	PRINTFORML 「那个人也会高兴的」
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
	PRINTFORML 「不只是%CALLNAME:MASTER%，那个人也会高兴的」
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
	PRINTFORML 「不只是%CALLNAME:MASTER%，那个人也会高兴的」
ELSE
	PRINTFORML 「不过我可不想让下半身着凉」
ENDIF
RETURN 1

