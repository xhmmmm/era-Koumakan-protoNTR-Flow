@KOJO_MESSAGE_COUNTER_K3_29_3
SELECTCASE BASE:PLAYER:精力
	CASE IS == 0
		;全部榨干了
		PRINTDATAL
			DATAFORM %"「已经结束了？嗯，榨了这么多大概够了吧」"%
			DATAFORM %"「这就到极限了吗？还想再多要一点的，不过没办法呢」"%
			DATAFORM %"「差不多该结束了吧？谢谢，帮大忙了」"%
		ENDDATA
	CASE IS < MAXBASE:PLAYER:精力 /2
		;榨了大半
		PRINTDATAL
			DATAFORM %"「出了不少呢。不过你应该还有余裕吧？」"%
			DATAFORM %"「恰到好处呢？不过看起来还很有精神。能再来一次吗？」"%
			DATAFORM %"「看起来还能继续呢？要不要再试试？」"%
		ENDDATA
	CASEELSE
		;只榨了一点
		PRINTDATAL
			DATAFORM %"「真厉害。虽然出了不少，但还远远不够哦？」"%
			DATAFORM %"「恰到好处呢？不过看起来还很有精神。继续吧？」"%
			DATAFORM %"「看起来还很从容呢？努力吧」"%
		ENDDATA
ENDSELECT
RETURN 1

;==================================================
;312,接吻
;==================================================
@KOJO_MESSAGE_COM_K3_312
IF TFLAG:193 == 0
	CALL TRAIN_MESSAGE
ENDIF
CALL KOJO_MESSAGE_COM_K3_312_1
RETURN RESULT
@KOJO_MESSAGE_COM_K3_312_1
;失败时
IF TFLAG:193 == -1
	PRINTDATAL
		DATAFORM 「住、住手」
		DATAFORM 「突然干什么！？」
		DATAFORM 「到此为止！」
	ENDDATA
	PRINTFORML 被拒绝了。
	;成功时
ELSE
	IF ABL:欲望 >= 5
		;彼此激烈地
		PRINTDATAL
			DATAFORM 「嗯……啾……咕啾……」
			DATAFORM 「啾……嘬……啾啪……」
			DATAFORM 「嗯……被舔了……嘞噜……」
		ENDDATA
		PRINTDATAL
			DATAFORM 互相贪婪地索取彼此的唇与舌，尽情品味着对方。
			DATAFORM 如啜饮般品味那柔软的舌尖，将清澈的甘露吞咽而下。
			DATAFORM 将唾液从探入%CALLNAME:TARGET%口中的舌头上渡过去，只见那白皙的喉间轻轻一动。
		ENDDATA
		PRINTDATAL
			DATAFORM 「哈……这还不是结束吧……？」
			DATAFORM 「呼……好舒服……再让我多喝一些……」
			DATAFORM 「呵呵……还不够呢……」
		ENDDATA
	ELSEIF ABL:亲密 >= 5
		;亲密地相互渴求
		PRINTDATAL
			DATAFORM 「嗯……啾……啾啪……」
			DATAFORM 「啾……嘬……」
			DATAFORM 「嗯……嗯嗯……啾……」
		ENDDATA
		PRINTDATAL
			DATAFORM 互相将唇凑近，品味那份柔软的触感。
			DATAFORM 以互相依偎的姿势交叠了双唇。
			DATAFORM 唇分开后，%CALLNAME:TARGET%双颊微红，似乎还在期待着后续。
		ENDDATA
		PRINTDATAL
			DATAFORM 「……结束了？」
			DATAFORM 「……你不觉得还有继续研究的余地吗……？」
			DATAFORM 「……好开心……」
		ENDDATA
	ELSE
		;突然袭击
		PRINTFORML 「嗯……！？」
		PRINTDATAL
			DATAFORM 似乎被打了个措手不及，嘴唇被夺走的%CALLNAME:TARGET%瞪大了眼睛。
			DATAFORM 双唇重叠，%CALLNAME:TARGET%一瞬间僵住了身子。
			DATAFORM 唇分开后，%CALLNAME:TARGET%深吸一口气，平复了心绪。
		ENDDATA
		PRINTDATAL
			DATAFORM 「……太突然了。对心脏不好」
			DATAFORM 「……光靠蛮横是不行的哦」
			DATAFORM 「……再多精进吧」
		ENDDATA
	ENDIF
ENDIF
RETURN 1

;==================================================
;通用处理
;==================================================
;-------------------------------------------
;帕秋莉称呼他人时的例外处理函数
;-------------------------------------------
@CALLNAME_K3(角色, 対象)
#FUNCTIONS
#DIM 角色
#DIM 対象
#DIMS 呼称

呼称 = %CALLNAME:対象%
IF CALLNAME:角色 == "パチュリー"
	IF CALLNAME:対象 == "蕾米莉亚"
		呼称 = レミィ
	ELSEIF CALLNAME:対象 == "フラン" || CALLNAME:対象 == "芙兰朵露"
		呼称 = フラン
	ELSE
	ENDIF
ELSE
	; 名称变更时使用默认
ENDIF
RETURNF 呼称
