@KOJO_MESSAGE_COUNTER_K3_29_1
#DIM 角色
角色 = 人物_帕秋莉
IF CFLAG:PLAYER:跳蛋A挿入 != 0
	;你菊花中插着跳蛋时的分支
	PRINTFORML %CALLNAME:角色%注意到%CALLNAME:PLAYER%的菊花里插着跳蛋，微微一笑。
	IF CFLAG:PLAYER:跳蛋挿入者 == 角色
		PRINTDATA
			DATAFORM %"「哎呀……看来有好好听话呢。"%
			DATAFORM %"「哎呀，没有擅自拔掉呢。"%
			DATAFORM %"「哎呀，是喜欢上跳蛋了吗？"%
		ENDDATA
	ELSE
		PRINTDATA
			DATAFORM %"「哎呀……是谁吩咐你的呢。"%
			DATAFORM %"「……这是谁放进去的呢？"%
			DATAFORM %"「不会是自己放进去的吧？"%
		ENDDATA
	ENDIF
	PRINTDATAL
		DATAFORM %" 正好，就这样给你弄吧」"%
		DATAFORM %" 舒服一点比较好吧？就这样不取出来给你弄吧」"%
		DATAFORM %" 喜欢跳蛋的话也没办法。就这样给你弄吧」"%
	ENDDATA
	PRINTL
ELSEIF EQUIP:PLAYER:下半身内衣_副 == 0 && EQUIP:PLAYER:下半身内衣_主 == 0
	;你没穿内裤时的分支
	PRINTFORML %CALLNAME:角色%注意到%CALLNAME:PLAYER%没有穿内裤，微微一笑。
	PRINTFORML 「哎呀……没穿内裤，呵呵，正好呢」
	PRINTDATAL
		DATAFORM %"「哎呀……没穿内裤，正好呢」"%
		DATAFORM %"「呵呵……没穿是什么养生法吗？」"%
		DATAFORM %"「……是被谁拿走了内裤吗？又干了什么好事？」"%
	ENDDATA
	PRINTL
ENDIF
PRINTDATA
	DATAFORM %"「为了霍蒙克鲁斯的研究，需要新鲜有活力的精液。"%
	DATAFORM %"「实验需要精液。"%
	DATAFORM %"「调配需要精液哦。"%
ENDDATA
IF TALENT:TARGET:施虐狂
	PRINTDATAL
		DATAFORM %" 所以，交出来。全部"%
		DATAFORM %" 在你抵抗之前赶紧射出来的话，痛苦会少一些哦」"%
		DATAFORM %" 不想被弄疼就老实点。还是说你更喜欢疼的？」"%
	ENDDATA
ELSE
	PRINTDATAL
		DATAFORM %" 所以，交出来吧」"%
		DATAFORM %" 在你抵抗之前赶紧射出来的话会轻松一些哦」"%
		DATAFORM %" 不会弄疼你的，老实点吧」"%
	ENDDATA
ENDIF
RETURN 1

