@KOJO_MESSAGE_COUNTER_K3_29_3
SELECTCASE BASE:PLAYER:精力
	CASE IS == 0
		;全部搾り取った
		PRINTDATAL
			DATAFORM %"「もうおしまい？ まぁこれだけ搾ればたぶん十分ね」"%
			DATAFORM %"「これで打ち止めかしら？ もう少し欲しかったけど、仕方ないわね」"%
			DATAFORM %"「いいかげん終わりかしら？ ありがとう、助かったわ」"%
		ENDDATA
	CASE IS < MAXBASE:PLAYER:精力 /2
		;大半搾り取った
		PRINTDATAL
			DATAFORM %"「結構出たわね。でもまだ余裕があるんじゃないかしら？」"%
			DATAFORM %"「いい塩梅ね？ でもまだ元気みたいね。もう一度、お願いできるかしら？」"%
			DATAFORM %"「まだまだいけそうね？ 頑張ってみる？」"%
		ENDDATA
	CASEELSE
		;少し搾り取った
		PRINTDATAL
			DATAFORM %"「さすがね。たっぷり出たけど、まだまだ足りないわよ？」"%
			DATAFORM %"「いい塩梅ね？ でもまだまだ元気みたいね。続けるわよ？」"%
			DATAFORM %"「まだまだ余裕でいけそうね？ 頑張りなさい」"%
		ENDDATA
ENDSELECT
RETURN 1

