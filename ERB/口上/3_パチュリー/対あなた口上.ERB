;==================================================
@KOJO_MESSAGE_COM_K3_312
IF TFLAG:193 == 0
	CALL TRAIN_MESSAGE
ENDIF
CALL KOJO_MESSAGE_COM_K3_312_1
RETURN RESULT
@KOJO_MESSAGE_COM_K3_312_1
;失敗時
IF TFLAG:193 == -1
	PRINTDATAL
		DATAFORM 「や、やめなさいっ」
		DATAFORM 「いきなり何をっ！？」
		DATAFORM 「そこまでよ！」
	ENDDATA
	PRINTFORML 拒絶されてしまった。
	;成功時
ELSE
	IF ABL:欲望 >= 5
		;互いに激しく
		PRINTDATAL
			DATAFORM 「んっ・・ちゅ・・くちゅっ・・」
			DATAFORM 「ちゅっ・・ぢゅっ・・ちゅぱっ・・」
			DATAFORM 「ん・・れる・・れろっ・・」
		ENDDATA
		PRINTDATAL
			DATAFORM 互いの唇と舌を貪り合い、その味を堪能した。
			DATAFORM 柔らかなその舌を啜るように味わい、清らかな露を飲み下した。
			DATAFORM %CALLNAME:TARGET%の口の中に送り込んだ舌から唾液を流し込むと、白い咽がこくりと鳴った。
		ENDDATA
		PRINTDATAL
			DATAFORM 「はぁ・・これでおわりじゃ、ないのよね・・？」
			DATAFORM 「ふ・・いいわ・・もっと飲ませて・・」
			DATAFORM 「ふふ・・まだ足りないわ・・」
		ENDDATA
	ELSEIF ABL:亲密 >= 5
		;親しく求め合うように
		PRINTDATAL
			DATAFORM 「んっ・・ちゅっ・・ちゅぱ・・」
			DATAFORM 「ちゅっ・・ぢゅ・・」
			DATAFORM 「ん・・んんっ・・ちゅ・・」
		ENDDATA
		PRINTDATAL
			DATAFORM 互いに唇を寄せ合い、柔らかなその味を堪能した。
			DATAFORM 互いに寄り添うような姿勢で唇を交わした。
			DATAFORM 唇を離すと、%CALLNAME:TARGET%は頬を染め続きを期待しているかのようであった。
		ENDDATA
		PRINTDATAL
			DATAFORM 「・・おしまい？」
			DATAFORM 「・・まだ研究の余地があると思わない・・？」
			DATAFORM 「・・うれしい・・」
		ENDDATA
	ELSE
		;不意打ちで
		PRINTFORML 「んっ・・！？」
		PRINTDATAL
			DATAFORM 不意を突かれたのか、唇を奪われた%CALLNAME:TARGET%は目を丸くしている。
			DATAFORM 唇を重ねられ、%CALLNAME:TARGET%は一瞬身を堅くした。
			DATAFORM 唇を離すと、%CALLNAME:TARGET%は一呼吸ついて気を静めた。
		ENDDATA
		PRINTDATAL
			DATAFORM 「・・いきなりなのね。心臓に悪いわ」
			DATAFORM 「・・強引なだけでは駄目よ」
			DATAFORM 「・・もっと精進なさい」
		ENDDATA
	ENDIF
ENDIF
RETURN 1

;==================================================
;汎用処理
;==================================================
;-------------------------------------------
;パチュリーが他の人を呼ぶときの例外処理関数
;-------------------------------------------
@CALLNAME_K3(角色, 対象)
#FUNCTIONS
#DIM 角色
#DIM 対象
#DIMS 呼称

呼称 = %CALLNAME:対象%
IF CALLNAME:角色 == "パチュリー"
	IF CALLNAME:対象 == "蕾米莉亚"
		呼称 = レミィ
	ELSEIF CALLNAME:対象 == "フラン" || CALLNAME:対象 == "芙兰朵露"
		呼称 = フラン
	ELSE
	ENDIF
ELSE
	; 名称変更時はデフォルトのまま
ENDIF
RETURNF 呼称
