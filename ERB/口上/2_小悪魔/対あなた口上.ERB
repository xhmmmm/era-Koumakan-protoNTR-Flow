;==================================================
;会话拡張：结婚戒指について
;　前提：恋慕かつ人妻
;==================================================
@KOJO_MESSAGE_COM_K2_300_14_01(角色, 調教者)
#DIM 調教者
#DIM 角色
IF TALENT:角色:NTR
	;チョーカーが優先
	PRINTFORML %"もう"+CALLNAME:MASTER+"のものではないのだから指輪をする必要は無いと言い切られた。"%
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
	;装着率３割
	IF TALENT:角色:浮気公認
		PRINTDATAL
			DATAFORM 「ふふっ、指輪はつけないようにしているんですよ♪」
			DATAFORM 「指輪ですか？最近はつけてない方が多いですね～」
			DATAFORM 「指輪ならお部屋の、鏡台の引き出しの中ですよ」
		ENDDATA
		PRINTDATAL
			DATAFORM 「だって、そのほうがあの方がよろこぶんですもの%MSG_HEART()%」
			DATAFORM 「デートに誘われたとき、结婚戒指なんてつけていたら無粋じゃないですか？」
			DATAFORM 「浮気して欲しいと言ったのは%CALLNAME:MASTER%でしたよね？」
		ENDDATA
		PRINTFORML 最近は意識して指輪を外しているのだと言われてしまった。
	ELSE
		PRINTFORML %"指に合わない感じがして、最近はあまり指輪をしないのだと言い返された。"%
	ENDIF
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
	;装着率５割
	IF TALENT:角色:浮気公認
		PRINTDATAL
			DATAFORM 「ごめんなさいっ、今日は忘れてしまって・・」
			DATAFORM 「た、たまたまです、たまたま」
			DATAFORM 「指輪ならお部屋ですよ？」
		ENDDATA
		PRINTDATAL
			DATAFORM 「そういう気分の時もあるんです」
			DATAFORM 「こうしているとフリーっぽくていいですよね？」
			DATAFORM 「でも、浮気して欲しいと言ったのは%CALLNAME:MASTER%でしたよね？」
		ENDDATA
		PRINTFORML 今日は敢えて指輪を外しているのだと言われてしまった。
	ELSE
		PRINTFORML %"最近指が腫れるので外している事が多いのだと言い訳された。"%
	ENDIF
	;ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
ELSE
	;装着率９割
	IF TALENT:角色:浮気公認
		PRINTDATAL
			DATAFORM 「ご、ごめんなさい、忘れてました」
			DATAFORM 「いっけな～い、うっかりしてました」
			DATAFORM 「あ・・ごめんなさい、部屋に置いてきました」
		ENDDATA
		PRINTDATAL
			DATAFORM 「うっかり本をこすってしまわないように、外したままにしてるんです」
			DATAFORM 「今日寝坊してしまって、慌ててたんです」
			DATAFORM 「明日は忘れないようにしますから、許してください」
		ENDDATA
		PRINTFORML 今日はたまたま指輪を外していたのだと謝られた。
	ELSE
		PRINTFORML %"手入れをするために外したまま忘れていたからだと謝られた。"%
	ENDIF
ENDIF

RETURN 1

