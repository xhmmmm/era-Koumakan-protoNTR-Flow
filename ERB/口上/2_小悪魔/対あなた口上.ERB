;-------------------------------------------
;小恶魔称呼他人时的例外处理函数
;-------------------------------------------
@CALLNAME_K2(角色, 対象)
#FUNCTIONS
#DIM 角色
#DIM 対象
#DIMS 呼称

呼称 = %CALLNAME:対象%さん
IF CALLNAME:角色 == "小恶魔"
	IF CALLNAME:対象 == "蕾米莉亚"
		呼称 = 蕾米莉亚大小姐
	ELSEIF CALLNAME:対象 == "フラン" || CALLNAME:対象 == "芙兰朵露"
		呼称 = 芙兰朵露大小姐
	ELSEIF CALLNAME:対象 == "パチュリー"
		呼称 = 帕秋莉大人
	ELSEIF CALLNAME:対象 == "子悪魔"
		呼称 = 子悪魔
	ELSE
	ENDIF
ELSE
	;名称变更时保持默认
ENDIF
RETURNF 呼称
