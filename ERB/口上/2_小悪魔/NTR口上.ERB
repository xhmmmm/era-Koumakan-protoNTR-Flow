;寝取られ补丁用小恶魔口上文件
;方针：小恶魔对H之事态度开放、贞操观念较低，因此出轨也很积极。
;以寝取られ补丁用咲夜口上文件为基础
;请随意填充内容
;然后如果可以的话请上传
;不，说真的
;注意：此口上被调用的前提是对象处于主人能看到的位置
;　　　或执行了筒抜け命令（调试用）的情况
;　　　对象并未察觉到被偷窥，书写时请注意这一点
;-------------------------------------------------


;==================================================
;与访问者交谈
;==================================================
;主人（MASTER）不在场
@NTR_KOJO_K2_1(角色)
#DIM 角色
;大浴场
IF CFLAG:角色:当前位置 == 位置_红魔馆_大浴场
	IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
		PRINTDATAL
			DATAFORM 「有什么地方痒吗？呵呵……」
			DATAFORM 「嘻，是这边吗？还是这边……？」
			DATAFORM 「呵呵，不光是外面，里面也一起洗洗吧……？」
		ENDDATA
		PRINTDATAL
			DATAFORM %CALLNAME:角色%把自己沾满泡沫的身体当作海绵，替%NTR_NAME(0)%清洗着身体。
			DATAFORM %CALLNAME:角色%把手伸向%NTR_NAME(0)%的下半身，仔细清洗到每一处角落。
			DATAFORM %CALLNAME:角色%的手指刺激到了微妙的位置，%NTR_NAME(0)%发出了一声低沉的闷哼。
		ENDDATA
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
		PRINTDATAL
			DATAFORM 「有什么地方痒吗？」
			DATAFORM 「我帮您擦背吧」
			DATAFORM 「诶？这边也要吗？呵呵……」
		ENDDATA
		PRINTDATAL
			DATAFORM %CALLNAME:角色%在为%NTR_NAME(0)%冲洗背部。
			DATAFORM %CALLNAME:角色%拿着海绵为%NTR_NAME(0)%清洗身体。
			DATAFORM %CALLNAME:角色%用起泡的毛巾擦拭着%NTR_NAME(0)%的后背。
		ENDDATA
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
		PRINTDATAL
			DATAFORM 「呀嗯，真是好色呢」
			DATAFORM 「啊，真是的，性骚扰哦？」
			DATAFORM 「不、不行，不可以乱捏啦」
		ENDDATA
		PRINTDATAL
			DATAFORM 坐在%NTR_NAME(0)%旁边的%CALLNAME:角色%即便偶尔被碰到身体也没有试图躲开。
			DATAFORM %NTR_NAME(0)%正享受着坐在身旁的%CALLNAME:角色%身体的柔软触感。
			DATAFORM %NTR_NAME(0)%对坐在旁边的%CALLNAME:角色%的身体东摸西摸，但在试图捏她腰侧时被瞪了一眼，总算停了手。
		ENDDATA
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)
		PRINTDATAL
			DATAFORM 「呵呵，是呢」
			DATAFORM 「是啊，我也这么觉得」
			DATAFORM 「不过其实呢……」
		ENDDATA
		IF IS_NTR_SOFT()
			PRINTDATAL
				DATAFORM %CALLNAME:角色%在%NTR_NAME(0)%身旁，不在意其他视线地交谈着。
				DATAFORM %CALLNAME:角色%沉浸于对话中，连%NTR_NAME(0)%的视线都不在意。
				DATAFORM %NTR_NAME(0)%趁着%CALLNAME:角色%不在意，注视着她赤裸的身体。
			ENDDATA
		ELSE
			PRINTDATAL
				DATAFORM %CALLNAME:角色%在%NTR_NAME(0)%身旁，不在意那仿佛要舔遍全身般的视线地交谈着。
				DATAFORM %CALLNAME:角色%沉浸于对话中，连%NTR_NAME(0)%那舔舐般的视线都不在意。
				DATAFORM %NTR_NAME(0)%趁着%CALLNAME:角色%不在意，将她赤裸的身体从头到脚打量了个遍。
			ENDDATA
		ENDIF
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_体を触らせる程度)
		PRINTDATAL
			DATAFORM 「呵呵，是呢」
			DATAFORM 「啊～你笑了吧？」
			DATAFORM 「说到这个，居然还有这种事……」
		ENDDATA
		PRINTFORML %CALLNAME:角色%不在意%NTR_NAME(0)%的视线地交谈着。
		;ELSEIF NTR_CHK_FAVORABLY(角色, FAV_接吻程度)
	ELSE
		PRINTDATAL
			DATAFORM 「请不要一直盯着我看……」
			DATAFORM 「请不要看太多了好吗？」
			DATAFORM 「请不要只盯着我看嘛」
		ENDDATA
		PRINTFORML %CALLNAME:角色%为了躲避%NTR_NAME(0)%的视线，在浴池里换了位置。
	ENDIF
	;其他
ELSE
	IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
		PRINTDATAL
			DATAFORM 「呵呵，去我房间好不好……？」
			DATAFORM 「呵呵，内衣的颜色，您在意吗？」
			DATAFORM 「嘻……下次再叫我哦？」
		ENDDATA
		PRINTFORML %CALLNAME:角色%依偎在%NTR_NAME(0)%身上说着话。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
		PRINTDATAL
			DATAFORM 「哎呀，那听起来真有趣呢」
			DATAFORM 「呵呵，可以哦，下次再说」
			DATAFORM 「诶？是这样的啊……」
		ENDDATA
		PRINTFORML %CALLNAME:角色%开心地笑着。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
		PRINTDATAL
			DATAFORM 「呀嗯，请住手」
			DATAFORM 「真是的，性骚扰哦？」
			DATAFORM 「我倒无所谓，但对大小姐可不能做这种事哦？」
		ENDDATA
		PRINTFORML 遭到轻度性骚扰的%CALLNAME:角色%嘴上虽然这么说，却对%NTR_NAME(0)%露出了笑容。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)
		PRINTDATAL
			DATAFORM 「是这样的吗？」
			DATAFORM 「第一次听说」
			DATAFORM 「啊，那个的话……」
		ENDDATA
		PRINTFORML %CALLNAME:角色%微笑着与%NTR_NAME(0)%交谈。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_体を触らせる程度)
		PRINTDATAL
			DATAFORM 「哎呀，是这样的吗？」
			DATAFORM 「是这样啊？」
			DATAFORM 「也有这种事吗？」
		ENDDATA
		PRINTFORML %CALLNAME:角色%似乎对对方的话题产生了兴趣。
		;ELSEIF NTR_CHK_FAVORABLY(角色, FAV_接吻程度)
	ELSE
		PRINTDATAL
			DATAFORM 「哎呀，是吗」
			DATAFORM 「是这样啊」
			DATAFORM 「也许会有这种事吧」
		ENDDATA
		PRINTFORML %CALLNAME:角色%兴趣寥寥地回答着。
	ENDIF
ENDIF
RETURN 0

;玩家在场
@NTR_KOJO_KW2_1(角色)
#DIM 角色
;大浴场
IF CFLAG:角色:当前位置 == 位置_红魔馆_大浴场
