;==================================================
;会话拡張：结婚戒指について
;　前提：恋慕かつ人妻
;==================================================
@KOJO_MESSAGE_COM_K5_300_14_01(角色, 調教者)
#DIM 調教者
#DIM 角色
IF TALENT:角色:NTR
	;チョーカーが優先
	PRINTFORML %"因为已经不是"+CALLNAME:MASTER+"的了、所以断言没有必要戴戒指"%
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
	;装着率３割
	PRINTFORML %"感觉手指不合适、她反驳说最近不太戴戒指."%
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
	;装着率５割
	PRINTFORML %"最近手指肿了、所以经常摘下来。"%
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
	;装着率９割
	PRINTFORML %"为打保养、拿下来就给忘了、所以我向我赔了个不是"%
ENDIF

RETURN 1

;==================================================
;会话拡張：ぱんつについて：ADULT下着（小恶魔/淫乱)
;==================================================
@KOJO_MESSAGE_COM_K5_300_15_02(角色, 調教者, ノーパン)
#DIM 調教者
#DIM 角色
#DIM ノーパン
#DIMS 下着名

下着名 = %下着名１_２(角色)%
IF ノーパン
	PRINTFORML 「库库、又开放又舒服呢？」
ELSE
	PRINTFORML 「库库、是不是太刺激了？」
ENDIF
PRINTDATAL
	DATAFORM 「%CALLNAME:MASTER%也喜欢这样吗？」
	DATAFORM 「%CALLNAME:MASTER%也喜欢这样啊」
	DATAFORM 「能看见我这样穿，你很高兴吧？」
ENDDATA
IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
	PRINTFORML 「而且那个人也会很高兴的」
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
	PRINTFORML 「而且、他也会很高兴的」
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
	PRINTFORML 「而且，不仅是%CALLNAME:MASTER%喜欢他也会很高兴的」
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
	PRINTFORML 「而且、不仅仅是%CALLNAME:MASTER%、他也很高兴」
ELSE
	;
ENDIF
RETURN 1

