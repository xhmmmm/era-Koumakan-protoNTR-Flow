	PRINTDATAL
		DATAFORM 「・・无礼之人」
		DATAFORM 「・・太慢了」
		DATAFORM 「・・我可没那种心情」
	ENDDATA
	PRINTFORML 被拒绝了、然后就被撞倒了。
	;成功時
ELSE
	IF ABL:欲望 >= 5
		;互いに激しく
		PRINTDATAL
			DATAFORM 「嗯・・嗯呼・・库姆・・」
			DATAFORM 「啾・・啾哈・・呼噗・・」
			DATAFORM 「嗯・・呼啊・・啾噗・・」
		ENDDATA
		PRINTDATAL
			DATAFORM 互相缠绕着嘴唇和舌头，品尝着它的滋味。
			DATAFORM 用送入%CALLNAME:TARGET%嘴中的舌头舔舐着每颗牙齿。包括尖锐的虎牙。
			DATAFORM 从送入%CALLNAME:TARGET%口中的舌头流出唾液时、娇嫩的咽喉中发出了呼噜噜的声音。
		ENDDATA
		PRINTDATAL
			DATAFORM 「库库・・胆子挺肥啊、居然把舌头塞进吸血鬼的嘴里。你想让我咬你吗？」
			DATAFORM 「继续・・再给我一些。直到我满意为止」
			DATAFORM 「技术已经成长了啊。库库、谁教你的？」
		ENDDATA
	ELSEIF ABL:亲密 >= 5
		;親しく求め合うように
		PRINTDATAL
			DATAFORM 「嗯・・啾・・」
			DATAFORM 「啾・・啾・・」
			DATAFORM 「嗯・・嗯嗯・・啾・・」
		ENDDATA
		PRINTDATAL
			DATAFORM 互相贴近嘴唇、品尝着柔软的感觉。
			DATAFORM 搂住娇小的身子轻轻咬着嘴唇
			DATAFORM 嘴唇离开时、%CALLNAME:TARGET%露出了期待的表情。
		ENDDATA
		PRINTDATAL
			DATAFORM 「库库库・・能让我玩得开心吗。下次从这边开始吧？」
			DATAFORM 「嗯・・没错。你要是又有欲望了、可以随时过来哦」
			DATAFORM 「库库库・・不是已经熟练了吗？再去练练技术，让我愉悦吧」
		ENDDATA
	ELSE
		;不意打ちで
		PRINTFORML 「嗯・・！？」
		PRINTDATAL
			DATAFORM 可能是突如其来，被夺走了嘴唇的%CALLNAME:TARGET%睁大了眼睛。
			DATAFORM 当嘴唇重叠时、%CALLNAME:TARGET%的身子一下子僵硬了
			DATAFORM 嘴唇离开时、%CALLNAME:TARGET%呼了一口气让自己冷静下来。
		ENDDATA
		PRINTDATAL
			DATAFORM 「・・没想到啊。这次我原谅你了」
			DATAFORM 「・・如果对%CALLNAME:人物_芙兰朵露%出手的话・・你应该知道后果吧？」
			DATAFORM 「・・还差得远呢」
		ENDDATA
	ENDIF
ENDIF
RETURN 1
