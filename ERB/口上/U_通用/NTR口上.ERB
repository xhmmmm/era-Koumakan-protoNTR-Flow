;==================================================
;「恋人」「伴侶」生成
;　从角色视角生成「你」的立场
;　　恋慕→恋人　人妻→丈夫等
;==================================================
@MSG_LOVER(角色)
#FUNCTIONS
#DIM 角色
IF TALENT:角色:人妻
	;同性情侣的情况
	IF (HAS_VAGINA(角色) && HAS_VAGINA(MASTER)) || (!HAS_VAGINA(角色) && !HAS_VAGINA(MASTER))
		IF RAND(2)== 0
			RETURNF "伴侶"
		ELSE
			RETURNF "配偶"
		ENDIF
	ELSEIF HAS_VAGINA(MASTER)
		RETURNF "妻子"
	ELSE
		RETURNF "丈夫"
	ENDIF
ELSEIF TALENT:角色:恋慕
	;「温顺」的话1/2概率为「思念之人」
	IF TALENT:角色:应答 == -1
		RETURNF "思念之人"
	ELSE
		RETURNF "恋人"
	ENDIF
ELSE
	;目前是保险措施
	RETURNF "熟人"
ENDIF

;==================================================
;「恋人」「伴侶」生成（逆)
;　从「你」视角生成角色的立场
;　　恋慕→恋人　人妻→丈夫等
;==================================================
@MSG_RE_LOVER(角色)
#FUNCTIONS
#DIM 角色
IF TALENT:角色:人妻
	;同性情侣的情况
	IF (HAS_VAGINA(角色) && HAS_VAGINA(MASTER)) || (!HAS_VAGINA(角色) && !HAS_VAGINA(MASTER))
		IF RAND(2)== 0
			RETURNF "伴侶"
		ELSE
			RETURNF "配偶"
		ENDIF
	ELSEIF HAS_VAGINA(角色)
		RETURNF "妻"
	ELSE
		RETURNF "夫"
	ENDIF
ELSEIF TALENT:角色:恋慕
	RETURNF "恋人"
ELSE
	;目前是保险措施
	RETURNF "熟人"
ENDIF

;==================================================
;「身为恋人的你」生成
;　角色对「你」有恋慕时，变成「身为恋人的你」等表现
;==================================================
@ANATA_LOVER(角色)
#FUNCTIONS
#DIM 角色
IF TALENT:角色:恋慕
	RETURNF MSG_LOVER(角色)+"的"+CALLNAME:MASTER
ELSE
	RETURNF CALLNAME:MASTER
ENDIF

;==================================================
;下半身描写
;　根据是否穿内裤返回「穿着○○的下半身」或「什么都没穿的下半身」
;==================================================
@BOTTOM_BODY(角色)
#FUNCTIONS
#DIM 角色
IF EQUIP:角色:下半身内衣_副
	RETURNF "穿着"+PANTSNAME(EQUIP:角色:下半身内衣_副)+"的下半身"
ELSEIF !EQUIP:角色:下半身内衣_主
	RETURNF "什么都没穿的下半身"
ELSE
	RETURNF "穿着"+PANTSNAME(EQUIP:角色:下半身内衣_主)+"的下半身"
ENDIF


