;-------------------------------------------------
;NTR补丁用通用口上文件
;以咲夜小姐的口上为基础，所以根据角色不同可能会有很大的违和感
;
;注意：此口上仅在被玩家能看见的位置时
;　　　或执行偷窥命令(调试用)时才会被调用
;　　　前提是对象没有察觉到，所以编写时请注意
;　　　部分同席状态下的口上也会存在，用函数名区分
;　　　NTR_KOJO_K_n   玩家不在场
;　　　NTR_KOJO_KW_n  玩家在场
;
;基本反应
;　寝取られ　……… 兴高采烈地做爱。连处女之身都献出去了。
;　寝取られ寸前　… 与寝取られ基本相同。只是恋慕时有分支而已。
;　寝取られそう　… 寝取られ寸前＋α
;　主人より高い　… 虽然对跨越底线犹豫不决，但还是被侵犯的感觉。
;　その他　………… 被强行侵犯的感觉
;-------------------------------------------------

;==================================================
;与访问者对话
;==================================================
;主人(玩家)不在场
@NTR_KOJO_K_1(角色)
#DIM 角色
;大浴场
IF CFLAG:角色:当前位置 == 位置_红魔馆_大浴场
	IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
		PRINTFORML %CALLNAME:角色%一边擦洗%NTR_NAME(0)%的后背，一边用手套弄着他的胯下。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
		PRINTFORML 在%NTR_NAME(0)%身旁入浴的%CALLNAME:角色%即使偶尔被碰到肌肤也不试图逃离。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
		IF IS_NTR_SOFT()
			PRINTFORML 在%NTR_NAME(0)%极近处入浴的%CALLNAME:角色%毫无遮挡裸体的意思。
		ELSE
			PRINTFORML 在%NTR_NAME(0)%极近处入浴的%CALLNAME:角色%毫不遮挡仿佛要将裸体暴露在舔舐般的视线中。
		ENDIF
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)
		PRINTFORML 在%NTR_NAME(0)%附近入浴的%CALLNAME:角色%毫不遮挡暴露在视线中的裸体。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_体を触らせる程度)
		IF IS_NTR_SOFT()
			PRINTFORML %CALLNAME:角色%因%NTR_NAME(0)%的视线而染红了脸颊。
		ELSE
			PRINTFORML %CALLNAME:角色%责备了%NTR_NAME(0)%那无礼的视线。
		ENDIF
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_接吻程度)
		PRINTFORML %CALLNAME:角色%为躲避%NTR_NAME(0)%的视线而改变了姿势。
	ELSE
		PRINTFORML %CALLNAME:角色%为躲避%NTR_NAME(0)%的视线而改变了姿势。
	ENDIF
	;其他
ELSE
	IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
		PRINTFORML %CALLNAME:角色%陶醉地染红脸颊微笑着。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
		PRINTFORML %CALLNAME:角色%陶醉地染红脸颊微笑着。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
		PRINTFORML %CALLNAME:角色%染红脸颊微笑着。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
		PRINTFORML %CALLNAME:角色%开心地笑着。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
		PRINTFORML %CALLNAME:角色%像害怕什么似的把话咽了回去。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)
		PRINTFORML %CALLNAME:角色%不安地回答着。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_体を触らせる程度)
		PRINTFORML %CALLNAME:角色%毫无兴趣地回答着。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_接吻程度)
		PRINTFORML %CALLNAME:角色%毫无兴趣地回答着。
	ELSE
		PRINTFORML %CALLNAME:角色%毫无兴趣地回答着。
	ENDIF
ENDIF
RETURN 0

;玩家在场
@NTR_KOJO_KW_1(角色)
#DIM 角色
;大浴场
IF CFLAG:角色:当前位置 == 位置_红魔馆_大浴场
	IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ) || NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
		PRINTFORML %CALLNAME:角色%紧贴着%NTR_NAME(0)%入浴。
		PRINTFORML %NTR_NAME(0)%的手在%CALLNAME:角色%身上各处抚摸游走。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
		PRINTFORML %CALLNAME:角色%与%CALLNAME:MASTER%保持距离，在%NTR_NAME(0)%附近交谈着。
		PRINTFORML 似乎并不太在意那仿佛舔遍全身般的视线。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
		PRINTFORML 被%NTR_NAME(0)%那舔舐般的视线弄得害羞的%CALLNAME:角色%，用依赖般的眼神看着%CALLNAME:MASTER%。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)
		PRINTFORML 感觉到%NTR_NAME(0)%视线的%CALLNAME:角色%不安地向%CALLNAME:MASTER%使眼色。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_体を触らせる程度)
		PRINTFORML 感觉到%NTR_NAME(0)%视线的%CALLNAME:角色%稍微向%CALLNAME:MASTER%那边移动拉开了距离。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_接吻程度)
		PRINTFORML 感觉到%NTR_NAME(0)%视线的%CALLNAME:角色%稍微向%CALLNAME:MASTER%那边移动拉开了距离。
	ELSE
		PRINTFORML 感觉到%NTR_NAME(0)%视线的%CALLNAME:角色%稍微向%CALLNAME:MASTER%那边移动拉开了距离。
	ENDIF
	;其他
ELSE
	IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ) || NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
		PRINTFORML %CALLNAME:角色%对%CALLNAME:MASTER%看都不看一眼，只顾着和%NTR_NAME(0)%说话。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
		PRINTFORML %CALLNAME:角色%不看%CALLNAME:MASTER%这边，只和%NTR_NAME(0)%说话。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
		PRINTFORML %CALLNAME:角色%不看%CALLNAME:MASTER%这边，只和%NTR_NAME(0)%说话。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
		IF IS_NTR_SOFT()
			PRINTFORML %CALLNAME:角色%向%CALLNAME:MASTER%露出笑容，但时不时向%NTR_NAME(0)%投去意味深长的视线。
		ELSE
			PRINTFORML %CALLNAME:角色%用依赖般的眼神看着%CALLNAME:MASTER%。
		ENDIF
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)
		IF IS_NTR_SOFT()
			PRINTFORML %CALLNAME:角色%向%CALLNAME:MASTER%露出笑容，但时不时偷偷看向%NTR_NAME(0)%那边。
		ELSE
			PRINTFORML %CALLNAME:角色%不安地向%CALLNAME:MASTER%使眼色。
		ENDIF
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_体を触らせる程度)
		PRINTFORML %CALLNAME:角色%开心地向%CALLNAME:MASTER%露出笑容。
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_接吻程度)
		PRINTFORML %CALLNAME:角色%开心地向%CALLNAME:MASTER%露出笑容。
	ELSE
		PRINTFORML %CALLNAME:角色%开心地向%CALLNAME:MASTER%露出笑容。
	ENDIF
ENDIF
RETURN 0

;==================================================
;与访问者接吻
;==================================================
;开始
@NTR_KOJO_K_2_0(角色)
#DIM 角色

IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)

	PRINTDATAL
		DATAFORM 「哈啊嗯……啾……%MSG_HEART()%」
		DATAFORM 「啾……嗯……%MSG_HEART()%」
		DATAFORM 「吻我……嗯……%MSG_HEART()%」
	ENDDATA
	IF NTR_CHK_PEEP_CONT(角色)
		PRINTFORML %CALLNAME:角色%主动抱住%NTR_NAME(0)%，仿佛要向%CALLNAME:MASTER%展示般缠绕上舌头。
	ELSE
		PRINTFORML %CALLNAME:角色%主动向%NTR_NAME(0)%缠绕上舌头。
	ENDIF

ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)

	PRINTDATAL
		DATAFORM 「哈啊嗯……啾……%MSG_HEART()%」
		DATAFORM 「啾……嗯……%MSG_HEART()%」
		DATAFORM 「吻我……嗯……%MSG_HEART()%」
	ENDDATA
	IF NTR_CHK_PEEP_CONT(角色)
		IF NTR_CHK_PEEP_CONT(角色) 
			PRINTFORML %CALLNAME:角色%主动抱住%NTR_NAME(0)%，仿佛要向%ANATA_LOVER(角色)%展示般重叠双唇缠绕上舌头。
		ELSE
			PRINTFORML %CALLNAME:角色%主动抱住%NTR_NAME(0)%，仿佛不在意%ANATA_LOVER(角色)%的视线般重叠双唇缠绕上舌头。
		ENDIF
	ELSE
		IF TALENT:角色:恋慕
			PRINTFORML %CALLNAME:角色%忘记了%CALLNAME:MASTER%的存在，主动向%NTR_NAME(0)%重叠双唇缠绕上舌头。
		ELSE
			PRINTFORML %CALLNAME:角色%主动向%NTR_NAME(0)%重叠双唇缠绕上舌头。
		ENDIF
	ENDIF

ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)

	PRINTDATAL
		DATAFORM 「哈啊嗯……啾……♪」
		DATAFORM 「啾……嗯……♪」
		DATAFORM 「吻我……嗯……♪」
	ENDDATA
	IF NTR_CHK_PEEP_CONT(角色) 
		IF NTR_CHK_MISETUKE(角色)
			PRINTFORML %CALLNAME:角色%主动抱住%NTR_NAME(0)%，仿佛要向%ANATA_LOVER(角色)%展示般重叠双唇。
		ELSE
			PRINTFORML %CALLNAME:角色%主动抱住%NTR_NAME(0)%，一边在意着%ANATA_LOVER(角色)%的视线一边重叠双唇。
		ENDIF
	ELSE
		IF TALENT:角色:恋慕
			PRINTFORML %CALLNAME:角色%忘记了%CALLNAME:MASTER%的存在，主动向%NTR_NAME(0)%重叠双唇。
		ELSE
			PRINTFORML %CALLNAME:角色%主动向%NTR_NAME(0)%重叠双唇。
		ENDIF
	ENDIF

ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)

	PRINTDATAL
		DATAFORM 「嗯咕……嗯呜咕」
		DATAFORM 「嗯咕！ 嗯嗯咕……」
		DATAFORM 「嗯咕 嗯……嗯嗯咕……」
	ENDDATA
	IF NTR_CHK_PEEP_CONT(角色)
		PRINTFORML %CALLNAME:角色%在%ANATA_LOVER(角色)%的视线注视下被重叠了双唇。
		IF NTR_CHK_MISETUKE(角色)
			PRINTFORML %CALLNAME:角色%没有抵抗%NTR_NAME(0)%，接受了被送入口中的他人的舌头。
		ELSE
			PRINTFORML %CALLNAME:角色%脸颊通红，但当%NTR_NAME(0)%的舌头侵入她口中后逐渐变得乖顺，最终接受了那条舌头。
		ENDIF
	ELSE
		PRINTFORML %CALLNAME:角色%被%NTR_NAME(0)%重叠了双唇却没有拒绝。
	ENDIF

ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)

	PRINTDATAL
		DATAFORM 「诶？　嗯咕……嗯呜咕！！」
		DATAFORM 「什么……嗯咕！ 嗯嗯咕……！」
		DATAFORM 「嗯咕！？ 嗯……嗯嗯咕……」
	ENDDATA
	IF NTR_CHK_PEEP_CONT(角色)
		PRINTFORML %CALLNAME:角色%在%ANATA_LOVER(角色)%的视线注视下被夺走了双唇。
		IF NTR_CHK_MISETUKE(角色)
			PRINTFORML %CALLNAME:角色%没有抵抗%NTR_NAME(0)%，接受了被送入口中的他人的舌头。
		ELSE
			PRINTFORML %CALLNAME:角色%微弱地抵抗着，但当%NTR_NAME(0)%的舌头侵入她口中后逐渐变得乖顺，最终接受了那条舌头。
		ENDIF
	ELSE
		PRINTFORML %CALLNAME:角色%被%NTR_NAME(0)%夺走了双唇却没有拒绝。
	ENDIF

	;其他
ELSE

	PRINTDATAL
		DATAFORM 「诶？　嗯咕、嗯嗯呜咕！！」
		DATAFORM 「不要……不要……嗯嗯咕！」
		DATAFORM 「嗯嗯咕！？ 不要……嗯……」
	ENDDATA
	IF NTR_CHK_PEEP_CONT(角色)
		PRINTFORML %CALLNAME:角色%在%ANATA_LOVER(角色)%的视线注视下被夺走了双唇。
	ELSE
		IF TALENT:角色:恋慕
			PRINTFORML %CALLNAME:角色%被%ANATA_LOVER(角色)%以外的男人粗暴地夺走了双唇。	
		ELSE
			PRINTFORML %CALLNAME:角色%被%NTR_NAME(0)%粗暴地夺走了双唇。	
		ENDIF
	ENDIF

ENDIF
RETURN 0

