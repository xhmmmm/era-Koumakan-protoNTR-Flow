		PRINTFORML 但不想让这件事被知道的%CALLNAME:角色%，也无法向%CALLNAME:MASTER%求救。
	ELSE
	ENDIF

ENDIF

;==================================================
;拥抱前口上
;==================================================
@NTR_KOJO_K6_COM311_0
;寝取られ
IF TALENT:6:NTR
	;好感度低的话会很冷淡
	IF CFLAG:6:好感度 < 500
		PRINTFORML 「嗯・・・会被主人骂的哦」
	ELSE
		PRINTFORML 「嗯・・・要对主人保密哦？」
	ENDIF

	;寝取られ寸前
ELSEIF CFLAG:6:好感度 < 1000 && CFLAG:6:屈服度 > CFLAG:6:好感度 && TALENT:6:恋慕

ELSE
ENDIF

RETURN 0
