@NTR_KOJO_MESSAGE_COM_K6_312
IF TFLAG:193 == 0
	CALL TRAIN_MESSAGE
ENDIF
CALL NTR_KOJO_MESSAGE_COM_K6_312_1
IF 1 == RESULT
	; 返回值为1时，执行非NTR对应口上
	TRYCALL KOJO_MESSAGE_COM_K6_312_1
ENDIF
RETURN RESULT

@NTR_KOJO_MESSAGE_COM_K6_312_1
#DIM 角色
#DIM RET_VAL

角色 = 人物_芙兰朵露
RET_VAL = 0

;因嘴唇污渍被拒绝时
IF TFLAG:193 == -2
	PRINTFORML 「不、不行！」
	PRINTFORML 虽然不知道原因，但在嘴唇碰到之前就被拒绝了。
	PRINTFORML 「呐，给我倒杯茶嘛。可以吧？」
	PRINTFORML %CALLNAME:角色%似乎想要喝茶。
	;失败时
ELSEIF TFLAG:193 == -1
	;成功时
	IF TALENT:TARGET:恋慕
		PRINTDATAL
			DATAFORM 「・・呀！・・啊，对不起，吓了一跳」
			DATAFORM 「・・呀んっ・・啊，没事吧？」
			DATAFORM 「・・呀っ・・啊・・对、对不起？」
		ENDDATA
		PRINTFORML 反射性地推开了%CALLNAME:MASTER%，正担心地凑近看TA的脸。
	ELSE
		PRINTDATAL
			DATAFORM 「・・你、你干什么啦！」
			DATAFORM 「・・呀んっ！！」
			DATAFORM 「・・呀！」
		ENDDATA
		PRINTFORML 被拒绝，还被推开了。
	ENDIF
ELSE
	IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
		;嘴唇被精液弄脏时
		IF CFLAG:射精者M != 0 && STAIN:口 & 汚れ_精液
			PRINTFORML 与%CALLNAME:角色%接吻的%CALLNAME:MASTER%对她唾液的味道感到异样，离开了嘴唇。
			PRINTFORML 「・・啊，苦吗？对不起呢・・呵呵」
			;好感度低时冷淡
		ELSE
			PRINTDATAL
				DATAFORM 「嗯っ・・不要・・会被骂的」
				DATAFORM 「嗯っ・・不行・・不行的」
				DATAFORM 「嗯っ・・明明・・已经不行的说・・」
			ENDDATA
			PRINTFORML %CALLNAME:TARGET%虽然没有拒绝，却用冷冰冰的眼神瞪着%CALLNAME:MASTER%。
		ENDIF
	ELSEIF ABL:欲望 >= 5
		;互相激烈地
		PRINTDATAL
			DATAFORM 「嗯っ・・嗯嗯っ・・啾啾っ・・」
			DATAFORM 「啾っ・・啾っ・・啾啪っ・・」
			DATAFORM 「嗯・・进来了・・舔舔っ・・」
		ENDDATA
		PRINTDATAL
			DATAFORM 互相贪婪地索取着彼此的唇与舌，尽情享受着其中的滋味。
			DATAFORM 把舌头伸进%CALLNAME:TARGET%的嘴里，舔过她的每一颗牙齿。连尖锐的獠牙也不放过。
			DATAFORM 把唾液从伸进%CALLNAME:TARGET%嘴里的舌头上注入进去，白色的喉咙发出咕嘟一声。
		ENDDATA
		IF NTR_CHK_FAVORABLY(TARGET, FAV_寝取られ寸前) || NTR_CHK_FAVORABLY(TARGET, FAV_寝取られそう)
			PRINTDATAL
				DATAFORM 「・・呐，就这些？」
				DATAFORM 「・・还想・・再做点・・」
				DATAFORM 「・・呵呵，想要更多%CALLNAME:TARGET%对吧？」
			ENDDATA
			PRINTFORML 凝视着%CALLNAME:MASTER%的%CALLNAME:TARGET%的视线中，能感受到一种饥渴般的热度。
		ELSE
			PRINTDATAL
				DATAFORM 「嗯ん・・可以舔得更深哦・・」
				DATAFORM 「嗯呵・・好厉害呢，%CALLNAME:MASTER%・・变得更想要了」
				DATAFORM 「嗯・・更多・・再多弄点・・」
			ENDDATA
		ENDIF
	ELSEIF ABL:亲密 >= 5
		;亲密地互相渴求
		PRINTDATAL
			DATAFORM 「嗯・・啾っ・・」
			DATAFORM 「啾っ・・啾啾・・」
			DATAFORM 「嗯・・嗯嗯・・」
		ENDDATA
		PRINTDATAL
			DATAFORM 互相靠近嘴唇，轻轻地让舌头微微颤动。
			DATAFORM 抱紧小小的身体，持续着嘴唇的交叠。
			DATAFORM 嘴唇分开后，%CALLNAME:TARGET%满脸通红地望着%CALLNAME:MASTER%。
		ENDDATA
		IF NTR_CHK_FAVORABLY(TARGET, FAV_寝取られ寸前) || NTR_CHK_FAVORABLY(TARGET, FAV_寝取られそう)
			PRINTDATAL
				DATAFORM 「呵呵・・对嘛。就得这样才行」
				DATAFORM 「嗯・・对哦。想让你多亲亲我嘛」
				DATAFORM 「嗯・・想再做更多」
			ENDDATA
			PRINTFORML 凝视着%CALLNAME:MASTER%的%CALLNAME:TARGET%的视线中，能感受到一种饥渴般的热度。
		ELSE
			PRINTDATAL
				DATAFORM 「啊・・就这些？还会再做的对吧？」
				DATAFORM 「嗯・・嗯，可以再多弄点哦・・」
				DATAFORM 「嗯・・%CALLNAME:MASTER%・・最喜欢了・・」
			ENDDATA
		ENDIF
	ELSE
		;突然袭击
		PRINTFORML 「嗯っ・・！？」
		PRINTDATAL
			DATAFORM 也许是猝不及防，被夺走嘴唇的%CALLNAME:TARGET%先是一愣，随后停顿了一拍，脸变得通红。
			DATAFORM 嘴唇被叠上，%CALLNAME:TARGET%浮现出惊讶的表情。
			DATAFORM 嘴唇分开后，%CALLNAME:TARGET%屏住了呼吸好一会儿，终于发出了声音。
		ENDDATA
		PRINTDATAL
			DATAFORM 「・・打招呼的亲亲，亲脸颊就好啦？」
			DATAFORM 「・・吓、吓死我了」
			DATAFORM 「・・诶・・刚才那个・・？」
		ENDDATA
	ENDIF
ENDIF
RETURN RET_VAL

