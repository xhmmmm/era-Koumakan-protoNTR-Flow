;==================================================
;会话拡張：结婚戒指について
;　前提：恋慕かつ人妻
;==================================================
@KOJO_MESSAGE_COM_K6_300_14_01(角色, 調教者)
#DIM 調教者
#DIM 角色

IF TALENT:角色:NTR
	;チョーカーが優先
	PRINTFORML %"もう"+CALLNAME:MASTER+"のものではないのだから指輪をする必要は無いと言い切られた。"%
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
	;装着率３割
	IF TALENT:角色:浮気公認
		PRINTDATAL
			DATAFORM 「えへへっ、指輪はつけてないんだ」
			DATAFORM 「指輪？最近はつけてないよ」
			DATAFORM 「指輪なら外してきたよ？」
		ENDDATA
		PRINTDATAL
			DATAFORM 「だって、そのほうがウワキっぽいよね%MSG_HEART()%」
			DATAFORM 「デートのお誘いがあった時に、结婚戒指なんてしないよね？」
			DATAFORM 「ウワキして欲しいと言ったのは%CALLNAME:MASTER%だよね？」
		ENDDATA
		PRINTFORML 最近は指輪を外しているのだと言われてしまった。
	ELSE
		PRINTFORML %"指に合わない感じがして、最近はあまり指輪をしないのだと言い返された。"%
	ENDIF
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
	;装着率５割
	IF TALENT:角色:浮気公認
		PRINTDATAL
			DATAFORM 「ごめんね、今日はつけていないの」
			DATAFORM 「たまたまだよ」
			DATAFORM 「指輪ならお部屋だよ」
		ENDDATA
		PRINTDATAL
			DATAFORM 「今日はそんな気分なんだ」
			DATAFORM 「えへへ、今日の私はフリーなんだ♪」
			DATAFORM 「でも、ウワキして欲しいと言ったのは%CALLNAME:MASTER%だよね？」
		ENDDATA
		PRINTFORML 今日は敢えて指輪を外しているのだと言われてしまった。
	ELSE
		PRINTFORML %"最近指が腫れるので外している事が多いのだと言い訳された。"%
	ENDIF
	;ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
ELSE
	;装着率９割
	IF TALENT:角色:浮気公認
		PRINTDATAL
			DATAFORM 「ごめんね、忘れちゃった」
			DATAFORM 「いけなーい、うっかりしちゃって」
			DATAFORM 「あ・・ごめんね、ちゃんと部屋にあるよ？」
		ENDDATA
		PRINTFORML 今日はたまたま指輪を外していたのだと謝られた。
	ELSE
		PRINTFORML %"たまたま外したまま忘れていたからだと謝られた。"%
	ENDIF
ENDIF

RETURN 1


