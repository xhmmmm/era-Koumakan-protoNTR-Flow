@KOJO_MESSAGE_COUNTER_K6_29_3
SELECTCASE BASE:PLAYER:精力
	CASE IS == 0
		;全部搾り取った
		PRINTFORML 「もう出ないの？ それじゃ、ここで許してあげる」
	CASE IS < MAXBASE:PLAYER:精力 /2
		;大半搾り取った
		PRINTFORML 「まだ出るよね？ 一滴残らず搾り取るんだから、わかってるよね？」
	CASEELSE
		;少し搾り取った
		PRINTFORML 「まだまだ元気だよね。もっと搾ってあげるよ？
ENDSELECT
RETURN 1

;-------------------------------------------
;フランが他の人を呼ぶときの例外処理関数
;-------------------------------------------
@CALLNAME_K6(角色, 対象)
#FUNCTIONS
#DIM 角色
#DIM 対象
#DIMS 呼称

呼称 = %CALLNAME:対象%
IF CALLNAME:角色 == "フラン" || CALLNAME:角色 == "芙兰朵露"
	IF CALLNAME:対象 == "蕾米莉亚"
		呼称 = お姉さま
	ELSE
	ENDIF
ELSE
	; 名称変更時はデフォルトのまま
ENDIF
RETURNF 呼称
