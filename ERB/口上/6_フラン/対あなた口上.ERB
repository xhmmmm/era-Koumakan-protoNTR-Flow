;==================================================
;计数器：榨乳手交
;==================================================
;芙兰默认有施虐狂属性，所以删除施虐狂分支
@KOJO_MESSAGE_COUNTER_K6_29_0
PRINTFORML 「…转过去，面对墙壁手撑着」
RETURN 1

@KOJO_MESSAGE_COUNTER_K6_29_1
#DIM 角色
角色 = 人物_芙兰朵露
IF CFLAG:PLAYER:跳蛋A挿入 != 0
	;你菊花插入跳蛋时分支
	PRINTFORML %CALLNAME:角色%发现%CALLNAME:PLAYER%的菊花里插着跳蛋，开心地笑了起来。
	IF CFLAG:PLAYER:跳蛋挿入者 == 角色
		PRINTFORML 「按照吩咐做了呢♪。正好，就这样继续做下去吧」
	ELSE
		PRINTFORML 「…是谁吩咐你的？ 不过正好，就这样继续做下去吧」
	ENDIF
	PRINTL
ELSEIF EQUIP:PLAYER:下半身内衣_副 == 0 && EQUIP:PLAYER:下半身内衣_主 == 0
	;你没穿内裤时分支
	PRINTFORML %CALLNAME:角色%发现%CALLNAME:PLAYER%没有穿内裤，开心地笑了起来。
	PRINTFORML 「啊～…没穿内裤呀。好色～♪」
	PRINTL
ENDIF
PRINTFORML 「%CALLNAME:PLAYER%要和%CALLNAME_K6(人物_芙兰朵露, 人物_蕾米莉亚)%还有%CALLNAME_K6(人物_芙兰朵露, 人物_咲夜)%做色色的事是不行的！」
PRINTFORML 「所以，要把%CALLNAME:PLAYER%的榨得一滴不剩」
RETURN 1

@KOJO_MESSAGE_COUNTER_K6_29_2
IF CFLAG:PLAYER:跳蛋A挿入 != 0
	PRINTFORML 「出来了出来了。果然跳蛋很舒服吧？」
ELSE
	PRINTFORML 「出来了出来了。不过，有点太快了吧？」
ENDIF
RETURN 1

@KOJO_MESSAGE_COUNTER_K6_29_3
SELECTCASE BASE:PLAYER:精力
	CASE IS == 0
		;全部榨干了
		PRINTFORML 「已经出不来了吗？那就在这里放过你吧」
	CASE IS < MAXBASE:PLAYER:精力 /2
		;榨了大半
		PRINTFORML 「还能出吧？要榨得一滴不剩的，明白吧？」
	CASEELSE
		;榨了一点
		PRINTFORML 「还很有精神嘛。再榨多一点吧？」
ENDSELECT
RETURN 1

;-------------------------------------------
;芙兰称呼其他人时的例外处理函数
;-------------------------------------------
@CALLNAME_K6(角色, 対象)
#FUNCTIONS
#DIM 角色
#DIM 対象
#DIMS 呼称

呼称 = %CALLNAME:対象%
IF CALLNAME:角色 == "フラン" || CALLNAME:角色 == "芙兰朵露"
	IF CALLNAME:対象 == "蕾米莉亚"
		呼称 = 姐姐大人
	ELSE
	ENDIF
ELSE
	;名称变更时保持默认
ENDIF
RETURNF 呼称
