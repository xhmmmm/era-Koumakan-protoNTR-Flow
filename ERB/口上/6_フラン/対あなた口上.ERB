;==================================================
;会话拡張：结婚戒指について
;　前提：恋慕かつ人妻
;==================================================
@KOJO_MESSAGE_COM_K6_300_14_01(角色, 調教者)
#DIM 調教者
#DIM 角色

IF TALENT:角色:NTR
	;チョーカーが優先
	PRINTFORML %"もう"+CALLNAME:MASTER+"のものではないのだから指輪をする必要は無いと言い切られた。"%
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
	;装着率３割
	PRINTFORML %"指に合わない感じがして、最近はあまり指輪をしないのだと言い返された。"%
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
	;装着率５割
	PRINTFORML %"最近指が腫れるので外している事が多いのだと言い訳された。"%
	;ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
ELSE
	;装着率９割
	PRINTFORML %"たまたま外したまま忘れていたからだと謝られた。"%
ENDIF

RETURN 1

