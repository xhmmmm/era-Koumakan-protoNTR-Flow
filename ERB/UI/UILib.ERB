;-------------------------------------------------------------------------------
;主界面UI组件库
;这些组件是为白天的主界面的方框+暗金装饰风格设计的
;全局常量 UI_行全角宽度 定义在 DIM.ERH 中
;不要复用！这只会导致满屏幕都是屎黄色的长线条
;-------------------------------------------------------------------------------

;===============================================================================
;内部辅助：生成 N 个 ─ 的字符串
;===============================================================================
@UI_重复横线(次数)
#FUNCTIONS
#DIM 次数
#DIM 循环计数
#DIMS 结果
结果 =
FOR 循环计数, 0, 次数
	结果 += "─"
NEXT
RETURNF 结果

;===============================================================================
;UI_重分隔线：✦──────...──────✦
;===============================================================================
@UI_重分隔()
#DIMS 横线
横线 = %UI_重复横线(UI_行全角宽度 - 1)%
SETCOLOR 颜色_暗金
PRINTFORM ✦%横线%✦
RESETCOLOR
PRINTL

;===============================================================================
;主界面_竖边框 │（不换行，供行内拼接）
;===============================================================================
@主界面_竖边框()
SETCOLOR 颜色_深暗金
PRINT │
RESETCOLOR

;===============================================================================
;主界面_节标题：✦ 标题 ──────...
;===============================================================================
@主界面_节标题(标题)
#DIMS 标题
#DIMS 横线
#DIM 标题宽度
#DIM 剩余
标题宽度 = STRLENS(标题)
剩余 = UI_行全角宽度 - 标题宽度
横线 = %UI_重复横线(剩余)%
SETCOLOR 颜色_暗金
PRINTFORM ✦ %标题% %横线%
RESETCOLOR
PRINTL

;===============================================================================
;主界面_方框上边缘：╭─✦ 标题 ───...───╮
;===============================================================================
@主界面_方框上边缘(标题)
#DIMS 标题
#DIMS 横线
#DIM 标题宽度
#DIM 剩余
标题宽度 = STRLENS(标题)
;'UI_行半角宽度'减去预先输出的几项所占的半角符号以及以半角计数的标题宽度，再除2就是需要补齐的"─"数量
;只要标题里面没有半角符号，那输出就是严丝合缝的
剩余 = (UI_行半角宽度 - 10 - 标题宽度)/2
横线 = %UI_重复横线(剩余)%
SETCOLOR 颜色_深暗金
PRINTFORM ╭─
RESETCOLOR
SETCOLOR 颜色_暗金
PRINTFORM  ✦
RESETCOLOR
SETCOLOR 颜色_深暗金
PRINTFORM %标题% %横线%╮
RESETCOLOR
PRINTL

;===============================================================================
;主界面_方框下边缘：╰──────...──────╯
;===============================================================================
@主界面_方框下边缘()
#DIMS 横线
横线 = %UI_重复横线(UI_行全角宽度 - 2)%
SETCOLOR 颜色_深暗金
PRINTFORM ╰%横线%╯
RESETCOLOR
PRINTL

;===============================================================================
;主界面_方框内子标题：│ ✧ 子标题 ✶
;===============================================================================
@主界面_方框内子标题(标题)
#DIMS 标题
CALL 主界面_竖边框
SETCOLOR 颜色_浅金
PRINTFORM  ✧ %标题% 
RESETCOLOR
CALL 主界面_装饰右边框(140)
PRINTL

;===============================================================================
;轻分隔线：──────...（单色细线，通用）
;===============================================================================
@UI_轻分隔()
#DIMS 横线
横线 = %UI_重复横线(UI_行全角宽度)%
SETCOLOR 颜色_浅灰
PRINTFORM %横线%
RESETCOLOR
PRINTL

;===============================================================================
;主界面_装饰右边框——输出ARG个空格后接一个装饰符号
;@param ARG 空格数量
;===============================================================================
@主界面_装饰右边框(ARG)
#DIM STATIC 行号
行号++
PRINTFORM %" "*ARG%
SETCOLOR 颜色_浅金
SELECTCASE 行号 % 6
	CASE 0
		PRINT ✶
	CASE 1
		PRINT ⋆
	CASE 2
		PRINT ✷
	CASE 3
		PRINT ⋆
	CASE 4
		PRINT ∗
	CASE 5
		PRINT ·
ENDSELECT
RESETCOLOR
