;-------------------------------------------------------------------------------
;訪問者の出現処理
;@return 1:访问者出现,0:访问者不出现
@VISITER_APPEARANCE
#DIM LOOP_CHR
#DIM 侍奉種別
#DIM 帰宅フラグ
#DIM 移动路线循环
#DIM 移动目撃フラグ
#DIM 访问者拜访几率
#DIM 外泊人数

SIF !GETBIT(FLAG:ＮＴＲパッチ設定,0)
	CALL NTR_OPTION
;----------------------------------------------------------------------------------------------------
;将不在访问者家的角色归位
;----------------------------------------------------------------------------------------------------
;お持ち帰りされていた場合は位置を初期化
SIF CFLAG:1:当前位置 < 位置_訪問者宅
	CFLAG:1:当前位置 = 位置_红魔馆_守卫小屋
SIF CFLAG:2:当前位置 < 位置_訪問者宅
	CFLAG:2:当前位置 = 位置_红魔馆_小恶魔私室
SIF CFLAG:3:当前位置 < 位置_訪問者宅
	CFLAG:3:当前位置 = 位置_红魔馆_帕秋莉私室
SIF CFLAG:4:当前位置 < 位置_訪問者宅
	CFLAG:4:当前位置 = 位置_红魔馆_咲夜私室
SIF CFLAG:5:当前位置 < 位置_訪問者宅
	CFLAG:5:当前位置 = 位置_红魔馆_蕾米莉亚私室
SIF CFLAG:6:当前位置 < 位置_訪問者宅
	CFLAG:6:当前位置 = 位置_红魔馆_地下室
SIF CFLAG:7:当前位置 < 位置_訪問者宅
	CFLAG:7:当前位置 = (TALENT:7:恋慕 ? 15 # 8)
SIF CFLAG:8:当前位置 < 位置_訪問者宅
	CFLAG:8:当前位置 = 位置_雾之湖_琪露诺的家
SIF CFLAG:9:当前位置 < 位置_訪問者宅
	CFLAG:9:当前位置 = 位置_雾之湖_大妖精的家
SIF CFLAG:10:当前位置 < 位置_訪問者宅
	CFLAG:10:当前位置 = 位置_魔法之森_雾雨魔法店
SIF CFLAG:11:当前位置 < 位置_訪問者宅
	CFLAG:11:当前位置 = 位置_博麗神社
SIF CFLAG:12:当前位置 < 位置_訪問者宅
	CFLAG:12:当前位置 = 位置_魔法之森_露米娅的树屋
SIF CFLAG:13:当前位置 < 位置_訪問者宅
	CFLAG:13:当前位置 = 位置_魔法之森_爱丽丝的家
;----------------------------------------------------------------------------------------------------
;处理在访问者家的角色
;----------------------------------------------------------------------------------------------------
FOR LOOP_CHR,1,CHARANUM
	帰宅フラグ = !IS_NTR_LONG_STAY()
	IF NTR_GET_STAYOUT_CURRENT(LOOP_CHR) >= NTR_GET_STAYOUT_MAXIMUM(LOOP_CHR)
		;外泊日数が最大日数に達していたら帰ってくる
		帰宅フラグ = 1
	ELSEIF ( 100 - 100 * CFLAG:LOOP_CHR:屈服度 / MAX(1,CFLAG:LOOP_CHR:好感度) ) > RAND:100
		;屈服度より好感度が高い場合、比率に応じた確率で帰ってくる
		帰宅フラグ = 1
	ENDIF
	IF CFLAG:LOOP_CHR:当前位置 == 位置_訪問者宅 && 帰宅フラグ
		PRINTFORML 
		;滞在日数のリセット
		CALL NTR_SET_STAYOUT_CURRENT(LOOP_CHR,0)
		;朝のご侍奉イベント
		IF NTR_CHK_VISIBLE(900)
			CALL NTR_MESSAGE_14(LOOP_CHR)
		ENDIF
		;侍奉種別…行為(0:口侍奉,1:尻穴侍奉,2:淫壷侍奉,)
		侍奉種別 = 0
		侍奉種別 = RAND:3
		SIF TALENT:LOOP_CHR:处女 && 侍奉種別 == 2
			侍奉種別 = 2
		;侍奉実行
		IF 侍奉種別 == 0
			CALL NTR_MORNING_SERVICE_FELLATIO(LOOP_CHR)
		ELSEIF 侍奉種別 == 1
			CALL NTR_MORNING_SERVICE_ASEX(LOOP_CHR)
		ELSEIF 侍奉種別 == 2
			CALL NTR_MORNING_SERVICE_VSEX(LOOP_CHR)
		ENDIF
		PRINTW
		;帰宅時のおみやげ
		CALL NTR_PUNISHMENT(LOOP_CHR)
		CALL NTR_SOURCE_CHECK(LOOP_CHR, 人物_訪問者)
		PRINTFORMW  ：
		PRINTFORMW  ：
		PRINTFORMW %CALLNAME:LOOP_CHR%不知道从哪里回来了
		CFLAG:LOOP_CHR:当前位置 = GET_PRIVATE_ROOM(LOOP_CHR, 0)
		;紅魔館玄関から私室への移动経路を算出
		CALLF FARMOVE(LOOP_CHR,位置_红魔馆_正门,CFLAG:LOOP_CHR:当前位置)
		移动目撃フラグ = 0
		FOR 移动路线循环,0,移动路线MAX
			IF NTR_CHK_VISIBLE( 移动路线:LOOP_CHR:移动路线循环 )
				移动目撃フラグ = 1
			ENDIF
		NEXT
		;重置移动路径
		CALLF RESET_ROUTE(LOOP_CHR,1)
		SIF FLAG:口上颜色
			CALL KOJO_COLOR(LOOP_CHR)
		;从访问者家回红魔馆的口上
		TRYCALLLIST
			;todo 从访问者家回红魔馆的口上
			FUNC 从访问者家回红魔馆的口上
			FUNC NTR_MESSAGE_0(LOOP_CHR)
		ENDFUNC
		IF 移动目撃フラグ
			TRYCALLLIST
				FUNC 从访问者家回红魔馆被看到的口上
				FUNC 从访问者家回红魔馆被看到的口上（通用）
			ENDFUNC
		ENDIF
		RESETCOLOR
		BASE:LOOP_CHR:体力 = MAXBASE:LOOP_CHR:体力
		BASE:LOOP_CHR:气力 = MAXBASE:LOOP_CHR:气力
		SIF !TALENT:LOOP_CHR:亲爱
			EXP:LOOP_CHR:浮気外泊经验 += NTR_GET_STAYOUT_MAXIMUM(LOOP_CHR)
		;訪問者と同伴してくる
		;RETURN 0
		;同行解除
		CFLAG:LOOP_CHR:同行 = 0
	ELSEIF CFLAG:LOOP_CHR:当前位置 == 位置_訪問者宅
		CFLAG:LOOP_CHR:当前長期滞在日数 += 1
		CALL NTR_RESET_VISITOR_ACTION(LOOP_CHR)
		FLAG:訪問者との汚れ判定に使用 = 0
		IF NTR_CHK_VISIBLE(CFLAG:LOOP_CHR:当前位置)
			SIF FLAG:口上颜色
				CALL KOJO_COLOR(LOOP_CHR)
			;滞在継続時口上
			TRYCALLLIST
				FUNC NTR_KOJO_K{CFLAG:LOOP_CHR:297}_10_7(LOOP_CHR)
				FUNC NTR_KOJO_K_10_7(LOOP_CHR)
			ENDFUNC
			RESETCOLOR
		ENDIF
	ENDIF
NEXT
;----------------------------------------------------------------------------------------------------
;访问者是否出现
;----------------------------------------------------------------------------------------------------
;下記値を変更すると訪問者の来る確率が変わります
CALL NTR_RESET_VISITOR_ACTION(-1)
访问者拜访几率 = 75
DEBUGPRINTFORML 访问者拜访几率{访问者拜访几率}
IF (GETBIT(FLAG:ゲームモード, 3) && IS_NTR_VISITOR_COME()) || (RAND(100) < 访问者拜访几率 && DAY > 7 && IS_NTR_VISITOR_COME())
	FOR LOOP_CHR,0,CHARANUM
		IF CFLAG:LOOP_CHR:当前位置 == 位置_訪問者宅
			FLAG:访问者当前位置 = 位置_訪問者宅
			FLAG:訪問者滞在時間カウンタ = 0
			RETURN 0
		ENDIF
	NEXT
	FLAG:访问者当前位置 = 位置_红魔馆_正门
	FLAG:訪問者との汚れ判定に使用 = 0
	FLAG:訪問者滞在時間カウンタ = 0
	PRINTFORML 
	PRINTFORML 好像有人来馆里拜访了
ELSE
	FLAG:访问者当前位置 = 位置_訪問者宅
	FLAG:訪問者滞在時間カウンタ = 0
ENDIF

;-------------------------------------------------------------------------------
;FIXME:関数の説明を書いてください
;@return 1:xxx,0:xxx
@VISITER_DO
#DIM LOOP_CHR

;ハーレム可否チェック
CALL NTR_HARAM_ABLE
IF RESULT
	CALL NTR_HARAM
	RETURN 0
ENDIF
;誰かいないかチェック
FOR LOOP_CHR,1,CHARANUM
	SIF !GETBIT(TALENT:LOOP_CHR:性別,0)
		CONTINUE
	IF CFLAG:LOOP_CHR:当前位置 == FLAG:访问者当前位置 && FLAG:访问者当前位置 != 位置_訪問者宅
		;ストライクゾーン範囲外の時スキップ
		SIF !NTR_CHK_STRIKE_ZONE(LOOP_CHR)
			CONTINUE
		;非恋慕住人が対象外のときスキップ
		IF IS_NTR_ATTACK_LOVER_ONLY() && !TALENT:LOOP_CHR:恋慕 && !TALENT:LOOP_CHR:NTR && !CFLAG:LOOP_CHR:睡眠
			SIF NTR_CHK_VISIBLE(FLAG:访问者当前位置) || IS_NTR_SHOW_ALL()
				PRINTFORML %NTR_NAME(0)%和%CALLNAME:LOOP_CHR%只是寒暄地说了几句话。
			CONTINUE
		ENDIF
		;不在睡眠中
		IF !CFLAG:LOOP_CHR:睡眠
			CALL NTR_ADD_SURRENDER(LOOP_CHR, TIME_PROGRESS(TFLAG:300))
			;好感度吸収あり
			IF TALENT:LOOP_CHR:亲爱 && CFLAG:LOOP_CHR:屈服度 > 500
				CALL NTR_DRAIN_LOVE(LOOP_CHR, 100)
			ENDIF
			CALL NTR_DRAIN_LOVE(LOOP_CHR, TIME_PROGRESS(TFLAG:300))
			CALL VISITER_FRIENDSHIP(LOOP_CHR)
		ENDIF
	ELSEIF CFLAG:LOOP_CHR:当前位置 == 位置_訪問者宅; && FLAG:访问者当前位置 == 位置_訪問者宅
		CALL VISITER_TAKEOUT(LOOP_CHR)
	ENDIF
NEXT
RETURN 0

;-------------------------------------------------------------------------------
;住民を口説きます
@VISITER_FRIENDSHIP(角色)
#DIM 角色
#DIM 同席人数		;MASTER含め訪問者と同じ部屋に居る人数
#DIM 密室度			;0:堂々 1:普通 2:個室 3:私室
#DIM 气氛上限値
#DIM 带回家里		;0:无 1:有

同席人数 = GET_N_WITH_VISITER(1)
IF 同席人数 == 2 && CFLAG:MASTER:当前位置 == FLAG:访问者当前位置
	IF 354 != PREVCOM
		; MASTERによる「そこまでよ」
		; [354]不打扰選択時は継続
		CALL NTR_RESET_VISITOR_ACTION(角色)
	ENDIF
ELSEIF 同席人数 > 1
	; ハーレム判定に失敗しているので、多人数ならリセット
	CALL NTR_RESET_VISITOR_ACTION(角色)
ENDIF
;----------------------------------------------------------------------------------------------------
;访问者行为确定（旧版）
;----------------------------------------------------------------------------------------------------
密室度 = GET_ROOM_SECURITY(FLAG:访问者当前位置)
IF FLAG:訪問者の气氛 == 0
	CALL JUDGE_VISITOR_MOOD_MAX(角色, 密室度, 同席人数)
	气氛上限値 = RESULT
	;NTRカウンター実行時それに応じる
	IF CFLAG:角色:NTR_CNT行为 && CFLAG:角色:にんっしんっ == 0
		CALL NTR_COUNTER_COUNTER(角色, 气氛上限値)
		FLAG:訪問者の气氛 = RESULT
		;覗きバレ後の行為エスカレート補正はNTR_COUNTER_COUNTER内で処理
	ELSE
		FLAG:訪問者の气氛 = RAND:(气氛上限値+1)
	ENDIF
ENDIF

;----------------------------------------------------------------------------------------------------
;访问者行为确定（新版）
;----------------------------------------------------------------------------------------------------
;我的想法是完全放弃旧版的逻辑，旧版的逻辑默认了角色的行为是从对话、接吻到做爱逐渐升级的
;甚至整个游戏都假设了角色不仅仅是被性骚扰而且多少有主动出轨的烂裤裆属性。
;而且原版的结局角色通常是直接抛弃玩家甚至羞辱玩家，要么就是无视玩家。
;我们想要的是玩家依然和角色保持关系，同时进行了不让玩家知道的出轨。显然角色无论怎么写都不能是烂裤裆，甚至必须是贞操观念强烈的，即使是出轨后也是对访问者很专一（再加上对玩家出于各种原因也不拒绝）。
;既然如此，气氛这种并没有在游戏中体现、显然只是原作者脑海里想象但又没能实现的东西就不必要了。
;根据不同角色的故事，或许是先从被强上开始、或许是先从意识模糊时的意外开始，又或者是单纯地自己出轨，总之对于不同的故事而言不同阶段所进行的行为应该是不一样的。
;那么对于没有专门写故事的角色，暂且直接走原版逻辑，毕竟要直接改的话也不知道改成什么样。
;而对于有专门故事的角色，直接对她自己专门写不同阶段的触发器，然后在此调用即可。
;只要构思完一个角色的故事就可以开工了，但是这样一来还有一个要处理的问题，因为角色的行为开始是VISITER_FRIENDSHIP_START处理的
;而且原版并没有区分很详细的性行为，比如V和A都算做爱，而且不分体位，因此那部分到时候估计也要重新写一套新的。
;那么下面执行行为的那里也应该加一个条件判断，至于判断是否走新版，在CFLAG里加一个是否完成新版口上的标签就行了。

