;主人空気化判定
;戻り値…0=空気じゃない 1=キス許容 2=おさわり許容 3=侍奉許容 4=セックス許容
@IS_AIR_MASTER(角色)
#FUNCTION
#DIM 角色
#DIM 結果
SIF FLAG:Flow版本
	RETURNF 0
結果 = 0
;キス許容
SIF CFLAG:MASTER:屈服度 > 200
	結果 = 1
;おさわり許容
SIF CFLAG:MASTER:屈服度 > 400
	結果 = 2
;侍奉許容
SIF CFLAG:MASTER:屈服度 > 600
	結果 = 3
;セックス許容
SIF CFLAG:MASTER:屈服度 > 1000
	結果 = 4
;住人による補正
IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
	結果 += 2
	;寝とられ寸前
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
	結果 += 2
	;寝とられそう
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
	結果 += 1
	;恋慕で主人への好意度高い
ELSEIF CFLAG:角色:屈服度 < CFLAG:角色:好感度 && TALENT:角色:恋慕
	結果 -= 1
ENDIF
;デバッグ用
;結果 = 4
RETURNF 結果

