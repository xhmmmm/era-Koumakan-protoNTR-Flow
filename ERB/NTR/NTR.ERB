IF !带回家里
	;訪問者が待機（行動終了状態）の場合。
	IF FLAG:访问者当前行为中止时刻 == 0
		CALL VISITER_FRIENDSHIP_START(角色, 密室度)
	;訪問者が行動中（行動終了時刻に満たない）の場合。
	ELSEIF FLAG:访问者当前行为中止时刻 > DATETIME()
		CALL VISITER_FRIENDSHIP_CONT(角色, 密室度)
	;訪問者が行動完了（行動終了時刻に到達した）の場合。
	ELSE
		CALL VISITER_FRIENDSHIP_FINISH(角色)
	ENDIF
ENDIF
