;-------------------------------------------------------------------------------
;NTRカウンター関連
;住人が訪問者に対して軽いセクハラを実行
@NTR_COUNTER(角色)
#DIM 角色
#DIM CNT行为
CNT行为 = 0
IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
	CNT行为 = RAND:(NTR_CNT_深吻+1)
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
	SIF RAND:2
		CNT行为 = RAND:(NTR_CNT_深吻+1)
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
	;玩家在场
	IF CFLAG:MASTER:当前位置 == FLAG:访问者当前位置
		SIF RAND:3
			CNT行为 = RAND:(NTR_CNT_揉搓股间+1)
		;玩家不在场
	ELSE
		SIF RAND:2
			CNT行为 = RAND:(NTR_CNT_深吻+1)
	ENDIF
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
	;玩家在场
	IF CFLAG:MASTER:当前位置 == FLAG:访问者当前位置
		SIF RAND:3
			CNT行为 = RAND:(NTR_CNT_接吻+1)
		;玩家不在场
	ELSE
		SIF RAND:2
			CNT行为 = RAND:(NTR_CNT_深吻+1)
	ENDIF
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
	;玩家在场
	IF CFLAG:MASTER:当前位置 == FLAG:访问者当前位置 
		SIF RAND:4
			CNT行为 = RAND:(NTR_CNT_耳边吹气+1)
		;玩家不在场
	ELSE
		SIF RAND:3
			CNT行为 = RAND:(NTR_CNT_正面拥抱+1)
	ENDIF
ELSEIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)
	;玩家在场
	IF CFLAG:MASTER:当前位置 == FLAG:访问者当前位置
		SIF RAND:5
			CNT行为 = RAND:(NTR_CNT_凝视+1)
		;玩家不在场
	ELSE
		SIF RAND:4
			CNT行为 = RAND:(NTR_CNT_接吻+1)
	ENDIF
ELSE
	CNT行为 = NTR_CNT_无行为
ENDIF
;寝ていたらカウンターはしない
IF CFLAG:角色:睡眠
	CNT行为 = NTR_CNT_无行为
ENDIF
IF CNT行为
	CALL NTR_COUNTER_DO(角色, CNT行为)
ENDIF
;NTRカウンター実行の保存
CFLAG:角色:NTR_CNT行为 = CNT行为
RETURN 1

;-------------------------------------------------------------------------------
;NTRカウンター実行
@NTR_COUNTER_DO(角色,CNT行为)
#DIM 角色
#DIM CNT行为
SELECTCASE CNT行为
	CASE NTR_CNT_诱惑姿势
		SOURCE:角色:诱惑 += 150
		SOURCE:角色:挑衅 += 50
	CASE NTR_CNT_凝视
		SOURCE:角色:诱惑 += 80
	CASE NTR_CNT_贴近身体
		SOURCE:角色:诱惑 += 100
		SOURCE:角色:侍奉 += 100
	CASE NTR_CNT_耳边吹气
		SOURCE:角色:诱惑 += 50
		SOURCE:角色:挑衅 += 100
	CASE NTR_CNT_接吻
		SOURCE:角色:诱惑 += 250
		SOURCE:角色:侍奉 += 100
		CALL NTR_ADD_SURRENDER(角色, 1)
		SIF TALENT:角色:浮気的蜜唇
			CALL NTR_ADD_SURRENDER(角色, 1)
		IF CFLAG:MASTER:当前位置 == FLAG:访问者当前位置
			CFLAG:角色:同席目撃回数 ++
			CFLAG:角色:同席目撃時行為 = MAX(CFLAG:角色:同席目撃時行為, 1)
		ENDIF
	CASE NTR_CNT_背面拥抱
		SOURCE:角色:诱惑 += 300
		SOURCE:角色:侍奉 += 100
	CASE NTR_CNT_正面拥抱
		SOURCE:角色:诱惑 += 300
		SOURCE:角色:侍奉 += 100
	CASE NTR_CNT_揉胸
		SOURCE:角色:诱惑 += 300
		SOURCE:角色:侍奉 += 200
		SOURCE:角色:强迫 += 200
		SOURCE:角色:快Ｂ += 200
		CALL NTR_ADD_SURRENDER(角色, 1)
	CASE NTR_CNT_揉搓股间
		SOURCE:角色:诱惑 += 300
		SOURCE:角色:挑衅 += 200
		SOURCE:角色:侍奉 += 200
		CALL NTR_ADD_SURRENDER(角色, 1)
		IF CFLAG:MASTER:当前位置 == FLAG:访问者当前位置
			CFLAG:角色:同席目撃回数 ++
			CFLAG:角色:同席目撃時行為 = MAX(CFLAG:角色:同席目撃時行為, 2)
		ENDIF
	CASE NTR_CNT_掀裙子看内裤
		SOURCE:角色:诱惑 += 400
		SOURCE:角色:挑衅 += 100
		CALL NTR_ADD_SURRENDER(角色, 1)
	CASE NTR_CNT_深吻
		SOURCE:角色:性行动 += 1000
		SOURCE:角色:诱惑 += 150
		SOURCE:角色:侍奉 += 150
		CALL NTR_EXP_ADD_KISS(角色,1)
		CALL LOST_VIRGIN_M(角色, 人物_訪問者)
		CALL NTR_ADD_SURRENDER(角色, 2)
		SIF TALENT:角色:浮気的蜜唇
			CALL NTR_ADD_SURRENDER(角色, 2)
		IF CFLAG:MASTER:当前位置 == FLAG:访问者当前位置
			CFLAG:角色:同席目撃回数 ++
			CFLAG:角色:同席目撃時行為 = MAX(CFLAG:角色:同席目撃時行為, 1)
		ENDIF
ENDSELECT
CALL NTR_CNT_KOJO(角色, CNT行为)
RETURN 1

;-------------------------------------------------------------------------------
;NTRカウンターに対するカウンター
@NTR_COUNTER_COUNTER(角色,行為上限)
#DIM 角色
#DIM 行為上限
#DIM 气氛
#DIM 激化		; 1:覗きバレ後行為エスカレート
气氛 = 0
;RAND時激化 = 1
激化 = 0

;会话しかできない時は判定しない
IF 行為上限 == NTR_MOOD_会话
	RETURN NTR_MOOD_会话
ENDIF
;以下の判定で、最低でもキスはできるものとする。
SELECTCASE CFLAG:角色:NTR_CNT行为
		;色っぽいしぐさ
	CASE NTR_CNT_诱惑姿势
		;特に影響なし
		气氛 = RAND:(行為上限+1)
		激化 = 1
		;見つめる
	CASE NTR_CNT_凝视
		;1/2でキス
		IF RAND:2 == 0
			IF NTR_CHK_VISIBLE(FLAG:访问者当前位置)
				PRINTFORMW 在%CALLNAME:角色%凝视着%NTR_NAME(0)%的时候，%NTR_NAME(0)%吻了上去、夺走了%CALLNAME:角色%的嘴唇…
			ENDIF
			气氛 = NTR_MOOD_キス
		ELSE
			气氛 = RAND:(行為上限+1)
			激化 = 1
		ENDIF
		;身体を摺り寄せる
	CASE NTR_CNT_贴近身体
		;1/2で爱抚
		IF 行為上限 >= NTR_MOOD_爱抚 && RAND:2 == 0
			IF NTR_CHK_VISIBLE(FLAG:访问者当前位置)
				PRINTFORMW 和%CALLNAME:角色%紧贴在一起的%NTR_NAME(0)%，爱抚了%CALLNAME:角色%的身体…
			ENDIF
			气氛 = NTR_MOOD_爱抚
			;1/2でキス
		ELSEIF 行為上限 >= NTR_MOOD_爱抚
			IF NTR_CHK_VISIBLE(FLAG:访问者当前位置)
				PRINTFORMW 和%CALLNAME:角色%紧贴在一起的%NTR_NAME(0)%，吻了%CALLNAME:角色%的唇…
			ENDIF
			气氛 = NTR_MOOD_キス
		ENDIF
		;耳元に息を吹きかける
	CASE NTR_CNT_耳边吹气
		;特に影響なし
		气氛 = RAND:(行為上限+1)
		激化 = 1
		;キス
	CASE NTR_CNT_接吻
		;1/2で爱抚
		IF 行為上限 >= NTR_MOOD_爱抚 && RAND:2 == 0
			IF NTR_CHK_VISIBLE(FLAG:访问者当前位置)
				PRINTFORMW 被%CALLNAME:角色%积极热吻着的%NTR_NAME(0)%，同时爱抚了%CALLNAME:角色%的身体…
			ENDIF
			气氛 = NTR_MOOD_爱抚
			;1/2でキス
		ELSE
			IF NTR_CHK_VISIBLE(FLAG:访问者当前位置)
				PRINTFORMW 被%CALLNAME:角色%热情地亲吻了的%NTR_NAME(0)%，为了回应%CALLNAME:角色%的期待，也主动吻了%CALLNAME:角色%的唇…
			ENDIF
			气氛 = NTR_MOOD_キス
		ENDIF
		;後ろから抱きつく
	CASE NTR_CNT_背面拥抱
		;特に影響なし
		气氛 = RAND:(行為上限+1)
		激化 = 1
		;前から抱きつく
	CASE NTR_CNT_正面拥抱
		;1/2でキス
		IF RAND:2
			IF NTR_CHK_VISIBLE(FLAG:访问者当前位置)
				PRINTFORMW 被%CALLNAME:角色%紧紧抱着的%NTR_NAME(0)%，低头夺取了%CALLNAME:角色%的唇…
			ENDIF
			气氛 = NTR_MOOD_キス
		ELSE
			气氛 = RAND:(行為上限+1)
			激化 = 1
		ENDIF
		;胸を揉ませる
	CASE NTR_CNT_揉胸
		;爱抚
		IF 行為上限 >= NTR_MOOD_爱抚
			IF NTR_CHK_VISIBLE(FLAG:访问者当前位置)
				PRINTFORMW 一边揉捏着%CALLNAME:角色%的乳房，%NTR_NAME(0)%一边爱抚了%CALLNAME:角色%的身体…
			ENDIF
			气氛 = NTR_MOOD_爱抚
		ELSE
			气氛 = RAND:(行為上限+1)
			激化 = 1
		ENDIF
		;股間をまさぐる
	CASE NTR_CNT_揉搓股间
		;侍奉
		IF 行為上限 >= NTR_MOOD_侍奉
			IF NTR_CHK_VISIBLE(FLAG:访问者当前位置)
				PRINTFORMW %CALLNAME:角色%被要求用大腿内侧侍奉%NTR_NAME(0)%勃起的肉棒…
			ENDIF
			气氛 = NTR_MOOD_侍奉
		ELSE
			气氛 = RAND:(行為上限+1)
			激化 = 1
		ENDIF
		;裙子の中を見せる
	CASE NTR_CNT_掀裙子看内裤
		;性交
		IF 行為上限 >= NTR_MOOD_性交
			IF NTR_CHK_VISIBLE(FLAG:访问者当前位置)
				PRINTFORMW 感受到%CALLNAME:角色%秘部的湿润，%NTR_NAME(0)%开始要求%CALLNAME:角色%用小穴来进行侍奉…
			ENDIF
			气氛 = NTR_MOOD_性交
			;爱抚
		ELSEIF 行為上限 >= NTR_MOOD_爱抚
			气氛 = NTR_MOOD_爱抚
		ELSE
			气氛 = RAND:(行為上限+1)
			激化 = 1
		ENDIF
		;ディープキス
	CASE NTR_CNT_深吻
		;1/2で侍奉
		IF 行為上限 >= NTR_MOOD_侍奉 && RAND:2 == 0
			IF NTR_CHK_VISIBLE(FLAG:访问者当前位置)
				PRINTFORMW 对%CALLNAME:角色%热情缠绵的吻感到满意，%NTR_NAME(0)%要求用嘴来进行侍奉…
			ENDIF
			气氛 = NTR_MOOD_侍奉
		ELSE
			气氛 = RAND:(行為上限+1)
			激化 = 1
		ENDIF
ENDSELECT
气氛 = LIMIT(气氛, NTR_MOOD_会话, 行為上限)
IF 激化 && !IS_NTR_SOFT()
	;覗きバレ後は行為エスカレート
	IF CFLAG:角色:覗き発覚回数 && FLAG:訪問者の气氛 < 2
		FLAG:訪問者の气氛 += 1
	ENDIF
ENDIF
RETURN 气氛

