;戻り値…訪問者の气氛上限値
@JUDGE_VISITOR_MOOD_MAX(角色, 密室度, 同席人数)
#DIM 角色
#DIM 密室度
#DIM 同席人数
#DIM 气氛上限値
气氛上限値 = 0
;訪問者と住民が二人きりまたは主人空気化（屈服度高いとき？）
IF 同席人数 == 1 || (!FLAG:Flow版本 && (同席人数 == 2 && CFLAG:MASTER:当前位置 == FLAG:访问者当前位置 && IS_AIR_MASTER(角色)))
	SIF NTR_CHK_FAVORABLY(角色, FAV_接吻程度)
		气氛上限値 += 1
	;光明正大地していない場所
	IF 密室度 > 0
		SIF NTR_CHK_FAVORABLY(角色, FAV_体を触らせる程度)
			气氛上限値 += 1
		;さらに目立たない場所または私室
		IF 密室度 >= 2
			SIF NTR_CHK_FAVORABLY(角色, FAV_侍奉する程度)
				气氛上限値 += 1
			SIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
				气氛上限値 += 1
		ENDIF
	ENDIF
	SIF CFLAG:角色:屈服度 > CFLAG:角色:好感度
		气氛上限値 += 1
	SIF CFLAG:角色:屈服度 > 500
		气氛上限値 += 1
	;和姦モード時は抑える
	IF IS_NTR_SOFT()
		IF NTR_CHK_FAVORABLY(角色, FAV_寝取られ)
			; 制限なし
		ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前)
			; 制限なし
		ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
			; 制限なし
		ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
			; 侍奉が上限
			气氛上限値 = LIMIT(气氛上限値-2, NTR_MOOD_会话, NTR_MOOD_侍奉)
		ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度2)
			; 爱抚が上限
			气氛上限値 = LIMIT(气氛上限値-2, NTR_MOOD_会话, NTR_MOOD_爱抚)
		ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度)
			; キスが上限
			气氛上限値 = LIMIT(气氛上限値-2, NTR_MOOD_会话, NTR_MOOD_キス)
		ELSE
			; これ以下はキスもしない
			气氛上限値 = NTR_MOOD_会话
		ENDIF
	ENDIF
ELSE
	CALL NTR_RESET_VISITOR_ACTION(角色)
ENDIF
RETURN 气氛上限値

