;覗きバレした時の見せつけ
@NTR_SHOW_PEEP(角色)
#DIM 角色
IF CFLAG:角色:睡眠
	PRINTFORMW %NTR_NAME(0)%似乎注意到了%CALLNAME:MASTER%的视线
ELSE
	PRINTFORMW %NTR_NAME(0)%和%CALLNAME:角色%似乎注意到了%CALLNAME:MASTER%的视线
	;NTR覗き発覚カウンタ更新
	CFLAG:角色:覗き発覚回数 ++
	;NTR覗き発覚時行為コード更新
	CFLAG:角色:覗き発覚時行為 = MAX(CFLAG:角色:覗き発覚時行為, FLAG:访问者当前行为)
	;会话以外の時覗きバレが２回目以降だと好意度低下
	IF FLAG:访问者当前行为 != 0 && CFLAG:角色:覗き発覚回数 > 1
		;NTRの場合減らないものとする。
		SIF !TALENT:角色:NTR
			CFLAG:角色:好感度 --
		SIF CFLAG:角色:睡眠
			CFLAG:角色:好感度 --
	ENDIF
	SELECTCASE FLAG:访问者当前行为
			;会话
		CASE 0
			;単に話している時は何もなし
		CASE NTR_行为_接吻
			CALL NTR_MESSAGE_KISS_SHOW(角色)
		CASE NTR_行为_爱抚
			CALL NTR_MESSAGE_PET_SHOW(角色)
		CASE NTR_行为_胸爱抚
			CALL NTR_MESSAGE_BUST_PET_SHOW(角色)
		CASE NTR_行为_口交
			CALL NTR_MESSAGE_FELLATIO_SHOW(角色)
		CASE NTR_行为_六九
			CALL NTR_MESSAGE_69_SHOW(角色)
		CASE NTR_行为_素股
			CALL NTR_MESSAGE_THUG_SHOW(角色)
			;セックス
		CASE NTR_行为_Ｖ正常位 TO NTR_行为_Ｖ背面立位
			CALL NTR_MESSAGE_SEX_SHOW(角色)
			;菊花セックス
		CASE NTR_行为_Ａ正常位 TO NTR_行为_Ａ背面立位
			CALL NTR_MESSAGE_A_SEX_SHOW(角色)
		CASEELSE
			PRINTW 出错
	ENDSELECT
ENDIF
RETURN 1

