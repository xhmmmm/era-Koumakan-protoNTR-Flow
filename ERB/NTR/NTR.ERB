;浮気した経験を記録し、合計の経験人数を返す
;@return 経験人数
@NTR_FickleCount(角色,相手,相手番号)
#FUNCTION
#DIM 角色
#DIM 相手
#DIM 相手番号
#DIMS 相手文字列
相手文字列 = %TOSTR(相手)%
SIF CSTR:角色:セックスした相手 == ""
	CSTR:角色:セックスした相手 = /
LOCALS = %"/"+相手文字列+"/"%
IF STRCOUNT(CSTR:角色:セックスした相手,LOCALS)
	;すでに記録済 已经记录完毕
ELSE
	CSTR:角色:セックスした相手 = %CSTR:角色:セックスした相手+相手文字列+"/"%
	EXP:角色:前回浮気人数 += 1
ENDIF
;初回判定更新
RETURNF (STRCOUNT(CSTR:角色:セックスした相手,"/")-1)

;-------------------------------------------------------------------------------
;住人が移动したことで空気が変わるかのチェック
@NTR_CHK_CHAR_MOVE(角色)
#DIM 角色	; 移动した人物
#DIM 結果	; 1:空気が変わった 0:空気変わらない
結果 = 0
;访问者当前位置に移动してきたかチェック
SIF CFLAG:角色:睡眠	
	RETURN 結果
SIF CFLAG:角色:当前位置 == CFLAG:角色:前ターン位置
	RETURN 結果
SIF CFLAG:角色:当前位置 != FLAG:访问者当前位置
	RETURN 結果
;空気変化
結果 = 1
;訪問者移动時は气氛等リセット
IF FLAG:访问者当前行为 != NTR_行为_无
	IF NTR_CHK_VISIBLE(FLAG:访问者当前位置)
		PRINTFORML %CALLNAME:角色%进来后、气氛改变了，%NTR_NAME(0)%不得不中止了行为。
	ENDIF
ENDIF
CALL NTR_RESET_VISITOR_ACTION(-1)
RETURN 結果	

