FOR LOOP_CHR,1,CHARANUM
	CFLAG:LOOP_CHR:射精者V = 0
	CFLAG:LOOP_CHR:射精者M = 0
	CFLAG:LOOP_CHR:射精者A = 0
	CFLAG:LOOP_CHR:覗き発覚回数 = 0
	CFLAG:LOOP_CHR:覗き発覚時行為 = 0
	CFLAG:LOOP_CHR:同席目撃回数 = 0
	CFLAG:LOOP_CHR:同席目撃時行為 = 0
