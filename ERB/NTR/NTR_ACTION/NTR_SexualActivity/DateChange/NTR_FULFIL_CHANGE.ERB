;----------------------------------------
;根据ntr行为增加角色满足度

@NTR_SIMPLE_FULFIL(角色)
#DIM 角色
LOCAL = 0
LOCAL:1 = 0
;各種快感
;50上限、25000と+500 この数値が大きければSOURCE:角色の増加に対して鈍感になる
LOCAL += (100 - 25000 / (SOURCE:角色:快Ｃ + SOURCE:角色:快Ｖ + SOURCE:角色:快Ａ + SOURCE:角色:快Ｂ + 250)) * (1 + TALENT:角色:快感应答)
;情爱
LOCAL += (100 - 200000 / (SOURCE:角色:情爱 + 2000))
;達成感
LOCAL += (30 - 30000 / (SOURCE:角色:达成 + 1000))
;欲情
LOCAL += (20 - 20000 / (SOURCE:角色:欲情 + 1000))
;恭顺
LOCAL += (20 - 20000 / (SOURCE:角色:恭顺 + 1000))
;屈服
LOCAL += (20 - 20000 / (SOURCE:角色:屈从 + 1000))
;露出
LOCAL += (30 - 30000 / (SOURCE:角色:露出 + 1000)) * (ABL:角色:露出癖 - 3) / 3
;恐怖
LOCAL += (50 - 20000 / (SOURCE:角色:恐怖 + 400)) * (ABL:角色:顺从 - 3) / 3
;苦痛
LOCAL += (50 - 20000 / (SOURCE:角色:苦痛 + 400)) * (ABL:角色:抖Ｍ之气 - 3) / 3
;欢乐
LOCAL += (50 - 100000 / (SOURCE:角色:欢乐 + 2000))
;征服
LOCAL += (30 - 90000 / (SOURCE:角色:征服 + 3000))
;被动
LOCAL += (30 - 90000 / (SOURCE:角色:被动 + 3000))
LOCAL:1 += LOCAL
;肮脏
LOCAL -= (50 - 25000 / (SOURCE:角色:肮脏 + 500)) * (2 - TALENT:角色:污臭耐性) / 2
;抑郁
LOCAL -= (50 - 15000 / (SOURCE:角色:抑郁 + 300))
;逸脱
LOCAL -= (50 - 25000 / (SOURCE:角色:逸脱 + 500))
;反発
LOCAL -= (50 - 10000 / (SOURCE:角色:反感 + 200))
BASE:角色:满足 += MAXBASE:角色:满足 * ((NOWEX:角色:Ｃ绝顶 + NOWEX:角色:Ｖ绝顶 + NOWEX:角色:Ａ绝顶 + NOWEX:角色:Ｂ绝顶 + 2 * NOWEX:角色:射精)) / (5 + ABL:角色:欲望)
BASE:角色:满足 = MIN(MAXBASE:角色:满足,BASE:角色:满足 + 2 * LOCAL / (1 + ABL:角色:欲望))