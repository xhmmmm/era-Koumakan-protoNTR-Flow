@NTR_SOURCE_CHECK_LITE(角色,調教者=人物_訪問者)
#DIM 角色
#DIM 調教者
#DIM SOURCE番号
#DIM LOOP_I
TCVAR:角色:行為者 = 調教者
CALL NTR_SIMPLE_FULFIL(角色)
CALL SOURCE_EXP(角色,調教者)
CALL SOURCE_快Ｃ(角色,調教者)
CALL SOURCE_快Ｖ(角色,調教者)
CALL SOURCE_快Ａ(角色,調教者)
CALL SOURCE_快Ｂ(角色,調教者)
CALL SOURCE_CVAB_EXTRA(角色,調教者)
CALL SOURCE_情爱(角色,調教者)
CALL SOURCE_性行动(角色,調教者)
CALL SOURCE_达成(角色,調教者)
CALL SOURCE_苦痛(角色,調教者)
CALL SOURCE_恐怖(角色,調教者)
CALL SOURCE_液体(角色,調教者)
CALL SOURCE_欲情(角色,調教者)
CALL SOURCE_恭顺(角色,調教者)
CALL SOURCE_露出(角色,調教者)
CALL SOURCE_屈从(角色,調教者)
CALL SOURCE_欢乐(角色,調教者)
CALL SOURCE_征服(角色,調教者)
CALL SOURCE_被动(角色,調教者)
CALL SOURCE_肮脏(角色,調教者)
CALL SOURCE_抑郁(角色,調教者)
CALL SOURCE_逸脱(角色,調教者)
CALL SOURCE_反感(角色,調教者)
CALL SOURCE_EXTRA(角色,調教者)
CALL SOURCE_DOWNBASE(角色,調教者)
CALL SOURCE_ABLUP(角色)
CALL MARK_GOT_CHECK(角色,調教者)
CALL KOJO_MESSAGE_MARKCNG(角色)
;パラメータの増加
FOR LOOP_I,0,100
	SIF PALAMNAME:LOOP_I == ""
		CONTINUE
	PALAM:角色:LOOP_I += CUP:角色:LOOP_I - CDOWN:角色:LOOP_I
	SIF FLAG:DEBUG模式
		PRINTFORML %PALAMNAME:LOOP_I,8,LEFT% {PALAM:(角色):LOOP_I,10,LEFT} + {CUP:(角色):LOOP_I,10,LEFT} =   {PALAM:(角色):LOOP_I + CUP:(角色):LOOP_I,10,LEFT}
	CUP:角色:LOOP_I = 0
	CDOWN:角色:LOOP_I = 0
NEXT
FOR SOURCE番号,0,VARSIZE("SOURCE")
	SOURCE:角色:SOURCE番号 = 0
NEXT
RETURN 0

