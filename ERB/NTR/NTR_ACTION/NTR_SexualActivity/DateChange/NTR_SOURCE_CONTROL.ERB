;以时间为单位加算角色的NTR SOURCE获取
@VISITER_FRIENDSHIP_TIMEPLUS(角色,調教者=人物_訪問者)
#DIM 角色
#DIM 調教者
TCVAR:角色:行為者 = 調教者
IF FLAG:访问者行为计时点 != 0
	;LOCAL 行为加算次数 每五分钟算一次
	LOCAL = TIME_PROGRESS(FLAG:访问者行为计时点)/5
	FLAG:访问者行为计时点 = DATETIME()
	SIF LOCAL < 1
		LOCAL = 1
	SELECTCASE FLAG:访问者当前行为
		CASE NTR_行为_接吻
			FOR LOCAL:1,0,LOCAL
				CALL NTR_ADD_SURRENDER(角色, 1)
				BASE:角色:气力 -= 20
				SOURCE:角色:情爱 += 20
				SOURCE:角色:性行动 += 10
				SOURCE:角色:逸脱 += 10
				SOURCE:角色:屈从 += 10
			NEXT
		CASE NTR_行为_爱抚
			FOR LOCAL:1,0,LOCAL
				CALL NTR_ADD_SURRENDER(角色, 1)
				BASE:角色:气力 -= 20
				SOURCE:角色:快Ｃ += 120 + 10 * (ABL:角色:Ｃ感觉) + 30 * TALENT:角色:Ｃ感度 + 60 * TALENT:角色:淫核
				SOURCE:角色:快Ｂ += 120 + 10 * (ABL:角色:Ｂ感觉) + 30 * TALENT:角色:Ｂ感度 + 60 * TALENT:角色:淫乳
				SOURCE:角色:情爱 += 20
				SOURCE:角色:欲情 += 80
				SOURCE:角色:性行动 += 30
				SOURCE:角色:露出 += 10
				SOURCE:角色:肮脏 += 10
				SOURCE:角色:逸脱 += 10
				CALL NTR_EXP_ADD_C(角色,1)
				CALL NTR_EXP_ADD_B(角色,1)
				CALL 改变乳头色素(角色,1)
				CALL 改变小穴色素(角色,1)
				CALL 改变乳头大小(角色,1)
			NEXT
		CASE NTR_行为_胸爱抚
			FOR LOCAL:1,0,LOCAL
				CALL NTR_ADD_SURRENDER(角色, 1)
				BASE:角色:气力 -= 20
				SOURCE:角色:快Ｂ += 180 + 20 * (ABL:角色:Ｂ感觉) + 45 * TALENT:角色:Ｂ感度 + 90 * TALENT:角色:淫乳
				SOURCE:角色:情爱 += 50
				SOURCE:角色:性行动 += 30
				SOURCE:角色:欲情 += 80
				SOURCE:角色:欢乐 += 50
				SOURCE:角色:露出 += 10
				CALL NTR_EXP_ADD_B(角色,1)
				CALL 改变乳头色素(角色,1)
				CALL 改变乳头大小(角色,1)
			NEXT
		CASE NTR_行为_口交
			FOR LOCAL:1,0,LOCAL
				CALL NTR_ADD_SURRENDER(角色, 1)
				BASE:角色:气力 -= 50
				SOURCE:角色:情爱 += 50
				SOURCE:角色:性行动 += 150
				SOURCE:角色:达成 += 80
				SOURCE:角色:屈从 += 300
				SOURCE:角色:欢乐 += 50
				SOURCE:角色:露出 += 10
				SOURCE:角色:肮脏 += 100
				SOURCE:角色:反感 += 50
				CALL NTR_EXP_ADD_M_SEX(角色,1)
			NEXT
		CASE NTR_行为_六九
			FOR LOCAL:1,0,LOCAL
				CALL NTR_ADD_SURRENDER(角色, 1)
				BASE:角色:气力 -= 80
				SOURCE:角色:快Ｃ += 150 + 25 * (ABL:角色:Ｃ感觉) + 50 * TALENT:角色:Ｃ感度 + 80 * TALENT:角色:淫核
				SOURCE:角色:情爱 += 50
				SOURCE:角色:欲情 += 80
				SOURCE:角色:性行动 += 250
				SOURCE:角色:达成 += 80
				SOURCE:角色:液体 += 40
				SOURCE:角色:露出 += 50
				SOURCE:角色:肮脏 += 10
				SOURCE:角色:屈从 += 400
				SOURCE:角色:逸脱 += 300
				IF !TALENT:处女
					SOURCE:角色:快Ｖ += 60
				ELSE
					SOURCE:角色:苦痛 += 10
				ENDIF
				CALL NTR_EXP_ADD_M_SEX(角色,1)
				CALL NTR_EXP_ADD_C(角色,1)
				CALL 改变小穴色素(角色,1)
			NEXT
		CASE NTR_行为_素股
			FOR LOCAL:1,0,LOCAL
				CALL NTR_ADD_SURRENDER(角色, 1)
				BASE:角色:气力 -= 50
				SOURCE:角色:快Ｃ += 150 + 25 * (ABL:角色:Ｃ感觉) + 50 * TALENT:角色:Ｃ感度 + 80 * TALENT:角色:淫核
				SOURCE:角色:情爱 += 50
				SOURCE:角色:欲情 += 80
				SOURCE:角色:性行动 += 100
				SOURCE:角色:达成 += 20
				SOURCE:角色:肮脏 += 10
				SOURCE:角色:屈从 += 200
				SOURCE:角色:逸脱 += 50
				CALL NTR_EXP_ADD_C(角色,1)
				CALL 改变小穴色素(角色,1)
			NEXT
		CASE NTR_行为_Ｖ正常位 TO NTR_行为_Ｖ背面立位
			FOR LOCAL:1,0,LOCAL
				CALL NTR_ADD_SURRENDER(角色, 1)
				BASE:角色:气力 -= 50
				SOURCE:角色:快Ｖ += 400 + 50 * (ABL:角色:Ｖ感觉) + 100 * TALENT:角色:Ｖ感度 + 200 * TALENT:角色:淫壶 + 400 * TALENT:角色:浮気的蜜壶
				SOURCE:角色:情爱 += 50
				SOURCE:角色:欲情 += 80
				SOURCE:角色:性行动 += 100
				SOURCE:角色:苦痛 += 200
				IF 訪問者_Ｐ大きさ == 2
					SOURCE:角色:苦痛 += 200
				ENDIF
				CALL NTR_EXP_ADD_V(角色,1)
				CALL 改变小穴色素(角色,1)
			NEXT
		CASE NTR_行为_Ａ正常位 TO NTR_行为_Ａ背面立位
			FOR LOCAL:1,0,LOCAL
				CALL NTR_ADD_SURRENDER(角色, 1)
				BASE:角色:气力 -= 50
				SOURCE:角色:快Ａ += 400 + 50 * (ABL:角色:Ａ感觉) + 100 * TALENT:角色:Ａ感度 + 200 * TALENT:角色:淫肛 + 400 * TALENT:角色:浮気的菊花
				SOURCE:角色:情爱 += 50
				SOURCE:角色:欲情 += 80
				SOURCE:角色:性行动 += 100
				SOURCE:角色:苦痛 += 200
				IF 訪問者_Ｐ大きさ == 2
					SOURCE:角色:苦痛 += 200
				ENDIF
				CALL NTR_EXP_ADD_A(角色,1)
				CALL 改变肛门色素(角色,1)
			NEXT
	ENDSELECT
	;	ENDIF
	CALL NTR_SOURCE_CHECK_LITE(角色,調教者)
ENDIF

