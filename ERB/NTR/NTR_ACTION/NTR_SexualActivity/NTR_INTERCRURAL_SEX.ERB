;-------------------------------------------------------------------------------
;素股
@NTR_THUG(角色,調教者=人物_訪問者)
#DIM 角色
#DIM 調教者
TCVAR:角色:行為者 = 調教者
IF NTR_CHK_VISIBLE(FLAG:访问者当前位置)
	PRINTFORM 在【%NTR_GetPlaceName(FLAG:访问者当前位置)%】，%CALLNAME:角色%把%NTR_NAME(0)%灼热的肉棒夹在了两腿之间、
	IF CFLAG:角色:屈服度 > CFLAG:角色:好感度
		PRINTFORM 一边用溢满爱慕的双眼，陶醉地注视着%NTR_NAME(0)%
	ELSEIF TALENT:角色:淫乱
		PRINTFORM 一边在嘴边勾起一丝淫媚的微笑，挑逗着%NTR_NAME(0)%
	ELSEIF TALENT:角色:羞耻心 < 0
		PRINTFORM 一边大胆地自己摇动着腰部
	ELSEIF TALENT:角色:缺乏感情
		PRINTFORM 一脸木然
	ELSE
		PRINT 双颊泛起了红晕
	ENDIF
	IF FLAG:访问者当前行为中止时刻 == 0
		PRINTFORMW 把肉棒贴在%MSG_SLIT(角色)%上擦拭
		SIF FLAG:口上颜色
			CALL KOJO_COLOR(角色)
		TRYCALLLIST
			FUNC NTR_KOJO_K{CFLAG:角色:口上パターン}_7_0(角色)
			FUNC NTR_KOJO_K_7_0(角色)
		ENDFUNC
		RESETCOLOR
	ELSE
		PRINTFORMW 把肉棒贴在%MSG_SLIT(角色)%上摩擦
		SIF FLAG:口上颜色
			CALL KOJO_COLOR(角色)
		TRYCALLLIST
			FUNC NTR_KOJO_K{CFLAG:角色:口上パターン}_7_1(角色)
			FUNC NTR_KOJO_K_7_1(角色)
		ENDFUNC
		RESETCOLOR
	ENDIF
ENDIF
IF FLAG:访问者当前行为中止时刻 == 0
	FLAG:访问者行为计时点 = DATETIME()
	CALL NTR_ADD_SURRENDER(角色, 4)
	SIF EXP:角色:NTR陷落经验 
		CALL NTR_ADD_SURRENDER(角色, 2)
	BASE:角色:体力 -= 40
	BASE:角色:气力 -= 130
	SOURCE:角色:快Ｃ = 150
	SOURCE:角色:情爱 = 80
	SOURCE:角色:性行动 = 250
	SOURCE:角色:达成 = 50
	SOURCE:角色:屈从 = 500
	SOURCE:角色:逸脱 = 120
	IF TALENT:角色:NTR
		SOURCE:角色:反感 = 60
	ELSEIF CFLAG:角色:屈服度 > 1000
		SOURCE:角色:反感 = 100
	ELSE
		SOURCE:角色:反感 = 120
	ENDIF
	SIF TALENT:角色:自己爱 < 0 || TALENT:角色:抵抗
		SOURCE:角色:抑郁 += 300
	CALL 改变小穴色素(角色,1)
	CALL STAIN_MOVE_BY_PENIS(部位_Ｖ, 角色, 人物_訪問者)
	FLAG:访问者当前行为中止时刻 = DATETIME() + 20  
	CALL NTR_EXP_ADD_C_EX(角色,1)
	FLAG:访问者当前行为 = NTR_行为_素股
	CFLAG:角色:当前与访问者行为 = NTR_行为_素股
	CALL NTR_SOURCE_CHECK_LITE(角色,調教者)
ENDIF
RETURN 0

;-------------------------------------------------------------------------------
;素股終了（絶頂）
;@return 常に0
@NTR_THUG_FINISH(角色)
#DIM 角色
IF NTR_CHK_VISIBLE(FLAG:访问者当前位置)
	PRINTFORMW 【%NTR_GetPlaceName(FLAG:访问者当前位置)%】%NTR_NAME(0)%的肉棒在%CALLNAME:角色%两腿间以惊人的气势喷射出了大量精液
	SIF FLAG:口上颜色
		CALL KOJO_COLOR(角色)
	TRYCALLLIST
		FUNC NTR_KOJO_K{CFLAG:角色:口上パターン}_7_2(角色)
		FUNC NTR_KOJO_K_7_2(角色)
	ENDFUNC
	RESETCOLOR
ENDIF
CALL NTR_SEMEN_STAIN(角色)
CALL NTR_EXP_ADD_SEMEN(角色,1)
TRYCALL 精力取得, 人物_訪問者
;素股で口は汚れなくていいと思う
;TRYCALL NTR_SAMEN_EXP_PLUS(角色, 1)
;SETBIT STAIN:角色:口,2
;CLEARBIT FLAG:訪問者との汚れ判定に使用,2
CFLAG:角色:射精者V = 人物_訪問者
RETURN 0