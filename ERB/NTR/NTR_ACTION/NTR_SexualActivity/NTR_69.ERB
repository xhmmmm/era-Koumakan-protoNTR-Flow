;-------------------------------------------------------------------------------
;六九式
@NTR_69(角色,調教者=人物_訪問者)
#DIM 角色
#DIM 調教者
TCVAR:角色:行為者 = 調教者
CALL NTR_KISS_PET_FELLA_MSG_KOJO_01(角色, 6)
IF FLAG:访问者当前行为中止时刻 == 0
	FLAG:访问者行为计时点 = DATETIME()
	CALL NTR_ADD_SURRENDER(角色, 3)
	SIF EXP:角色:NTR陷落经验 
		CALL NTR_ADD_SURRENDER(角色, 1)
	BASE:角色:体力 -= 20
	BASE:角色:气力 -= 160
	SOURCE:角色:快Ｃ = 100 + 10 * (ABL:角色:Ｃ感觉) + 25 * TALENT:角色:Ｃ感度 + 50 * TALENT:角色:淫核
	SOURCE:角色:情爱 = 100
	SOURCE:角色:性行动 = 450
	SOURCE:角色:达成 = 200
	SOURCE:角色:液体 = 80
	SOURCE:角色:露出 = 100
	SOURCE:角色:屈从 = 800
	SOURCE:角色:逸脱 = 600
	IF TALENT:角色:NTR
		SOURCE:角色:反感 = 200
	ELSEIF CFLAG:角色:屈服度 > 1000
		SOURCE:角色:反感 = 400
	ELSE
		SOURCE:角色:反感 = 600
	ENDIF
	IF !TALENT:处女
		SOURCE:角色:快Ｖ += 120 + 10 * (ABL:角色:Ｖ感觉) + 30 * TALENT:角色:Ｖ感度 + 60 * TALENT:角色:淫壶 + 120 * TALENT:角色:浮気的蜜壶
		SOURCE:角色:苦痛 += 15
		SOURCE:角色:露出 += 10
		SOURCE:角色:逸脱 += 20
		SOURCE:角色:反感 += 20
	ELSE
		;69で破瓜してしまうのを避けるためコメントアウト
		;SOURCE:角色:快Ｖ += 60
		SOURCE:角色:苦痛 += 10
		SOURCE:角色:露出 += 30
		SOURCE:角色:逸脱 += 30
		SOURCE:角色:反感 += 30
	ENDIF
	SIF TALENT:角色:自己爱 < 0 || TALENT:角色:抵抗
		SOURCE:角色:抑郁 += 800
	CALL NTR_EXP_ADD_M_SEX(角色,1)
	CALL NTR_EXP_ADD_C(角色,1)
	EXP:角色:浮気嗜虐快乐经验 += 1
	CALL 改变小穴色素(角色,1)
	CALL STAIN_MOVE_BY_PENIS(部位_口, 角色, 人物_訪問者)
	CALL LOST_VIRGIN_M(角色, 人物_訪問者,1)
	IF GETBIT(FLAG:訪問者との汚れ判定に使用,汚れB_精液)
		CALL NTR_EXP_ADD_DRINK_SEMEN(角色,1)
		SIF ABL:精饮中毒 < 2
			;无知去除
			CALL 无知去除(角色)
		CFLAG:角色:射精者M = 調教者
	ENDIF
	FLAG:访问者当前行为中止时刻 = DATETIME() + 10
	CALL NTR_EXP_ADD_C_EX(角色,1)
	CALL NTR_EXP_ADD_M_EX(角色,1)
	FLAG:访问者当前行为 = NTR_行为_六九
	CFLAG:角色:当前与访问者行为 = NTR_行为_六九
	;处女菊花厨時の特殊処理。菊花も責められる。
	;IF IS_NTR_KEEP_VIRGIN()
	CALL NTR_EXP_ADD_A(角色,1)
	CALL 改变肛门色素(角色,1)
	IF TALENT:角色:浮気的菊花
		SOURCE:角色:快Ａ = 200 + 10 * (ABL:角色:Ａ感觉) + 50 * TALENT:角色:Ａ感度 + 100 * TALENT:角色:淫肛
		SOURCE:角色:情爱 += 100
		SOURCE:角色:苦痛 += 100
	ELSE
		SOURCE:角色:快Ａ = 100 + 10 * (ABL:角色:Ａ感觉) + 25 * TALENT:角色:Ａ感度 + 50 * TALENT:角色:淫肛
		SOURCE:角色:情爱 += 50
		SOURCE:角色:苦痛 += 200
		SOURCE:角色:逸脱 += 50
	ENDIF
	IF TALENT:角色:NTR || TALENT:角色:浮気的菊花
		SOURCE:角色:反感 += 50
	ELSEIF CFLAG:角色:屈服度 > 1000
		SOURCE:角色:反感 += 100
	ELSE
		SOURCE:角色:反感 += 200
	ENDIF
	SIF TALENT:角色:自己爱 < 0 || TALENT:角色:抵抗
		SOURCE:角色:抑郁 += 100
	;ENDIF
	CALL NTR_SOURCE_CHECK_LITE(角色,調教者)
ENDIF
RETURN 0

;-------------------------------------------------------------------------------
;六九式終了（絶頂）
;@return 常に0
@NTR_69_FINISH(角色)
#DIM 角色
CALL NTR_KISS_PET_FELLA_MSG_KOJO_2(角色, 6)
CALL EJACULATION_M(角色, 人物_訪問者)
CALL NTR_EXP_ADD_M_SEX(角色,1)
RETURN 0