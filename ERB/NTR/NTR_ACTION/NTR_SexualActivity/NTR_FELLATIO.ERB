;-------------------------------------------------------------------------------
;口交
@NTR_FELLATIO(角色,調教者=人物_訪問者)
#DIM 角色
#DIM 調教者
TCVAR:角色:行為者 = 調教者
CALL NTR_KISS_PET_FELLA_MSG_KOJO_01(角色, 5)
IF FLAG:访问者当前行为中止时刻 == 0
	FLAG:访问者行为计时点 = DATETIME()
	CALL NTR_ADD_SURRENDER(角色, 3)
	SIF EXP:角色:NTR陷落经验 
		CALL NTR_ADD_SURRENDER(角色, 1)
	BASE:角色:体力 -= 10
	BASE:角色:气力 -= 100
	SOURCE:角色:情爱 = 100
	SOURCE:角色:性行动 = 300
	SOURCE:角色:达成 = 150
	SOURCE:角色:屈从 = 700
	SOURCE:角色:肮脏 = 200
	IF TALENT:角色:NTR
		SOURCE:角色:反感 = 50
	ELSEIF CFLAG:角色:屈服度 > 1000
		SOURCE:角色:反感 = 100
	ELSE
		SOURCE:角色:反感 = 200
	ENDIF
	SIF TALENT:角色:自己爱 < 0 || TALENT:角色:抵抗
		SOURCE:角色:抑郁 += 400
	CALL NTR_EXP_ADD_M_SEX(角色,1)
	SIF TALENT:角色:猫舌
		EXP:角色:浮気嗜虐快乐经验 ++
	CALL STAIN_MOVE_BY_PENIS(部位_口, 角色, 人物_訪問者)
	CALL LOST_VIRGIN_M(角色, 人物_訪問者,1)
	IF GETBIT(FLAG:訪問者との汚れ判定に使用,汚れB_精液)
		CALL NTR_EXP_ADD_DRINK_SEMEN(角色,1)
		CFLAG:角色:射精者M = 調教者
		SIF ABL:精饮中毒 < 2
			;无知去除
			CALL 无知去除(角色)
	ENDIF
	FLAG:访问者当前行为中止时刻 = DATETIME() + 10
	CALL NTR_EXP_ADD_M_EX(角色,1)
	FLAG:访问者当前行为 = NTR_行为_口交
	CFLAG:角色:当前与访问者行为 = NTR_行为_口交
	CALL LOST_VIRGIN_M(角色, 人物_訪問者)
	CALL NTR_SOURCE_CHECK_LITE(角色,調教者)
ENDIF
RETURN 0

;-------------------------------------------------------------------------------
;口交終了（絶頂）
;@return 常に0
@NTR_FELLATIO_FINISH(角色)
#DIM 角色
CALL NTR_KISS_PET_FELLA_MSG_KOJO_2(角色, 5)
CALL EJACULATION_M(角色, 人物_訪問者)
CALL NTR_EXP_ADD_M_SEX(角色,1)
RETURN 0