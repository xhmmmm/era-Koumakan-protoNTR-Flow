;-------------------------------------------------------------------------------
;精液残留
;角色 … 対象者コード
;部位 … 0:膣内 1:菊花
@NTR_PUNISHMENT_10(角色, 部位)
#DIM 角色
#DIM 部位
SIF !HAS_VAGINA(角色)
	RETURN 1
SIF CFLAG:角色:精液残留中 != 0
	RETURN 1
CFLAG:角色:精液残留中 = 40
IF NTR_CHK_VISIBLE(CFLAG:角色:当前位置)
	PRINTFORML 
	IF 部位 == 0
		PRINTFORML %NTR_NAME(0)%注入的大量精液就像是拒绝溢出一样在%CALLNAME:角色%的膣内留了下来…
	ELSE
		PRINTFORML %NTR_NAME(0)%注入的大量精液就像是拒绝溢出一样在%CALLNAME:角色%的肠内留了下来…
	ENDIF
	SIF FLAG:口上颜色
		CALL KOJO_COLOR(角色)
	TRYCALLLIST
		FUNC NTR_KOJO_K{CFLAG:角色:口上パターン}_15_10(角色)
		FUNC NTR_KOJO_K_15_10(角色)
	ENDFUNC
	RESETCOLOR
ENDIF
RETURN 0