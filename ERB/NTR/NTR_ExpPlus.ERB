EXP:角色:Ａ经验 += 次数
EXP:角色:浮気Ａ经验 += 次数
EXP:角色:Ａ性交经验 += 次数
EXP:角色:浮気Ａ性交经验 += 次数
IF 訪問者_Ｐ大きさ >= 2
	CALL NTR_EXP_ADD_A_EXPANSION(角色,1)
	IF GETBIT(FLAG:ＮＴＲパッチ設定,32) || CFLAG:MASTER:当前位置 == CFLAG:角色:当前位置
		SIF NTR_CHK_VISIBLE(FLAG:访问者当前位置)
			PRINTFORML %CALLNAME:角色%的尻穴被%NTR_NAME(0)%超常规的肉棒不断拓展着…
	ENDIF
	IF ( TALENT:角色:受虐狂 || ABL:角色:抖Ｍ之气 > 2 ) && EXP:角色:浮気Ａ扩张经验+EXP:角色:Ａ扩张经验 < 450
		CUP:角色:欲情 += 500
		CUP:角色:苦痛 += 250
		CFLAG:角色:覚醒 += 1
	ELSEIF EXP:角色:浮気Ａ扩张经验+EXP:角色:Ａ扩张经验 < 450
		CUP:角色:苦痛 += 500
		CFLAG:角色:覚醒 += 1
	ENDIF
ENDIF

