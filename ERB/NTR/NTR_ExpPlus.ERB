EXP:角色:Ｍ绝顶经验 += 次数
EXP:角色:浮気Ｍ绝顶经验 += 次数
EXP:角色:绝顶经验 += 次数
EXP:角色:浮気绝顶经验 += 次数

@NTR_EXP_ADD_V_SEX(角色,次数)
#DIM 角色
#DIM 次数
EXP:角色:Ｖ经验 += 次数
EXP:角色:浮気Ｖ经验 += 次数
EXP:角色:Ｖ性交经验 += 次数
EXP:角色:浮気Ｖ性交经验 += 次数
IF 訪問者_Ｐ大きさ == 2
	CALL NTR_EXP_ADD_V_EXPANSION(角色,1)
	CALL 締り具合変動, 角色, 18, 0
	IF GETBIT(FLAG:ＮＴＲパッチ設定,32) || CFLAG:MASTER:当前位置 == CFLAG:角色:当前位置
		SIF NTR_CHK_VISIBLE(FLAG:访问者当前位置)
			PRINTFORML %CALLNAME:角色%的小穴被%NTR_NAME(0)%超常规的肉棒不断拓展着…
	ENDIF
	IF ( TALENT:角色:受虐狂 || ABL:角色:抖Ｍ之气 > 2 ) && EXP:角色:浮気Ｖ扩张经验+EXP:角色:Ｖ扩张经验 < 450
		CUP:角色:欲情 += 500
		CUP:角色:苦痛 += 250
	ELSEIF EXP:角色:浮気Ｖ扩张经验+EXP:角色:Ｖ扩张经验 < 450
		CUP:角色:苦痛 += 500
	ENDIF
ENDIF

