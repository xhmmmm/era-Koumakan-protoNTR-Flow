;--------------------------------------------

;-------------------------------------------------------------------------------
;Ｖ感觉高いときの绝顶经验加算（強絶頂のようなもの）
@NTR_V_EXP_PLUS(角色)
#DIM 角色
IF ABL:角色:Ｖ感觉 >= 2
	IF RAND:3 == 0
		CALL NTR_EXP_ADD_V_EX(角色,1)
	ENDIF
ELSEIF ABL:角色:Ｖ感觉 >= 4
	IF RAND:2 == 0
		CALL NTR_EXP_ADD_V_EX(角色,1)
		; EXP:角色:浮気绝顶经验 ++
	ENDIF
ENDIF
IF TALENT:角色:浮気的蜜壶
	IF RAND:2 == 0
		CALL NTR_EXP_ADD_V_EX(角色,1)
		; EXP:角色:浮気绝顶经验 ++
	ENDIF
ENDIF
RETURN 0

;-------------------------------------------------------------------------------
;Ａ感觉高いときの绝顶经验加算（強絶頂のようなもの）
@NTR_A_EXP_PLUS(角色)
#DIM 角色
IF ABL:角色:Ａ感觉 >= 2
	IF RAND:3 == 0
		CALL NTR_EXP_ADD_A_EX(角色,1)
		; EXP:角色:浮気绝顶经验 ++
	ENDIF
ELSEIF ABL:角色:Ａ感觉 >= 4
	IF RAND:2 == 0
		CALL NTR_EXP_ADD_A_EX(角色,1)
		; EXP:角色:浮気绝顶经验 ++
	ENDIF
ENDIF
IF TALENT:角色:浮気的菊花
	IF RAND:2 == 0
		CALL NTR_EXP_ADD_A_EX(角色,1)
		; EXP:角色:浮気绝顶经验 ++
	ENDIF
ENDIF
RETURN 0