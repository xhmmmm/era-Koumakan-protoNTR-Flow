;-------------------------------------------------------------------------------
;性交時メッセージ分岐
;角色…対象キャラ
;行為段階…0=開始 1=継続 2=終了
;玩家在场…0=二人きり 1=玩家在场
;関数種別…口上または地の文の関数名の一部
@NTR_SEX_KOJO_EX(角色, 行為段階, 玩家在场, 関数種別)
#DIM 角色
#DIM 行為段階
#DIM 玩家在场
#DIMS 関数種別
#DIM 体位
SIF FLAG:口上テキスト設定 <= 0 && 関数種別 == "KOJO_PRE"
	RETURN 0
SIF FLAG:口上テキスト設定 <= 0 && 関数種別 == "KOJO"
	RETURN 0
SIF FLAG:情景テキスト設定 <= 0 && 関数種別 == "MESSAGE"
	RETURN 0
SIF 関数種別 != "MESSAGE" && 関数種別 != "KOJO" && 関数種別 != "KOJO_PRE"
	RETURN 0
体位 = FLAG:访问者当前行为 - NTR_行为_Ｖ正常位
SIF FLAG:访问者当前行为 > NTR_行为_Ｖ背面座位
	体位 = FLAG:访问者当前行为 - NTR_行为_Ｖ背面座位
IF 玩家在场 != 0
	CFLAG:角色:同席目撃回数 ++
	CFLAG:角色:同席目撃時行為 = MAX(CFLAG:角色:同席目撃時行為, FLAG:访问者当前行为)
ENDIF


SIF FLAG:口上颜色
	CALL KOJO_COLOR(角色)
IF (NTR_KOJO_SEX_FIRSTTIME(角色,体位) || NTR_KOJO_SEX_FIRSTTIME(角色,1000)) && CFLAG:角色:(2000+体位) != 3 && (関数種別 == "KOJO" || 関数種別 == "KOJO_PRE")
	;简化口上书写，不写PRE（前口上）
	;在确定有第一次口上的情况下，跳过PRE绝对没什么问题，也防止输出两次
	IF 関数種別 == "KOJO"
		TRYCALLLIST
			FUNC NTR_KOJO_SEX_FIRSTTIME_K{角色}_{体位}_{行為段階}(角色)
			FUNC NTR_KOJO_SEX_FIRSTTIME_KU_{体位}_{行為段階}(角色)
			;通用体位
			FUNC NTR_KOJO_SEX_FIRSTTIME_K{角色}_U_{行為段階}(角色)
			FUNC NTR_KOJO_SEX_FIRSTTIME_KU_U_{行為段階}(角色)
[SKIPSTART]
			FUNC NTR_%関数種別%_%LOCALS%{角色}_8_{体位}_{行為段階}(角色)
			FUNC NTR_%関数種別%_%LOCALS%{角色}_8_U_{行為段階}(角色)
			FUNC NTR_%関数種別%_%LOCALS%_8_{体位}_{行為段階}(角色)
			FUNC NTR_%関数種別%_%LOCALS%_8_U_{行為段階}(角色)
			FUNC NTR_%関数種別%_%LOCALS%_8_0_{行為段階}(角色)
[SKIPEND]
		ENDFUNC
		CFLAG:角色:(2000+体位) += 1
	ENDIF
ELSE
	; ここで使われているLOCALSの用途が不明 <- 他说他不知道这里的字符串是干嘛用的 等会不是你写的这坨屎山吗？！——超级猫猫
	TRYCALLLIST
		;キャラ専用・体位専用
		FUNC NTR_%関数種別%_%LOCALS%{角色}_8_{体位}_{行為段階}(角色)
		;キャラ専用・体位汎用
		FUNC NTR_%関数種別%_%LOCALS%{角色}_8_U_{行為段階}(角色)
		;キャラ汎用・体位専用
		FUNC NTR_%関数種別%_%LOCALS%_8_{体位}_{行為段階}(角色)
		;キャラ汎用・体位汎用
		FUNC NTR_%関数種別%_%LOCALS%_8_U_{行為段階}(角色)
		;キャラ汎用・体位汎用がなければ正常位で代用
		FUNC NTR_%関数種別%_%LOCALS%_8_0_{行為段階}(角色)
	ENDFUNC
ENDIF
IF 玩家在场 != 0
	; 同席のときは _KW, _K の順で検索
	TRYCALLLIST
		;キャラ専用・体位専用
		FUNC NTR_%関数種別%_KW{CFLAG:角色:口上パターン}_8_{体位}_{行為段階}(角色)
		FUNC NTR_%関数種別%_K{CFLAG:角色:口上パターン}_8_{体位}_{行為段階}(角色)
		;キャラ専用・体位汎用
		FUNC NTR_%関数種別%_KW{CFLAG:角色:口上パターン}_8_U_{行為段階}(角色)
		FUNC NTR_%関数種別%_K{CFLAG:角色:口上パターン}_8_U_{行為段階}(角色)
		;キャラ汎用・体位専用
		FUNC NTR_%関数種別%_KW_8_{体位}_{行為段階}(角色)
		FUNC NTR_%関数種別%_K_8_{体位}_{行為段階}(角色)
		;キャラ汎用・体位汎用
		FUNC NTR_%関数種別%_KW_8_U_{行為段階}(角色)
		FUNC NTR_%関数種別%_K_8_U_{行為段階}(角色)
		;キャラ汎用・体位汎用がなければ正常位で代用
		FUNC NTR_%関数種別%_KW_8_0_{行為段階}(角色)
		FUNC NTR_%関数種別%_K_8_0_{行為段階}(角色)
	ENDFUNC
ELSE
	; 同席でないときは _K の関数のみ検索
	TRYCALLLIST
		;キャラ専用・体位専用
		FUNC NTR_%関数種別%_K{CFLAG:角色:口上パターン}_8_{体位}_{行為段階}(角色)
		;キャラ専用・体位汎用
		FUNC NTR_%関数種別%_K{CFLAG:角色:口上パターン}_8_U_{行為段階}(角色)
		;キャラ汎用・体位専用
		FUNC NTR_%関数種別%_K_8_{体位}_{行為段階}(角色)
		;キャラ汎用・体位汎用
		FUNC NTR_%関数種別%_K_8_U_{行為段階}(角色)
		;キャラ汎用・体位汎用がなければ正常位で代用
		FUNC NTR_%関数種別%_K_8_0_{行為段階}(角色)
	ENDFUNC
ENDIF
RESETCOLOR
RETURN 0

