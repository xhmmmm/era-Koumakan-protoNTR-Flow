;-------------------------------------------------------------------------------
;性交時メッセージ・口上分岐
;玩家在场での見せつけも考慮
;角色…対象キャラ
@NTR_SEX_MSG_KOJO(角色)
#DIM 角色
#DIM 開始継続
#DIM 玩家在场
SIF FLAG:口上颜色
	CALL KOJO_COLOR(角色)
IF NTR_CHK_VISIBLE(FLAG:访问者当前位置)
	; 開始／継続フラグ
	開始継続 = ( FLAG:访问者当前行为中止时刻 == 0 ? 0 # 1 )
	; 玩家在场（見せつけ）フラグ
	玩家在场 = ( CFLAG:MASTER:当前位置 == FLAG:访问者当前位置 ? 1 # 0 )
	CALL NTR_SEX_KOJO_EX(角色, 開始継続, 玩家在场, "KOJO_PRE")
	CALL NTR_SEX_KOJO_EX(角色, 開始継続, 玩家在场, "MESSAGE")
	CALL NTR_SEX_KOJO_EX(角色, 開始継続, 玩家在场, "KOJO")
ENDIF
RESETCOLOR
RETURN 0

