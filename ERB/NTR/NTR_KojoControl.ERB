	RETURN 0
SIF FLAG:情景テキスト設定 <= 0 && 関数種別 == "MESSAGE"
	RETURN 0
SIF 関数種別 != "MESSAGE" && 関数種別 != "KOJO" && 関数種別 != "KOJO_PRE"
	RETURN 0
体位 = FLAG:访问者当前行为 - NTR_行为_Ａ正常位
SIF FLAG:访问者当前行为 > NTR_行为_Ａ背面座位
	体位 = FLAG:访问者当前行为 - NTR_行为_Ａ背面座位
IF 玩家在场 != 0
	CFLAG:角色:同席目撃回数 ++
	CFLAG:角色:同席目撃時行為 = MAX(CFLAG:角色:同席目撃時行為, FLAG:访问者当前行为)
ENDIF
SIF FLAG:口上颜色
	CALL KOJO_COLOR(角色)
IF 玩家在场 != 0
	; 同席のときは _KW, _K の順で検索
	TRYCALLLIST
		;キャラ専用・体位専用
		FUNC NTR_%関数種別%_KW{CFLAG:角色:口上パターン}_9_{体位}_{行為段階}(角色)
		FUNC NTR_%関数種別%_K{CFLAG:角色:口上パターン}_9_{体位}_{行為段階}(角色)
