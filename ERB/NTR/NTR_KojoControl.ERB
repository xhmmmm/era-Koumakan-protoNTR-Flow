;-------------------------------------------------------------------------------
;キス、爱抚、侍奉時メッセージ・口上分岐
;玩家在场での見せつけも考慮
;角色…対象キャラ
;行為…行為コード 2:キス 3:爱抚 4:胸爱抚 5:口交 6:69 7:素股
@NTR_KISS_PET_FELLA_MSG_KOJO_01(角色, 行為)
#DIM 角色
#DIM 行為
SIF FLAG:口上颜色
	CALL KOJO_COLOR(角色)
;玩家在场（見せつけ）
IF CFLAG:MASTER:当前位置 == FLAG:访问者当前位置 && 角色 != MASTER
	;開始
	IF FLAG:访问者当前行为中止时刻 == 0
		CALLFORM NTR_MESSAGE_W_{行為}_0(角色)
		TRYCALLLIST
			FUNC NTR_KOJO_KW{CFLAG:角色:口上パターン}_{行為}_0(角色)
			FUNC NTR_KOJO_KW_{行為}_0(角色)
			FUNC NTR_KOJO_K{CFLAG:角色:口上パターン}_{行為}_0(角色)
		ENDFUNC
		;継続
	ELSE
		CALLFORM NTR_MESSAGE_W_{行為}_1(角色)
		TRYCALLLIST
			FUNC NTR_KOJO_KW{CFLAG:角色:口上パターン}_{行為}_1(角色)
			FUNC NTR_KOJO_KW_{行為}_1(角色)
			FUNC NTR_KOJO_K{CFLAG:角色:口上パターン}_{行為}_1(角色)
		ENDFUNC
	ENDIF
	CFLAG:角色:同席目撃回数 ++
	CFLAG:角色:同席目撃時行為 = MAX(CFLAG:角色:同席目撃時行為, 行為)
	;二人きり
ELSE
	IF NTR_CHK_VISIBLE(FLAG:访问者当前位置)
		;開始
		IF FLAG:访问者当前行为中止时刻 == 0
			CALLFORM NTR_MESSAGE_{行為}_0(角色)
			TRYCALLLIST
				FUNC NTR_KOJO_K{CFLAG:角色:口上パターン}_{行為}_0(角色)
				FUNC NTR_KOJO_K_{行為}_0(角色)
			ENDFUNC
			;継続
		ELSE
			CALLFORM NTR_MESSAGE_{行為}_1(角色)
			TRYCALLLIST
				FUNC NTR_KOJO_K{CFLAG:角色:口上パターン}_{行為}_1(角色)
				FUNC NTR_KOJO_K_{行為}_1(角色)
			ENDFUNC
		ENDIF
	ENDIF
ENDIF
RESETCOLOR
RETURN 0

