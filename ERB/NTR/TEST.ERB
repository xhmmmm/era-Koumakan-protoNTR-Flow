@NTR_NumberOfActivity_KU(角色)
#FUNCTION
#DIM 角色
IF NTR_CHK_FAVORABLY(角色,FAV_寝取られ) 
	RETURNF 8
ELSEIF NTR_CHK_FAVORABLY(角色,FAV_寝取られ寸前)
	RETURNF 8
ELSEIF NTR_CHK_FAVORABLY(角色,FAV_寝取られそう)
	RETURNF 8
ELSEIF NTR_CHK_FAVORABLY(角色,FAV_主人より高い)
	RETURNF 8
ELSEIF NTR_CHK_FAVORABLY(角色,FAV_うふふする程度2)
	RETURNF 8
ELSEIF NTR_CHK_FAVORABLY(角色,FAV_うふふする程度)
	RETURNF 6
ELSEIF NTR_CHK_FAVORABLY(角色,FAV_侍奉する程度)
	RETURNF 6
ELSEIF NTR_CHK_FAVORABLY(角色,FAV_体を触らせる程度)
	RETURNF 3
ELSEIF NTR_CHK_FAVORABLY(角色,FAV_接吻程度)
	RETURNF 1
ENDIF
RETURNF 0

@NTR_ActivityCall_KU(角色,阶段行为编号,密室度)
#DIM 角色
#DIM 阶段行为编号
#DIM 密室度
IF NTR_CHK_FAVORABLY(角色,FAV_うふふする程度2)
	SELECTCASE 阶段行为编号
		CASE 8
			CALL NTR_A_SEX(角色,密室度)
		CASE 7
			CALL NTR_SEX(角色,密室度)
		CASE 6
			CALL NTR_THUG(角色)
		CASE 5
			CALL NTR_69(角色)
		CASE 4
			CALL NTR_FELLATIO(角色)
		CASE 3
			CALL NTR_BUST_PET(角色)
		CASE 2
			CALL NTR_PET(角色)
		CASE 1
			CALL NTR_KISS(角色)
		CASEELSE
			IF CFLAG:MASTER:当前位置 == FLAG:访问者当前位置 && !CFLAG:角色:睡眠
				;会话（玩家在场）
				CALL NTR_MESSAGE_1_1(角色)
				CALL NTR_RESET_VISITOR_ACTION(角色)
				TRYCALLLIST
					FUNC NTR_KOJO_KW{CFLAG:角色:口上パターン}_1(角色)
					FUNC NTR_KOJO_KW_1(角色)
				ENDFUNC
			ELSEIF NTR_CHK_VISIBLE(FLAG:访问者当前位置) && !CFLAG:角色:睡眠
				;会话（玩家不在场）
				CALL NTR_MESSAGE_1_0(角色)
				CALL NTR_RESET_VISITOR_ACTION(角色)
				SIF FLAG:口上颜色
					CALL KOJO_COLOR(角色)
				TRYCALLLIST 
					FUNC NTR_KOJO_K{CFLAG:角色:口上パターン}_1(角色)
					FUNC NTR_KOJO_K_1(角色)
				ENDFUNC
				RESETCOLOR
			ENDIF
			CALL NTR_COUNTER(角色)
	ENDSELECT
ELSEIF NTR_CHK_FAVORABLY(角色,FAV_侍奉する程度)
	SELECTCASE 阶段行为编号
		CASE 6
			CALL NTR_THUG(角色)
		CASE 5
			CALL NTR_69(角色)
		CASE 4
			CALL NTR_FELLATIO(角色)
		CASE 3
			CALL NTR_BUST_PET(角色)
		CASE 2
			CALL NTR_PET(角色)
		CASE 1
			CALL NTR_KISS(角色)
		CASEELSE
			IF CFLAG:MASTER:当前位置 == FLAG:访问者当前位置 && !CFLAG:角色:睡眠
				;会话（玩家在场）
				CALL NTR_MESSAGE_1_1(角色)
				CALL NTR_RESET_VISITOR_ACTION(角色)
				TRYCALLLIST
					FUNC NTR_KOJO_KW{CFLAG:角色:口上パターン}_1(角色)
					FUNC NTR_KOJO_KW_1(角色)
				ENDFUNC
			ELSEIF NTR_CHK_VISIBLE(FLAG:访问者当前位置) && !CFLAG:角色:睡眠
				;会话（玩家不在场）
				CALL NTR_MESSAGE_1_0(角色)
				CALL NTR_RESET_VISITOR_ACTION(角色)
				SIF FLAG:口上颜色
					CALL KOJO_COLOR(角色)
				TRYCALLLIST 
					FUNC NTR_KOJO_K{CFLAG:角色:口上パターン}_1(角色)
					FUNC NTR_KOJO_K_1(角色)
				ENDFUNC
				RESETCOLOR
			ENDIF
			CALL NTR_COUNTER(角色)
	ENDSELECT
ELSEIF NTR_CHK_FAVORABLY(角色,FAV_体を触らせる程度)
	SELECTCASE 阶段行为编号
		CASE 3
			CALL NTR_BUST_PET(角色)
		CASE 2
			CALL NTR_PET(角色)
		CASE 1
			CALL NTR_KISS(角色)
		CASEELSE
			IF CFLAG:MASTER:当前位置 == FLAG:访问者当前位置 && !CFLAG:角色:睡眠
				;会话（玩家在场）
				CALL NTR_MESSAGE_1_1(角色)
				CALL NTR_RESET_VISITOR_ACTION(角色)
				TRYCALLLIST
					FUNC NTR_KOJO_KW{CFLAG:角色:口上パターン}_1(角色)
					FUNC NTR_KOJO_KW_1(角色)
				ENDFUNC
			ELSEIF NTR_CHK_VISIBLE(FLAG:访问者当前位置) && !CFLAG:角色:睡眠
				;会话（玩家不在场）
				CALL NTR_MESSAGE_1_0(角色)
				CALL NTR_RESET_VISITOR_ACTION(角色)
				SIF FLAG:口上颜色
					CALL KOJO_COLOR(角色)
				TRYCALLLIST 
					FUNC NTR_KOJO_K{CFLAG:角色:口上パターン}_1(角色)
					FUNC NTR_KOJO_K_1(角色)
				ENDFUNC
				RESETCOLOR
			ENDIF
			CALL NTR_COUNTER(角色)
	ENDSELECT
ELSEIF NTR_CHK_FAVORABLY(角色,FAV_接吻程度)
	SELECTCASE 阶段行为编号
		CASE 1
			CALL NTR_KISS(角色)
		CASEELSE
			IF CFLAG:MASTER:当前位置 == FLAG:访问者当前位置 && !CFLAG:角色:睡眠
				;会话（玩家在场）
				CALL NTR_MESSAGE_1_1(角色)
				CALL NTR_RESET_VISITOR_ACTION(角色)
				TRYCALLLIST
					FUNC NTR_KOJO_KW{CFLAG:角色:口上パターン}_1(角色)
					FUNC NTR_KOJO_KW_1(角色)
				ENDFUNC
			ELSEIF NTR_CHK_VISIBLE(FLAG:访问者当前位置) && !CFLAG:角色:睡眠
				;会话（玩家不在场）
				CALL NTR_MESSAGE_1_0(角色)
				CALL NTR_RESET_VISITOR_ACTION(角色)
				SIF FLAG:口上颜色
					CALL KOJO_COLOR(角色)
				TRYCALLLIST 
					FUNC NTR_KOJO_K{CFLAG:角色:口上パターン}_1(角色)
					FUNC NTR_KOJO_K_1(角色)
				ENDFUNC
				RESETCOLOR
			ENDIF
			CALL NTR_COUNTER(角色)
	ENDSELECT
ELSE
	IF CFLAG:MASTER:当前位置 == FLAG:访问者当前位置 && !CFLAG:角色:睡眠
				;会话（玩家在场）
		CALL NTR_MESSAGE_1_1(角色)
		CALL NTR_RESET_VISITOR_ACTION(角色)
		TRYCALLLIST
			FUNC NTR_KOJO_KW{CFLAG:角色:口上パターン}_1(角色)
			FUNC NTR_KOJO_KW_1(角色)
		ENDFUNC
	ELSEIF NTR_CHK_VISIBLE(FLAG:访问者当前位置) && !CFLAG:角色:睡眠
				;会话（玩家不在场）
		CALL NTR_MESSAGE_1_0(角色)
		CALL NTR_RESET_VISITOR_ACTION(角色)
		SIF FLAG:口上颜色
			CALL KOJO_COLOR(角色)
		TRYCALLLIST 
			FUNC NTR_KOJO_K{CFLAG:角色:口上パターン}_1(角色)
			FUNC NTR_KOJO_K_1(角色)
		ENDFUNC
		RESETCOLOR
	ENDIF
	CALL NTR_COUNTER(角色)
ENDIF
RETURN 0