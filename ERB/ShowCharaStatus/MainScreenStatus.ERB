;-------------------------------------------------------------------------------
;日数および時間を表示する
;@param ARG:0 キャラクターの番号
@INFO_PrintCurrentTime(ARG:0)
;24時を回っていたら日付を進める
IF TIME > 1440
	DAY ++
	TIME -= 1440
	CALL 日期_日期变更
	CALL 日間気温設定
ENDIF
PRINTFORM %日期_月份名称(日期_月数)%{日期_天数}日[%TOSTR(DAY)+"日目]("+GET_DAY()+") "+TOSTR(TIME/60,"00")+"時"+TOSTR(TIME%60,"00")+"分"%
IF 6<=TIME/60 && TIME/60<=18
	;06時から18時までは昼間
	SETCOLOR 颜色_时间_白天
	PRINTFORM %UNICODE(0x2600)%
ELSE
	;18時から06時までは夜間
	SETCOLOR 颜色_时间_夜间
	PRINTFORM %UNICODE(0x262A)%
ENDIF
RESETCOLOR
PRINTFORM （%天候(天候値)%）{FLAG:60}℃
IF DATETIME() - CFLAG:(ARG:0):起床時間 >= 要睡眠経過時間
	;起床から16時間経過していれば[要睡眠]
	SETCOLOR 颜色_状态_要睡眠
	PRINTFORM %"[要睡眠]"%
ELSEIF DATETIME() - CFLAG:(ARG:0):起床時間 >= 睡眠可経過時間
	;起床から12時間経過していれば[睡眠可]
	SETCOLOR 颜色_状态_可睡眠
	PRINTFORM %"[睡眠可]"%
ENDIF
PRINTFORML 
RESETCOLOR
RETURN

;-------------------------------------------------------------------------------
;位置信息行：✦ 位置：XXX 清洁度：YYY ────...───
;位置名保持默认色，清洁度值用对应颜色，其余用主题星色
;@param ARG:0 角色编号
;-------------------------------------------------------------------------------
@INFO_PrintPositionLine(ARG:0)
#DIMS 位置名
#DIMS 清洁度字段
#DIM 清洁度颜色
#DIM 内容宽度
#DIM 剩余宽度
;获取位置名
TRYCCALLFORM %"GetPlaceName_"+TOSTR(CFLAG:(ARG:0):当前位置)%, ARG:0
	位置名 = %GetPlaceName(CFLAG:(ARG:0):当前位置)%(%RESULTS:0%)
CATCH
	位置名 = %GetPlaceName(CFLAG:(ARG:0):当前位置)%
ENDCATCH
;获取清洁度
清洁度字段 =
清洁度颜色 = 0
IF !FLAG:ゴミ表示OFF && TFLAG:COMABLE管理 != 2
	SELECTCASE FLAG:(100+CFLAG:(ARG:0):当前位置)
		CASE IS < 100
			清洁度颜色 = 颜色_清洁度1
			清洁度字段 = 最高
		CASE IS < 500
			清洁度颜色 = 颜色_清洁度2
			清洁度字段 = 高
		CASE IS < 1000
			清洁度颜色 = 颜色_清洁度3
			清洁度字段 = 较高
		CASE IS < 2000
			清洁度颜色 = 颜色_清洁度4
			清洁度字段 = 中
		CASE IS < 3500
			清洁度颜色 = 颜色_清洁度5
			清洁度字段 = 较低
		CASE IS < 5000
			清洁度颜色 = 颜色_清洁度6
			清洁度字段 = 低
		CASEELSE
			清洁度颜色 = 颜色_清洁度7
			清洁度字段 = 垃圾之山
	ENDSELECT
ENDIF
内容宽度 = (18 + STRLENS(位置名) + STRLENS(清洁度字段))/2
剩余宽度 = UI_行全角宽度 - 内容宽度
SIF 剩余宽度 < 0
	剩余宽度 = 0
;输出
SETCOLOR 颜色_暗金
PRINTFORM ✦ 位置：
RESETCOLOR
PRINTFORM %位置名%
IF STRLENS(清洁度字段) > 0
	SETCOLOR 颜色_暗金
	PRINTFORM  清洁度：
	RESETCOLOR
	SETCOLOR 清洁度颜色
	PRINTFORM %清洁度字段%
	RESETCOLOR
ENDIF
SETCOLOR 颜色_暗金
PRINTFORM  %UI_重复横线(剩余宽度)%
RESETCOLOR
PRINTL
RETURN 0

