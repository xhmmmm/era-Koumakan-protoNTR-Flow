		CALL 主界面_装饰右边框(128)
		PRINTL
	ENDIF
ENDIF
RETURN 0

;-------------------------------------------------------------------------------
;調教ターゲットを選択する。
;部屋内における各キャラの亲密程度についても設定。
;@param ARG:0 未使用
@INFO_SetTarget(ARG:0)
;ターゲットを初期化
VARSET TARGET
;CFLAG:館内地位(310)でソート
CALL SORT_CFLAG(310)
; LOCAL 0:ループ用、1:キャラ番号、2:ターゲット数、3:起きてるキャラの最小亲密程度
VARSET LOCAL
LOCAL:3 = 99
TCVAR:MASTER:亲密程度=0
;当前位置が同じキャラを取得し、ターゲット候補一覧に追加
FOR LOCAL:0,1,CHARANUM
	;先ほど取得した館内地位順でキャラ番号を取得
	LOCAL:1 = RESULT:(LOCAL:0)
	IF CFLAG:(LOCAL:1):当前位置 == CFLAG:MASTER:当前位置
		;同じ位置にいるのなら、(寝ていたとしても)ターゲット候補に追加
		LOCAL:2++
		TARGET:(LOCAL:2) = LOCAL:1
		;ターゲットが未定だったら、とりあえず仮ターゲットとする
		IF TARGET:0 == 0
			TARGET:0 = LOCAL:1
		ENDIF
		;前回のターゲットがいるなら、(寝ていたとしても)それを最優先でターゲットにする。
		IF LOCAL:1 == TFLAG:現在のTARGET
			TARGET:0 = LOCAL:1
		ENDIF
		;亲密程度は、同室中の上位キャラの亲密程度以下に制限される。偉い人の前ではうふふできない。
		TCVAR:(LOCAL:1):亲密程度 = TALENT:(LOCAL:1):NTR ? 3 # MIN(CFLAG:(LOCAL:1):亲密程度,LOCAL:3)
		IF !CFLAG:(LOCAL:1):睡眠
			;起きてるキャラの最小亲密程度を取得
			LOCAL:3 = MIN(CFLAG:(LOCAL:1):亲密程度,LOCAL:3)
			TCVAR:MASTER:亲密程度 = TALENT:(LOCAL:1):NTR ? 3 # MAX(CFLAG:(LOCAL:1):亲密程度,0)
		ENDIF
	ENDIF
	;DEBUGPRINTFORML %CALLNAME:(LOCAL:1)+"の亲密程度:"%{TCVAR:(LOCAL:1):亲密程度}
NEXT
;DEBUGPRINTFORML %CALLNAME:MASTER+"の亲密程度:"%{TCVAR:MASTER:亲密程度}
;現在のターゲットを更新
TFLAG:現在のTARGET = TARGET:0
RETURN 0

;-------------------------------------------------------------------------------
;うふふモードの切り替えなど
;とりあえず関数に切り出しただけの状態なんでさらにリファクタリング必要
;@param ARG:0 未使用
@INFO_SetTrainMode(ARG:0)
#DIM 角色
#DIM 同室人数
#DIM POS_NOW		; MASTERの当前位置
#DIM LOOP_CHR
#DIM 告白判定値
#DIM 右侧宽度
#DIM 左侧宽度
#DIM 填充宽度
#DIM 填充宽度补正
#DIMS 按钮文本

角色 = TARGET:0
POS_NOW = CFLAG:MASTER:当前位置
IF 角色 && !CFLAG:角色:睡眠
	;MASTERの位置から見て他の部屋にだれかいるかどうか
	同室人数 = 0
	FOR LOOP_CHR,1,CHARANUM
		SIF CFLAG:LOOP_CHR:当前位置 == POS_NOW
			CONTINUE
		SIF CAN_MOVE(POS_NOW, CFLAG:LOOP_CHR:当前位置) == 2
			同室人数 ++
	NEXT
	IF CFLAG:角色:うふふ == 1
		;うふふ(1)時
		TFLAG:COMABLE管理 = 2
	ELSEIF CFLAG:角色:うふふ == 2
		;押し倒し(2)時
		TFLAG:COMABLE管理 = 3
	ELSEIF TCVAR:MASTER:亲密程度 > 2 && !同室人数 && BASE:角色:满足*2 < MAXBASE:角色:满足 && !OPENPLACE(POS_NOW) && POS_NOW != FLAG:访问者当前位置 && !TALENT:NTR && CHK_350_STAIN_SEMEN(角色) && CFLAG:角色:性欲 > 25
		;あなたの亲密程度が3以上で、対象が满足状態でなく、密室で、訪問者がいなく、NTRでもない場合は押し倒される
		;オープンスペース（正門、広間、庭、二階踊り場、廊下）では押し倒されない
		;精液汚れによる押し倒し可否で失敗すると押し倒されない
		IF TFLAG:COMABLE管理 != 3
			PRINTL
			PRINTFORMW %CALLNAME:MASTER%は押し倒された！
			CALL KOJO_EVENT(12, TARGET)
		ENDIF
		FOR LOOP_CHR,1,CHARANUM
			CFLAG:(TARGET:LOOP_CHR):うふふ = 2
		NEXT
		CFLAG:MASTER:うふふ = 2
		TFLAG:COMABLE管理 = 3
		;ELSEIF GET_TARGETNUM() < 2 && TCVAR:MASTER:130 && !GETBIT(CFLAG:既成事実 , 0) && !CFLAG:睡眠 && BASE:MASTER:气力 > 0
	ELSEIF GET_TARGETNUM() < 2 && TCVAR:MASTER:130 && !TALENT:恋人 && !CFLAG:睡眠 && BASE:MASTER:气力 > 0
		TFLAG:COMABLE管理 = 1
		告白判定値 = 0
		告白判定値 += GET_MARK_LEVEL(角色,刻印番号_屈服刻印,MASTER) * 3 ;あなたが付けた屈服刻印のLV×3
		告白判定値 += GET_MARK_LEVEL(角色,刻印番号_快乐刻印,MASTER) * 3 ;あなたが付けた快乐刻印のLV×3
		告白判定値 += MIN(ABL:亲密 * 10, 50)                            ;亲密×10、最大50
		告白判定値 += MIN(ABL:欲望 * 10, 50)                            ;欲望×10、最大50
		告白判定値 += GETPALAMLV(PALAM:欲情, 5) * 5                     ;好意レベル×5
		告白判定値 += GETPALAMLV(PALAM:好意, 5) * 5                     ;好意レベル×5
		告白判定値 += BASE:气氛 / 50                                  ;气氛による増加:0～30
		告白判定値 += (1000 - BASE:理性) / 30                           ;理性による増加:0～33
		;NTR時告白してこない
		IF 告白判定値 > 180 + TALENT:难以越过的界线 * 20
			PRINTFORMW %CALLNAME:TARGET%向%CALLNAME:MASTER%诉说了自己的恋情・・・・・・
			PRINTFORMW %CALLNAME:MASTER%红着脸接受了%CALLNAME:TARGET%的告白……
			TALENT:TARGET:恋人 = 1
		ENDIF
	ELSE
		TFLAG:COMABLE管理 = 1
	ENDIF
ELSE
	TFLAG:COMABLE管理 = 0
ENDIF
;同じ場所にいるキャラクターを表示

同室人数 = 0
右侧宽度 = 0
填充宽度补正 = 0
;计算右侧宽度
;访问者
IF FLAG:访问者当前位置 == POS_NOW
	按钮文本 = ✧ %NTR_NAME(0)%
	SIF FLAG:訪問者同行フラグ
		按钮文本 += "(同行中)"
	按钮文本 += " "
	右侧宽度 += STRLENS(按钮文本)
	填充宽度补正 += 1
	同室人数++
ENDIF
;角色们
FOR LOOP_CHR,1,CHARANUM
	IF CFLAG:LOOP_CHR:当前位置 == POS_NOW && LOOP_CHR != TARGET
		按钮文本 = ✧ %CALLNAME:LOOP_CHR%
		IF CFLAG:LOOP_CHR:睡眠
			按钮文本 += "(睡眠中)"
		ELSEIF CFLAG:LOOP_CHR:同行
			按钮文本 += "(同行中)"
		ENDIF
		按钮文本 += " "
		右侧宽度 += STRLENS(按钮文本)
		填充宽度补正 += 1
		同室人数++
	ENDIF
NEXT
IF 同室人数 > 0
	右侧宽度 += STRLENS("✧ 点击切换对象")
	填充宽度补正 += 1
ENDIF
;左侧宽度
左侧宽度 = STRLENS("  ✧ 当前对象：")
填充宽度补正 += 1
IF TARGET > 0
	左侧宽度 += STRLENS(CALLNAME:TARGET)
	IF CFLAG:TARGET:睡眠
		左侧宽度 += STRLENS("(睡眠中)")
	ELSEIF CFLAG:TARGET:同行
		左侧宽度 += STRLENS("(同行中)")
	ENDIF
ELSE
	左侧宽度 += STRLENS("无")
ENDIF
;“填充宽度补正”计算的是有几个“✧”，而在游戏中5个“✧”大概是6格半角，因此每5个“✧”应该减去一个空格，这样长度才能差不多不超过限度
填充宽度 = UI_行半角宽度 - 左侧宽度 - 右侧宽度 - 填充宽度补正/5
SIF 填充宽度 < 1
	填充宽度 = 1
;输出左侧
SETCOLOR 颜色_浅金
PRINT   ✧ 当前对象：
RESETCOLOR
IF TARGET > 0
	IF CFLAG:TARGET:睡眠
		SETCOLOR 颜色_状态_睡眠中
		PRINTFORM %CALLNAME:TARGET%(睡眠中)
		RESETCOLOR
	ELSEIF CFLAG:TARGET:同行
		SETCOLOR 颜色_状态_同行中
		PRINTFORM %CALLNAME:TARGET%(同行中)
		RESETCOLOR
	ELSE
		PRINTFORM %CALLNAME:TARGET%
	ENDIF
ELSE
	PRINT 无
ENDIF
;输出填充
PRINTFORM %" "*填充宽度%
;输出右侧
;其他在场角色（排除TARGET）
FOR LOOP_CHR,1,CHARANUM
	IF CFLAG:LOOP_CHR:当前位置 == POS_NOW && LOOP_CHR != TARGET
		SETCOLOR 颜色_浅金
		PRINT ✧ 
		RESETCOLOR
		IF CFLAG:LOOP_CHR:睡眠
			SETCOLOR 颜色_状态_睡眠中
			LOCALS = (睡眠中)
		ELSEIF CFLAG:LOOP_CHR:同行
			SETCOLOR 颜色_状态_同行中
			LOCALS = (同行中)
		ELSE
			LOCALS = 
		ENDIF
		PRINTBUTTON CALLNAME:LOOP_CHR+LOCALS, 700 + LOOP_CHR
		RESETCOLOR
		PRINT  
	ENDIF
NEXT
;访问者
IF FLAG:访问者当前位置 == POS_NOW
	SETCOLOR 颜色_浅金
	PRINT ✧
	RESETCOLOR
	PRINTFORM %NTR_NAME(0)%
	SIF FLAG:訪問者同行フラグ
		PRINT (同行中)
	PRINT  
ENDIF
;提示
IF 同室人数 > 0
	SETCOLOR 颜色_浅金
	PRINTFORMC %"✧ 点击切换对象           "%
	PRINT 
	RESETCOLOR
ENDIF
PRINTL
RETURN 0

