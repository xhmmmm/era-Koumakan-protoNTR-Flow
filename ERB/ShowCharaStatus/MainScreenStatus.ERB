;-------------------------------------------------------------------------------
;パラメーターを表示する
;@param ARG:0 表示するキャラクター番号
@INFO_PrintPalams(角色)
#DIM 角色
#DIM ParamNo
#DIM ParamLv
#DIM NextSource
#DIM DispCount
#DIM 项宽
#DIM 空项数
DispCount = 0
CALL 主界面_竖边框
FOR ParamNo, 0, 101
	;跳过没有PALAMNAME的PALAM
	IF !STRLENS(PALAMNAME:ParamNo)
		CONTINUE
	ENDIF
	;何度も使うので現在のPALAMLVを保持
	ParamLv = GETPALAMLV(PALAM:角色:ParamNo,15)
	;显示PALAM名和当前等级
	PRINTFORM %" "+PALAMNAME:ParamNo + "Lv"%{ParamLv,2}
	PRINTFORM %" "%
	;PALAMLV超过15就当作全满处理
	IF ParamLv >= 15
		SETCOLOR 颜色_灰粉
		PRINTFORM %"░"*8%
		RESETCOLOR
	ELSE
		;进度条长度为8，用`颜色_灰粉`和`颜色_深灰`填色
		SETCOLOR 颜色_灰粉
		PRINTFORM %"░"*LIMIT(  8 * (PALAM:角色:ParamNo - PALAMLV:ParamLv) / (PALAMLV:(ParamLv+1) - PALAMLV:ParamLv), 0, 8)%
		RESETCOLOR
		SETCOLOR 颜色_深灰
		PRINTFORM %"░"*LIMIT(8-8 * (PALAM:角色:ParamNo - PALAMLV:ParamLv) / (PALAMLV:(ParamLv+1) - PALAMLV:ParamLv), 0, 8)%
		RESETCOLOR
	ENDIF
	PRINTFORM %" "%
	IF ParamNo == 9 && PALAM:角色:ParamNo >= 20000
		;润滑(9)が十分にある場合だけ特殊表示
		PRINTFORM %"摩擦 0 "%
	ELSE
		;それ以外はSI接頭語を付けて表示
		PRINTFORM %INFO_ToSIPrefixed(PALAM:角色:ParamNo),7%
	ENDIF
	DispCount++
	IF DispCount % PRINTCPERLINE() == 0
		CALL 主界面_装饰右边框(1)
		PRINTL 
		CALL 主界面_竖边框
	ENDIF
NEXT
;最后一行的项目不满一行，补空项数×项宽个空格
空项数 = PRINTCPERLINE() - DispCount % PRINTCPERLINE()
IF 空项数 == PRINTCPERLINE()
	空项数 = 0
ENDIF
;反正空两项的情况下，60个空格是差不多对的，姑且就这样吧
CALL 主界面_装饰右边框(空项数*30)
PRINTL
RETURN 0

;-------------------------------------------------------------------------------
;数値に対して「整数部3桁+少数部2桁+SI接頭語」を返す。
;@return 1:xxx,0:xxx
@INFO_ToSIPrefixed(ARG:0)
#FUNCTIONS
;Int64の最大値は9,223,372,036,854,775,807であるため、対応はエクサまでで良い。
SELECTCASE ARG:0
	CASE IS >= 1000000000000000000
		RETURNF TOSTR(ARG:0,"###,,,,,,.00E")
	CASE IS >= 1000000000000000
		RETURNF TOSTR(ARG:0,"###,,,,,.00P")
	CASE IS >= 1000000000000
		RETURNF TOSTR(ARG:0,"###,,,,.00T")
	CASE IS >= 1000000000
		RETURNF TOSTR(ARG:0,"###,,,.00G")
	CASE IS >= 1000000
		RETURNF TOSTR(ARG:0,"###,,.00M")
	CASE IS >= 1000
		RETURNF TOSTR(ARG:0,"###,.00k")
	CASEELSE
		RETURNF TOSTR(ARG:0,"##0    ")
ENDSELECT
RETURNF ""

;-------------------------------------------------------------------------------
;対象の衣服の状態を表示
;@param ARG キャラクターの番号
@INFO_PrintTargetCloth(角色)
#DIM 角色
#DIM 服番号
#DIM 着衣数
#DIM 下着不可见
#DIMS 服装内容
#DIMS 配件内容
#DIM 行宽
着衣数 = 0
服装内容 = 服装(%CALLNAME:角色%)：
IF !EQUIP:角色:衣服着用
	服装内容 += "[全裸]"
ELSE
	FOR 服番号,1,20
		SELECTCASE 服番号
			CASE GETNUM(EQUIP,"下半身下着１")
				IF (角色 != MASTER) && Unknown下着(角色, 服番号)
					服装内容 += "[？下着？]"
					着衣数++
					CONTINUE
				ENDIF
			CASE GETNUM(EQUIP,"下半身下着２")
				IF (角色 != MASTER) && Unknown下着(角色, 服番号)
					服装内容 += ""
					着衣数++
					CONTINUE
				ENDIF
			CASEELSE
		ENDSELECT
		IF EQUIP:角色:服番号
			IF GETBIT(FLAG:匂いフェチ,1)
				服装内容 += @"["+IRUINAME_SMELL(EQUIP:角色:服番号)+CLOTHNAME(服番号,EQUIP:角色:服番号)+"]"
			ELSE
				服装内容 += @"["+CLOTHNAME(服番号,EQUIP:角色:服番号)+"]"
			ENDIF
			着衣数++
		ENDIF
	NEXT
	IF 着衣数 == 0
		服装内容 += "[全裸]"
	ENDIF
ENDIF
行宽 = STRLENS(服装内容)
CALL 主界面_竖边框
PRINTFORM %服装内容%
;配件显示（肛塞/膣塞/口塞/眼罩），接在服装后面同一行
下着不可见 = GETBIT(FLAG:雑多設定,1)
配件内容 =
IF 下着不可见
	IF 下着可见判定(角色)
		IF !EQUIP:角色:下半身下着２ && CFLAG:角色:肛塞
			配件内容 += @"[{CFLAG:角色:肛塞}cm肛塞]装备！  "
		ENDIF
		IF !EQUIP:角色:下半身下着２ && CFLAG:角色:膣塞
			配件内容 += @"[{CFLAG:角色:膣塞}cm膣塞]装备！  "
		ENDIF
	ENDIF
ELSE
	IF CFLAG:角色:肛塞
		配件内容 += @"[{CFLAG:角色:肛塞}cm肛塞]装备！  "
	ENDIF
	IF CFLAG:角色:膣塞
		配件内容 += @"[{CFLAG:角色:膣塞}cm膣塞]装备！  "
	ENDIF
ENDIF
IF CFLAG:角色:口塞
	配件内容 += @"[%口塞类型名称(角色)%]装备！  "
ENDIF
IF CFLAG:角色:眼罩
	配件内容 += "[眼罩]装备！  "
ENDIF
IF STRLENSU(配件内容) > 0
	SETCOLOR 颜色_红
	PRINTFORM %配件内容%
	RESETCOLOR
	行宽 += STRLENS(配件内容)
ENDIF
CALL 主界面_装饰右边框(UI_行半角宽度辅助 - 行宽)
PRINTL
RETURN 0

