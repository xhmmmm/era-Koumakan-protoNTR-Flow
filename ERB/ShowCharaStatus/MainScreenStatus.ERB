;-------------------------------------------------------------------------------
;角色关系信息一行显示：好感度 + 屈服度 + 性欲 + 怒意
;@param ARG:0 キャラクターの番号
;格式：│ 好感 320  屈服 50  性欲 12  怒！！！！ │
;-------------------------------------------------------------------------------
@INFO_PrintTargetRelation(ARG:0)
#DIM 怒数
#DIMS 前半内容
#DIMS 怒意内容
#DIM 行宽
前半内容 = 好感度：{CFLAG:(ARG:0):好感度}
SIF !FLAG:真实模式
	前半内容 += @"  屈服度：{CFLAG:(ARG:0):屈服度}"
前半内容 += @"  性欲：{CFLAG:(ARG:0):性欲}"
行宽 = 1 + STRLENS(前半内容)
CALL 主界面_竖边框
PRINTFORM %前半内容%
IF CFLAG:(ARG:0):怒意
	怒意内容 = " 怒"
	SETCOLOR 颜色_状态_激怒
	PRINTFORM %怒意内容%
	RESETCOLOR
	行宽 += STRLENS(怒意内容)
ELSE
	怒数 = BASE:(ARG:0):怒意/200
	怒意内容 = %" 怒意："%
	IF 怒数 > 0
		怒意内容 += @"%"！"*怒数%"
		SETCOLOR 颜色_状态_注意
	ENDIF
	PRINTFORM %怒意内容%
	RESETCOLOR
	行宽 += STRLENS(怒意内容)
ENDIF
CALL 主界面_装饰右边框(UI_行半角宽度辅助 - 行宽 + 1)
PRINTL
RETURN 0

;-------------------------------------------------
;関数名:SORT_CFLAG
;CFLAG:ARGの昇順でRESULT:1にキャラ番号を代入する
;ARG CFLAGの番号
@SORT_CFLAG(ARG)
VARSET LOCAL
VARSET RESULT
FOR LOCAL:10,1,CHARANUM
	LOCAL:1 = 0
	FOR LOCAL,1,CHARANUM
		SIF MATCH(RESULT,LOCAL)
			CONTINUE
		IF CFLAG:LOCAL:ARG >= LOCAL:1
			LOCAL:1 = CFLAG:LOCAL:ARG
			LOCAL:2 = LOCAL
		ENDIF
	NEXT
	RESULT:(LOCAL:10) = LOCAL:2
NEXT

;-------------------------------------------------------------------------------
;キャラの态度(亲密程度)を決定する。
;基本的に「そのキャラがどれくらい積極的に行動してくるか」を示すもの。
;強度 0:身体接触まで ,1:軽いセクハラしてくる ,2:セクハラしてくる ,3+:押し倒してくる
;@return 0
@CHARA_ATTITUDE
#DIM 亲密程度上限
#DIM 好感度基准值
#DIM 暂定值
#DIM 角色
;0:ループ用キャラ番号、1:馴れ合い基準値、2:最大馴れ合いランク制限
VARSET 角色
FOR 角色,1,CHARANUM
	;このタイミングで全員の好感度マイナスを０に補正
	CFLAG:角色:好感度 = MAX(0,CFLAG:角色:好感度)
	;同時に全員の屈服度マイナスを０に補正
	CFLAG:角色:屈服度 = MAX(0,CFLAG:角色:屈服度)
	;好感度補正、基準は0
	好感度基准值 = 0
	好感度基准值 += TALENT:角色:恋慕 * 10                             ;恋慕(10)
	好感度基准值 += GET_MARK_LEVEL(角色,刻印番号_屈服刻印,MASTER) * 3 ;屈服刻印(LV×3)
	好感度基准值 += GET_MARK_LEVEL(角色,刻印番号_快乐刻印,MASTER) * 3 ;快乐刻印(LV×3)
	好感度基准值 += MIN(ABL:角色:亲密 * 10, 50)                       ;亲密(LV×10、最大50)
	好感度基准值 += MIN(ABL:角色:欲望 * 10, 50)                       ;欲望(LV×10、最大50)
	好感度基准值 += GETPALAMLV(PALAM:角色:欲情,5) * 5                 ;欲情(LV×5)
	好感度基准值 += GETPALAMLV(PALAM:角色:好意,5) * 5                 ;好意(LV×5)
	好感度基准值 += BASE:角色:气氛 / 50                             ;气氛(最大30)
	好感度基准值 += (1000 - BASE:角色:理性) / 30                      ;理性の低さ(最大33)
	; 好感度基准值 += 5*GETBIT(CFLAG:角色:既成事実,1)                   ;既成事実:うふふ(5)、うふふはセクハラしやすさには影響しない。
	好感度基准值 += 5*CFLAG:角色:和主角已做爱

	;基本的に亲密程度の上限は1
	亲密程度上限 = 1
	;亲密程度上限 += GETBIT(CFLAG:角色:既成事実,0) ;既成事実:告白がある場合は最大ランク+1
	亲密程度上限 += TALENT:角色:恋人
	亲密程度上限 += TALENT:角色:恋慕

	;弱みを握っていないなら欲情補正(0.5～1.0倍)
	好感度基准值 = 好感度基准值 * (5000 + MIN(PALAM:角色:欲情,5000)) / 10000

	IF CFLAG:角色:怒意 || CFLAG:角色:睡眠
		;怒意 or 睡眠なら最大ランクは０
		亲密程度上限 = 0
	ENDIF

	;馴れ合い基準値50(一線超えない場合60)毎に仮ランク１、NTRがある場合は仮ランクが減る
	;NTRでも、我慢できなくなれば的な表現。
	暂定值 = MAX( 好感度基准值 / (50+TALENT:角色:难以越过的界线*10) - (TALENT:角色:NTR) , 0 )
	;最大ランクまでに切り詰める
	CFLAG:角色:亲密程度 = TALENT:角色:NTR ? 3 # MIN( 暂定值 , 亲密程度上限 )
	;DEBUGPRINTFORML %CALLNAME:角色+"(CFLAG:亲密程度"%{CFLAG:角色:亲密程度}%")"%
	IF TALENT:角色:恋人
		IF TALENT:角色:恋慕
			CFLAG:角色:亲密程度 = MAX(2, CFLAG:角色:亲密程度)
		ELSEIF TALENT:角色:NTR
			CFLAG:角色:亲密程度 = 3
		ELSE
			CFLAG:角色:亲密程度 = MAX(3, CFLAG:角色:亲密程度)
		ENDIF
	ENDIF
NEXT
RETURN 0

;-------------------------------------------------------------------------------
;情事の発覚
@AFFAIR_DISCLOSURE(ARG, ARG:1)
;ARG 入室してきたキャラの番号　ARG:1 0なら同室、1なら覗き
VARSET LOCAL
LOCAL:1 = IN_ROOM("MAX", CFLAG:MASTER:当前位置, "CFLAG", GETNUM(CFLAG, "うふふ"), 1)
IF (LOCAL:1 && CFLAG:(LOCAL:1):うふふ) || CFLAG:MASTER:うふふ == 3
	IF ARG:1 == 1 && 天候(天候値) == "云雾" && OPENPLACE(CFLAG:MASTER:当前位置) == 2
	ELSEIF ARG:1 == 1 && 天候(天候値) == "白夜"
	ELSE
		DRAWLINE
		PRINTFORM %CALLNAME:ARG%に
		IF  CFLAG:MASTER:うふふ == 3
			PRINTFORMW %CALLNAME:PLAYER%の情事を見られてしまった！
		ELSE
			PRINTFORMW %CALLNAME:(LOCAL:1)%との情事を見られてしまった！
			;伤心判定
			SIF TALENT:ARG:恋慕 && !TALENT:ARG:亲爱 && !TALENT:ARG:淫乱 && !TALENT:ARG:NTR
				LOCAL:4 = 1
		ENDIF
		IF LOCAL:4 == 1
			CALL 素質伤心取得, ARG
		ELSEIF !GETBIT(CFLAG:ARG:MASTERの弱味 , 1)
			PRINTFORMW %CALLNAME:ARG%に弱みを握られた
		ENDIF
		IF CFLAG:ARG:亲密程度 < 2
			IF !ARG:1
				;見た人
				CALL KOJO_EVENT(1,ARG,LOCAL:1)
				;見られた人（最も地位の高いTARGETで代表）
				CALL KOJO_EVENT(2,LOCAL:1,ARG)
			ENDIF
			CALL TOUCH_SET(0,0,0,1)
			DRAWLINE
			LOCAL:2 = 1
			;謹慎処分とか弱味とかの処理を入れる予定
		ELSEIF !ARG:1
			PRINTFORMW %CALLNAME:ARG%は負けじと%CALLNAME:MASTER%に体を摺り寄せてきた
			CFLAG:ARG:うふふ = CFLAG:(LOCAL:1):うふふ
			;見た人
			CALL KOJO_EVENT(3,ARG,LOCAL:1)
			;見られた人（最も地位の高いTARGETで代表）
			CALL KOJO_EVENT(4,LOCAL:1,ARG)
			DRAWLINE
			RETURN 0
		ENDIF
		SIF !LOCAL:4 && !GETBIT(CFLAG:ARG:MASTERの弱味 , 1)
			SETBIT CFLAG:ARG:MASTERの弱味 ,1
	ENDIF
ENDIF
IF LOCAL:2
	FOR LOCAL,0,CHARANUM
		CFLAG:LOCAL:うふふ = 0
	NEXT
	RETURN 1
ENDIF
;通常遭遇
;こちらからも見える位置にいる、もしくは同室
IF !CFLAG:ARG:睡眠 && (!ARG:1 || CAN_MOVE(CFLAG:MASTER:当前位置, CFLAG:ARG:当前位置) == 2)
	;さっきから居るのは分かっていたか否か
	IF CFLAG:ARG:前ターン位置 == CFLAG:ARG:当前位置
		CALL 自慰中断, ARG
		IF CAN_MOVE(CFLAG:MASTER:前ターン位置, CFLAG:ARG:当前位置) == 2
			PRINTFORML %CALLNAME:ARG+"が"+GetPlaceName(CFLAG:ARG:当前位置)+"に居る"%
			SIF !TEQUIP:ARG:0 == 0 && TEQUIP:ARG:1 == 0
				PRINTFORML %CALLNAME:ARG+"は半裸の上半身を晒け出している…"%
			SIF TEQUIP:ARG:0 == 0 && !TEQUIP:ARG:1 == 0
				PRINTFORML %CALLNAME:ARG+"は半裸の下半身を晒け出している…"%
			SIF TEQUIP:ARG:0 == 0 && TEQUIP:ARG:1 == 0
				PRINTFORML %CALLNAME:ARG+"は服を着ていない…"%
			CALL INFO_PrintPortrayal(ARG)
		ELSE
			PRINTFORML %CALLNAME:ARG+"が"+GetPlaceName(CFLAG:ARG:当前位置)+"に居た"%
			SIF !TEQUIP:ARG:0 == 0 && TEQUIP:ARG:1 == 0
				PRINTFORML %CALLNAME:ARG+"は半裸の上半身を晒け出している…"%
			SIF TEQUIP:ARG:0 == 0 && !TEQUIP:ARG:1 == 0
				PRINTFORML %CALLNAME:ARG+"は半裸の下半身を晒け出している…"%
			SIF TEQUIP:ARG:0 == 0 && TEQUIP:ARG:1 == 0
				PRINTFORML %CALLNAME:ARG+"は服を着ていない…"%
			CALL INFO_PrintPortrayal(ARG)
		ENDIF
		WAIT
		LOCAL:3 = 1
		;さっきから居るのは分かってて相手が移动した場合は別の場所で表示が出る
	ELSEIF CAN_MOVE(CFLAG:MASTER:前ターン位置, CFLAG:ARG:前ターン位置) < 2 && CFLAG:ARG:前ターン位置 != CFLAG:MASTER:前ターン位置
		PRINTFORMW %CALLNAME:ARG%が%GetPlaceName(CFLAG:ARG:当前位置)%に来た
		SIF !TEQUIP:ARG:0 == 0 && TEQUIP:ARG:1 == 0
			PRINTFORML %CALLNAME:ARG+"は半裸の上半身を晒け出している…"%
		SIF TEQUIP:ARG:0 == 0 && !TEQUIP:ARG:1 == 0
			PRINTFORML %CALLNAME:ARG+"は半裸の下半身を晒け出している…"%
		SIF TEQUIP:ARG:0 == 0 && TEQUIP:ARG:1 == 0
			PRINTFORML %CALLNAME:ARG+"は服を着ていない…"%
		LOCAL:3 = 2
	ENDIF
	IF !ARG:1 && LOCAL:3
		IF CFLAG:ARG:情事目撃 && CFLAG:(CFLAG:ARG:情事目撃):当前位置 != CFLAG:ARG:当前位置
			PRINTFORMW %CALLNAME:ARG%に先の%CALLNAME:(CFLAG:ARG:情事目撃)%との一件について問い詰められた…
			CALL KOJO_EVENT(0, ARG, 2)
			CFLAG:ARG:情事目撃 = 0
		ELSE
			CALL KOJO_EVENT(0, ARG, LOCAL:3 - 1)
		ENDIF
	ENDIF
ENDIF

