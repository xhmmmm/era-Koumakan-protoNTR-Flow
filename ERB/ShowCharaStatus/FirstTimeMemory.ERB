;--------------------------------------------------------------------------------
;记录角色第一次时对第一次的态度、发生地点和当时天气
;--------------------------------------------------------------------------------
@FirstTimeAttitude(角色, 对方, 部位)
#DIM 角色
#DIM 对方
#DIM 部位
#DIM 态度
;部位：1=V 2=A 3=M 4=接吻
;1=被夺走 2=半推半就（无法抵抗的状态被夺走） 3=交给他（不主动但感觉可以接受） 
;4=献给他 5=悄悄献给他（NTR） 6=满怀爱意、爱到无以复加、不在意旁人目光也要献给他（访问者专属）
;-1=不愿意但是无法拒绝（NTR）
IF 对方 == 人物_訪問者
	IF TALENT:角色:NTR || (角色 == 人物_玩家 && (FLAG:1840 >= 11 && FLAG:1840 <= 15))
		态度 = 6
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られ寸前) || (角色 == 人物_玩家 && FLAG:1840 == 10)
		态度 = 5
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_寝取られそう)
		态度 = 4
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_主人より高い)
		态度 = 3
	ELSEIF NTR_CHK_FAVORABLY(角色, FAV_うふふする程度) 
		态度 = 2
	ELSE
		态度 = 1
	ENDIF
ELSEIF 对方 == 人物_玩家
	IF TALENT:角色:NTR
		;我感觉应该没有NTR了还是处女的吧……？
		态度 = -1
	ELSEIF TALENT:角色:恋慕
		;告白后并且真的喜欢玩家时
		态度 = 4
	ELSEIF TALENT:角色:恋人
		;告白后没有恋慕
		态度 = 3
	ELSE
		;感觉可以加个半推半就……
		态度 = 1
	ENDIF
ENDIF
IF 部位 == 1
	CFLAG:角色:处女丧失时态度_V = 态度
	CFLAG:角色:处女丧失时位置_V = CFLAG:角色:当前位置
	CSTR:角色:处女丧失时天气_V = %天候(天候値)%
ELSEIF 部位 == 2
	CFLAG:角色:处女丧失时态度_A = 态度
	CFLAG:角色:处女丧失时位置_A = CFLAG:角色:当前位置
	CSTR:角色:处女丧失时天气_A = %天候(天候値)%
ELSEIF 部位 == 3
	CFLAG:角色:处女丧失时态度_M = 态度
	CFLAG:角色:处女丧失时位置_M = CFLAG:角色:当前位置
	CSTR:角色:处女丧失时天气_M = %天候(天候値)%
ELSEIF 部位 == 4
	CFLAG:角色:初吻丧失时态度 = 态度
	CFLAG:角色:初吻丧失时位置 = CFLAG:角色:当前位置
	CSTR:角色:初吻丧失时天气 = %天候(天候値)%
ENDIF