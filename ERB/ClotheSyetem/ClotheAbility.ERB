;----------------------------------
;服装効果
;---------------------------------
@CLOTHE_EFFECT(ARG)

;------------------------------------------------------------------------------------------------------------------------------------
;素質付加について：何も無いなら素質付加後の能力保存(1を保存)、鈍感なら先に能力保存してからの素質付加(-1を保存)、敏感ならそのまま放置
;				   コスプレ効果発動後、素質が付きっぱなしになるので能力保存の値を元に素質を再設定する。
;------------------------------------------------------------------------------------------------------------------------------------


;チア効果　がんばれがんばれ
;素質付加：鼓舞
;リジェネ効果：侍奉快乐经验
IF EQUIP:ARG:上半身上着２ == 12
	;もしウフフじゃなかったら効果は発動しない
	IF CFLAG:ARG:うふふ == 0
		SIF CFLAG:ARG:能力保存１ == 1  && TALENT:ARG:鼓舞 == 1
			TALENT:ARG:鼓舞 = 0
		SIF CFLAG:ARG:能力保存１ == -1 && TALENT:ARG:鼓舞 == 1
			TALENT:ARG:鼓舞 = -1
		RETURN 0
	ELSE
		IF TALENT:ARG:鼓舞 == 0
			TALENT:ARG:鼓舞 = 1
			CFLAG:ARG:能力保存１ = TALENT:ARG:鼓舞
		ELSEIF TALENT:ARG:鼓舞 == -1
			CFLAG:ARG:能力保存１ = TALENT:ARG:鼓舞
			TALENT:ARG:鼓舞 = -1
		ENDIF
		EXP:ARG:侍奉快乐经验 += 1
	ENDIF
	RETURN 1

	;裸体围裙効果　旧「新妻PLAY」
	;リジェネ効果：爱情经验
ELSEIF EQUIP:ARG:连衣裙 == 5
	;もしウフフじゃなかったら効果は発動しない
	SIF CFLAG:ARG:うふふ == 0
		RETURN 0
	EXP:ARG:爱情经验 += 1
	RETURN 1

	;女騎士効果　気の強い女はなんとやら
	;素質付加：A敏感、淫肛、药毒耐性
	;感度増加:Ａ
ELSEIF EQUIP:ARG:上半身上着１ == 2
	;ウフフじゃなくなったら能力を元に戻す
	IF CFLAG:ARG:うふふ == 0
		SIF CFLAG:ARG:能力保存１ == 1  && TALENT:ARG:淫乳 == 1
			TALENT:ARG:淫乳 = 0
		SIF CFLAG:ARG:能力保存１ == -1 && TALENT:ARG:淫乳 == 1
			TALENT:ARG:淫乳 = -1
		SIF CFLAG:ARG:能力保存２ == 1 && TALENT:ARG:Ａ感度 == 1
			TALENT:ARG:Ａ感度 = 0
		SIF CFLAG:ARG:能力保存２ == -1 && TALENT:ARG:Ａ感度 == 1
			TALENT:ARG:Ａ感度 = -1
		SIF CFLAG:ARG:能力保存３ == 1 && TALENT:ARG:药毒耐性 == 1
			TALENT:ARG:药毒耐性 = 0
		SIF CFLAG:ARG:能力保存３ == -1 && TALENT:ARG:药毒耐性 == 1
			TALENT:ARG:药毒耐性 = -1
		RETURN 0
		;ウフフ中効果
	ELSE
		IF TALENT:ARG:淫乳 == 0
			TALENT:ARG:淫乳 = 1
			CFLAG:ARG:能力保存１ = TALENT:ARG:淫乳
		ELSEIF TALENT:ARG:淫乳 == -1
			CFLAG:ARG:能力保存１ = TALENT:ARG:淫乳
			TALENT:ARG:淫乳 = 1
		ELSEIF TALENT:ARG:Ａ感度 == 0
			TALENT:ARG:Ａ感度 = 1
			CFLAG:ARG:能力保存２ = TALENT:ARG:Ａ感度
		ELSEIF TALENT:ARG:Ａ感度 == -1
			CFLAG:ARG:能力保存２ = TALENT:ARG:淫乳
			TALENT:ARG:淫乳 = 1
		ELSEIF TALENT:ARG:药毒耐性 == 0
			TALENT:ARG:药毒耐性 = 1
			CFLAG:ARG:能力保存３ = TALENT:ARG:药毒耐性
		ELSEIF TALENT:ARG:药毒耐性 == -1
			CFLAG:ARG:能力保存３ = TALENT:ARG:药毒耐性
			TALENT:ARG:药毒耐性 = 1
		ENDIF

	ENDIF
	RETURN 1

	;忍者効果：アイエ！？対魔忍！？
ELSEIF EQUIP:ARG:紧身衣 == 3
	;ウフフ以外で戻す
	IF CFLAG:ARG:うふふ == 0
		SIF CFLAG:ARG:能力保存１ == 1 && TALENT:ARG:容易中毒 == 1
			TALENT:ARG:容易中毒 = 0
		SIF CFLAG:ARG:能力保存１ == -1 && TALENT:ARG:容易中毒 == 1
			TALENT:ARG:容易中毒 = -1
		SIF CFLAG:ARG:能力保存２ == 1 && TALENT:ARG:Ｃ感度 == 1
			TALENT:ARG:Ｃ感度 = 0
		SIF CFLAG:ARG:能力保存２ == -1 && TALENT:ARG:Ｃ感度 == 1
			TALENT:ARG:Ｃ感度 = -1
		SIF CFLAG:ARG:能力保存３ == 1 && TALENT:ARG:Ｖ感度 == 1
			TALENT:ARG:Ｖ感度 = 0
		SIF CFLAG:ARG:能力保存３ == -1 && TALENT:ARG:Ｖ感度 == 1
			TALENT:ARG:Ｖ感度 = -1
		SIF CFLAG:ARG:能力保存４ == 1 && TALENT:ARG:Ａ感度 == 1
			TALENT:ARG:Ａ感度 = 0
		SIF CFLAG:ARG:能力保存４ == -1 && TALENT:ARG:Ａ感度 == 1
			TALENT:ARG:Ａ感度 = -1
		SIF CFLAG:ARG:能力保存５ == 1 && TALENT:ARG:Ｂ感度 == 1
			TALENT:ARG:Ｂ感度 = 0
		SIF CFLAG:ARG:能力保存５ == -1 && TALENT:ARG:淫乳 == 1
			TALENT:ARG:Ｂ感度 = -1
		RETURN 0
	ELSE
		IF TALENT:ARG:容易中毒 == 0
			TALENT:ARG:容易中毒 = 1
			CFLAG:ARG:能力保存１ = TALENT:ARG:容易中毒
		ELSEIF TALENT:ARG:容易中毒 == -1
			CFLAG:ARG:能力保存１ = TALENT:ARG:容易中毒
			TALENT:ARG:容易中毒 = 1
		ELSEIF TALENT:ARG:Ｃ感度 == 0
			TALENT:ARG:Ｃ感度 = 1
			CFLAG:ARG:能力保存２ = TALENT:ARG:Ｃ感度
		ELSEIF TALENT:ARG:Ｃ感度 == -1
			CFLAG:ARG:能力保存２ = TALENT:ARG:Ｃ感度
			TALENT:ARG:Ｃ感度 = 1
		ELSEIF TALENT:ARG:Ｖ感度 == 0
			TALENT:ARG:Ｖ感度 = 1
			CFLAG:ARG:能力保存３ = TALENT:ARG:Ｖ感度
		ELSEIF TALENT:ARG:Ｖ感度 == -1
			CFLAG:ARG:能力保存３ = TALENT:ARG:Ｖ感度
			TALENT:ARG:Ｖ感度 = 1
		ELSEIF TALENT:ARG:Ａ感度 == 0
			TALENT:ARG:Ａ感度 = 1
			CFLAG:ARG:能力保存４ = TALENT:ARG:Ａ感度
		ELSEIF TALENT:ARG:Ａ感度 == -1
			CFLAG:ARG:能力保存４ = TALENT:ARG:Ａ感度
			TALENT:ARG:Ａ感度 = 1
		ELSEIF TALENT:ARG:Ｂ感度 == 0
			TALENT:ARG:Ｂ感度 = 1
			CFLAG:ARG:能力保存５ = TALENT:ARG:Ｂ感度
		ELSEIF TALENT:ARG:Ｂ感度 == -1
			CFLAG:ARG:能力保存５ = TALENT:ARG:Ｂ感度
			TALENT:ARG:Ｂ感度 = 1
		ENDIF
	ENDIF
	RETURN 1

	;ボンデージ効果　SM用な感じに
	;素質効果：倒错的
	;リジェネ効果：緊縛体験
ELSEIF EQUIP:ARG:下半身下着２ == 4 || EQUIP:ARG:上半身上着２ == 14
	;ウフフ以外で戻す
	IF CFLAG:ARG:うふふ == 0
		SIF CFLAG:ARG:能力保存１ == 1 && TALENT:ARG:倒错的 == 1
			TALENT:ARG:倒错的 = 0
		SIF CFLAG:ARG:能力保存１ == -1 && TALENT:ARG:倒错的 == 1
			TALENT:ARG:倒错的 = -1
		RETURN 0
	ELSE
		IF TALENT:ARG:倒错的 == 0
			TALENT:ARG:倒错的 = 1
			CFLAG:ARG:能力保存１ = TALENT:ARG:倒错的
		ELSEIF TALENT:ARG:倒错的 == -1
			CFLAG:ARG:能力保存１ = TALENT:ARG:倒错的
			TALENT:ARG:倒错的 = -1
		ENDIF
		EXP:ARG:紧缚经验 += 1
	ENDIF
	RETURN 1


	;ナース効果　そりゃナースですし
	;素質効果：治癒
ELSEIF EQUIP:ARG:上半身上着２ == 15
	;ウフフ以外で戻す
	IF CFLAG:ARG:うふふ == 0
		SIF CFLAG:ARG:能力保存１ == 1 && TALENT:ARG:治疗 == 1
			TALENT:ARG:治疗 = 0
		SIF CFLAG:ARG:能力保存１ == -1 && TALENT:ARG:治疗 == 1
			TALENT:ARG:治疗 = -1
		RETURN 0
	ELSE
		IF TALENT:ARG:治疗 == 0
			TALENT:ARG:治疗 = 1
			CFLAG:ARG:能力保存１ = TALENT:ARG:治疗
		ELSEIF TALENT:ARG:治疗 == -1
			CFLAG:ARG:能力保存１ = TALENT:ARG:治疗
			TALENT:ARG:治疗 = -1
		ENDIF
	ENDIF
	RETURN 1

	;魔法少女効果　謎の魔力のある服
	;常時効果：男が女に
ELSEIF EQUIP:ARG:上半身上着２ == 17
	IF TALENT:ARG:性别 == 2
		CFLAG:ARG:コスプレ着用 = 1
		TALENT:ARG:性别 = 1
	ENDIF
	RETURN 1
	;魔法少女効果削除
ELSEIF CFLAG:ARG:コスプレ着用 == 1 && EQUIP:ARG:上半身上着２ != 17
	TALENT:ARG:性别 = 2
	CFLAG:ARG:コスプレ着用 = 0
	RETURN 0

	;触手服効果　触手宮から持ってきたのだろうか
	;常時リジェネ：异常经验＋いろいろ増加。何かしらの快楽が溜まる
ELSEIF EQUIP:ARG:紧身衣 == 5
	CFLAG:ARG:コスプレ着用 = 2
	EXP:ARG:异常经验 ++
	SOURCE:ARG:快Ｃ += TIME_PROGRESS(TFLAG:300) * 5
	SOURCE:ARG:快Ａ += TIME_PROGRESS(TFLAG:300) * 5
	SOURCE:ARG:快Ｂ += TIME_PROGRESS(TFLAG:300) * 5
	IF TALENT:ARG:性别 != 2 && TALENT:ARG:处女 == 0
		SOURCE:ARG:快Ｖ += TIME_PROGRESS(TFLAG:300) * 5
	ENDIF
	RETURN 1

	;牛娘　でもちょっと搾乳ならみてみたいかも
	;素質効果：母乳
ELSEIF EQUIP:ARG:上半身下着２ == 9
	;ウフフ以外で戻す
	IF CFLAG:ARG:うふふ == 0
		SIF CFLAG:ARG:能力保存１ == 1 && TALENT:ARG:泌乳体质 == 1
			TALENT:ARG:泌乳体质 = 0
		SIF CFLAG:ARG:能力保存１ == -1 && TALENT:ARG:泌乳体质 == 1
			TALENT:ARG:泌乳体质 = -1
		RETURN 0
	ELSE
		IF TALENT:ARG:泌乳体质 == 0
			TALENT:ARG:泌乳体质 = 1
			CFLAG:ARG:能力保存１ = TALENT:ARG:泌乳体质
		ELSEIF TALENT:ARG:泌乳体质 == -1
			CFLAG:ARG:能力保存１ = TALENT:ARG:泌乳体质
			TALENT:ARG:泌乳体质 = -1
		ENDIF
	ENDIF
	RETURN 1
	;サンタ:プレゼントが…？
ELSEIF EQUIP:ARG:上半身上着２ == 19 && 日期_月数 == 5 && 日期_天数 == 24
	IF ARG != 0
		CFLAG:ARG:サンタ = 1
	ELSE
		RETURN 0
	ENDIF
	;効果がなんにもないならそのまま返し、常時効果を消す
ELSE
	;触手服効果削除
	IF CFLAG:ARG:コスプレ着用 == 2
		CFLAG:ARG:コスプレ着用 = 0
	ENDIF
	RETURN 0
ENDIF


@SANTA(ARG)
IF CFLAG:ARG:サンタ == 1
	PRINTL 早上起来的时候旁边放着什么东西
	PRINTL 像圣诞礼物一样
	PRINTFORML 「%CALLNAME:ARG%送给%CALLNAME:MASTER%嗒へ」拿出了里面的东西

	IF TALENT:ARG:NTR == 1
		LOCAL = RAND:2
		IF LOCAL == 0
			PRINTFORML 是访问者和%CALLNAME:ARG%做爱的照片
		ELSEIF LOCAL == 1
			PRINTL 是一份录像，于是播放里面的内容
			PRINTL ・・・
			PRINTL
			PRINTL ・・・・・・
			PRINTFORML %CALLNAME:ARG%跟不认识的男人乱交的视频
		ENDIF
	ELSE
		PRINTL 手织的毛衣,有什么东西掉下来了
		LOCAL = RAND:2
		IF LOCAL == 0
			PRINTFORML 是情书……读起来使人害羞的内容
		ELSE
			PRINTFORML 是内裤，接触到的时候感到奇妙的温暖
		ENDIF
	ENDIF

	CFLAG:ARG:サンタ = 0
ENDIF
