;-------------------------------------------------------------------------------
;与女仆妖精对话(我TM魔改版) - 各种各样的事情
; RETURN 0 コマンドの実行に失敗
; RETURN 1 コマンドの実行に成功
@COM420_05
#DIMS 指令,100
#DIM 指令值 = 0
指令值 = 0
FOR LOCAL:0,0,100
	TRYCCALLFORM %@"COM420_05_{LOCAL}_ENABLE"%
		IF RESULT:0
			指令:指令值 = %RESULTS:0%
			指令值++
		ENDIF
	CATCH
	ENDCATCH
NEXT
;直接番号叩かれたら呼べるけど、まあ妥協。
IF (指令值 > 0)
	FOR LOCAL,0,指令值
		PRINTFORML %指令:LOCAL%
	NEXT
	PRINTL --------------------
	PRINTFORML %"[ 0]-果然还是算了"%
	$重选
	INPUT
	SIF RESULT == 0
		RETURN 0
	TRYCCALLFORM COM420_05_{RESULT}
		RETURN RESULT:0
	CATCH
		CLEARLINE 1
		GOTO 重选
	ENDCATCH
ELSE
	CALL COM420_01
	RETURN RESULT:0
ENDIF
RETURN 0


@COM420_05_1_ENABLE
RESULTS:0 = %"[ 1]-避孕药的事"%
;常に実行可能
RETURN 1
RETURN 0
@COM420_05_1_购买吃避孕药写真
#DIMS 临时写真集,100
#DIM 写真数量
#DIMS 购买的写真
#DIM 妖精持有的写真数量
#DIM 购买选项值
VARSET 临时写真集
妖精持有的写真数量 = 0
PRINTL 妖精女仆「200元一张，不挑选，不退货。」
FOR LOCAL,1,CHARANUM
	IF CSTR:LOCAL:妖精持有的吃避孕药的写真 != ""
		PRINTFORML [{LOCAL,2}] - 有%CALLNAME:LOCAL%的写真
		妖精持有的写真数量 += STRCOUNT(CSTR:LOCAL:妖精持有的吃避孕药的写真,",")
	ENDIF
NEXT
PRINTFORML 妖精女仆「一共有{妖精持有的写真数量}张写真，如果全都买的话，价格是 {妖精持有的写真数量 * 200} 元。」
PRINTFORML 手头有 {MONEY:MASTER} 元，要买一张谁的写真呢？
PRINTL [ 0] - 还是不买吧…
SIF 妖精持有的写真数量 > 1
	PRINTL [-1] - 我全都要！
INPUT
购买选项值 = RESULT
IF 购买选项值 == 0
	PRINTW 妖精女仆「明白了，改变主意了的话，随时欢迎~~」
	TIME += 2
	RETURN 1
ELSEIF 购买选项值 == -1 && 妖精持有的写真数量 > 1
	IF MONEY:MASTER < 妖精持有的写真数量 * 200
		PRINTW 钱不够…
		RESTART
	ENDIF
	MONEY:MASTER -= 妖精持有的写真数量 * 200
	FOR LOCAL,1,CHARANUM
		CSTR:LOCAL:吃避孕药的写真 += CSTR:LOCAL:妖精持有的吃避孕药的写真
		CSTR:LOCAL:妖精持有的吃避孕药的写真 = ""
	NEXT
	PRINTFORMW 妖精女仆「谢谢惠顾~~」
	PRINTFORMW 买下了所有的写真，回去再拆开看吧。
	TIME += 2
	RETURN 1
ELSEIF CSTR:购买选项值:妖精持有的吃避孕药的写真 != ""
	IF MONEY:MASTER < 200
		PRINTW 钱不够…
		RESTART
	ENDIF
	SPLIT CSTR:购买选项值:妖精持有的吃避孕药的写真,",",临时写真集
	FOR LOCAL,0,VARSIZE("临时写真集")
		SIF 临时写真集:LOCAL == ""
			CONTINUE
		写真数量 = LOCAL+1
	NEXT
	MONEY:MASTER -= 200
	购买的写真 '= 临时写真集:RAND(0,写真数量)
	CSTR:购买选项值:吃避孕药的写真 += 购买的写真 + ","
	;移除妖精手里的这张写真
	CSTR:购买选项值:妖精持有的吃避孕药的写真 '= REPLACE(CSTR:购买选项值:妖精持有的吃避孕药的写真,ESCAPE(购买的写真 + ","),"")
	PRINTFORMW 妖精女仆「谢谢惠顾~~」
	PRINTFORMW 付钱之后马上拆开看了
	PRINTFORMW 「%购买的写真%」是记录了这样的情况的写真
	TIME += 2
	RETURN 1
ELSE
	RESTART
ENDIF
@COM420_05_1_查看访问者的避孕药数量
#DIM 价格 = 200
PRINTFORML 妖精女仆「会在意这种事啊？不过作为妖精怎么能放弃这种简单的生意呢！」
PRINTFORML 妖精女仆「每次探查的价格是 {价格} 元！」
PRINTL [0] - 付钱
PRINTFORML [1] - 还是算了（手头有 {MONEY:MASTER} 元）
INPUT
IF RESULT == 0
	IF MONEY:MASTER < 价格
		PRINTL 钱不够……
		RESTART
	ENDIF
	MONEY:MASTER -= 价格
	PRINTFORML 妖精女仆「谢谢惠顾~~」
	PRINTFORMW 妖精女仆「%NTR_NAME(0)%的手里还有 {FLAG:访问者的避孕药} 粒避孕药~~」
	TIME += 2
	RETURN 1
ELSEIF RESULT == 1
	PRINTW 想了想还是算了…
	PRINTW 妖精女仆「随时恭候~~」
	TIME += 1
	RETURN 1
ENDIF
RESTART
@COM420_05_1_让妖精送避孕药给访问者
#DIM 价格 = 200
PRINTFORML 妖精女仆「送药给%NTR_NAME(0)%是吗，好的没问题~~」
PRINTFORML 妖精女仆「每次递送的价格是 {价格} 元！」
PRINTL [0] - 付钱
PRINTFORML [1] - 还是算了（手头有 {MONEY:MASTER} 元）
INPUT
IF RESULT == 0
	IF MONEY:MASTER < 价格
		PRINTL 钱不够……
		RESTART
	ENDIF
	MONEY:MASTER -= 价格
	PRINTFORML 妖精女仆「谢谢惠顾~~」
	$重新打印1
	PRINTFORML 妖精女仆「那么要送多少过去呢？」
	PRINTL [0]-给1个  [1]-给5个  [2]-给10个  [3]-给20个
	PRINTFORML [4]-全部给出（手头有 {ITEM:避孕药} 粒避孕药）
	INPUT
	SELECTCASE RESULT
		CASE 0
			FLAG:访问者的避孕药 += 1
			ITEM:避孕药 -= 1
		CASE 1
			SIF ITEM:避孕药 < 5
				GOTO 重新打印1
			FLAG:访问者的避孕药 += 5
			ITEM:避孕药 -= 5
		CASE 2
			SIF ITEM:避孕药 < 10
				GOTO 重新打印1
			FLAG:访问者的避孕药 += 10
			ITEM:避孕药 -= 10
		CASE 3
			SIF ITEM:避孕药 < 20
				GOTO 重新打印1
			FLAG:访问者的避孕药 += 20
			ITEM:避孕药 -= 20
		CASE 4
			FLAG:访问者的避孕药 += ITEM:避孕药
			ITEM:避孕药 = 0
		CASEELSE
			GOTO 重新打印1
	ENDSELECT
	TIME += 2
	RETURN 1
ELSEIF RESULT == 1
	PRINTW 想了想还是算了…
	PRINTW 妖精女仆「随时恭候~~」
	TIME += 1
	RETURN 1
ENDIF
RESTART


@COM420_05_1
#DIM 有吃避孕药写真
有吃避孕药写真 = 0
PRINTW 妖精女仆「避孕药吗？妖精不会怀孕，所以也不是很懂啦。」
FOR LOCAL,1,CHARANUM
	IF CSTR:LOCAL:妖精持有的吃避孕药的写真 != ""
		有吃避孕药写真++
	ENDIF
NEXT
IF 有吃避孕药写真 > 0
	PRINTFORML 妖精女仆「不过依靠着我等妖精的力量，相关的写真倒是有的哦❤~要买吗？」
	PRINTFORML [0] - 要！
ENDIF
PRINTFORML [1] - 想知道%NTR_NAME(0)%手里有多少避孕药
SIF ITEM:避孕药 > 0
	PRINTFORML [2] - 想拜托妖精帮忙把避孕药送到%NTR_NAME(0)%那里去
PRINTFORML [-1] - 还是算了吧……
INPUT
SELECTCASE RESULT
	CASE -1
		RETURN 1
	CASE 0
		SIF 有吃避孕药写真 == 0
			RESTART
		CALL COM420_05_1_购买吃避孕药写真
		RETURN RESULT
	CASE 1
		CALL COM420_05_1_查看访问者的避孕药数量
		RETURN RESULT
	CASE 2
		SIF ITEM:避孕药 <= 0
			RESTART
		CALL COM420_05_1_让妖精送避孕药给访问者
	CASEELSE

ENDSELECT
RETURN 1