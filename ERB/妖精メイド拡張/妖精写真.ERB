@查看从妖精女仆那取得的收藏
DRAWLINE
PRINTL [0] - 写真
PRINTL [1] - 录像
PRINTL --------------------
PRINTL [-1] - 返回
INPUT
SELECTCASE RESULT
	CASE -1
		RETURN
	CASE 0
		CALL 查看从妖精女仆那取得的收藏_写真
		RESTART
	CASE 1

		RESTART
ENDSELECT

@查看从妖精女仆那取得的收藏_写真
#DIM 写真分割起始位置 = 0
#DIM 当前逗号索引值 = 0
#DIMS 当前写真内容 = ""
#DIM 展示的人物 = 5
#DIM 每页展示数量 = 8
#DIM 当前展示数量 = 0
#DIM 页数 = 1
#DIM 总页数
#DIM 写真数量 = 0
写真分割起始位置 = 0
当前逗号索引值 = 0
当前写真内容 '= ""
写真数量 = STRCOUNT(CSTR:展示的人物:吃避孕药的写真,",")
总页数 = 写真数量 / 每页展示数量 + (写真数量 % 每页展示数量 > 0)
IF CSTR:展示的人物:吃避孕药的写真 == ""
	PRINTW 一张写真都没有……
ELSE
	PRINTFORML 根据购买的日期把写真列出来了,%CALLNAME:展示的人物%的写真一共有 {写真数量} 张
	PRINTL --------------------
	当前展示数量 = 0
	WHILE STRFINDU(CSTR:展示的人物:吃避孕药的写真,",",写真分割起始位置) >= 0
		SIF 当前展示数量 >= 页数 * 每页展示数量
			BREAK
		;能查找到结果
		当前逗号索引值 = STRFINDU(CSTR:展示的人物:吃避孕药的写真,",",写真分割起始位置)
		当前写真内容 '= SUBSTRINGU(CSTR:展示的人物:吃避孕药的写真,写真分割起始位置,当前逗号索引值 - 写真分割起始位置)
		写真分割起始位置 = 当前逗号索引值 + 1
		IF 当前展示数量 >= 页数 * 每页展示数量 - 每页展示数量
			PRINTSL "「"+当前写真内容+"」"
			PRINTL -----
		ENDIF
		当前展示数量++
	WEND
ENDIF
PRINTL --------------------
FOR LOCAL,1,CHARANUM
	PRINTFORMC [{LOCAL}]%CALLNAME:LOCAL%
NEXT
PRINTL
PRINTL ----------
$重新翻页
IF 页数 == 1
	PRINT -------------
ELSE
	PRINTBUTTON "[-2] - 上一页",-2
ENDIF
IF 页数 == 总页数
	PRINTL     -------------
ELSE
	PRINT     
	PRINTBUTTON "[-3] - 下一页",-3
	PRINTL
ENDIF
PRINTL [-1] - 返回
INPUT
IF RESULT == -1
	RETURN
ELSEIF RESULT == -2
	IF 页数 == 1
		CLEARLINE 3
		GOTO 重新翻页
	ENDIF
	页数--
	RESTART
ELSEIF RESULT == -3
	IF 页数 == 总页数
		CLEARLINE 3
		GOTO 重新翻页
	ENDIF
	页数++
	RESTART
ELSEIF RESULT > 0
	展示的人物 = RESULT
	RESTART
ENDIF


@妖精写真_吃避孕药(ARG)
#DIMS DYNAMIC 拍摄时间 = ""
#DIMS DYNAMIC 拍摄地点 = ""
#DIMS DYNAMIC 写真内容 = ""
#DIMS DYNAMIC 吃药方式 = ""
#DIMS DYNAMIC 腹部状态 = ""
#DIMS DYNAMIC 外表 = ""
拍摄时间 = %日期_月份名称(日期_月数)%{日期_天数}日，第{DAY}日，%天候(天候値)%の日，在
拍摄地点 = %GetPlaceName(CFLAG:ARG:当前位置)%，
腹部状态 = 小腹%腹部精液膨胀状态(ARG)%，

IF TALENT:ARG:NTR || NTR_CHK_FAVORABLY(ARG,FAV_寝取られ寸前)
	IF RAND:2
		吃药方式 = 被%NTR_NAME(0)%捏着下巴，张开的嘴里满是精液，避孕药正浸泡在精液中，准备吞下去的瞬间
	ELSE
		吃药方式 = 辛福地张开嘴等待%NTR_NAME(0)%将避孕药投入口中的瞬间
	ENDIF
ELSEIF TALENT:ARG:亲爱
	吃药方式 = 一脸无奈地让%NTR_NAME(0)%拿着药塞入嘴中的瞬间
ELSEIF TALENT:ARG:恋慕
	吃药方式 = 红着脸拿着避孕药放入口中的瞬间
ENDIF
写真内容 += 拍摄时间
写真内容 += 拍摄地点
写真内容 += 腹部状态
写真内容 += 外表
写真内容 += CALLNAME:ARG
写真内容 += 吃药方式
写真内容 += ","
CSTR:ARG:妖精持有的吃避孕药的写真 += 写真内容

@腹部精液膨胀状态(ARG)
#FUNCTIONS
SELECTCASE 获取子宫精液填充率(ARG,0)
	CASE IS >= 200
		RETURNF "被精液撑的膨胀起来"
	CASE 100 TO 199
		RETURNF "被精液填满得微微隆起"
	CASEELSE
		RETURNF "显得很平坦"
ENDSELECT

;ARG:1 为 1 则有主人公精液填充率为0 否则返回真实填充率
@获取子宫精液填充率(ARG,ARG:1 = 1)
#FUNCTION
#DIM LOOP_CHR
#DIM あなた以外フラグ	; 0:MASTERを含む 1:MASTERを含まない
#DIM 精子量
#DIM 人数
#DIM 充填率		; 子宮が精液で満たされている率（％）

あなた以外フラグ = 1
精子量 = 0
人数 = 0
FOR LOOP_CHR, 0, 301
	SIF LOOP_CHR == CHARANUM
		LOOP_CHR = 精子主_スキップ

	;精子量を再計算
	DA:ARG:LOOP_CHR = 0
	REPEAT 9
		DA:ARG:LOOP_CHR += TA:ARG:LOOP_CHR:COUNT
	REND

	;精子量チェック
	IF DA:ARG:LOOP_CHR > 0
		IF LOOP_CHR == MASTER
			あなた以外フラグ = 0
		ENDIF
		精子量 += DA:ARG:LOOP_CHR
		人数 ++
	ENDIF
NEXT

;暫定措置 子宫内体积が0未満のとき、追加パッチと同じ扱いで子宫内体积設定をする
IF 0 >= CFLAG:ARG:子宫内体积
	CFLAG:ARG:子宫内体积 = 子宫内体积設定F(ARG)
ENDIF
充填率 = 100*精子量/(CFLAG:ARG:子宫内体积)
IF ARG:1 == 1
	RETURNF LIMIT(充填率,0,200)*あなた以外フラグ
ELSE
	RETURNF LIMIT(充填率,0,200)
ENDIF